{
  "extends": [
    "./tsconfig.base.json"
  ],
  "exclude": [
    "esm",
    "examples",
    "tests",
    "node_modules",
    "**/.DS_Store",
    "_site",
    ".git",
    ".git",
    ".gitmodules",
    "packages"
  ],
  "compilerOptions": {
    "declarationDir": "dist/dts/others",
    "outDir": "dist/others",
    "tsBuildInfoFile": ".tsbuildinfo/others.tsbuildinfo",
    "isolatedModules": false,
    "isolatedDeclarations": false,
    "allowJs": true,
    "checkJs": true
  }
}