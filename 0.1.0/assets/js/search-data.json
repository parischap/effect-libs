ype . ", "url": "/0.1.0/ansi-styles/Color/EightBitColor.ts.html#turquoise2", "relUrl": "/ansi-styles/Color/EightBitColor.ts.html#turquoise2" },"675": { "doc": "Color/EightBitColor.ts", "title": "turquoise4", "content": "Eightbit Turquoise4 Color instance . Signature . export declare const turquoise4: Type . ", "url": "/0.1.0/ansi-styles/Color/EightBitColor.ts.html#turquoise4", "relUrl": "/ansi-styles/Color/EightBitColor.ts.html#turquoise4" },"676": { "doc": "Color/EightBitColor.ts", "title": "violet", "content": "Eightbit Violet Color instance . Signature . export declare const violet: Type . ", "url": "/0.1.0/ansi-styles/Color/EightBitColor.ts.html#violet", "relUrl": "/ansi-styles/Color/EightBitColor.ts.html#violet" },"677": { "doc": "Color/EightBitColor.ts", "title": "wheat1", "content": "Eightbit Wheat1 Color instance . Signature . export declare const wheat1: Type . ", "url": "/0.1.0/ansi-styles/Color/EightBitColor.ts.html#wheat1", "relUrl": "/ansi-styles/Color/EightBitColor.ts.html#wheat1" },"678": { "doc": "Color/EightBitColor.ts", "title": "wheat4", "content": "Eightbit Wheat4 Color instance . Signature . export declare const wheat4: Type . ", "url": "/0.1.0/ansi-styles/Color/EightBitColor.ts.html#wheat4", "relUrl": "/ansi-styles/Color/EightBitColor.ts.html#wheat4" },"679": { "doc": "Color/EightBitColor.ts", "title": "white", "content": "Eightbit White Color instance . Signature . export declare const white: Type . ", "url": "/0.1.0/ansi-styles/Color/EightBitColor.ts.html#white", "relUrl": "/ansi-styles/Color/EightBitColor.ts.html#white" },"680": { "doc": "Color/EightBitColor.ts", "title": "yellow", "content": "Eightbit Yellow Color instance . Signature . export declare const yellow: Type . ", "url": "/0.1.0/ansi-styles/Color/EightBitColor.ts.html#yellow", "relUrl": "/ansi-styles/Color/EightBitColor.ts.html#yellow" },"681": { "doc": "Color/EightBitColor.ts", "title": "yellow1", "content": "Eightbit Yellow1 Color instance . Signature . export declare const yellow1: Type . ", "url": "/0.1.0/ansi-styles/Color/EightBitColor.ts.html#yellow1", "relUrl": "/ansi-styles/Color/EightBitColor.ts.html#yellow1" },"682": { "doc": "Color/EightBitColor.ts", "title": "yellow2", "content": "Eightbit Yellow2 Color instance . Signature . export declare const yellow2: Type . ", "url": "/0.1.0/ansi-styles/Color/EightBitColor.ts.html#yellow2", "relUrl": "/ansi-styles/Color/EightBitColor.ts.html#yellow2" },"683": { "doc": "Color/EightBitColor.ts", "title": "yellow3_1", "content": "Eightbit Yellow3_1 Color instance . Signature . export declare const yellow3_1: Type . ", "url": "/0.1.0/ansi-styles/Color/EightBitColor.ts.html#yellow3_1", "relUrl": "/ansi-styles/Color/EightBitColor.ts.html#yellow3_1" },"684": { "doc": "Color/EightBitColor.ts", "title": "yellow3_2", "content": "Eightbit Yellow3_2 Color instance . Signature . export declare const yellow3_2: Type . ", "url": "/0.1.0/ansi-styles/Color/EightBitColor.ts.html#yellow3_2", "relUrl": "/ansi-styles/Color/EightBitColor.ts.html#yellow3_2" },"685": { "doc": "Color/EightBitColor.ts", "title": "yellow4_1", "content": "Eightbit Yellow4_1 Color instance . Signature . export declare const yellow4_1: Type . ", "url": "/0.1.0/ansi-styles/Color/EightBitColor.ts.html#yellow4_1", "relUrl": "/ansi-styles/Color/EightBitColor.ts.html#yellow4_1" },"686": { "doc": "Color/EightBitColor.ts", "title": "yellow4_2", "content": "Eightbit Yellow4_2 Color instance . Signature . export declare const yellow4_2: Type . ", "url": "/0.1.0/ansi-styles/Color/EightBitColor.ts.html#yellow4_2", "relUrl": "/ansi-styles/Color/EightBitColor.ts.html#yellow4_2" },"687": { "doc": "Color/EightBitColor.ts", "title": "Models", "content": " ", "url": "/0.1.0/ansi-styles/Color/EightBitColor.ts.html#models", "relUrl": "/ansi-styles/Color/EightBitColor.ts.html#models" },"688": { "doc": "Color/EightBitColor.ts", "title": "Type (class)", "content": "EightBit color Type . Signature . export declare class Type { private constructor({ code }: { readonly code: ASEightBitColorCode.Type }) } . make (static method) . Static constructor . Signature . static make(params: { readonly code: ASEightBitColorCode.Type }): Type . [Hash.symbol] (method) . Calculates the hash value of this . Signature . [Hash.symbol](): number . [MEquivalenceBasedEqualityData.isEquivalentToSymbol] (method) . Function that implements the equivalence of this and that . Signature . [MEquivalenceBasedEqualityData.isEquivalentToSymbol](this: this, that: this): boolean . [MEquivalenceBasedEqualityData.hasSameTypeMarkerAsSymbol] (method) . Predicate that returns true if that has the same type marker as this . Signature . [MEquivalenceBasedEqualityData.hasSameTypeMarkerAsSymbol](that: unknown): boolean . code (property) . Code of this color . Signature . readonly code: ASEightBitColorCode.Type . ", "url": "/0.1.0/ansi-styles/Color/EightBitColor.ts.html#type-class", "relUrl": "/ansi-styles/Color/EightBitColor.ts.html#type-class" },"689": { "doc": "Color/EightBitColor.ts", "title": "Module markers", "content": " ", "url": "/0.1.0/ansi-styles/Color/EightBitColor.ts.html#module-markers", "relUrl": "/ansi-styles/Color/EightBitColor.ts.html#module-markers" },"690": { "doc": "Color/EightBitColor.ts", "title": "moduleTag", "content": "Module tag . Signature . export declare const moduleTag: \"@parischap/ansi-styles/Color/EightBitColor/\" . ", "url": "/0.1.0/ansi-styles/Color/EightBitColor.ts.html#moduletag", "relUrl": "/ansi-styles/Color/EightBitColor.ts.html#moduletag" },"691": { "doc": "Color/EightBitColor.ts", "title": "Color/EightBitColor.ts", "content": " ", "url": "/0.1.0/ansi-styles/Color/EightBitColor.ts.html", "relUrl": "/ansi-styles/Color/EightBitColor.ts.html" },"692": { "doc": "Data/EquivalenceBasedEqualityData.ts", "title": "EquivalenceBasedEqualityData overview", "content": "Base class for value objects that derive Equal.Equal from a user-defined equivalence. ", "url": "/0.1.0/effect-lib/Data/EquivalenceBasedEqualityData.ts.html#equivalencebasedequalitydata-overview", "relUrl": "/effect-lib/Data/EquivalenceBasedEqualityData.ts.html#equivalencebasedequalitydata-overview" },"693": { "doc": "Data/EquivalenceBasedEqualityData.ts", "title": "Mental model", "content": ". | Class extends {@link “./Data.js” | MData.Class} and implements Equal.Equal. | . | Subclasses provide three pieces of behavior: . | [isEquivalentToSymbol] — the semantic equivalence between two same-type instances. | [hasSameTypeMarkerAsSymbol] — a runtime check that two values share the same type marker. Used as a guard before calling [isEquivalentToSymbol]. It is intentionally not declared as a TypeScript type guard because two instances of the same generic class may share a marker yet have different type parameters. | [Hash.symbol] — a hash consistent with the equivalence; return 0 to disable hashing when the equivalence is cheaper than computing a hash. | . | . ", "url": "/0.1.0/effect-lib/Data/EquivalenceBasedEqualityData.ts.html#mental-model", "relUrl": "/effect-lib/Data/EquivalenceBasedEqualityData.ts.html#mental-model" },"694": { "doc": "Data/EquivalenceBasedEqualityData.ts", "title": "Quickstart", "content": "Example (Equality by a single field) . import { Equal, Hash } from \"effect\" import * as MData from \"@parischap/effect-lib/MData\" import * as MEquivalenceBasedEqualityData from \"@parischap/effect-lib/Data/EquivalenceBasedEqualityData\" class UserId extends MEquivalenceBasedEqualityData.Class { constructor(readonly value: number) { super() } [MData.idSymbol]() { return \"@example/UserId/\" } [MEquivalenceBasedEqualityData.hasSameTypeMarkerAsSymbol](that: unknown) { return that instanceof UserId } [MEquivalenceBasedEqualityData.isEquivalentToSymbol](that: this) { return this.value === that.value } [Hash.symbol]() { return Hash.number(this.value) } } console.log(Equal.equals(new UserId(1), new UserId(1))) // true console.log(Equal.equals(new UserId(1), new UserId(2))) // false . ", "url": "/0.1.0/effect-lib/Data/EquivalenceBasedEqualityData.ts.html#quickstart", "relUrl": "/effect-lib/Data/EquivalenceBasedEqualityData.ts.html#quickstart" },"695": { "doc": "Data/EquivalenceBasedEqualityData.ts", "title": "Table of contents", "content": ". | Model symbols . | hasSameTypeMarkerAsSymbol | isEquivalentToSymbol | . | Models . | Class (class) . | [isEquivalentToSymbol] (method) | [hasSameTypeMarkerAsSymbol] (method) | [Hash.symbol] (method) | [Equal.symbol] (method) | . | Type (type alias) | . | Module markers . | moduleTag | . | . ", "url": "/0.1.0/effect-lib/Data/EquivalenceBasedEqualityData.ts.html", "relUrl": "/effect-lib/Data/EquivalenceBasedEqualityData.ts.html" },"696": { "doc": "Data/EquivalenceBasedEqualityData.ts", "title": "Model symbols", "content": " ", "url": "/0.1.0/effect-lib/Data/EquivalenceBasedEqualityData.ts.html#model-symbols", "relUrl": "/effect-lib/Data/EquivalenceBasedEqualityData.ts.html#model-symbols" },"697": { "doc": "Data/EquivalenceBasedEqualityData.ts", "title": "hasSameTypeMarkerAsSymbol", "content": "Symbol naming the runtime same-type-marker predicate. Subclasses implement it to gate the equivalence check and to keep generic instances from comparing equal across distinct type parameters. Signature . export declare const hasSameTypeMarkerAsSymbol: typeof hasSameTypeMarkerAsSymbol . ", "url": "/0.1.0/effect-lib/Data/EquivalenceBasedEqualityData.ts.html#hassametypemarkerassymbol", "relUrl": "/effect-lib/Data/EquivalenceBasedEqualityData.ts.html#hassametypemarkerassymbol" },"698": { "doc": "Data/EquivalenceBasedEqualityData.ts", "title": "isEquivalentToSymbol", "content": "Symbol naming the user-defined equivalence between two same-type-marker instances. Signature . export declare const isEquivalentToSymbol: typeof isEquivalentToSymbol . ", "url": "/0.1.0/effect-lib/Data/EquivalenceBasedEqualityData.ts.html#isequivalenttosymbol", "relUrl": "/effect-lib/Data/EquivalenceBasedEqualityData.ts.html#isequivalenttosymbol" },"699": { "doc": "Data/EquivalenceBasedEqualityData.ts", "title": "Models", "content": " ", "url": "/0.1.0/effect-lib/Data/EquivalenceBasedEqualityData.ts.html#models", "relUrl": "/effect-lib/Data/EquivalenceBasedEqualityData.ts.html#models" },"700": { "doc": "Data/EquivalenceBasedEqualityData.ts", "title": "Class (class)", "content": "| Abstract base class adding Equal.Equal to {@link “./Data.js” | MData.Class}. | . Signature . export declare class Class . [isEquivalentToSymbol] (method) . Implements the equivalence between this and that. Called only after [hasSameTypeMarkerAsSymbol] confirmed that both share the same type marker. Signature . abstract [isEquivalentToSymbol](this: this, that: this): boolean; . [hasSameTypeMarkerAsSymbol] (method) . Returns true when that has the same type marker as this. Not declared as a TypeScript type guard because two instances of the same generic class may share a marker yet differ in their type parameters. Signature . abstract [hasSameTypeMarkerAsSymbol](that: unknown): boolean; . [Hash.symbol] (method) . Returns the hash of this. Return 0 to disable hashing when computing a real hash would be more expensive than evaluating the equivalence directly. Signature . abstract [Hash.symbol](): number; . [Equal.symbol] (method) . Implements Equal.Equal by combining the same-type-marker guard and the equivalence. Signature . [Equal.symbol](this: this, that: Equal.Equal): boolean . ", "url": "/0.1.0/effect-lib/Data/EquivalenceBasedEqualityData.ts.html#class-class", "relUrl": "/effect-lib/Data/EquivalenceBasedEqualityData.ts.html#class-class" },"701": { "doc": "Data/EquivalenceBasedEqualityData.ts", "title": "Type (type alias)", "content": "Type of objects produced by this module. Signature . export type Type = MData.Type &amp; Equal.Equal &amp; { [isEquivalentToSymbol](this: Type, that: Type): boolean [hasSameTypeMarkerAsSymbol](that: unknown): boolean } . ", "url": "/0.1.0/effect-lib/Data/EquivalenceBasedEqualityData.ts.html#type-type-alias", "relUrl": "/effect-lib/Data/EquivalenceBasedEqualityData.ts.html#type-type-alias" },"702": { "doc": "Data/EquivalenceBasedEqualityData.ts", "title": "Module markers", "content": " ", "url": "/0.1.0/effect-lib/Data/EquivalenceBasedEqualityData.ts.html#module-markers", "relUrl": "/effect-lib/Data/EquivalenceBasedEqualityData.ts.html#module-markers" },"703": { "doc": "Data/EquivalenceBasedEqualityData.ts", "title": "moduleTag", "content": "Module tag. Signature . export declare const moduleTag: \"@parischap/effect-lib/Data/EquivalenceBasedEqualityData/\" . ", "url": "/0.1.0/effect-lib/Data/EquivalenceBasedEqualityData.ts.html#moduletag", "relUrl": "/effect-lib/Data/EquivalenceBasedEqualityData.ts.html#moduletag" },"704": { "doc": "Data/EquivalenceBasedEqualityData.ts", "title": "Data/EquivalenceBasedEqualityData.ts", "content": " ", "url": "/0.1.0/effect-lib/Data/EquivalenceBasedEqualityData.ts.html", "relUrl": "/effect-lib/Data/EquivalenceBasedEqualityData.ts.html" },"705": { "doc": "Function.ts", "title": "Function overview", "content": "Extension to the Effect Function module providing function introspection, lazy memoization, conditional application, and function-identity helpers. ", "url": "/0.1.0/effect-lib/Function.ts.html#function-overview", "relUrl": "/effect-lib/Function.ts.html#function-overview" },"706": { "doc": "Function.ts", "title": "Mental model", "content": ". | Functions are values that can be inspected, copied with a fresh identity, and partially composed. | All functions are pure unless explicitly noted (once and clone produce wrappers; once carries internal mutable state). | . ", "url": "/0.1.0/effect-lib/Function.ts.html#mental-model", "relUrl": "/effect-lib/Function.ts.html#mental-model" },"707": { "doc": "Function.ts", "title": "Common tasks", "content": ". | Conditional application: {@link fIfTrue} | Currying / shape-shifting: {@link flipDual} | Introspection: {@link parameterNumber}, {@link name} | Lazy memoization: {@link once} | this plumbing: {@link applyAsThis} | Evaluation: {@link execute} | Identity: {@link clone} | Constants: {@link constEmptyString}, {@link constFailVoid}, {@link proto} | . ", "url": "/0.1.0/effect-lib/Function.ts.html#common-tasks", "relUrl": "/effect-lib/Function.ts.html#common-tasks" },"708": { "doc": "Function.ts", "title": "Quickstart", "content": "Example (Curry a dual function and inspect it) . import { Array, pipe } from \"effect\" import * as MFunction from \"@parischap/effect-lib/MFunction\" const curriedMap = MFunction.flipDual&lt;ReadonlyArray&lt;number&gt;, readonly [(n: number) =&gt; number], ReadonlyArray&lt;number&gt;&gt;( Array.map ) console.log( pipe( [1, 2, 3], curriedMap((n) =&gt; n * 2) ) ) // [2, 4, 6] console.log(MFunction.parameterNumber((a: number, b: number) =&gt; a + b)) // 2 . ", "url": "/0.1.0/effect-lib/Function.ts.html#quickstart", "relUrl": "/effect-lib/Function.ts.html#quickstart" },"709": { "doc": "Function.ts", "title": "Table of contents", "content": ". | Constants . | constEmptyString | constFailVoid | proto | . | Utils . | applyAsThis | clone | execute | fIfTrue | flipDual | name | once | parameterNumber | . | . ", "url": "/0.1.0/effect-lib/Function.ts.html", "relUrl": "/effect-lib/Function.ts.html" },"710": { "doc": "Function.ts", "title": "Constants", "content": " ", "url": "/0.1.0/effect-lib/Function.ts.html#constants", "relUrl": "/effect-lib/Function.ts.html#constants" },"711": { "doc": "Function.ts", "title": "constEmptyString", "content": "A constant lazy value always returning ''. Signature . export declare const constEmptyString: Function.LazyArg&lt;\"\"&gt; . ", "url": "/0.1.0/effect-lib/Function.ts.html#constemptystring", "relUrl": "/effect-lib/Function.ts.html#constemptystring" },"712": { "doc": "Function.ts", "title": "constFailVoid", "content": "A constant lazy value always returning Result.failVoid. | Useful as the failure callback of helpers like Result.liftPredicate when no error context is needed. | . Signature . export declare const constFailVoid: Function.LazyArg&lt;Result.Result&lt;never, void&gt;&gt; . ", "url": "/0.1.0/effect-lib/Function.ts.html#constfailvoid", "relUrl": "/effect-lib/Function.ts.html#constfailvoid" },"713": { "doc": "Function.ts", "title": "proto", "content": "The Function.prototype object, captured via the prototype of a built-in function. | Useful as a reference when checking whether an object inherits from Function.prototype. | . Signature . export declare const proto: Function . ", "url": "/0.1.0/effect-lib/Function.ts.html#proto", "relUrl": "/effect-lib/Function.ts.html#proto" },"714": { "doc": "Function.ts", "title": "Utils", "content": " ", "url": "/0.1.0/effect-lib/Function.ts.html#utils", "relUrl": "/effect-lib/Function.ts.html#utils" },"715": { "doc": "Function.ts", "title": "applyAsThis", "content": "Calls self with o bound as the this context. | Use to invoke a method-like function whose body relies on this. | . Example (Bind this and invoke) . import { pipe } from \"effect\" import * as MFunction from \"@parischap/effect-lib/MFunction\" function getValue(this: { readonly value: number }) { return this.value } console.log(pipe(getValue, MFunction.applyAsThis({ value: 42 }))) // 42 . Signature . export declare const applyAsThis: &lt;O extends MTypes.ReadonlyNonPrimitive&gt;( o: NoInfer&lt;O&gt; ) =&gt; &lt;A&gt;(self: (this: O) =&gt; A) =&gt; A . ", "url": "/0.1.0/effect-lib/Function.ts.html#applyasthis", "relUrl": "/effect-lib/Function.ts.html#applyasthis" },"716": { "doc": "Function.ts", "title": "clone", "content": "Returns a fresh wrapper around self that exhibits the same behavior but is referentially distinct. | Use when downstream code keys off function identity (e.g. cache invalidation, equality checks). | . Example (Distinct identity, identical behavior) . import * as MFunction from \"@parischap/effect-lib/MFunction\" const original = (a: number) =&gt; a * 2 const copy = MFunction.clone(original) console.log(original === copy) // false console.log(original(5) === copy(5)) // true . Signature . export declare const clone: &lt;This, Args extends ReadonlyArray&lt;unknown&gt;, R&gt;( self: (this: This, ...args: Args) =&gt; R ) =&gt; (this: This, ...args: Args) =&gt; R . ", "url": "/0.1.0/effect-lib/Function.ts.html#clone", "relUrl": "/effect-lib/Function.ts.html#clone" },"717": { "doc": "Function.ts", "title": "execute", "content": "Invokes a lazy value, i.e. calls self with no argument. | Use as the terminal step of a pipeline that builds up a LazyArg&lt;A&gt;. | . Example (Force a lazy value) . import * as MFunction from \"@parischap/effect-lib/MFunction\" console.log(MFunction.execute(() =&gt; 42)) // 42 . Signature . export declare const execute: &lt;A&gt;(self: Function.LazyArg&lt;A&gt;) =&gt; A . ", "url": "/0.1.0/effect-lib/Function.ts.html#execute", "relUrl": "/effect-lib/Function.ts.html#execute" },"718": { "doc": "Function.ts", "title": "fIfTrue", "content": "Applies f to the input value when condition is true; returns the input unchanged otherwise. | Use to gate a transformation by a flag without breaking the pipeline. | condition is captured at construction time and re-read on every call (it does not get re-evaluated — it is already a boolean). | . Example (Conditional doubling) . import { pipe } from \"effect\" import * as MFunction from \"@parischap/effect-lib/MFunction\" const doubleIfFlag = (flag: boolean) =&gt; MFunction.fIfTrue({ condition: flag, f: (n: number) =&gt; n * 2 }) console.log(pipe(5, doubleIfFlag(true))) // 10 console.log(pipe(5, doubleIfFlag(false))) // 5 . Signature . export declare const fIfTrue: &lt;A&gt;({ condition, f }: { readonly condition: boolean readonly f: (a: NoInfer&lt;A&gt;) =&gt; NoInfer&lt;A&gt; }) =&gt; (a: A) =&gt; A . ", "url": "/0.1.0/effect-lib/Function.ts.html#fiftrue", "relUrl": "/effect-lib/Function.ts.html#fiftrue" },"719": { "doc": "Function.ts", "title": "flipDual", "content": "Converts an n-ary, data-first function into its curried, data-first equivalent. The first argument becomes the outer parameter; the remaining arguments are taken by the returned function. | Use to feed a built-in Array.map-style API into a pipe chain. | The TypeScript inference engine cannot recover generic type parameters from a curried wrapper, so generic self’s usually require explicit type arguments at the call site. | . Example (Curry Array.map) . import { Array, pipe } from \"effect\" import * as MFunction from \"@parischap/effect-lib/MFunction\" const curriedMap = MFunction.flipDual&lt;ReadonlyArray&lt;number&gt;, readonly [(n: number) =&gt; number], ReadonlyArray&lt;number&gt;&gt;( Array.map ) console.log( pipe( [1, 2, 3], curriedMap((n) =&gt; n * 2) ) ) // [2, 4, 6] . Signature . export declare const flipDual: &lt;First, Others extends ReadonlyArray&lt;unknown&gt;, R&gt;( self: (first: First, ...others: Others) =&gt; R ) =&gt; (first: First) =&gt; (...others: Others) =&gt; R . ", "url": "/0.1.0/effect-lib/Function.ts.html#flipdual", "relUrl": "/effect-lib/Function.ts.html#flipdual" },"720": { "doc": "Function.ts", "title": "name", "content": "Returns f.name. | Returns an empty string for anonymous arrow expressions assigned to nothing. | . Example (Function name) . import * as MFunction from \"@parischap/effect-lib/MFunction\" const add = (a: number, b: number) =&gt; a + b console.log(MFunction.name(add)) // 'add' . Signature . export declare const name: (f: MTypes.AnyFunction) =&gt; string . ", "url": "/0.1.0/effect-lib/Function.ts.html#name", "relUrl": "/effect-lib/Function.ts.html#name" },"721": { "doc": "Function.ts", "title": "once", "content": "Memoizes a zero-argument function so that f runs at most once and subsequent calls return the cached result. | Use to defer the cost of building a constant until the first time it is actually needed, provided that constant is read more than once. | The wrapper holds mutable state internally; create one wrapper per cache slot. | . Example (Lazy initialization) . import * as MFunction from \"@parischap/effect-lib/MFunction\" let calls = 0 const expensive = MFunction.once(() =&gt; { calls++ return 42 }) console.log(expensive()) // 42 console.log(expensive()) // 42 console.log(calls) // 1 . Signature . export declare const once: &lt;A&gt;(f: Function.LazyArg&lt;A&gt;) =&gt; Function.LazyArg&lt;A&gt; . ", "url": "/0.1.0/effect-lib/Function.ts.html#once", "relUrl": "/effect-lib/Function.ts.html#once" },"722": { "doc": "Function.ts", "title": "parameterNumber", "content": "Returns the declared arity of f (i.e. f.length). | Returns the number of named parameters before the first one with a default value or the rest parameter. | . Example (Declared arity) . import * as MFunction from \"@parischap/effect-lib/MFunction\" console.log(MFunction.parameterNumber((a: number, b: number) =&gt; a + b)) // 2 console.log(MFunction.parameterNumber((a: number) =&gt; a)) // 1 . Signature . export declare const parameterNumber: (f: MTypes.AnyFunction) =&gt; number . ", "url": "/0.1.0/effect-lib/Function.ts.html#parameternumber", "relUrl": "/effect-lib/Function.ts.html#parameternumber" },"723": { "doc": "Function.ts", "title": "Function.ts", "content": " ", "url": "/0.1.0/effect-lib/Function.ts.html", "relUrl": "/effect-lib/Function.ts.html" },"724": { "doc": "InputError.ts", "title": "InputError overview", "content": "Tagged error type for input-validation failures, paired with constructors that build the error message and assertion helpers that lift those constructors into Result-returning predicates. ", "url": "/0.1.0/effect-lib/InputError.ts.html#inputerror-overview", "relUrl": "/effect-lib/InputError.ts.html#inputerror-overview" },"725": { "doc": "InputError.ts", "title": "Mental model", "content": ". | Type is a Data.TaggedError whose only field is a human-readable message. | For each validation scenario this module exports two functions: . | A constructor (e.g. {@link wrongValue}, {@link missized}) that builds an InputError with a pre-formatted message; | An assertion (e.g. {@link assertValue}, {@link assertLength}) that returns a curried predicate (input) =&gt; Result.Result&lt;input, Type&gt; using that constructor on failure. | . | All name-bearing inputs default the prefix of the message to \"value\" when omitted. | . ", "url": "/0.1.0/effect-lib/InputError.ts.html#mental-model", "relUrl": "/effect-lib/InputError.ts.html#mental-model" },"726": { "doc": "InputError.ts", "title": "Common tasks", "content": ". | Validate equality: {@link assertValue} (and constructor {@link wrongValue}) | Validate length: {@link assertLength}, {@link assertMaxLength} (constructors {@link missized}, {@link oversized}) | Validate range: {@link assertInRange} (constructor {@link outOfBounds}) | Validate strings: {@link assertStartsWith}, {@link assertMatches}, {@link match}, {@link assertEmpty} (constructors {@link notStartingWith}, {@link notMatching}, {@link notEmpty}) | . ", "url": "/0.1.0/effect-lib/InputError.ts.html#common-tasks", "relUrl": "/effect-lib/InputError.ts.html#common-tasks" },"727": { "doc": "InputError.ts", "title": "Quickstart", "content": "Example (Validate a value) . import { Result, pipe } from \"effect\" import * as MInputError from \"@parischap/effect-lib/MInputError\" console.log(pipe(\"admin\", MInputError.assertValue({ expected: \"admin\", name: \"role\" }))) // Success('admin') console.log(pipe(\"user\", MInputError.assertValue({ expected: \"admin\", name: \"role\" }))) // Failure(InputError(\"Expected role to be: 'admin'. Actual: 'user'\")) . ", "url": "/0.1.0/effect-lib/InputError.ts.html#quickstart", "relUrl": "/effect-lib/InputError.ts.html#quickstart" },"728": { "doc": "InputError.ts", "title": "Table of contents", "content": ". | Constructors . | missized | notEmpty | notMatching | notStartingWith | outOfBounds | oversized | wrongValue | . | Models . | Type (class) | . | Module markers . | moduleTag | . | Utils . | assertEmpty | assertInRange | assertLength | assertMatches | assertMaxLength | assertStartsWith | assertValue | match | . | . ", "url": "/0.1.0/effect-lib/InputError.ts.html", "relUrl": "/effect-lib/InputError.ts.html" },"729": { "doc": "InputError.ts", "title": "Constructors", "content": " ", "url": "/0.1.0/effect-lib/InputError.ts.html#constructors", "relUrl": "/effect-lib/InputError.ts.html#constructors" },"730": { "doc": "InputError.ts", "title": "missized", "content": "Builds an InputError for an array-like value whose length differs from the expected one. Signature . export declare const missized: ({ expected, actual, name }: { readonly expected: number readonly actual: number readonly name?: string }) =&gt; Type . ", "url": "/0.1.0/effect-lib/InputError.ts.html#missized", "relUrl": "/effect-lib/InputError.ts.html#missized" },"731": { "doc": "InputError.ts", "title": "notEmpty", "content": "Builds an InputError for a string that should have been empty. Signature . export declare const notEmpty: ({ actual, name }: { readonly actual: string; readonly name?: string }) =&gt; Type . ", "url": "/0.1.0/effect-lib/InputError.ts.html#notempty", "relUrl": "/effect-lib/InputError.ts.html#notempty" },"732": { "doc": "InputError.ts", "title": "notMatching", "content": "Builds an InputError for a string that does not match a given regular expression. | regExpDescriptor is the human-readable description used in the error message (e.g. \"a valid email\"). | . Signature . export declare const notMatching: ({ regExpDescriptor, actual, name }: { readonly regExpDescriptor: string readonly actual: string readonly name?: string }) =&gt; Type . ", "url": "/0.1.0/effect-lib/InputError.ts.html#notmatching", "relUrl": "/effect-lib/InputError.ts.html#notmatching" },"733": { "doc": "InputError.ts", "title": "notStartingWith", "content": "Builds an InputError for a string that does not start with startString. Signature . export declare const notStartingWith: ({ startString, actual, name }: { readonly startString: string readonly actual: string readonly name?: string }) =&gt; Type . ", "url": "/0.1.0/effect-lib/InputError.ts.html#notstartingwith", "relUrl": "/effect-lib/InputError.ts.html#notstartingwith" },"734": { "doc": "InputError.ts", "title": "outOfBounds", "content": "Builds an InputError for a numeric value that fell outside [min, max]. | minIncluded / maxIncluded control whether the corresponding bound is inclusive. | offset is added to min, max and actual only when formatting the message — it is purely cosmetic and lets callers report bounds in a different unit (e.g. 1-based indexing). | . Signature . export declare const outOfBounds: ({ min, max, minIncluded, maxIncluded, offset, actual, name }: { readonly min: number readonly max: number readonly minIncluded: boolean readonly maxIncluded: boolean readonly offset: number readonly actual: number readonly name?: string }) =&gt; Type . ", "url": "/0.1.0/effect-lib/InputError.ts.html#outofbounds", "relUrl": "/effect-lib/InputError.ts.html#outofbounds" },"735": { "doc": "InputError.ts", "title": "oversized", "content": "Builds an InputError for an array-like value whose length exceeds the expected upper bound. Signature . export declare const oversized: ({ expected, actual, name }: { readonly expected: number readonly actual: number readonly name?: string }) =&gt; Type . ", "url": "/0.1.0/effect-lib/InputError.ts.html#oversized", "relUrl": "/effect-lib/InputError.ts.html#oversized" },"736": { "doc": "InputError.ts", "title": "wrongValue", "content": "Builds an InputError for a value that did not match the expected one. | String operands are quoted with single quotes in the message; other primitives are stringified with toString. | name defaults to \"value\" when omitted. | . Example (Manual error construction) . import * as MInputError from \"@parischap/effect-lib/MInputError\" console.log(MInputError.wrongValue({ expected: \"admin\", actual: \"user\", name: \"role\" }).message) // \"Expected role to be: 'admin'. Actual: 'user'\" . Signature . export declare const wrongValue: &lt;T extends MTypes.NonNullablePrimitive&gt;({ expected, actual, name }: { readonly expected: T readonly actual: T readonly name?: string }) =&gt; Type . ", "url": "/0.1.0/effect-lib/InputError.ts.html#wrongvalue", "relUrl": "/effect-lib/InputError.ts.html#wrongvalue" },"737": { "doc": "InputError.ts", "title": "Models", "content": " ", "url": "/0.1.0/effect-lib/InputError.ts.html#models", "relUrl": "/effect-lib/InputError.ts.html#models" },"738": { "doc": "InputError.ts", "title": "Type (class)", "content": "Tagged error returned by every assertion in this module. Signature . export declare class Type . ", "url": "/0.1.0/effect-lib/InputError.ts.html#type-class", "relUrl": "/effect-lib/InputError.ts.html#type-class" },"739": { "doc": "InputError.ts", "title": "Module markers", "content": " ", "url": "/0.1.0/effect-lib/InputError.ts.html#module-markers", "relUrl": "/effect-lib/InputError.ts.html#module-markers" },"740": { "doc": "InputError.ts", "title": "moduleTag", "content": "Module tag. Signature . export declare const moduleTag: \"@parischap/effect-lib/InputError/\" . ", "url": "/0.1.0/effect-lib/InputError.ts.html#moduletag", "relUrl": "/effect-lib/InputError.ts.html#moduletag" },"741": { "doc": "InputError.ts", "title": "Utils", "content": " ", "url": "/0.1.0/effect-lib/InputError.ts.html#utils", "relUrl": "/effect-lib/InputError.ts.html#utils" },"742": { "doc": "InputError.ts", "title": "assertEmpty", "content": "Asserts that input is the empty string. | Returns a {@link notEmpty} error on failure. | . Example (Empty check) . import { pipe } from \"effect\" import * as MInputError from \"@parischap/effect-lib/MInputError\" console.log(pipe(\"\", MInputError.assertEmpty())) // Success('') console.log(pipe(\"x\", MInputError.assertEmpty())) // Failure(InputError(...)) . Signature . export declare const assertEmpty: (params?: { readonly name?: string }) =&gt; MTypes.OneArgFunction&lt;string, Result.Result&lt;string, Type&gt;&gt; . ", "url": "/0.1.0/effect-lib/InputError.ts.html#assertempty", "relUrl": "/effect-lib/InputError.ts.html#assertempty" },"743": { "doc": "InputError.ts", "title": "assertInRange", "content": "Asserts that input lies in the interval [min, max], with each bound inclusive or exclusive according to minIncluded / maxIncluded. | Returns an {@link outOfBounds} error on failure. | . Example (Range check) . import { pipe } from \"effect\" import * as MInputError from \"@parischap/effect-lib/MInputError\" const isPercentage = MInputError.assertInRange({ min: 0, max: 100, minIncluded: true, maxIncluded: true, offset: 0, name: \"percentage\" }) console.log(pipe(50, isPercentage)) // Success(50) console.log(pipe(150, isPercentage)) // Failure(InputError(...)) . Signature . export declare const assertInRange: (params: { readonly min: number readonly max: number readonly minIncluded: boolean readonly maxIncluded: boolean readonly offset: number readonly name?: string }) =&gt; MTypes.OneArgFunction&lt;number, Result.Result&lt;number, Type&gt;&gt; . ", "url": "/0.1.0/effect-lib/InputError.ts.html#assertinrange", "relUrl": "/effect-lib/InputError.ts.html#assertinrange" },"744": { "doc": "InputError.ts", "title": "assertLength", "content": "Asserts that input.length === expected. | Works with any ArrayLike&lt;unknown&gt; or string. | Returns a {@link missized} error on failure. | . Example (Length check) . import { pipe } from \"effect\" import * as MInputError from \"@parischap/effect-lib/MInputError\" console.log(pipe(\"abc\", MInputError.assertLength({ expected: 3 }))) // Success('abc') console.log(pipe(\"abcd\", MInputError.assertLength({ expected: 3 }))) // Failure(InputError(...)) . Signature . export declare const assertLength: (params: { readonly expected: number readonly name?: string }) =&gt; &lt;A extends ArrayLike&lt;unknown&gt; | string&gt;(self: A) =&gt; Result.Result&lt;A, Type&gt; . ", "url": "/0.1.0/effect-lib/InputError.ts.html#assertlength", "relUrl": "/effect-lib/InputError.ts.html#assertlength" },"745": { "doc": "InputError.ts", "title": "assertMatches", "content": "Asserts that input matches regExp. | Returns the matched input on success, a {@link notMatching} error on failure. | . Example (Regex check) . import { pipe } from \"effect\" import * as MInputError from \"@parischap/effect-lib/MInputError\" console.log(pipe(\"hello\", MInputError.assertMatches({ regExp: /^[a-z]+$/, regExpDescriptor: \"lowercase letters\" }))) // Success('hello') . Signature . export declare const assertMatches: (params: { readonly regExp: RegExp readonly regExpDescriptor: string readonly name?: string }) =&gt; MTypes.OneArgFunction&lt;string, Result.Result&lt;string, Type&gt;&gt; . ", "url": "/0.1.0/effect-lib/InputError.ts.html#assertmatches", "relUrl": "/effect-lib/InputError.ts.html#assertmatches" },"746": { "doc": "InputError.ts", "title": "assertMaxLength", "content": "Asserts that input.length &lt;= expected. | Works with any ArrayLike&lt;unknown&gt; or string. | Returns an {@link oversized} error on failure. | . Example (Maximum length check) . import { pipe } from \"effect\" import * as MInputError from \"@parischap/effect-lib/MInputError\" const within10 = MInputError.assertMaxLength({ expected: 10 }) console.log(pipe(\"hello\", within10)) // Success('hello') console.log(pipe(\"hello world!\", within10)) // Failure(InputError(...)) . Signature . export declare const assertMaxLength: (params: { readonly expected: number readonly name?: string }) =&gt; &lt;A extends ArrayLike&lt;unknown&gt; | string&gt;(self: A) =&gt; Result.Result&lt;A, Type&gt; . ", "url": "/0.1.0/effect-lib/InputError.ts.html#assertmaxlength", "relUrl": "/effect-lib/InputError.ts.html#assertmaxlength" },"747": { "doc": "InputError.ts", "title": "assertStartsWith", "content": "Asserts that input starts with startString. | Returns a {@link notStartingWith} error on failure. | . Example (Prefix check) . import { pipe } from \"effect\" import * as MInputError from \"@parischap/effect-lib/MInputError\" console.log(pipe(\"hello world\", MInputError.assertStartsWith({ startString: \"hello\" }))) // Success('hello world') . Signature . export declare const assertStartsWith: (params: { readonly startString: string readonly name?: string }) =&gt; MTypes.OneArgFunction&lt;string, Result.Result&lt;string, Type&gt;&gt; . ", "url": "/0.1.0/effect-lib/InputError.ts.html#assertstartswith", "relUrl": "/effect-lib/InputError.ts.html#assertstartswith" },"748": { "doc": "InputError.ts", "title": "assertValue", "content": "Asserts that input === expected (using strict equality). | Returns Result.success(input) when the equality holds, otherwise Result.failure with a {@link wrongValue} error. | . Example (Equality check) . import { pipe } from \"effect\" import * as MInputError from \"@parischap/effect-lib/MInputError\" const isAdmin = MInputError.assertValue({ expected: \"admin\", name: \"role\" }) console.log(pipe(\"admin\", isAdmin)) // Success('admin') console.log(pipe(\"user\", isAdmin)) // Failure(InputError(...)) . Signature . export declare const assertValue: &lt;T extends MTypes.NonNullablePrimitive&gt;(params: { readonly expected: NoInfer&lt;T&gt; readonly name?: string }) =&gt; MTypes.OneArgFunction&lt;T, Result.Result&lt;T, Type&gt;&gt; . ", "url": "/0.1.0/effect-lib/InputError.ts.html#assertvalue", "relUrl": "/effect-lib/InputError.ts.html#assertvalue" },"749": { "doc": "InputError.ts", "title": "match", "content": "Returns the substring of input matching regExp. Returns a {@link notMatching} error when input does not match. | Differs from {@link assertMatches} in that the success value is the matched substring, not the whole input. | . Example (Extract first match) . import { pipe } from \"effect\" import * as MInputError from \"@parischap/effect-lib/MInputError\" console.log(pipe(\"abc123\", MInputError.match({ regExp: /\\d+/, regExpDescriptor: \"digits\" }))) // Success('123') . Signature . export declare const match: (params: { readonly regExp: RegExp readonly regExpDescriptor: string readonly name?: string }) =&gt; (self: string) =&gt; Result.Result&lt;string, Type&gt; . ", "url": "/0.1.0/effect-lib/InputError.ts.html#match", "relUrl": "/effect-lib/InputError.ts.html#match" },"750": { "doc": "InputError.ts", "title": "InputError.ts", "content": " ", "url": "/0.1.0/effect-lib/InputError.ts.html", "relUrl": "/effect-lib/InputError.ts.html" },"751": { "doc": "Match.ts", "title": "Match overview", "content": "Compilation-free pattern matcher that branches on predicates and refinements. ", "url": "/0.1.0/effect-lib/Match.ts.html#match-overview", "relUrl": "/effect-lib/Match.ts.html#match-overview" },"752": { "doc": "Match.ts", "title": "Mental model", "content": ". | Type&lt;Input, Output, Rest&gt; is a matcher in progress. | Input is the original value being matched. | Output is the union of result types contributed so far. | Rest is the part of Input that no previous refinement has eliminated. | . | Each when/whenIs/whenOr/whenAnd/tryFunction short-circuits on success: as soon as a case produces an output, every subsequent case is skipped. | Terminate with {@link exhaustive} (compile-time check that Rest is never) or {@link orElse} (runtime fallback). | . ", "url": "/0.1.0/effect-lib/Match.ts.html#mental-model", "relUrl": "/effect-lib/Match.ts.html#mental-model" },"753": { "doc": "Match.ts", "title": "Common tasks", "content": ". | Create: {@link make} | Add cases: {@link when}, {@link whenIs}, {@link whenIsOr}, {@link tryFunction} | Combine cases: {@link whenOr}, {@link whenAnd} | Terminate: {@link exhaustive}, {@link orElse}, {@link unsafeWhen} | . ", "url": "/0.1.0/effect-lib/Match.ts.html#common-tasks", "relUrl": "/effect-lib/Match.ts.html#common-tasks" },"754": { "doc": "Match.ts", "title": "Quickstart", "content": "Example (Sign of a number) . import { Number, pipe } from \"effect\" import * as MMatch from \"@parischap/effect-lib/MMatch\" const sign = (n: number) =&gt; pipe( n, MMatch.make, MMatch.when(Number.isLessThan(0), () =&gt; \"negative\"), MMatch.when(Number.isGreaterThan(0), () =&gt; \"positive\"), MMatch.orElse(() =&gt; \"zero\") ) console.log(sign(5)) // 'positive' console.log(sign(0)) // 'zero' . ", "url": "/0.1.0/effect-lib/Match.ts.html#quickstart", "relUrl": "/effect-lib/Match.ts.html#quickstart" },"755": { "doc": "Match.ts", "title": "Table of contents", "content": ". | Constructors . | make | . | Models . | Type (class) . | make (static method) | [MData.idSymbol] (method) | input (property) | output (property) | . | . | Module markers . | moduleTag | . | Utils . | exhaustive | orElse | tryFunction | unsafeWhen | when | whenAnd | whenIs | whenIsOr | whenOr | . | . ", "url": "/0.1.0/effect-lib/Match.ts.html", "relUrl": "/effect-lib/Match.ts.html" },"756": { "doc": "Match.ts", "title": "Constructors", "content": " ", "url": "/0.1.0/effect-lib/Match.ts.html#constructors", "relUrl": "/effect-lib/Match.ts.html#constructors" },"757": { "doc": "Match.ts", "title": "make", "content": "Builds a new matcher. | Use to start building a matcher for a value. | The returned matcher has no cases yet. | Chain with when, whenIs, etc. to add cases. | . Example (Create matcher) . import * as MMatch from \"@parischap/effect-lib/MMatch\" const m = MMatch.make(5) console.log(m.input) // 5 . Signature . export declare const make: &lt;Input&gt;(input: Input) =&gt; Type&lt;Input, never, Input&gt; . ", "url": "/0.1.0/effect-lib/Match.ts.html#make", "relUrl": "/effect-lib/Match.ts.html#make" },"758": { "doc": "Match.ts", "title": "Models", "content": " ", "url": "/0.1.0/effect-lib/Match.ts.html#models", "relUrl": "/effect-lib/Match.ts.html#models" },"759": { "doc": "Match.ts", "title": "Type (class)", "content": "Type that represents a matcher . Signature . export declare class Type&lt;Input, Output, Rest&gt; { private constructor({ input, output }: MTypes.Data&lt;Type&lt;Input, Output, Rest&gt;&gt;) } . make (static method) . Static constructor . Signature . static make&lt;Input, Output, Rest extends Input&gt;( params: MTypes.Data&lt;Type&lt;Input, Output, Rest&gt;&gt;, ): Type&lt;Input, Output, Rest&gt; . [MData.idSymbol] (method) . Returns the id of this . Signature . [MData.idSymbol](): string | (() =&gt; string) . input (property) . The input to match . Signature . readonly input: Input . output (property) . The output of the matcher when it has been found . Signature . readonly output: Option.Option&lt;Output&gt; . ", "url": "/0.1.0/effect-lib/Match.ts.html#type-class", "relUrl": "/effect-lib/Match.ts.html#type-class" },"760": { "doc": "Match.ts", "title": "Module markers", "content": " ", "url": "/0.1.0/effect-lib/Match.ts.html#module-markers", "relUrl": "/effect-lib/Match.ts.html#module-markers" },"761": { "doc": "Match.ts", "title": "moduleTag", "content": "Module tag . Signature . export declare const moduleTag: \"@parischap/effect-lib/Match/\" . ", "url": "/0.1.0/effect-lib/Match.ts.html#moduletag", "relUrl": "/effect-lib/Match.ts.html#moduletag" },"762": { "doc": "Match.ts", "title": "Utils", "content": " ", "url": "/0.1.0/effect-lib/Match.ts.html#utils", "relUrl": "/effect-lib/Match.ts.html#utils" },"763": { "doc": "Match.ts", "title": "exhaustive", "content": "Returns the output of the matcher if all cases are covered. Shows a type error if Rest is not never, meaning there are still uncovered input cases. | Use only when you have covered all possible input cases. | Throws if no case matched. | TypeScript ensures exhaustiveness through the Rest type parameter. | Prefer orElse for non-exhaustive patterns. | . Example (Exhaustive match) . import { pipe } from \"effect\" import * as MMatch from \"@parischap/effect-lib/MMatch\" import * as Number from \"effect/Number\" enum Status { Active = \"a\", Inactive = \"i\" } const describe = (s: Status) =&gt; pipe( s, MMatch.make, MMatch.whenIs(Status.Active, () =&gt; \"Active\"), MMatch.whenIs(Status.Inactive, () =&gt; \"Inactive\"), MMatch.exhaustive ) console.log(describe(Status.Active)) // \"Active\" . Signature . export declare const exhaustive: &lt;Input, Output&gt;(self: Type&lt;Input, Output, never&gt;) =&gt; Output . ", "url": "/0.1.0/effect-lib/Match.ts.html#exhaustive", "relUrl": "/effect-lib/Match.ts.html#exhaustive" },"764": { "doc": "Match.ts", "title": "orElse", "content": "Provides a default value if no match has occurred. Returns the output if there is one, otherwise returns f(self.input). | Use to handle the case where no previous predicates matched. | Receives the original input value. | Guaranteed to produce a result (exhaustive). | . Example (Provide default value) . import { pipe } from \"effect\" import * as MMatch from \"@parischap/effect-lib/MMatch\" import * as Number from \"effect/Number\" const result = pipe( 5, MMatch.make, MMatch.when(Number.isLessThan(0), () =&gt; \"negative\"), MMatch.orElse(() =&gt; \"non-negative\") ) console.log(result) // \"non-negative\" . Signature . export declare const orElse: &lt;Input, Rest extends Input, Output1&gt;( f: (value: NoInfer&lt;Rest&gt;) =&gt; Output1 ) =&gt; &lt;Output&gt;(self: Type&lt;Input, Output, Rest&gt;) =&gt; Output | Output1 . ", "url": "/0.1.0/effect-lib/Match.ts.html#orelse", "relUrl": "/effect-lib/Match.ts.html#orelse" },"765": { "doc": "Match.ts", "title": "tryFunction", "content": "Tries applying a function that returns an Option. Matches if the function returns a some. Returns a copy of self if self already has an output. Otherwise, applies f to self.input. If f returns some, sets the output. If f returns none, tries the next case. | Use when matching using optional computations. | Useful for extracting values from containers like arrays. | The match succeeds only when f returns Option.some. | . Example (Match with optional function) . import { pipe } from \"effect\" import { Array } from \"effect\" import * as MMatch from \"@parischap/effect-lib/MMatch\" const result = pipe( [1, 2, 3], MMatch.make, MMatch.tryFunction(Array.get(1)), MMatch.orElse(() =&gt; 0) ) console.log(result) // 2 . Signature . export declare const tryFunction: &lt;Input, Rest extends Input, Output1&gt;( f: (value: NoInfer&lt;Rest&gt;) =&gt; Option.Option&lt;Output1&gt; ) =&gt; &lt;Output&gt;(self: Type&lt;Input, Output, Rest&gt;) =&gt; Type&lt;Input, Output | Output1, Rest&gt; . ", "url": "/0.1.0/effect-lib/Match.ts.html#tryfunction", "relUrl": "/effect-lib/Match.ts.html#tryfunction" },"766": { "doc": "Match.ts", "title": "unsafeWhen", "content": "Terminates the matcher with f applied to the input, without evaluating the runtime predicate. The supplied refinement is only used at the type level to narrow the input handed to f. | Use to remove a final type-level case the matcher can’t otherwise prove (e.g. the last branch of a discriminated union after every other variant has been matched). | When a previous case already produced an output, that output is returned and f is not called. | Unsafe: if the runtime value does not actually satisfy refinement, f is still invoked, silently producing a value typed as if narrowing succeeded. | . Example (Closing a discriminated union) . import { pipe } from \"effect\" import * as MMatch from \"@parischap/effect-lib/MMatch\" type Shape = { readonly _tag: \"Circle\"; readonly r: number } | { readonly _tag: \"Square\"; readonly s: number } const area = (shape: Shape) =&gt; pipe( shape, MMatch.make, MMatch.when( (s): s is Extract&lt;Shape, { readonly _tag: \"Circle\" }&gt; =&gt; s._tag === \"Circle\", (c) =&gt; Math.PI * c.r * c.r ), MMatch.unsafeWhen( (s): s is Extract&lt;Shape, { readonly _tag: \"Square\" }&gt; =&gt; s._tag === \"Square\", (s) =&gt; s.s * s.s ) ) console.log(area({ _tag: \"Circle\", r: 1 })) // 3.141592653589793 console.log(area({ _tag: \"Square\", s: 2 })) // 4 . Signature . export declare const unsafeWhen: &lt;Input, Rest extends Input, Refined extends Rest, Output1&gt;( _predicate: Predicate.Refinement&lt;Rest, Refined&gt;, f: (value: NoInfer&lt;Refined&gt;) =&gt; Output1 ) =&gt; &lt;Output&gt;(self: Type&lt;Input, Output, Rest&gt;) =&gt; Output | Output1 . ", "url": "/0.1.0/effect-lib/Match.ts.html#unsafewhen", "relUrl": "/effect-lib/Match.ts.html#unsafewhen" },"767": { "doc": "Match.ts", "title": "when", "content": "Matches against a refinement or a predicate. Returns a copy of self if self already has an output. Otherwise, applies the predicate/refinement to self.input. Returns a copy of self if the predicate returns false. Otherwise, returns a copy of self with the output set to f(self.input). | Use to add a case to the matcher. | If a previous case matched, this case is skipped. | Use with refinements for type narrowing. | Use with predicates for boolean checks. | . Example (Add matching case) . import { pipe } from \"effect\" import * as MMatch from \"@parischap/effect-lib/MMatch\" import * as Number from \"effect/Number\" const result = pipe( 5, MMatch.make, MMatch.when(Number.isLessThan(0), () =&gt; \"negative\"), MMatch.when(Number.isGreaterThan(0), () =&gt; \"positive\"), MMatch.orElse(() =&gt; \"zero\") ) console.log(result) // \"positive\" . Signature . export declare const when: { &lt;Input, Rest extends Input, Refined extends Rest, Output1&gt;( predicate: Predicate.Refinement&lt;NoInfer&lt;Rest&gt;, Refined&gt;, f: (value: Refined) =&gt; Output1 ): &lt;Output&gt;(self: Type&lt;Input, Output, Rest&gt;) =&gt; Type&lt;Input, Output | Output1, Exclude&lt;Rest, Refined&gt;&gt; &lt;Input, Rest extends Input, Output1&gt;( predicate: Predicate.Predicate&lt;NoInfer&lt;Rest&gt;&gt;, f: (value: Rest) =&gt; Output1 ): &lt;Output&gt;(self: Type&lt;Input, Output, Rest&gt;) =&gt; Type&lt;Input, Output | Output1, Rest&gt; } . ", "url": "/0.1.0/effect-lib/Match.ts.html#when", "relUrl": "/effect-lib/Match.ts.html#when" },"768": { "doc": "Match.ts", "title": "whenAnd", "content": "Matches using multiple predicates where all must be satisfied. The match occurs if all predicates return true. Returns a copy of self if self already has an output. Otherwise, applies all predicates to self.input and returns a copy with the output set to f(self.input) if all match. | Use when multiple conditions must all be true to trigger the same handler. | Efficient alternative to chaining multiple when calls with AND logic. | All predicates are evaluated. | . Example (Match with all predicates required) . import { pipe } from \"effect\" import * as MMatch from \"@parischap/effect-lib/MMatch\" import * as Number from \"effect/Number\" const result = pipe( 5, MMatch.make, MMatch.whenAnd(Number.isGreaterThan(0), Number.isLessThan(10), () =&gt; \"in range\"), MMatch.orElse(() =&gt; \"out of range\") ) console.log(result) // \"in range\" . Signature . export declare const whenAnd: &lt; Input, Rest extends Input, R extends MTypes.ReadonlyOverTwo&lt;Predicate.Predicate&lt;Rest&gt;&gt;, Output1 &gt;( ...args: readonly [ ...refinements: R, f: ( value: NoInfer&lt;MTypes.IntersectAndSimplify&lt;MTypes.ToKeyIntersection&lt;MPredicate.PredicatesToTargets&lt;R&gt;&gt;, Rest&gt;&gt; ) =&gt; Output1 ] ) =&gt; &lt;Output&gt;( self: Type&lt;Input, Output, Rest&gt; ) =&gt; Type&lt;Input, Output | Output1, Exclude&lt;Rest, MTypes.ToKeyIntersection&lt;MPredicate.PredicatesToCoverages&lt;R&gt;&gt;&gt;&gt; . ", "url": "/0.1.0/effect-lib/Match.ts.html#whenand", "relUrl": "/effect-lib/Match.ts.html#whenand" },"769": { "doc": "Match.ts", "title": "whenIs", "content": "Matches against a primitive value using strict equality. Returns a copy of self if self already has an output. Otherwise, self.input is compared to the provided value using strict equality. Returns a copy of self if the two values are not equal. Otherwise, returns a copy of self with the output set to the result of f(self.input). | Use when matching against specific literal values. | Comparison uses strict equality (===). | Useful for enum matching or constant comparisons. | . Example (Match against value) . import { pipe } from \"effect\" import * as MMatch from \"@parischap/effect-lib/MMatch\" enum Status { A = \"a\", B = \"b\" } const describe = (s: Status) =&gt; pipe( s, MMatch.make, MMatch.whenIs(Status.A, () =&gt; \"A status\"), MMatch.orElse(() =&gt; \"other\") ) console.log(describe(Status.A)) // \"A status\" . Signature . export declare const whenIs: &lt;Input extends MTypes.Primitive, Rest extends Input, const A extends Rest, Output1&gt;( value: A, f: (value: A) =&gt; Output1 ) =&gt; &lt;Output&gt;(self: Type&lt;Input, Output, Rest&gt;) =&gt; Type&lt;Input, Output | Output1, Exclude&lt;Rest, A&gt;&gt; . ", "url": "/0.1.0/effect-lib/Match.ts.html#whenis", "relUrl": "/effect-lib/Match.ts.html#whenis" },"770": { "doc": "Match.ts", "title": "whenIsOr", "content": "Matches against multiple primitive values using strict equality. Returns a copy of self if self already has an output. Otherwise, self.input is compared to each provided value using strict equality. Returns a copy of self if no values match. Otherwise, returns a copy of self with the output set to the result of f(self.input). | Use when matching against multiple literal values with the same handler. | All values are compared using strict equality (===). | Efficient alternative to chaining multiple whenIs calls. | . Example (Match against multiple values) . import { pipe } from \"effect\" import * as MMatch from \"@parischap/effect-lib/MMatch\" enum Status { A = \"a\", B = \"b\", C = \"c\" } const describe = (s: Status) =&gt; pipe( s, MMatch.make, MMatch.whenIs(Status.A, () =&gt; \"A\"), MMatch.whenIsOr(Status.B, Status.C, () =&gt; \"B or C\"), MMatch.exhaustive ) console.log(describe(Status.B)) // \"B or C\" . Signature . export declare const whenIsOr: &lt; Input extends MTypes.Primitive, Rest extends Input, R extends MTypes.ReadonlyOverTwo&lt;Rest&gt;, Output1 &gt;( ...args: readonly [...values: R, f: (value: R[number]) =&gt; Output1] ) =&gt; &lt;Output&gt;(self: Type&lt;Input, Output, Rest&gt;) =&gt; Type&lt;Input, Output | Output1, Exclude&lt;Rest, R[number]&gt;&gt; . ", "url": "/0.1.0/effect-lib/Match.ts.html#whenisor", "relUrl": "/effect-lib/Match.ts.html#whenisor" },"771": { "doc": "Match.ts", "title": "whenOr", "content": "Matches using multiple predicates. The match occurs if one of the predicates returns true. Returns a copy of self if self already has an output. Otherwise, applies all predicates to self.input and returns a copy with the output set to f(self.input) if any predicate matches. | Use when multiple unrelated conditions trigger the same handler. | Efficient alternative to chaining multiple when calls with OR logic. | All predicates are evaluated (non-short-circuit). | . Example (Match with multiple predicates) . import { pipe } from \"effect\" import * as MMatch from \"@parischap/effect-lib/MMatch\" import * as Number from \"effect/Number\" const result = pipe( 5, MMatch.make, MMatch.whenOr(Number.isLessThan(0), Number.isGreaterThan(10), () =&gt; \"out of range\"), MMatch.orElse(() =&gt; \"in range\") ) console.log(result) // \"in range\" . Signature . export declare const whenOr: &lt; Input, Rest extends Input, R extends MTypes.ReadonlyOverTwo&lt;Predicate.Predicate&lt;Rest&gt;&gt;, Output1 &gt;( ...args: readonly [ ...refinements: R, f: (value: NoInfer&lt;MTypes.IntersectAndSimplify&lt;MPredicate.PredicatesToTargets&lt;R&gt;[number], Rest&gt;&gt;) =&gt; Output1 ] ) =&gt; &lt;Output&gt;( self: Type&lt;Input, Output, Rest&gt; ) =&gt; Type&lt;Input, Output | Output1, Exclude&lt;Rest, MPredicate.PredicatesToCoverages&lt;R&gt;[number]&gt;&gt; . ", "url": "/0.1.0/effect-lib/Match.ts.html#whenor", "relUrl": "/effect-lib/Match.ts.html#whenor" },"772": { "doc": "Match.ts", "title": "Match.ts", "content": " ", "url": "/0.1.0/effect-lib/Match.ts.html", "relUrl": "/effect-lib/Match.ts.html" },"773": { "doc": "formatting/DateTimeFormat/DateTimeFormatContext/MonthNames.ts", "title": "MonthNames overview", "content": "Module that implements a type that represents the names of the twelve months of a year . ", "url": "/0.1.0/conversions/formatting/DateTimeFormat/DateTimeFormatContext/MonthNames.ts.html#monthnames-overview", "relUrl": "/conversions/formatting/DateTimeFormat/DateTimeFormatContext/MonthNames.ts.html#monthnames-overview" },"774": { "doc": "formatting/DateTimeFormat/DateTimeFormatContext/MonthNames.ts", "title": "Table of contents", "content": ". | Models . | Type (interface) | . | . ", "url": "/0.1.0/conversions/formatting/DateTimeFormat/DateTimeFormatContext/MonthNames.ts.html", "relUrl": "/conversions/formatting/DateTimeFormat/DateTimeFormatContext/MonthNames.ts.html" },"775": { "doc": "formatting/DateTimeFormat/DateTimeFormatContext/MonthNames.ts", "title": "Models", "content": " ", "url": "/0.1.0/conversions/formatting/DateTimeFormat/DateTimeFormatContext/MonthNames.ts.html#models", "relUrl": "/conversions/formatting/DateTimeFormat/DateTimeFormatContext/MonthNames.ts.html#models" },"776": { "doc": "formatting/DateTimeFormat/DateTimeFormatContext/MonthNames.ts", "title": "Type (interface)", "content": "Type of a CVMonthNames . Signature . export interface Type extends MTypes.ReadonlyTuple&lt;string, 12&gt; {} . ", "url": "/0.1.0/conversions/formatting/DateTimeFormat/DateTimeFormatContext/MonthNames.ts.html#type-interface", "relUrl": "/conversions/formatting/DateTimeFormat/DateTimeFormatContext/MonthNames.ts.html#type-interface" },"777": { "doc": "formatting/DateTimeFormat/DateTimeFormatContext/MonthNames.ts", "title": "formatting/DateTimeFormat/DateTimeFormatContext/MonthNames.ts", "content": " ", "url": "/0.1.0/conversions/formatting/DateTimeFormat/DateTimeFormatContext/MonthNames.ts.html", "relUrl": "/conversions/formatting/DateTimeFormat/DateTimeFormatContext/MonthNames.ts.html" },"778": { "doc": "Parameters/NonPrimitiveFormatter.ts", "title": "NonPrimitiveFormatter overview", "content": "This module implements a type that assembles the stringified representation of a non-primitive value from the already-stringified representations of its properties. It is responsible for decisions such as: adding opening/closing marks (brackets, braces), choosing between single-line and multi-line output, and applying tree-style indentation. Use the make function to define custom instances if the pre-built ones do not suit your needs. ", "url": "/0.1.0/pretty-print/Parameters/NonPrimitiveFormatter.ts.html#nonprimitiveformatter-overview", "relUrl": "/pretty-print/Parameters/NonPrimitiveFormatter.ts.html#nonprimitiveformatter-overview" },"779": { "doc": "Parameters/NonPrimitiveFormatter.ts", "title": "Table of contents", "content": ". | Constructors . | make | singleLine | splitOnConstituentNumber | splitOnLongestPropLength | splitOnTotalLength | tabify | treeify | . | Equivalences . | equivalence | . | Getters . | action | id | . | Instances . | usualTreeify | utilInspectLikeArray | utilInspectLikeRecord | . | Models . | Type (class) . | [MData.idSymbol] (method) | [Hash.symbol] (method) | [MEquivalenceBasedEqualityData.isEquivalentToSymbol] (method) | [MEquivalenceBasedEqualityData.hasSameTypeMarkerAsSymbol] (method) | id (property) | action (property) | . | . | Module markers . | moduleTag | . | . ", "url": "/0.1.0/pretty-print/Parameters/NonPrimitiveFormatter.ts.html", "relUrl": "/pretty-print/Parameters/NonPrimitiveFormatter.ts.html" },"780": { "doc": "Parameters/NonPrimitiveFormatter.ts", "title": "Constructors", "content": " ", "url": "/0.1.0/pretty-print/Parameters/NonPrimitiveFormatter.ts.html#constructors", "relUrl": "/pretty-print/Parameters/NonPrimitiveFormatter.ts.html#constructors" },"781": { "doc": "Parameters/NonPrimitiveFormatter.ts", "title": "make", "content": "Constructor . Signature . export declare const make: (params: MTypes.Data&lt;Type&gt;) =&gt; Type . ", "url": "/0.1.0/pretty-print/Parameters/NonPrimitiveFormatter.ts.html#make", "relUrl": "/pretty-print/Parameters/NonPrimitiveFormatter.ts.html#make" },"782": { "doc": "Parameters/NonPrimitiveFormatter.ts", "title": "singleLine", "content": "Constructor that returns a PPNonPrimitiveFormatter instance that always prints non-primitive values on a single line, surrounding properties with the opening/closing marks and separating them with inBetweenPropertySeparatorMark. Signature . export declare const singleLine: ({ inBetweenPropertySeparatorMark, nonPrimitiveValueOpeningMark, nonPrimitiveValueClosingMark, singleLineSpacingMark }: { readonly inBetweenPropertySeparatorMark: string readonly nonPrimitiveValueOpeningMark: string readonly nonPrimitiveValueClosingMark: string readonly singleLineSpacingMark: string }) =&gt; Type . ", "url": "/0.1.0/pretty-print/Parameters/NonPrimitiveFormatter.ts.html#singleline", "relUrl": "/pretty-print/Parameters/NonPrimitiveFormatter.ts.html#singleline" },"783": { "doc": "Parameters/NonPrimitiveFormatter.ts", "title": "splitOnConstituentNumber", "content": "Constructor that returns a PPNonPrimitiveFormatter instance that prints a non-primitive value on a single line if the number of its displayed properties (after filtering and deduping) is less than or equal to limit. Falls back to tabify otherwise. Signature . export declare const splitOnConstituentNumber: ({ limit, inBetweenPropertySeparatorMark, nonPrimitiveValueOpeningMark, nonPrimitiveValueClosingMark, singleLineSpacingMark, tabMark }: { readonly limit: number readonly inBetweenPropertySeparatorMark: string readonly nonPrimitiveValueOpeningMark: string readonly nonPrimitiveValueClosingMark: string readonly singleLineSpacingMark: string readonly tabMark: string }) =&gt; Type . ", "url": "/0.1.0/pretty-print/Parameters/NonPrimitiveFormatter.ts.html#splitonconstituentnumber", "relUrl": "/pretty-print/Parameters/NonPrimitiveFormatter.ts.html#splitonconstituentnumber" },"784": { "doc": "Parameters/NonPrimitiveFormatter.ts", "title": "splitOnLongestPropLength", "content": "Constructor that returns a PPNonPrimitiveFormatter instance that prints a non-primitive value on a single line if the length of the longest property to print (excluding formatting characters and object marks) is less than or equal to limit. Falls back to tabify otherwise. Signature . export declare const splitOnLongestPropLength: ({ limit, inBetweenPropertySeparatorMark, nonPrimitiveValueOpeningMark, nonPrimitiveValueClosingMark, singleLineSpacingMark, tabMark }: { readonly limit: number readonly inBetweenPropertySeparatorMark: string readonly nonPrimitiveValueOpeningMark: string readonly nonPrimitiveValueClosingMark: string readonly singleLineSpacingMark: string readonly tabMark: string }) =&gt; Type . ", "url": "/0.1.0/pretty-print/Parameters/NonPrimitiveFormatter.ts.html#splitonlongestproplength", "relUrl": "/pretty-print/Parameters/NonPrimitiveFormatter.ts.html#splitonlongestproplength" },"785": { "doc": "Parameters/NonPrimitiveFormatter.ts", "title": "splitOnTotalLength", "content": "Constructor that returns a PPNonPrimitiveFormatter instance that prints a non-primitive value on a single line if its total display length (including header, separators and delimiters) is less than or equal to limit. Falls back to tabify otherwise. Signature . export declare const splitOnTotalLength: ({ limit, inBetweenPropertySeparatorMark, nonPrimitiveValueOpeningMark, nonPrimitiveValueClosingMark, singleLineSpacingMark, tabMark }: { readonly limit: number readonly inBetweenPropertySeparatorMark: string readonly nonPrimitiveValueOpeningMark: string readonly nonPrimitiveValueClosingMark: string readonly singleLineSpacingMark: string readonly tabMark: string }) =&gt; Type . ", "url": "/0.1.0/pretty-print/Parameters/NonPrimitiveFormatter.ts.html#splitontotallength", "relUrl": "/pretty-print/Parameters/NonPrimitiveFormatter.ts.html#splitontotallength" },"786": { "doc": "Parameters/NonPrimitiveFormatter.ts", "title": "tabify", "content": "Constructor that returns a PPNonPrimitiveFormatter instance that always prints non-primitive values on multiple lines with tabMark as indentation prefix for each property line. Signature . export declare const tabify: ({ inBetweenPropertySeparatorMark, nonPrimitiveValueOpeningMark, nonPrimitiveValueClosingMark, tabMark }: { readonly inBetweenPropertySeparatorMark: string readonly nonPrimitiveValueOpeningMark: string readonly nonPrimitiveValueClosingMark: string readonly tabMark: string }) =&gt; Type . ", "url": "/0.1.0/pretty-print/Parameters/NonPrimitiveFormatter.ts.html#tabify", "relUrl": "/pretty-print/Parameters/NonPrimitiveFormatter.ts.html#tabify" },"787": { "doc": "Parameters/NonPrimitiveFormatter.ts", "title": "treeify", "content": "Constructor that returns a PPNonPrimitiveFormatter instance that prints non-primitive values in a tree-like fashion using the four provided indentation marks. The header and value marks are not printed. Signature . export declare const treeify: ({ treeIndentForFirstLineOfInitPropsMark, treeIndentForTailLinesOfInitPropsMark, treeIndentForFirstLineOfLastPropMark, treeIndentForTailLinesOfLastPropMark }: { readonly treeIndentForFirstLineOfInitPropsMark: string readonly treeIndentForTailLinesOfInitPropsMark: string readonly treeIndentForFirstLineOfLastPropMark: string readonly treeIndentForTailLinesOfLastPropMark: string }) =&gt; Type . ", "url": "/0.1.0/pretty-print/Parameters/NonPrimitiveFormatter.ts.html#treeify", "relUrl": "/pretty-print/Parameters/NonPrimitiveFormatter.ts.html#treeify" },"788": { "doc": "Parameters/NonPrimitiveFormatter.ts", "title": "Equivalences", "content": " ", "url": "/0.1.0/pretty-print/Parameters/NonPrimitiveFormatter.ts.html#equivalences", "relUrl": "/pretty-print/Parameters/NonPrimitiveFormatter.ts.html#equivalences" },"789": { "doc": "Parameters/NonPrimitiveFormatter.ts", "title": "equivalence", "content": "Equivalence . Signature . export declare const equivalence: Equivalence.Equivalence&lt;Type&gt; . ", "url": "/0.1.0/pretty-print/Parameters/NonPrimitiveFormatter.ts.html#equivalence", "relUrl": "/pretty-print/Parameters/NonPrimitiveFormatter.ts.html#equivalence" },"790": { "doc": "Parameters/NonPrimitiveFormatter.ts", "title": "Getters", "content": " ", "url": "/0.1.0/pretty-print/Parameters/NonPrimitiveFormatter.ts.html#getters", "relUrl": "/pretty-print/Parameters/NonPrimitiveFormatter.ts.html#getters" },"791": { "doc": "Parameters/NonPrimitiveFormatter.ts", "title": "action", "content": "Returns the action property of self . Signature . export declare const action: MTypes.OneArgFunction&lt; Type, MTypes.OneArgFunction&lt; { readonly nonPrimitive: PPValue.ReadonlyNonPrimitive readonly parameters: PPParameters.Type readonly applicableNonPrimitiveParameters: PPResolvedNonPrimitiveParameters.Type readonly header: Function.LazyArg&lt;ASText.Type&gt; readonly stringifiedProperties: PPStringifiedProperties.Type }, [ASText.Type, ...ASText.Type[]] &gt; &gt; . ", "url": "/0.1.0/pretty-print/Parameters/NonPrimitiveFormatter.ts.html#action", "relUrl": "/pretty-print/Parameters/NonPrimitiveFormatter.ts.html#action" },"792": { "doc": "Parameters/NonPrimitiveFormatter.ts", "title": "id", "content": "Returns the id property of self . Signature . export declare const id: MTypes.OneArgFunction&lt;Type, string&gt; . ", "url": "/0.1.0/pretty-print/Parameters/NonPrimitiveFormatter.ts.html#id", "relUrl": "/pretty-print/Parameters/NonPrimitiveFormatter.ts.html#id" },"793": { "doc": "Parameters/NonPrimitiveFormatter.ts", "title": "Instances", "content": " ", "url": "/0.1.0/pretty-print/Parameters/NonPrimitiveFormatter.ts.html#instances", "relUrl": "/pretty-print/Parameters/NonPrimitiveFormatter.ts.html#instances" },"794": { "doc": "Parameters/NonPrimitiveFormatter.ts", "title": "usualTreeify", "content": "NonPrimitiveFormatter instance that treeifies a non-primitive value: no header, no value marks, no inBetweenProperty separator. Tabs are replaced by lines. Signature . export declare const usualTreeify: Type . ", "url": "/0.1.0/pretty-print/Parameters/NonPrimitiveFormatter.ts.html#usualtreeify", "relUrl": "/pretty-print/Parameters/NonPrimitiveFormatter.ts.html#usualtreeify" },"795": { "doc": "Parameters/NonPrimitiveFormatter.ts", "title": "utilInspectLikeArray", "content": "NonPrimitiveFormatter instance that formats a non-primitive value in the way util.inspect does for arrays. Properties are separated by , and surrounded by [, ]. Arrays are split on several lines if the length of the object on a single line would exceed 80 characters. Uses two spaces as tab if the record is printed on several lines . Signature . export declare const utilInspectLikeArray: Type . ", "url": "/0.1.0/pretty-print/Parameters/NonPrimitiveFormatter.ts.html#utilinspectlikearray", "relUrl": "/pretty-print/Parameters/NonPrimitiveFormatter.ts.html#utilinspectlikearray" },"796": { "doc": "Parameters/NonPrimitiveFormatter.ts", "title": "utilInspectLikeRecord", "content": "NonPrimitiveFormatter instance that formats a non-primitive value in the way util.inspect does for records. Properties are separated by , and surrounded by {, }. Records are split on several lines if the length of the object on a single line would exceed 80 characters. Uses two spaces as tab if the record is printed on several lines . Signature . export declare const utilInspectLikeRecord: Type . ", "url": "/0.1.0/pretty-print/Parameters/NonPrimitiveFormatter.ts.html#utilinspectlikerecord", "relUrl": "/pretty-print/Parameters/NonPrimitiveFormatter.ts.html#utilinspectlikerecord" },"797": { "doc": "Parameters/NonPrimitiveFormatter.ts", "title": "Models", "content": " ", "url": "/0.1.0/pretty-print/Parameters/NonPrimitiveFormatter.ts.html#models", "relUrl": "/pretty-print/Parameters/NonPrimitiveFormatter.ts.html#models" },"798": { "doc": "Parameters/NonPrimitiveFormatter.ts", "title": "Type (class)", "content": "Type that represents a NonPrimitiveFormatter. Signature . export declare class Type { constructor({ id, action }: MTypes.Data&lt;Type&gt;) } . [MData.idSymbol] (method) . Returns the id of this . Signature . [MData.idSymbol](): string | (() =&gt; string) . [Hash.symbol] (method) . Calculates the hash value of this . Signature . [Hash.symbol](): number . [MEquivalenceBasedEqualityData.isEquivalentToSymbol] (method) . Function that implements the equivalence of this and that . Signature . [MEquivalenceBasedEqualityData.isEquivalentToSymbol](this: this, that: this): boolean . [MEquivalenceBasedEqualityData.hasSameTypeMarkerAsSymbol] (method) . Predicate that returns true if that has the same type marker as this . Signature . [MEquivalenceBasedEqualityData.hasSameTypeMarkerAsSymbol](that: unknown): boolean . id (property) . Id of this NonPrimitiveFormatter instance. Useful for equality and debugging . Signature . readonly id: string . action (property) . Action of this PPNonPrimitiveFormatter. Takes as input: . | nonPrimitive: the non-primitive value being stringified (used as context for styling), | parameters: the PPParameters instance passed to the PPStringifier, | applicableNonPrimitiveParameters: the merged, fully-resolved PPNonPrimitiveParameters fields applicable to nonPrimitive (see PPResolvedNonPrimitiveParameters.fromApplicableNonPrimitiveParameters), | header: a lazy ASText header placed before the properties (usually the value’s name and property count, e.g. Map(2) ), | stringifiedProperties: the already-stringified representation of each property. | . Returns the complete stringified representation of the non-primitive value. Signature . readonly action: MTypes.OneArgFunction&lt;{ readonly nonPrimitive: PPValue.ReadonlyNonPrimitive; readonly parameters: PPParameters.Type; readonly applicableNonPrimitiveParameters: PPResolvedNonPrimitiveParameters.Type; readonly header: Function.LazyArg&lt;ASText.Type&gt;; readonly stringifiedProperties: PPStringifiedProperties.Type; }, [ASText.Type, ...ASText.Type[]]&gt; . ", "url": "/0.1.0/pretty-print/Parameters/NonPrimitiveFormatter.ts.html#type-class", "relUrl": "/pretty-print/Parameters/NonPrimitiveFormatter.ts.html#type-class" },"799": { "doc": "Parameters/NonPrimitiveFormatter.ts", "title": "Module markers", "content": " ", "url": "/0.1.0/pretty-print/Parameters/NonPrimitiveFormatter.ts.html#module-markers", "relUrl": "/pretty-print/Parameters/NonPrimitiveFormatter.ts.html#module-markers" },"800": { "doc": "Parameters/NonPrimitiveFormatter.ts", "title": "moduleTag", "content": "Module tag . Signature . export declare const moduleTag: \"@parischap/pretty-print/Parameters/NonPrimitiveFormatter/\" . ", "url": "/0.1.0/pretty-print/Parameters/NonPrimitiveFormatter.ts.html#moduletag", "relUrl": "/pretty-print/Parameters/NonPrimitiveFormatter.ts.html#moduletag" },"801": { "doc": "Parameters/NonPrimitiveFormatter.ts", "title": "Parameters/NonPrimitiveFormatter.ts", "content": " ", "url": "/0.1.0/pretty-print/Parameters/NonPrimitiveFormatter.ts.html", "relUrl": "/pretty-print/Parameters/NonPrimitiveFormatter.ts.html" },"802": { "doc": "Parameters/NonPrimitiveParameters.ts", "title": "NonPrimitiveParameters overview", "content": "This module implements the pretty-printing parameters that govern how a specific category of non- primitive values is displayed. A PPParameters instance holds an ordered array of PPNonPrimitiveParameters. When stringifying a non-primitive value, every entry whose isApplicableTo predicate matches is selected and the matching ones are merged together (lower- index entries override higher-index ones); fields not specified by any of the merged entries fall back to the record-like defaults exposed by PPResolvedNonPrimitiveParameters.utilInspectLikeRecord. Apart from id and isApplicableTo, every field is optional: an instance therefore acts as a partial override layer. Use the make function to define your own. ", "url": "/0.1.0/pretty-print/Parameters/NonPrimitiveParameters.ts.html#nonprimitiveparameters-overview", "relUrl": "/pretty-print/Parameters/NonPrimitiveParameters.ts.html#nonprimitiveparameters-overview" },"803": { "doc": "Parameters/NonPrimitiveParameters.ts", "title": "Table of contents", "content": ". | Constructors . | make | . | Equivalences . | equivalence | . | Getters . | id | isApplicableTo | . | Instances . | treeify | treeifyHideLeaves | utilInspectLikeArray | utilInspectLikeFunction | utilInspectLikeIterable | . | Models . | Type (class) . | [MData.idSymbol] (method) | [Hash.symbol] (method) | [MEquivalenceBasedEqualityData.isEquivalentToSymbol] (method) | [MEquivalenceBasedEqualityData.hasSameTypeMarkerAsSymbol] (method) | id (property) | isApplicableTo (property) | showName (property) | propertyNumberDisplayOption (property) | byPasser (property) | maxPrototypeDepth (property) | propertyFilter (property) | propertySortOrder (property) | dedupeProperties (property) | maxPropertyNumber (property) | propertyFormatter (property) | nonPrimitiveFormatter (property) | hideAutoGeneratedKeys (property) | extractIterableElements (property) | . | . | Module markers . | moduleTag | . | . ", "url": "/0.1.0/pretty-print/Parameters/NonPrimitiveParameters.ts.html", "relUrl": "/pretty-print/Parameters/NonPrimitiveParameters.ts.html" },"804": { "doc": "Parameters/NonPrimitiveParameters.ts", "title": "Constructors", "content": " ", "url": "/0.1.0/pretty-print/Parameters/NonPrimitiveParameters.ts.html#constructors", "relUrl": "/pretty-print/Parameters/NonPrimitiveParameters.ts.html#constructors" },"805": { "doc": "Parameters/NonPrimitiveParameters.ts", "title": "make", "content": "Constructor of a PPNonPrimitiveParameters. Only id and isApplicableTo are required; every other field is optional and falls back to the module-level default after merging. Signature . export declare const make: (params: MTypes.Data&lt;Type&gt;) =&gt; Type . ", "url": "/0.1.0/pretty-print/Parameters/NonPrimitiveParameters.ts.html#make", "relUrl": "/pretty-print/Parameters/NonPrimitiveParameters.ts.html#make" },"806": { "doc": "Parameters/NonPrimitiveParameters.ts", "title": "Equivalences", "content": " ", "url": "/0.1.0/pretty-print/Parameters/NonPrimitiveParameters.ts.html#equivalences", "relUrl": "/pretty-print/Parameters/NonPrimitiveParameters.ts.html#equivalences" },"807": { "doc": "Parameters/NonPrimitiveParameters.ts", "title": "equivalence", "content": "Equivalence . Signature . export declare const equivalence: Equivalence.Equivalence&lt;Type&gt; . ", "url": "/0.1.0/pretty-print/Parameters/NonPrimitiveParameters.ts.html#equivalence", "relUrl": "/pretty-print/Parameters/NonPrimitiveParameters.ts.html#equivalence" },"808": { "doc": "Parameters/NonPrimitiveParameters.ts", "title": "Getters", "content": " ", "url": "/0.1.0/pretty-print/Parameters/NonPrimitiveParameters.ts.html#getters", "relUrl": "/pretty-print/Parameters/NonPrimitiveParameters.ts.html#getters" },"809": { "doc": "Parameters/NonPrimitiveParameters.ts", "title": "id", "content": "Returns the id property of self . Signature . export declare const id: MTypes.OneArgFunction&lt;Type, string&gt; . ", "url": "/0.1.0/pretty-print/Parameters/NonPrimitiveParameters.ts.html#id", "relUrl": "/pretty-print/Parameters/NonPrimitiveParameters.ts.html#id" },"810": { "doc": "Parameters/NonPrimitiveParameters.ts", "title": "isApplicableTo", "content": "Returns the isApplicableTo property of self . Signature . export declare const isApplicableTo: MTypes.OneArgFunction&lt;Type, Predicate.Predicate&lt;MTypes.ReadonlyNonPrimitive&gt;&gt; . ", "url": "/0.1.0/pretty-print/Parameters/NonPrimitiveParameters.ts.html#isapplicableto", "relUrl": "/pretty-print/Parameters/NonPrimitiveParameters.ts.html#isapplicableto" },"811": { "doc": "Parameters/NonPrimitiveParameters.ts", "title": "Instances", "content": " ", "url": "/0.1.0/pretty-print/Parameters/NonPrimitiveParameters.ts.html#instances", "relUrl": "/pretty-print/Parameters/NonPrimitiveParameters.ts.html#instances" },"812": { "doc": "Parameters/NonPrimitiveParameters.ts", "title": "treeify", "content": "Catch-all PPNonPrimitiveParameters instance used to treeify any non-primitive value. Shows leaf keys regardless of whether the keys were auto-generated. Signature . export declare const treeify: Type . ", "url": "/0.1.0/pretty-print/Parameters/NonPrimitiveParameters.ts.html#treeify", "relUrl": "/pretty-print/Parameters/NonPrimitiveParameters.ts.html#treeify" },"813": { "doc": "Parameters/NonPrimitiveParameters.ts", "title": "treeifyHideLeaves", "content": "Same as treeify but hides leaf values, only displaying their keys. Signature . export declare const treeifyHideLeaves: Type . ", "url": "/0.1.0/pretty-print/Parameters/NonPrimitiveParameters.ts.html#treeifyhideleaves", "relUrl": "/pretty-print/Parameters/NonPrimitiveParameters.ts.html#treeifyhideleaves" },"814": { "doc": "Parameters/NonPrimitiveParameters.ts", "title": "utilInspectLikeArray", "content": "PPNonPrimitiveParameters instance for arrays. Shows [Array] when maxDepth is exceeded; otherwise displays the array as util.inspect does (e.g. [ 3, 4 ]). The contents are extracted through iteration; properties of the array object (e.g. length) are not displayed unless you change maxPrototypeDepth to 1 or more. Note: this instance must be placed before utilInspectLikeIterable in the nonPrimitiveParametersArray (lower index = higher priority during merge). It explicitly resets showName, propertyNumberDisplayOption and propertyFormatter because, when an array is processed, utilInspectLikeIterable (which is also applicable) would otherwise contribute its iterable-style values for those fields. Signature . export declare const utilInspectLikeArray: Type . ", "url": "/0.1.0/pretty-print/Parameters/NonPrimitiveParameters.ts.html#utilinspectlikearray", "relUrl": "/pretty-print/Parameters/NonPrimitiveParameters.ts.html#utilinspectlikearray" },"815": { "doc": "Parameters/NonPrimitiveParameters.ts", "title": "utilInspectLikeFunction", "content": "PPNonPrimitiveParameters instance for functions. Functions are displayed as util.inspect does (e.g. [Function: foo], or [Function: (anonymous)] when the function has no name) . Signature . export declare const utilInspectLikeFunction: Type . ", "url": "/0.1.0/pretty-print/Parameters/NonPrimitiveParameters.ts.html#utilinspectlikefunction", "relUrl": "/pretty-print/Parameters/NonPrimitiveParameters.ts.html#utilinspectlikefunction" },"816": { "doc": "Parameters/NonPrimitiveParameters.ts", "title": "utilInspectLikeIterable", "content": "PPNonPrimitiveParameters instance for iterables (Arrays, Maps, Sets, HashMaps, HashSets, typed arrays…). Always shows the value’s name and total element count in the header, e.g. Map(1) { 'A' =&gt; 2 }. The name itself comes from PPParameters.name, whose default uses value.constructor.name, so this transparently handles Map, Set, WeakMap, WeakSet, Int8Array, Float32Array, etc. as well as user-defined iterable classes. Signature . export declare const utilInspectLikeIterable: Type . ", "url": "/0.1.0/pretty-print/Parameters/NonPrimitiveParameters.ts.html#utilinspectlikeiterable", "relUrl": "/pretty-print/Parameters/NonPrimitiveParameters.ts.html#utilinspectlikeiterable" },"817": { "doc": "Parameters/NonPrimitiveParameters.ts", "title": "Models", "content": " ", "url": "/0.1.0/pretty-print/Parameters/NonPrimitiveParameters.ts.html#models", "relUrl": "/pretty-print/Parameters/NonPrimitiveParameters.ts.html#models" },"818": { "doc": "Parameters/NonPrimitiveParameters.ts", "title": "Type (class)", "content": "Type that represents a PPNonPrimitiveParameters. Apart from id and isApplicableTo, every field is optional: unset fields are filled in by PPResolvedNonPrimitiveParameters.fromApplicableNonPrimitiveParameters from the record-like defaults. Signature . export declare class Type { constructor(params: MTypes.Data&lt;Type&gt;) } . [MData.idSymbol] (method) . Returns the id of this . Signature . [MData.idSymbol](): string | (() =&gt; string) . [Hash.symbol] (method) . Calculates the hash value of this . Signature . [Hash.symbol](): number . [MEquivalenceBasedEqualityData.isEquivalentToSymbol] (method) . Function that implements the equivalence of this and that . Signature . [MEquivalenceBasedEqualityData.isEquivalentToSymbol](this: this, that: this): boolean . [MEquivalenceBasedEqualityData.hasSameTypeMarkerAsSymbol] (method) . Predicate that returns true if that has the same type marker as this . Signature . [MEquivalenceBasedEqualityData.hasSameTypeMarkerAsSymbol](that: unknown): boolean . id (property) . Id of this PPNonPrimitiveParameters. Used for equality and debugging . Signature . readonly id: string . isApplicableTo (property) . Predicate that returns true if this PPNonPrimitiveParameters is applicable to nonPrimitive. Signature . readonly isApplicableTo: Predicate.Predicate&lt;MTypes.ReadonlyNonPrimitive&gt; . showName (property) . When true, the value’s name (computed by PPParameters.name) is shown in the header before the properties, separated by headerSeparatorMark. Property counts (when enabled via propertyNumberDisplayOption) are inserted between the name and the separator. Example: Map(2) { 'a' =&gt; 1, 'b' =&gt; 2 }. Signature . readonly showName: boolean | undefined . propertyNumberDisplayOption (property) . Controls whether and how property counts are shown in the header. When not None, counts are wrapped in propertyNumberOpeningMark / propertyNumberClosingMark. For AllAndActual and AllAndActualIfDifferent, the two counts are separated by propertyNumberSeparatorMark. Examples: Map(2) { 'a' =&gt; 1 } with Actual; Map(5,2) { 'a' =&gt; 1 } with AllAndActual. Signature . readonly propertyNumberDisplayOption: PPPropertyNumberDisplayOption.Type | undefined . byPasser (property) . PPByPasser instance (see PPByPasser.ts) to apply to the non-primitive values to which self is applicable. If you need to pass several PPByPasser’s, use the PPByPasser.merge constructor. Signature . readonly byPasser: PPByPasser.Type | undefined . maxPrototypeDepth (property) . Indicates the level in the prototypal chain of a non-primitive value down to which properties are shown. maxPrototypeDepth &lt;= 0 means that no properties are shown. maxPrototypeDepth = 1 means that only the own properties of a non-primitive value are shown. maxPrototypeDepth = 2 means that only the own properties of a non-primitive value and that of its direct prototype are shown… . Signature . readonly maxPrototypeDepth: number | undefined . propertyFilter (property) . PPPropertyFilter instance (see PropertyFilter.ts) to apply to the properties of non-primitive values to which this is applicable. If you need to pass several PPPropertyFilter instances, use the PPPropertyFilter.merge function. Signature . readonly propertyFilter: PPPropertyFilter.Type | undefined . propertySortOrder (property) . Order to use to sort the properties of that type of non-primitive values just after application of the property filter. If none is passed, properties are not sorted. Signature . readonly propertySortOrder: Option.Option&lt;PPValueOrder.Type&gt; | undefined . dedupeProperties (property) . Non-primitive values can have several properties with the same key. For instance, the same key can appear in an object and one or several of its prototypes. This option allows you to decide if you want to keep all the properties with the same key. If true, only the first occurrence of each property with the same key is kept. Sorting happens before deduping, so you can decide which property will be first by choosing your propertySortOrder carefully (e.g. you may use PropertyOrder.byPrototypalDepth). If false, all occurrences of the same property are kept. Signature . readonly dedupeProperties: boolean | undefined . maxPropertyNumber (property) . Maximal number of properties to keep for non-primitive values. Pass +Infinity to show all properties. Keeps the maxPropertyNumber first properties after filtering, sorting and deduping. Signature . readonly maxPropertyNumber: number | undefined . propertyFormatter (property) . PPPropertyFormatter instance which allows you to specify how to format properties of non- primitive values (see PropertyFormatter.ts). Signature . readonly propertyFormatter: PPPropertyFormatter.Type | undefined . nonPrimitiveFormatter (property) . PPNonPrimitiveFormatter instance: allows you to specify how to print a non-primitive value from its stringified properties (see NonPrimitiveFormatter.ts). Signature . readonly nonPrimitiveFormatter: PPNonPrimitiveFormatter.Type | undefined . hideAutoGeneratedKeys (property) . Keys of the properties of a non-primitive value are not shown if hideAutoGeneratedKeys is true and if all the keys of the properties of that non-primitive value have been generated (this usually happens for an iterable when maxPrototypeDepth is equal to 0). Otherwise, the keys are shown. Signature . readonly hideAutoGeneratedKeys: boolean | undefined . extractIterableElements (property) . When true and the non-primitive value is iterable, its elements are extracted via iteration (in addition to its own keyed properties controlled by maxPrototypeDepth). When false, iteration is skipped even when the value is iterable. Defaults to true. Set to false for categories whose iteration is not meaningful for display, e.g. functions. Signature . readonly extractIterableElements: boolean | undefined . ", "url": "/0.1.0/pretty-print/Parameters/NonPrimitiveParameters.ts.html#type-class", "relUrl": "/pretty-print/Parameters/NonPrimitiveParameters.ts.html#type-class" },"819": { "doc": "Parameters/NonPrimitiveParameters.ts", "title": "Module markers", "content": " ", "url": "/0.1.0/pretty-print/Parameters/NonPrimitiveParameters.ts.html#module-markers", "relUrl": "/pretty-print/Parameters/NonPrimitiveParameters.ts.html#module-markers" },"820": { "doc": "Parameters/NonPrimitiveParameters.ts", "title": "moduleTag", "content": "Module tag . Signature . export declare const moduleTag: \"@parischap/pretty-print/Parameters/NonPrimitiveParameters/\" . ", "url": "/0.1.0/pretty-print/Parameters/NonPrimitiveParameters.ts.html#moduletag", "relUrl": "/pretty-print/Parameters/NonPrimitiveParameters.ts.html#moduletag" },"821": { "doc": "Parameters/NonPrimitiveParameters.ts", "title": "Parameters/NonPrimitiveParameters.ts", "content": " ", "url": "/0.1.0/pretty-print/Parameters/NonPrimitiveParameters.ts.html", "relUrl": "/pretty-print/Parameters/NonPrimitiveParameters.ts.html" },"822": { "doc": "Number.ts", "title": "Number overview", "content": "Extension to the Effect Number module providing safe conversions from bigint and BigDecimal, positive integer modulo, decimal shifting and truncation, and a few numeric predicates. ", "url": "/0.1.0/effect-lib/Number.ts.html#number-overview", "relUrl": "/effect-lib/Number.ts.html#number-overview" },"823": { "doc": "Number.ts", "title": "Mental model", "content": ". | Type is just number. | Conversions come in unsafe* (lossy: too-large or non-finite values become ±Infinity or NaN) and *Option (validating, returning Option) flavors. | Use {@link intModulo} when you need a positive modulo (the JavaScript % operator is sign-preserving). | . ", "url": "/0.1.0/effect-lib/Number.ts.html#mental-model", "relUrl": "/effect-lib/Number.ts.html#mental-model" },"824": { "doc": "Number.ts", "title": "Common tasks", "content": ". | Convert from bigint: {@link unsafeFromBigInt}, {@link fromBigIntOption} | Convert from BigDecimal: {@link unsafeFromBigDecimal}, {@link fromBigDecimalOption} | Convert from string: {@link unsafeFromString} | Arithmetic: {@link opposite}, {@link intModulo}, {@link quotientAndRemainder}, {@link shift}, {@link trunc} | Predicates: {@link equals}, {@link isMultipleOf} | Sign: {@link sign2} | Constants: {@link MAX_SAFE_INTEGER}, {@link MIN_SAFE_INTEGER} | . ", "url": "/0.1.0/effect-lib/Number.ts.html#common-tasks", "relUrl": "/effect-lib/Number.ts.html#common-tasks" },"825": { "doc": "Number.ts", "title": "Quickstart", "content": "Example (Safe conversion and positive modulo) . import * as MNumber from \"@parischap/effect-lib/MNumber\" console.log(MNumber.fromBigIntOption(123n)) // Some(123) console.log(MNumber.intModulo(3)(-7)) // 2 (vs. -7 % 3 === -1) . ", "url": "/0.1.0/effect-lib/Number.ts.html#quickstart", "relUrl": "/effect-lib/Number.ts.html#quickstart" },"826": { "doc": "Number.ts", "title": "Table of contents", "content": ". | Constants . | { MAX_SAFE_INTEGER, MIN_SAFE_INTEGER } | . | Constructors . | fromBigDecimalOption | fromBigIntOption | unsafeFromBigDecimal | unsafeFromBigInt | unsafeFromString | . | Destructors . | quotientAndRemainder | . | Models . | Type (type alias) | . | Predicates . | equals | isMultipleOf | . | Utils . | intModulo | opposite | shift | sign2 | trunc | . | . ", "url": "/0.1.0/effect-lib/Number.ts.html", "relUrl": "/effect-lib/Number.ts.html" },"827": { "doc": "Number.ts", "title": "Constants", "content": " ", "url": "/0.1.0/effect-lib/Number.ts.html#constants", "relUrl": "/effect-lib/Number.ts.html#constants" },"828": { "doc": "Number.ts", "title": "{ MAX_SAFE_INTEGER, MIN_SAFE_INTEGER }", "content": "Number.MAX_SAFE_INTEGER (2^53 − 1) and Number.MIN_SAFE_INTEGER (−(2^53 − 1)). Signature . export declare const { MAX_SAFE_INTEGER, MIN_SAFE_INTEGER }: any . ", "url": "/0.1.0/effect-lib/Number.ts.html#-max_safe_integer-min_safe_integer-", "relUrl": "/effect-lib/Number.ts.html#-max_safe_integer-min_safe_integer-" },"829": { "doc": "Number.ts", "title": "Constructors", "content": " ", "url": "/0.1.0/effect-lib/Number.ts.html#constructors", "relUrl": "/effect-lib/Number.ts.html#constructors" },"830": { "doc": "Number.ts", "title": "fromBigDecimalOption", "content": "Builds a number from a BigDecimal, returning Option.some when the input lies in [Number.MIN_SAFE_INTEGER, Number.MAX_SAFE_INTEGER] and Option.none otherwise. Signature . export declare const fromBigDecimalOption: MTypes.OneArgFunction&lt;BigDecimal.BigDecimal, Option.Option&lt;number&gt;&gt; . ", "url": "/0.1.0/effect-lib/Number.ts.html#frombigdecimaloption", "relUrl": "/effect-lib/Number.ts.html#frombigdecimaloption" },"831": { "doc": "Number.ts", "title": "fromBigIntOption", "content": "Builds a number from a bigint, returning Option.some when the input lies in [Number.MIN_SAFE_INTEGER, Number.MAX_SAFE_INTEGER] and Option.none otherwise. Example (Safe conversion) . import * as MNumber from \"@parischap/effect-lib/MNumber\" console.log(MNumber.fromBigIntOption(42n)) // Some(42) console.log(MNumber.fromBigIntOption(2n ** 100n)) // None . Signature . export declare const fromBigIntOption: MTypes.OneArgFunction&lt;bigint, Option.Option&lt;number&gt;&gt; . ", "url": "/0.1.0/effect-lib/Number.ts.html#frombigintoption", "relUrl": "/effect-lib/Number.ts.html#frombigintoption" },"832": { "doc": "Number.ts", "title": "unsafeFromBigDecimal", "content": "Builds a number from a BigDecimal without range checks. Values outside the safe-integer range are coerced to ±Infinity. Signature . export declare const unsafeFromBigDecimal: MTypes.OneArgFunction&lt;BigDecimal.BigDecimal, number&gt; . ", "url": "/0.1.0/effect-lib/Number.ts.html#unsafefrombigdecimal", "relUrl": "/effect-lib/Number.ts.html#unsafefrombigdecimal" },"833": { "doc": "Number.ts", "title": "unsafeFromBigInt", "content": "Builds a number from a bigint without range checks. Values outside the safe-integer range are coerced to ±Infinity. | Use only when the input is statically known to fit in a JavaScript number. | . Example (Lossy conversion) . import * as MNumber from \"@parischap/effect-lib/MNumber\" console.log(MNumber.unsafeFromBigInt(42n)) // 42 console.log(MNumber.unsafeFromBigInt(2n ** 100n)) // Infinity . Signature . export declare const unsafeFromBigInt: MTypes.OneArgFunction&lt;bigint, number&gt; . ", "url": "/0.1.0/effect-lib/Number.ts.html#unsafefrombigint", "relUrl": "/effect-lib/Number.ts.html#unsafefrombigint" },"834": { "doc": "Number.ts", "title": "unsafeFromString", "content": "Builds a number from a string. Returns NaN when the string is not a valid numeric literal. | 'Infinity' / '+Infinity' produce Infinity; '-Infinity' produces -Infinity. | . Example (String to number) . import * as MNumber from \"@parischap/effect-lib/MNumber\" console.log(MNumber.unsafeFromString(\"42\")) // 42 console.log(MNumber.unsafeFromString(\"abc\")) // NaN . Signature . export declare const unsafeFromString: MTypes.NumberFromString . ", "url": "/0.1.0/effect-lib/Number.ts.html#unsafefromstring", "relUrl": "/effect-lib/Number.ts.html#unsafefromstring" },"835": { "doc": "Number.ts", "title": "Destructors", "content": " ", "url": "/0.1.0/effect-lib/Number.ts.html#destructors", "relUrl": "/effect-lib/Number.ts.html#destructors" },"836": { "doc": "Number.ts", "title": "quotientAndRemainder", "content": "Returns [quotient, remainder] for the Euclidean division of self by divisor. The remainder carries the sign of divisor. | Both inputs must be finite integers; otherwise the result is meaningless. | . Example (Quotient and remainder) . import { pipe } from \"effect\" import * as MNumber from \"@parischap/effect-lib/MNumber\" console.log(pipe(7, MNumber.quotientAndRemainder(3))) // [2, 1] console.log(pipe(-7, MNumber.quotientAndRemainder(3))) // [-3, 2] . Signature . export declare const quotientAndRemainder: (divisor: number) =&gt; (self: Type) =&gt; [quotient: number, remainder: number] . ", "url": "/0.1.0/effect-lib/Number.ts.html#quotientandremainder", "relUrl": "/effect-lib/Number.ts.html#quotientandremainder" },"837": { "doc": "Number.ts", "title": "Models", "content": " ", "url": "/0.1.0/effect-lib/Number.ts.html#models", "relUrl": "/effect-lib/Number.ts.html#models" },"838": { "doc": "Number.ts", "title": "Type (type alias)", "content": "Type on which this module’s functions operate. Signature . export type Type = number . ", "url": "/0.1.0/effect-lib/Number.ts.html#type-type-alias", "relUrl": "/effect-lib/Number.ts.html#type-type-alias" },"839": { "doc": "Number.ts", "title": "Predicates", "content": " ", "url": "/0.1.0/effect-lib/Number.ts.html#predicates", "relUrl": "/effect-lib/Number.ts.html#predicates" },"840": { "doc": "Number.ts", "title": "equals", "content": "Returns true when self and n differ by less than Number.EPSILON. | Use to compare floating-point numbers where exact === is unreliable. | This is an absolute, not relative, tolerance — it is not appropriate for very large magnitudes. | . Example (Floating-point equality) . import { pipe } from \"effect\" import * as MNumber from \"@parischap/effect-lib/MNumber\" console.log(pipe(0.1 + 0.2, MNumber.equals(0.3))) // true . Signature . export declare const equals: (n: number) =&gt; Predicate.Predicate&lt;Type&gt; . ", "url": "/0.1.0/effect-lib/Number.ts.html#equals", "relUrl": "/effect-lib/Number.ts.html#equals" },"841": { "doc": "Number.ts", "title": "isMultipleOf", "content": "Returns true when self is a multiple of a. | Works for any signs of self and a. | . Example (Multiplicity check) . import { pipe } from \"effect\" import * as MNumber from \"@parischap/effect-lib/MNumber\" console.log(pipe(10, MNumber.isMultipleOf(2))) // true console.log(pipe(-9, MNumber.isMultipleOf(3))) // true . Signature . export declare const isMultipleOf: (a: number) =&gt; Predicate.Predicate&lt;Type&gt; . ", "url": "/0.1.0/effect-lib/Number.ts.html#ismultipleof", "relUrl": "/effect-lib/Number.ts.html#ismultipleof" },"842": { "doc": "Number.ts", "title": "Utils", "content": " ", "url": "/0.1.0/effect-lib/Number.ts.html#utils", "relUrl": "/effect-lib/Number.ts.html#utils" },"843": { "doc": "Number.ts", "title": "intModulo", "content": "Returns the non-negative remainder of the integer division of self by divisor. | Use when a positive remainder is needed (the built-in % preserves the sign of self). | Both inputs must be finite integers; otherwise the result is meaningless. | . Example (Positive integer modulo) . import { pipe } from \"effect\" import * as MNumber from \"@parischap/effect-lib/MNumber\" console.log(pipe(-7, MNumber.intModulo(3))) // 2 console.log(pipe(7, MNumber.intModulo(3))) // 1 . Signature . export declare const intModulo: (divisor: number) =&gt; MTypes.OneArgFunction&lt;Type&gt; . ", "url": "/0.1.0/effect-lib/Number.ts.html#intmodulo", "relUrl": "/effect-lib/Number.ts.html#intmodulo" },"844": { "doc": "Number.ts", "title": "opposite", "content": "Returns the additive inverse of self (i.e. -self). Example (Negation) . import * as MNumber from \"@parischap/effect-lib/MNumber\" console.log(MNumber.opposite(3)) // -3 console.log(MNumber.opposite(-3)) // 3 . Signature . export declare const opposite: (self: Type) =&gt; number . ", "url": "/0.1.0/effect-lib/Number.ts.html#opposite", "relUrl": "/effect-lib/Number.ts.html#opposite" },"845": { "doc": "Number.ts", "title": "shift", "content": "Multiplies self by 10^n (i.e. shifts the decimal point by n positions). | Use as the building block of decimal-aware truncation/rounding. | . Example (Decimal shift) . import { pipe } from \"effect\" import * as MNumber from \"@parischap/effect-lib/MNumber\" console.log(pipe(1.5, MNumber.shift(2))) // 150 console.log(pipe(150, MNumber.shift(-2))) // 1.5 . Signature . export declare const shift: (n: number) =&gt; (self: Type) =&gt; number . ", "url": "/0.1.0/effect-lib/Number.ts.html#shift", "relUrl": "/effect-lib/Number.ts.html#shift" },"846": { "doc": "Number.ts", "title": "sign2", "content": "Returns the sign of n as either 1 or -1. Treats +0 (and the unsigned literal 0) as positive and -0 as negative. | Differs from Math.sign, which returns 0/-0 for those inputs. | . Example (Sign with ±0 distinction) . import * as MNumber from \"@parischap/effect-lib/MNumber\" console.log(MNumber.sign2(3)) // 1 console.log(MNumber.sign2(-3)) // -1 console.log(MNumber.sign2(0)) // 1 console.log(MNumber.sign2(-0)) // -1 . Signature . export declare const sign2: (n: number) =&gt; 1 | -1 . ", "url": "/0.1.0/effect-lib/Number.ts.html#sign2", "relUrl": "/effect-lib/Number.ts.html#sign2" },"847": { "doc": "Number.ts", "title": "trunc", "content": "Truncates self to precision decimal digits. | precision must be a non-negative finite integer; defaults to 0. | Rounds towards zero. | . Example (Truncation) . import { pipe } from \"effect\" import * as MNumber from \"@parischap/effect-lib/MNumber\" console.log(pipe(3.14159, MNumber.trunc(2))) // 3.14 console.log(pipe(3.7, MNumber.trunc())) // 3 . Signature . export declare const trunc: (precision?: number) =&gt; (self: Type) =&gt; number . ", "url": "/0.1.0/effect-lib/Number.ts.html#trunc", "relUrl": "/effect-lib/Number.ts.html#trunc" },"848": { "doc": "Number.ts", "title": "Number.ts", "content": " ", "url": "/0.1.0/effect-lib/Number.ts.html", "relUrl": "/effect-lib/Number.ts.html" },"849": { "doc": "formatting/NumberBase10Format/NumberBase10Format.ts", "title": "NumberBase10Format overview", "content": "This module implements a CVNumberBase10Format which describes the possible options to format/parse a base-10 number or BigDecimal and implements the Formatting/parsing algorithms . ", "url": "/0.1.0/conversions/formatting/NumberBase10Format/NumberBase10Format.ts.html#numberbase10format-overview", "relUrl": "/conversions/formatting/NumberBase10Format/NumberBase10Format.ts.html#numberbase10format-overview" },"850": { "doc": "formatting/NumberBase10Format/NumberBase10Format.ts", "title": "Table of contents", "content": ". | Constructors . | make | . | Destructors . | toDescription | . | Getters . | eNotationChars | fractionalSeparator | integerPartPadding | maximumFractionalDigits | minimumFractionalDigits | roundingOption | scientificNotationOption | showNullIntegerPart | signDisplayOption | thousandSeparator | . | Instances . | dutchStyleInteger | dutchStyleNumber | dutchStyleUngroupedNumber | fourDigitSignedInteger | fourDigitUnsignedInteger | frenchStyleInteger | frenchStyleNumber | frenchStyleUngroupedNumber | integer | signedInteger | threeDigitSignedInteger | threeDigitUnsignedInteger | twoDigitSignedInteger | twoDigitUnsignedInteger | ukStyleInteger | ukStyleNumber | ukStyleUngroupedNumber | unsignedInteger | . | Models . | Type (class) . | make (static method) | [MData.idSymbol] (method) | thousandSeparator (property) | fractionalSeparator (property) | showNullIntegerPart (property) | integerPartPadding (property) | minimumFractionalDigits (property) | maximumFr