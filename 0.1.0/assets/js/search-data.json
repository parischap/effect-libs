isplayoption-overview", "relUrl": "/conversions/formatting/NumberBase10Format/NumberBase10FormatSignDisplayOption/NumberBase10FormatSignDisplayOption.ts.html#numberbase10formatsigndisplayoption-overview" },"925": { "doc": "formatting/NumberBase10Format/NumberBase10FormatSignDisplayOption/NumberBase10FormatSignDisplayOption.ts", "title": "Table of contents", "content": ". ", "url": "/0.1.0/conversions/formatting/NumberBase10Format/NumberBase10FormatSignDisplayOption/NumberBase10FormatSignDisplayOption.ts.html", "relUrl": "/conversions/formatting/NumberBase10Format/NumberBase10FormatSignDisplayOption/NumberBase10FormatSignDisplayOption.ts.html" },"926": { "doc": "formatting/NumberBase10Format/NumberBase10FormatSignDisplayOption/NumberBase10FormatSignDisplayOption.ts", "title": "formatting/NumberBase10Format/NumberBase10FormatSignDisplayOption/NumberBase10FormatSignDisplayOption.ts", "content": " ", "url": "/0.1.0/conversions/formatting/NumberBase10Format/NumberBase10FormatSignDisplayOption/NumberBase10FormatSignDisplayOption.ts.html", "relUrl": "/conversions/formatting/NumberBase10Format/NumberBase10FormatSignDisplayOption/NumberBase10FormatSignDisplayOption.ts.html" },"927": { "doc": "formatting/NumberBase10Format/NumberBase10Formatter.ts", "title": "NumberBase10Formatter overview", "content": "This module implements a CVNumberBase10Formatter, i.e. an object that can convert a number into a string according to the CVNumberBase10Format that was used to construct it . ", "url": "/0.1.0/conversions/formatting/NumberBase10Format/NumberBase10Formatter.ts.html#numberbase10formatter-overview", "relUrl": "/conversions/formatting/NumberBase10Format/NumberBase10Formatter.ts.html#numberbase10formatter-overview" },"928": { "doc": "formatting/NumberBase10Format/NumberBase10Formatter.ts", "title": "Table of contents", "content": ". | Constructors . | fromFormat | . | Getters . | description | format | . | Models . | Type (class) . | [MData.idSymbol] (method) | description (property) | format (property) | . | . | Module markers . | moduleTag | . | . ", "url": "/0.1.0/conversions/formatting/NumberBase10Format/NumberBase10Formatter.ts.html", "relUrl": "/conversions/formatting/NumberBase10Format/NumberBase10Formatter.ts.html" },"929": { "doc": "formatting/NumberBase10Format/NumberBase10Formatter.ts", "title": "Constructors", "content": " ", "url": "/0.1.0/conversions/formatting/NumberBase10Format/NumberBase10Formatter.ts.html#constructors", "relUrl": "/conversions/formatting/NumberBase10Format/NumberBase10Formatter.ts.html#constructors" },"930": { "doc": "formatting/NumberBase10Format/NumberBase10Formatter.ts", "title": "fromFormat", "content": "Constructor of a CVNumberBase10Formatter from a CVNumberBase10Format . Signature . export declare const fromFormat: (format: CVNumberBase10Format.Type) =&gt; Type . ", "url": "/0.1.0/conversions/formatting/NumberBase10Format/NumberBase10Formatter.ts.html#fromformat", "relUrl": "/conversions/formatting/NumberBase10Format/NumberBase10Formatter.ts.html#fromformat" },"931": { "doc": "formatting/NumberBase10Format/NumberBase10Formatter.ts", "title": "Getters", "content": " ", "url": "/0.1.0/conversions/formatting/NumberBase10Format/NumberBase10Formatter.ts.html#getters", "relUrl": "/conversions/formatting/NumberBase10Format/NumberBase10Formatter.ts.html#getters" },"932": { "doc": "formatting/NumberBase10Format/NumberBase10Formatter.ts", "title": "description", "content": "Returns the description property of self . Signature . export declare const description: MTypes.OneArgFunction&lt;Type, string&gt; . ", "url": "/0.1.0/conversions/formatting/NumberBase10Format/NumberBase10Formatter.ts.html#description", "relUrl": "/conversions/formatting/NumberBase10Format/NumberBase10Formatter.ts.html#description" },"933": { "doc": "formatting/NumberBase10Format/NumberBase10Formatter.ts", "title": "format", "content": "Returns the format property of self. Signature . export declare const format: MTypes.OneArgFunction&lt;Type, MTypes.OneArgFunction&lt;number | BigDecimal.BigDecimal, string&gt;&gt; . ", "url": "/0.1.0/conversions/formatting/NumberBase10Format/NumberBase10Formatter.ts.html#format", "relUrl": "/conversions/formatting/NumberBase10Format/NumberBase10Formatter.ts.html#format" },"934": { "doc": "formatting/NumberBase10Format/NumberBase10Formatter.ts", "title": "Models", "content": " ", "url": "/0.1.0/conversions/formatting/NumberBase10Format/NumberBase10Formatter.ts.html#models", "relUrl": "/conversions/formatting/NumberBase10Format/NumberBase10Formatter.ts.html#models" },"935": { "doc": "formatting/NumberBase10Format/NumberBase10Formatter.ts", "title": "Type (class)", "content": "Type that represents a CVNumberBase10Formatter . Signature . export declare class Type { constructor(numberFormat: CVNumberBase10Format.Type) } . [MData.idSymbol] (method) . Returns the id of this . Signature . [MData.idSymbol](): string | (() =&gt; string) . description (property) . Description of this formatter, e.g. ‘signed integer formatter’ . Signature . readonly description: string . format (property) . Function that formats a number respecting the options represented by the CVNumberBase10Format from which this was constructed. If successful, that function returns a some of the formatted number. Otherwise, it returns a none. number can be of type number or BigDecimal for better accuracy. There is a difference between number and BigDecimal (and bigint) regarding the sign of 0. In Javascript, Object.is(0,-0) is false whereas Object.is(0n,- 0n) is true. So if the sign of zero is important to you, prefer passing a number to the function. 0 as a BigDecimal will always be interpreted as a positive 0 as we have no means of knowing if it is negative or positive . Signature . readonly format: MTypes.OneArgFunction&lt;number | BigDecimal.BigDecimal, string&gt; . ", "url": "/0.1.0/conversions/formatting/NumberBase10Format/NumberBase10Formatter.ts.html#type-class", "relUrl": "/conversions/formatting/NumberBase10Format/NumberBase10Formatter.ts.html#type-class" },"936": { "doc": "formatting/NumberBase10Format/NumberBase10Formatter.ts", "title": "Module markers", "content": " ", "url": "/0.1.0/conversions/formatting/NumberBase10Format/NumberBase10Formatter.ts.html#module-markers", "relUrl": "/conversions/formatting/NumberBase10Format/NumberBase10Formatter.ts.html#module-markers" },"937": { "doc": "formatting/NumberBase10Format/NumberBase10Formatter.ts", "title": "moduleTag", "content": "Module tag . Signature . export declare const moduleTag: \"@parischap/conversions/formatting/NumberBase10Format/NumberBase10Formatter/\" . ", "url": "/0.1.0/conversions/formatting/NumberBase10Format/NumberBase10Formatter.ts.html#moduletag", "relUrl": "/conversions/formatting/NumberBase10Format/NumberBase10Formatter.ts.html#moduletag" },"938": { "doc": "formatting/NumberBase10Format/NumberBase10Formatter.ts", "title": "formatting/NumberBase10Format/NumberBase10Formatter.ts", "content": " ", "url": "/0.1.0/conversions/formatting/NumberBase10Format/NumberBase10Formatter.ts.html", "relUrl": "/conversions/formatting/NumberBase10Format/NumberBase10Formatter.ts.html" },"939": { "doc": "formatting/NumberBase10Format/NumberBase10Parser.ts", "title": "NumberBase10Parser overview", "content": "This module implements a CVNumberBase10Parser, i.e. an object that can convert a string into a number according to the CVNumberBase10Format that was used to construct it . ", "url": "/0.1.0/conversions/formatting/NumberBase10Format/NumberBase10Parser.ts.html#numberbase10parser-overview", "relUrl": "/conversions/formatting/NumberBase10Format/NumberBase10Parser.ts.html#numberbase10parser-overview" },"940": { "doc": "formatting/NumberBase10Format/NumberBase10Parser.ts", "title": "Table of contents", "content": ". | Constructors . | fromFormat | . | Getters . | description | extractAsBigDecimal | extractAsBigDecimalOrThrow | extractAsNumber | extractAsNumberOrThrow | parseAsBigDecimal | parseAsBigDecimalOrThrow 