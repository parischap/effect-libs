st be an integer greater than or equal to 1 and less than or equal to the number of days in the current year . Signature . export declare const setOrdinalDay: (ordinalDay: number) =&gt; (self: Type) =&gt; Result.Result&lt;Type, MInputError.Type&gt; . ", "url": "/0.1.0/conversions/DateTime/DateTime.ts.html#setordinalday", "relUrl": "/conversions/DateTime/DateTime.ts.html#setordinalday" },"284": { "doc": "DateTime/DateTime.ts", "title": "setOrdinalDayOrThrow", "content": "Same as setOrdinalDay but returns directly a CVDateTime or throws in case of an error . Signature . export declare const setOrdinalDayOrThrow: MTypes.OneArgFunction&lt;number, MTypes.OneArgFunction&lt;Type, Type&gt;&gt; . ", "url": "/0.1.0/conversions/DateTime/DateTime.ts.html#setordinaldayorthrow", "relUrl": "/conversions/DateTime/DateTime.ts.html#setordinaldayorthrow" },"285": { "doc": "DateTime/DateTime.ts", "title": "setSecond", "content": "If possible, returns a Success of a CVDateTime having second second and the same year, ordinalDay, hour23, minute, millisecond and zoneOffset as self. Returns a Failure of an error otherwise. second must be an integer greater than or equal to 0 and less than or equal to 59 . Signature . export declare const setSecond: (second: number) =&gt; (self: Type) =&gt; Result.Result&lt;Type, MInputError.Type&gt; . ", "url": "/0.1.0/conversions/DateTime/DateTime.ts.html#setsecond", "relUrl": "/conversions/DateTime/DateTime.ts.html#setsecond" },"286": { "doc": "DateTime/DateTime.ts", "title": "setSecondOrThrow", "content": "Same as setSecond but returns directly a CVDateTime or throws in case of an error . Signature . export declare const setSecondOrThrow: MTypes.OneArgFunction&lt;number, MTypes.OneArgFunction&lt;Type, Type&gt;&gt; . ", "url": "/0.1.0/conversions/DateTime/DateTime.ts.html#setsecondorthrow", "relUrl": "/conversions/DateTime/DateTime.ts.html#setsecondorthrow" },"287": { "doc": "DateTime/DateTime.ts", "title": "setWeekday", "content": "If possible, returns a Success of a CVDateTime having weekday weekday and the same isoYear, isoWeek, hour23, minute, second, millisecond and zoneOffset as self. Returns a Failure of an error otherwise. weekday must be an integer greater than or equal to 1 (monday) and less than or equal to 7 (sunday). Signature . export declare const setWeekday: (weekday: number) =&gt; (self: Type) =&gt; Result.Result&lt;Type, MInputError.Type&gt; . ", "url": "/0.1.0/conversions/DateTime/DateTime.ts.html#setweekday", "relUrl": "/conversions/DateTime/DateTime.ts.html#setweekday" },"288": { "doc": "DateTime/DateTime.ts", "title": "setWeekdayOrThrow", "content": "Same as setWeekday but returns directly a CVDateTime or throws in case of an error . Signature . export declare const setWeekdayOrThrow: MTypes.OneArgFunction&lt;number, MTypes.OneArgFunction&lt;Type, Type&gt;&gt; . ", "url": "/0.1.0/conversions/DateTime/DateTime.ts.html#setweekdayorthrow", "relUrl": "/conversions/DateTime/DateTime.ts.html#setweekdayorthrow" },"289": { "doc": "DateTime/DateTime.ts", "title": "setYear", "content": "If possible, returns a Success of a CVDateTime having year year and the same month, monthDay, hour23, minute, second, millisecond and zoneOffset as self. Returns a Failure otherwise. year must be an integer comprised in the range [MIN_FULL_YEAR, MAX_FULL_YEAR]. Signature . export declare const setYear: (year: number) =&gt; (self: Type) =&gt; Result.Result&lt;Type, MInputError.Type&gt; . ", "url": "/0.1.0/conversions/DateTime/DateTime.ts.html#setyear", "relUrl": "/conversions/DateTime/DateTime.ts.html#setyear" },"290": { "doc": "DateTime/DateTime.ts", "title": "setYearOrThrow", "content": "Same as setYear but returns directly a CVDateTime or throws in case of an error . Signature . export declare const setYearOrThrow: MTypes.OneArgFunction&lt;number, MTypes.OneArgFunction&lt;Type, Type&gt;&gt; . ", "url": "/0.1.0/conversions/DateTime/DateTime.ts.html#setyearorthrow", "relUrl": "/conversions/DateTime/DateTime.ts.html#setyearorthrow" },"291": { "doc": "DateTime/DateTime.ts", "title": "setZoneOffsetKeepParts", "content": "If possible, returns a Success of a copy of self with the same parts (except zoneOffset) and zoneOffset set to zoneOffset. See setZoneOffsetKeepTimestamp for more details . Signature . export declare const setZoneOffsetKeepParts: ( zoneOffset?: number | { readonly zoneHour: number; readonly zoneMinute: number; readonly zoneSecond: number } ) =&gt; (self: Type) =&gt; Result.Result&lt;Type, MInputError.Type&gt; . ", "url": "/0.1.0/conversions/DateTime/DateTime.ts.html#setzoneoffsetkeepparts", "relUrl": "/conversions/DateTime/DateTime.ts.html#setzoneoffsetkeepparts" },"292": { "doc": "DateTime/DateTime.ts", "title": "setZoneOffsetKeepPartsOrThrow", "content": "Same as setZoneOffsetKeepParts but returns directly a CVDateTime or throws in case of an error . Signature . export declare const setZoneOffsetKeepPartsOrThrow: MTypes.OneArgFunction&lt; number | { readonly zoneHour: number; readonly zoneMinute: number; readonly zoneSecond: number }, MTypes.OneArgFunction&lt;Type, Type&gt; &gt; . ", "url": "/0.1.0/conversions/DateTime/DateTime.ts.html#setzoneoffsetkeeppartsorthrow", "relUrl": "/conversions/DateTime/DateTime.ts.html#setzoneoffsetkeeppartsorthrow" },"293": { "doc": "DateTime/DateTime.ts", "title": "setZoneOffsetKeepTimestamp", "content": "If possible, returns a Success of a copy of self with the same timestamp and zoneOffset set to zoneOffset. If zoneOffset is omitted, the local time zone offset of the machine this code is running on is used. zoneOffset can be expressed as a number of hours. In this case, it must be strictly greater to . | 13 and strictly less than 15. | . It can also be expressed as an object containing three components: . | zoneHour which must be greater than or equal to -12 and less than or equal to 14. | zoneMinute which must be greater than or equal to 0 and less than or equal to 59. | zoneSecond which must be greater than or equal to 0 and less than or equal to 59. | . zoneHour, zoneMinute and zoneSecond should be integers. zoneOffset, when expressed as a number of hours, does not need to be an integer. Signature . export declare const setZoneOffsetKeepTimestamp: ( zoneOffset?: number | { readonly zoneHour: number; readonly zoneMinute: number; readonly zoneSecond: number } ) =&gt; (self: Type) =&gt; Result.Result&lt;Type, MInputError.Type&gt; . ", "url": "/0.1.0/conversions/DateTime/DateTime.ts.html#setzoneoffsetkeeptimestamp", "relUrl": "/conversions/DateTime/DateTime.ts.html#setzoneoffsetkeeptimestamp" },"294": { "doc": "DateTime/DateTime.ts", "title": "setZoneOffsetKeepTimestampOrThrow", "content": "Same as setZoneOffsetKeepTimestamp but returns directly a CVDateTime or throws in case of an error . Signature . export declare const setZoneOffsetKeepTimestampOrThrow: MTypes.OneArgFunction&lt; number | { readonly zoneHour: number; readonly zoneMinute: number; readonly zoneSecond: number }, MTypes.OneArgFunction&lt;Type, Type&gt; &gt; . ", "url": "/0.1.0/conversions/DateTime/DateTime.ts.html#setzoneoffsetkeeptimestamporthrow", "relUrl": "/conversions/DateTime/DateTime.ts.html#setzoneoffsetkeeptimestamporthrow" },"295": { "doc": "DateTime/DateTime.ts", "title": "Utils", "content": " ", "url": "/0.1.0/conversions/DateTime/DateTime.ts.html#utils", "relUrl": "/conversions/DateTime/DateTime.ts.html#utils" },"296": { "doc": "DateTime/DateTime.ts", "title": "toDate", "content": "Builds a Javascript Date from a CVDateTime . Signature . export declare const toDate: (self: Type) =&gt; Date . ", "url": "/0.1.0/conversions/DateTime/DateTime.ts.html#todate", "relUrl": "/conversions/DateTime/DateTime.ts.html#todate" },"297": { "doc": "DateTime/DateTime.ts", "title": "toEffectDateTime", "content": "Builds an Effect.DateTime.Zoned from a CVDateTime . Signature . export declare const toEffectDateTime: (self: Type) =&gt; DateTime.Zoned . ", "url": "/0.1.0/conversions/DateTime/DateTime.ts.html#toeffectdatetime", "relUrl": "/conversions/DateTime/DateTime.ts.html#toeffectdatetime" },"298": { "doc": "DateTime/DateTime.ts", "title": "DateTime/DateTime.ts", "content": " ", "url": "/0.1.0/conversions/DateTime/DateTime.ts.html", "relUrl": "/conversions/DateTime/DateTime.ts.html" },"299": { "doc": "formatting/DateTimeFormat/DateTimeFormat.ts", "title": "DateTimeFormat overview", "content": "This module implements a CVDateTimeFormat, i.e. a CVTemplate (see Template.ts) dedicated to parsing and formatting dates. It supports many of the available Unicode tokens (see https://www.unicode.org/reports/tr35/tr35-dates.html#Date_Field_Symbol_Table). A CVDateTimeFormat is context-independent: it describes the structure of a date string but carries no locale information. To parse or format a date string, you must combine a CVDateTimeFormat with a CVDateTimeFormatContext by constructing a CVDateTimeParser or a CVDateTimeFormatter. ", "url": "/0.1.0/conversions/formatting/DateTimeFormat/DateTimeFormat.ts.html#datetimeformat-overview", "relUrl": "/conversions/formatting/DateTimeFormat/DateTimeFormat.ts.html#datetimeformat-overview" },"300": { "doc": "formatting/DateTimeFormat/DateTimeFormat.ts", "title": "Table of contents", "content": ". | Constructors . | make | . | Getters . | name | parts | . | Instances . | basicIso8601 | euDate | euDotDate | iso8601 | isoDateTime | isoDateTimeMs | longDate | shortDate | time12h | time12hWithSeconds | time24h | time24hWithSeconds | usDate | . | Models . | Type (class) . | make (static method) | [MData.idSymbol] (method) | name (property) | parts (property) | . | . | Module markers . | moduleTag | . | . ", "url": "/0.1.0/conversions/formatting/DateTimeFormat/DateTimeFormat.ts.html", "relUrl": "/conversions/formatting/DateTimeFormat/DateTimeFormat.ts.html" },"301": { "doc": "formatting/DateTimeFormat/DateTimeFormat.ts", "title": "Constructors", "content": " ", "url": "/0.1.0/conversions/formatting/DateTimeFormat/DateTimeFormat.ts.html#constructors", "relUrl": "/conversions/formatting/DateTimeFormat/DateTimeFormat.ts.html#constructors" },"302": { "doc": "formatting/DateTimeFormat/DateTimeFormat.ts", "title": "make", "content": "Constructs a CVDateTimeFormat from the given CVDateTimeFormatPart’s. Signature . export declare const make: (...parts: CVDateTimeFormatParts.Type) =&gt; Type . ", "url": "/0.1.0/conversions/formatting/DateTimeFormat/DateTimeFormat.ts.html#make", "relUrl": "/conversions/formatting/DateTimeFormat/DateTimeFormat.ts.html#make" },"303": { "doc": "formatting/DateTimeFormat/DateTimeFormat.ts", "title": "Getters", "content": " ", "url": "/0.1.0/conversions/formatting/DateTimeFormat/DateTimeFormat.ts.html#getters", "relUrl": "/conversions/formatting/DateTimeFormat/DateTimeFormat.ts.html#getters" },"304": { "doc": "formatting/DateTimeFormat/DateTimeFormat.ts", "title": "name", "content": "Returns the name property of self. Signature . export declare const name: MTypes.OneArgFunction&lt;Type, string&gt; . ", "url": "/0.1.0/conversions/formatting/DateTimeFormat/DateTimeFormat.ts.html#name", "relUrl": "/conversions/formatting/DateTimeFormat/DateTimeFormat.ts.html#name" },"305": { "doc": "formatting/DateTimeFormat/DateTimeFormat.ts", "title": "parts", "content": "Returns the parts property of self. Signature . export declare const parts: MTypes.OneArgFunction&lt;Type, CVDateTimeFormatParts.Type&gt; . ", "url": "/0.1.0/conversions/formatting/DateTimeFormat/DateTimeFormat.ts.html#parts", "relUrl": "/conversions/formatting/DateTimeFormat/DateTimeFormat.ts.html#parts" },"306": { "doc": "formatting/DateTimeFormat/DateTimeFormat.ts", "title": "Instances", "content": " ", "url": "/0.1.0/conversions/formatting/DateTimeFormat/DateTimeFormat.ts.html#instances", "relUrl": "/conversions/formatting/DateTimeFormat/DateTimeFormat.ts.html#instances" },"307": { "doc": "formatting/DateTimeFormat/DateTimeFormat.ts", "title": "basicIso8601", "content": "CVDateTimeFormat instance for the basic ISO 8601 date format (YYYYMMDD, e.g. 20050605). Signature . export declare const basicIso8601: Type . ", "url": "/0.1.0/conversions/formatting/DateTimeFormat/DateTimeFormat.ts.html#basiciso8601", "relUrl": "/conversions/formatting/DateTimeFormat/DateTimeFormat.ts.html#basiciso8601" },"308": { "doc": "formatting/DateTimeFormat/DateTimeFormat.ts", "title": "euDate", "content": "CVDateTimeFormat instance for the European date format with slashes (DD/MM/YYYY, e.g. 05/06/2005). Signature . export declare const euDate: Type . ", "url": "/0.1.0/conversions/formatting/DateTimeFormat/DateTimeFormat.ts.html#eudate", "relUrl": "/conversions/formatting/DateTimeFormat/DateTimeFormat.ts.html#eudate" },"309": { "doc": "formatting/DateTimeFormat/DateTimeFormat.ts", "title": "euDotDate", "content": "CVDateTimeFormat instance for the European date format with dots (DD.MM.YYYY, e.g. 05.06.2005). Signature . export declare const euDotDate: Type . ", "url": "/0.1.0/conversions/formatting/DateTimeFormat/DateTimeFormat.ts.html#eudotdate", "relUrl": "/conversions/formatting/DateTimeFormat/DateTimeFormat.ts.html#eudotdate" },"310": { "doc": "formatting/DateTimeFormat/DateTimeFormat.ts", "title": "iso8601", "content": "CVDateTimeFormat instance for the ISO 8601 date format (YYYY-MM-DD, e.g. 2005-06-05). Signature . export declare const iso8601: Type . ", "url": "/0.1.0/conversions/formatting/DateTimeFormat/DateTimeFormat.ts.html#iso8601", "relUrl": "/conversions/formatting/DateTimeFormat/DateTimeFormat.ts.html#iso8601" },"311": { "doc": "formatting/DateTimeFormat/DateTimeFormat.ts", "title": "isoDateTime", "content": "CVDateTimeFormat instance for the ISO 8601 date-time format without milliseconds (YYYY-MM- DDTHH:mm:ss, e.g. 2005-06-05T14:05:05). Signature . export declare const isoDateTime: Type . ", "url": "/0.1.0/conversions/formatting/DateTimeFormat/DateTimeFormat.ts.html#isodatetime", "relUrl": "/conversions/formatting/DateTimeFormat/DateTimeFormat.ts.html#isodatetime" },"312": { "doc": "formatting/DateTimeFormat/DateTimeFormat.ts", "title": "isoDateTimeMs", "content": "CVDateTimeFormat instance for the ISO 8601 date-time format with milliseconds (YYYY-MM- DDTHH:mm:ss.SSS, e.g. 2005-06-05T14:05:05.007). Signature . export declare const isoDateTimeMs: Type . ", "url": "/0.1.0/conversions/formatting/DateTimeFormat/DateTimeFormat.ts.html#isodatetimems", "relUrl": "/conversions/formatting/DateTimeFormat/DateTimeFormat.ts.html#isodatetimems" },"313": { "doc": "formatting/DateTimeFormat/DateTimeFormat.ts", "title": "longDate", "content": "CVDateTimeFormat instance for a long date format (MMMM d, yyyy, e.g. June 5, 2005). The month name is locale-dependent and requires an appropriate CVDateTimeFormatContext. Signature . export declare const longDate: Type . ", "url": "/0.1.0/conversions/formatting/DateTimeFormat/DateTimeFormat.ts.html#longdate", "relUrl": "/conversions/formatting/DateTimeFormat/DateTimeFormat.ts.html#longdate" },"314": { "doc": "formatting/DateTimeFormat/DateTimeFormat.ts", "title": "shortDate", "content": "CVDateTimeFormat instance for a short date format (MMM d, yyyy, e.g. Jun 5, 2005). The abbreviated month name is locale-dependent and requires an appropriate CVDateTimeFormatContext. Signature . export declare const shortDate: Type . ", "url": "/0.1.0/conversions/formatting/DateTimeFormat/DateTimeFormat.ts.html#shortdate", "relUrl": "/conversions/formatting/DateTimeFormat/DateTimeFormat.ts.html#shortdate" },"315": { "doc": "formatting/DateTimeFormat/DateTimeFormat.ts", "title": "time12h", "content": "CVDateTimeFormat instance for the 12-hour time format without seconds (KK:mm a, e.g. 02:05 PM). Signature . export declare const time12h: Type . ", "url": "/0.1.0/conversions/formatting/DateTimeFormat/DateTimeFormat.ts.html#time12h", "relUrl": "/conversions/formatting/DateTimeFormat/DateTimeFormat.ts.html#time12h" },"316": { "doc": "formatting/DateTimeFormat/DateTimeFormat.ts", "title": "time12hWithSeconds", "content": "CVDateTimeFormat instance for the 12-hour time format with seconds (KK:mm:ss a, e.g. 02:05:05 PM). Signature . export declare const time12hWithSeconds: Type . ", "url": "/0.1.0/conversions/formatting/DateTimeFormat/DateTimeFormat.ts.html#time12hwithseconds", "relUrl": "/conversions/formatting/DateTimeFormat/DateTimeFormat.ts.html#time12hwithseconds" },"317": { "doc": "formatting/DateTimeFormat/DateTimeFormat.ts", "title": "time24h", "content": "CVDateTimeFormat instance for the 24-hour time format without seconds (HH:mm, e.g. 14:05). Signature . export declare const time24h: Type . ", "url": "/0.1.0/conversions/formatting/DateTimeFormat/DateTimeFormat.ts.html#time24h", "relUrl": "/conversions/formatting/DateTimeFormat/DateTimeFormat.ts.html#time24h" },"318": { "doc": "formatting/DateTimeFormat/DateTimeFormat.ts", "title": "time24hWithSeconds", "content": "CVDateTimeFormat instance for the 24-hour time format with seconds (HH:mm:ss, e.g. 14:05:05). Signature . export declare const time24hWithSeconds: Type . ", "url": "/0.1.0/conversions/formatting/DateTimeFormat/DateTimeFormat.ts.html#time24hwithseconds", "relUrl": "/conversions/formatting/DateTimeFormat/DateTimeFormat.ts.html#time24hwithseconds" },"319": { "doc": "formatting/DateTimeFormat/DateTimeFormat.ts", "title": "usDate", "content": "CVDateTimeFormat instance for the US date format (MM/DD/YYYY, e.g. 06/05/2005). Signature . export declare const usDate: Type . ", "url": "/0.1.0/conversions/formatting/DateTimeFormat/DateTimeFormat.ts.html#usdate", "relUrl": "/conversions/formatting/DateTimeFormat/DateTimeFormat.ts.html#usdate" },"320": { "doc": "formatting/DateTimeFormat/DateTimeFormat.ts", "title": "Models", "content": " ", "url": "/0.1.0/conversions/formatting/DateTimeFormat/DateTimeFormat.ts.html#models", "relUrl": "/conversions/formatting/DateTimeFormat/DateTimeFormat.ts.html#models" },"321": { "doc": "formatting/DateTimeFormat/DateTimeFormat.ts", "title": "Type (class)", "content": "Type that represents a CVDateTimeFormat . Signature . export declare class Type { private con