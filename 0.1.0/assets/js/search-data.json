e . ", "url": "/0.1.0/ansi-styles/Palette.ts.html#alloriginalcolors", "relUrl": "/ansi-styles/Palette.ts.html#alloriginalcolors" },"981": { "doc": "Palette.ts", "title": "allStandardOriginalColors", "content": "Palette instance which contains all standard original colors . Signature . export declare const allStandardOriginalColors: Type . ", "url": "/0.1.0/ansi-styles/Palette.ts.html#allstandardoriginalcolors", "relUrl": "/ansi-styles/Palette.ts.html#allstandardoriginalcolors" },"982": { "doc": "Palette.ts", "title": "Models", "content": " ", "url": "/0.1.0/ansi-styles/Palette.ts.html#models", "relUrl": "/ansi-styles/Palette.ts.html#models" },"983": { "doc": "Palette.ts", "title": "Type (class)", "content": "Type that represents a Palette. Signature . export declare class Type { private constructor({ styles }: MTypes.Data&lt;Type&gt;) } . make (static method) . Static constructor . Signature . static make(params: MTypes.Data&lt;Type&gt;): Type . [MData.idSymbol] (method) . Returns the id of this . Signature . [MData.idSymbol](): string | (() =&gt; string) . styles (property) . Array of styles contained by this Palette . Signature . readonly styles: readonly [ASStyle.Type, ASStyle.Type, ...ASStyle.Type[]] . ", "url": "/0.1.0/ansi-styles/Palette.ts.html#type-class", "relUrl": "/ansi-styles/Palette.ts.html#type-class" },"984": { "doc": "Palette.ts", "title": "Module markers", "content": " ", "url": "/0.1.0/ansi-styles/Palette.ts.html#module-markers", "relUrl": "/ansi-styles/Palette.ts.html#module-markers" },"985": { "doc": "Palette.ts", "title": "moduleTag", "content": "Module tag . Signature . export declare const moduleTag: \"@parischap/ansi-styles/Palette/\" . ", "url": "/0.1.0/ansi-styles/Palette.ts.html#moduletag", "relUrl": "/ansi-styles/Palette.ts.html#moduletag" },"986": { "doc": "Palette.ts", "title": "Utils", "content": " ", "url": "/0.1.0/ansi-styles/Palette.ts.html#utils", "relUrl": "/ansi-styles/Palette.ts.html#utils" },"987": { "doc": "Palette.ts", "title": "append", "content": "Appends that to self . Signature . export declare const append: (that: Type) =&gt; (self: Type) =&gt; Type . ", "url": "/0.1.0/ansi-styles/Palette.ts.html#append", "relUrl": "/ansi-styles/Palette.ts.html#append" },"988": { "doc": "Palette.ts", "title": "Palette.ts", "content": " ", "url": "/0.1.0/ansi-styles/Palette.ts.html", "relUrl": "/ansi-styles/Palette.ts.html" },"989": { "doc": "Parameters/Parameters.ts", "title": "Parameters overview", "content": "This module implements the top-level parameters that configure the stringification process. A PPParameters instance bundles together a PPStyleMap, a PPPrimitiveFormatter, and one or more PPNonPrimitiveParameters instances, plus global settings that govern depth limits, circular-reference marks, and property-count formatting. Use the make function to define custom instances if the pre-built ones do not suit your needs. ", "url": "/0.1.0/pretty-print/Parameters/Parameters.ts.html#parameters-overview", "relUrl": "/pretty-print/Parameters/Parameters.ts.html#parameters-overview" },"990": { "doc": "Parameters/Parameters.ts", "title": "Table of contents", "content": ". | Constructors . | make | . | Equivalences . | equivalence | . | Getters . | id | styleMap | . | Instances . | darkModeTreeify | darkModeTreeifyHideLeaves | darkModeUtilInspectLike | treeify | treeifyHideLeaves | utilInspectLike | . | Models . | Type (class) . | make (static method) | [MData.idSymbol] (method) | [Hash.symbol] (method) | [MEquivalenceBasedEqualityData.isEquivalentToSymbol] (method) | [MEquivalenceBasedEqualityData.hasSameTypeMarkerAsSymbol] (method) | id (property) | styleMap (property) | primitiveFormatter (property) | nonPrimitiveParametersArray (property) | name (property) | maxDepth (property) | openingTagMark (property) | closingTagMark (property) | circularReferenceTag (property) | circularAnchorOpeningMark (property) | circularAnchorClosingMark (property) | headerSeparatorMark (property) | propertyNumberSeparatorMark (property) | propertyNumberOpeningMark (property) | propertyNumberClosingMark (property) | . | . | Module markers . | moduleTag | . | . ", "url": "/0.1.0/pretty-print/Parameters/Parameters.ts.html", "relUrl": "/pretty-print/Parameters/Parameters.ts.html" },"991": { "doc": "Parameters/Parameters.ts", "title": "Constructors", "content": " ", "url": "/0.1.0/pretty-print/Parameters/Parameters.ts.html#constructors", "relUrl": "/pretty-print/Parameters/Parameters.ts.html#constructors" },"992": { "doc": "Parameters/Parameters.ts", "title": "make", "content": "Constructor of a PPParameters . Signature . export declare const make: (params: MTypes.Data&lt;Type&gt;) =&gt; Type . ", "url": "/0.1.0/pretty-print/Parameters/Parameters.ts.html#make", "relUrl": "/pretty-print/Parameters/Parameters.ts.html#make" },"993": { "doc": "Parameters/Parameters.ts", "title": "Equivalences", "content": " ", "url": "/0.1.0/pretty-print/Parameters/Parameters.ts.html#equivalences", "relUrl": "/pretty-print/Parameters/Parameters.ts.html#equivalences" },"994": { "doc": "Parameters/Parameters.ts", "title": "equivalence", "content": "Equivalence . Signature . export declare const equivalence: Equivalence.Equivalence&lt;Type&gt; . ", "url": "/0.1.0/pretty-print/Parameters/Parameters.ts.html#equivalence", "relUrl": "/pretty-print/Parameters/Parameters.ts.html#equivalence" },"995": { "doc": "Parameters/Parameters.ts", "title": "Getters", "content": " ", "url": "/0.1.0/pretty-print/Parameters/Parameters.ts.html#getters", "relUrl": "/pretty-print/Parameters/Parameters.ts.html#getters" },"996": { "doc": "Parameters/Parameters.ts", "title": "id", "content": "Returns the id property of self . Signature . export declare const id: MTypes.OneArgFunction&lt;Type, string&gt; . ", "url": "/0.1.0/pretty-print/Parameters/Parameters.ts.html#id", "relUrl": "/pretty-print/Parameters/Parameters.ts.html#id" },"997": { "doc": "Parameters/Parameters.ts", "title": "styleMap", "content": "Returns the styleMap property of self . Signature . export declare const styleMap: MTypes.OneArgFunction&lt;Type, PPStyleMap.Type&gt; . ", "url": "/0.1.0/pretty-print/Parameters/Parameters.ts.html#stylemap", "relUrl": "/pretty-print/Parameters/Parameters.ts.html#stylemap" },"998": { "doc": "Parameters/Parameters.ts", "title": "Instances", "content": " ", "url": "/0.1.0/pretty-print/Parameters/Parameters.ts.html#instances", "relUrl": "/pretty-print/Parameters/Parameters.ts.html#instances" },"999": { "doc": "Parameters/Parameters.ts", "title": "darkModeTreeify", "content": "PPParameters instance that renders a value as a tree with colors adapted to dark-mode terminals . Signature . export declare const darkModeTreeify: Type . ", "url": "/0.1.0/pretty-print/Parameters/Parameters.ts.html#darkmodetreeify", "relUrl": "/pretty-print/Parameters/Parameters.ts.html#darkmodetreeify" },"1000": { "doc": "Parameters/Parameters.ts", "title": "darkModeTreeifyHideLeaves", "content": "PPParameters instance that renders a value as a tree with hidden leaf values, using colors adapted to dark-mode terminals . Signature . export declare const darkModeTreeifyHideLeaves: Type . ", "url": "/0.1.0/pretty-print/Parameters/Parameters.ts.html#darkmodetreeifyhideleaves", "relUrl": "/pretty-print/Parameters/Parameters.ts.html#darkmodetreeifyhideleaves" },"1001": { "doc": "Parameters/Parameters.ts", "title": "darkModeUtilInspectLike", "content": "PPParameters instance that pretty-prints a value in a way very similar to util.inspect with colors adapted to a terminal in dark mode. Signature . export declare const darkModeUtilInspectLike: Type . ", "url": "/0.1.0/pretty-print/Parameters/Parameters.ts.html#darkmodeutilinspectlike", "relUrl": "/pretty-print/Parameters/Parameters.ts.html#darkmodeutilinspectlike" },"1002": { "doc": "Parameters/Parameters.ts", "title": "treeify", "content": "PPParameters instance that renders a value as a tree (without color styling) . Signature . export declare const treeify: Type . ", "url": "/0.1.0/pretty-print/Parameters/Parameters.ts.html#treeify", "relUrl": "/pretty-print/Parameters/Parameters.ts.html#treeify" },"1003": { "doc": "Parameters/Parameters.ts", "title": "treeifyHideLeaves", "content": "PPParameters instance that renders a value as a tree and hides leaf values (only keys are shown), useful for inspecting an object’s shape . Signature . export declare const treeifyHideLeaves: Type . ", "url": "/0.1.0/pretty-print/Parameters/Parameters.ts.html#treeifyhideleaves", "relUrl": "/pretty-print/Parameters/Parameters.ts.html#treeifyhideleaves" },"1004": { "doc": "Parameters/Parameters.ts", "title": "utilInspectLike", "content": "PPParameters instance that pretty-prints a value in a style very similar to util.inspect, without any color styling . Signature . export declare const utilInspectLike: Type . ", "url": "/0.1.0/pretty-print/Parameters/Parameters.ts.html#utilinspectlike", "relUrl": "/pretty-print/Parameters/Parameters.ts.html#utilinspectlike" },"1005": { "doc": "Parameters/Parameters.ts", "title": "Models", "content": " ", "url": "/0.1.0/pretty-print/Parameters/Parameters.ts.html#models", "relUrl": "/pretty-print/Parameters/Parameters.ts.html#models" },"1006": { "doc": "Parameters/Parameters.ts", "title": "Type (class)", "content": "Type that represents a PPParameters . Signature . export declare class Type { private constructor({ id, styleMap, primitiveFormatter, nonPrimitiveParametersArray, name, maxDepth, openingTagMark, closingTagMark, circularReferenceTag, circularAnchorOpeningMark, circularAnchorClosingMark, headerSeparatorMark, propertyNumberSeparatorMark, propertyNumberOpeningMark, propertyNumberClosingMark }: MTypes.Data&lt;Type&gt;) } . make (static method) . Static constructor . Signature . static make(params: MTypes.Data&lt;Type&gt;): Type . [MData.idSymbol] (method) . Returns the id of this . Signature . [MData.idSymbol](): string | (() =&gt; string) . [Hash.symbol] (method) . Calculates the hash value of this . Signature . [Hash.symbol](): number . [MEquivalenceBasedEqualityData.isEquivalentToSymbol] (method) . Function that implements the equivalence of this and that . Signature . [MEquivalenceBasedEqualityData.isEquivalentToSymbol](this: this, that: this): boolean . [MEquivalenceBasedEqualityData.hasSameTypeMarkerAsSymbol] (method) . Predicate that returns true if that has the same type marker as this . Signature . [MEquivalenceBasedEqualityData.hasSameTypeMarkerAsSymbol](that: unknown): boolean . id (property) . Id of this. Useful for equality and debugging . Signature . readonly id: string . styleMap (property) . The PPStyleMap that assigns a style to each visual element of the output . Signature . readonly styleMap: PPStyleMap.Type . primitiveFormatter (property) . The PPPrimitiveFormatter used to convert primitive values to their string representation . Signature . readonly primitiveFormatter: PPPrimitiveFormatter.Type . nonPrimitiveParametersArray (property) . Non-empty array of PPNonPrimitiveParameters. When a non-primitive value is encountered, every entry whose isApplicableTo predicate returns true is selected and the matching entries are merged into a single fully-resolved set of parameters; lower-index entries override higher-index ones, and any field not specified by any matching entry falls back to the module- level default in PPNonPrimitiveParameters.defaultParams. Elements should therefore be ordered in decreasing specificity. Signature . readonly nonPrimitiveParametersArray: [PPNonPrimitiveParameters.Type, ...PPNonPrimitiveParameters.Type[]] . name (property) . Function that derives the display name from any non-primitive value. The name is shown in two places: . | Surrounded by openingTagMark / closingTagMark when maxDepth is exceeded (e.g. [Array], [Function: foo]). | In the header before the properties when the applicable PPNonPrimitiveParameters.showName is true (e.g. the Map in Map(2) { 'a' =&gt; 1, 'b' =&gt; 2 }). | . The default implementation returns 'Function: &lt;name&gt;' (or 'Function: (anonymous)') for functions, then tries Effect’s toJSON()._id convention, then falls back to value.constructor.name. This transparently covers Map, Set, WeakMap, WeakSet, all typed arrays, and user-defined classes. Signature . readonly name: (nonPrimitive: MTypes.ReadonlyNonPrimitive) =&gt; string . maxDepth (property) . Maximum number of nested non-primitive values that will be opened. A value of 0 or less means that only the value to stringify is shown if it is primitive; if it is non-primitive it is replaced by a tag that depends on its type (e.g. [Object], [Array]). Pass +Infinity to expand all levels. Signature . readonly maxDepth: number . openingTagMark (property) . Mark prepended to tags — both the header tag shown when maxDepth is exceeded and the circular-reference tag . Signature . readonly openingTagMark: string . closingTagMark (property) . Mark appended to tags — both the header tag shown when maxDepth is exceeded and the circular- reference tag . Signature . readonly closingTagMark: string . circularReferenceTag (property) . Text inserted in place of a non-primitive value that has already appeared higher up in the output tree, indicating a circular reference (e.g. Circular *1) . Signature . readonly circularReferenceTag: string . circularAnchorOpeningMark (property) . Mark prepended to the representation of a non-primitive value that is referenced again deeper in the tree (e.g. &lt;Ref *1&gt;) . Signature . readonly circularAnchorOpeningMark: string . circularAnchorClosingMark (property) . Mark appended to the representation of a non-primitive value that is referenced again deeper in the tree . Signature . readonly circularAnchorClosingMark: string . headerSeparatorMark (property) . Separator inserted between the header of a non-primitive value and the opening bracket of its properties (e.g. the space in Map(2) { 'a' =&gt; 1 }) . Signature . readonly headerSeparatorMark: string . propertyNumberSeparatorMark (property) . Separator used between the two property counts inside the header (e.g. the , in Map(5,2) { … }), applicable when propertyNumberDisplayOption is AllAndActual or AllAndActualIfDifferent . Signature . readonly propertyNumberSeparatorMark: string . propertyNumberOpeningMark (property) . Mark placed before the property count(s) in the header (e.g. the ( in Map(2) { … }), applicable when propertyNumberDisplayOption is not None . Signature . readonly propertyNumberOpeningMark: string . propertyNumberClosingMark (property) . Mark placed after the property count(s) in the header (e.g. the ) in Map(2) { … }), applicable when propertyNumberDisplayOption is not None . Signature . readonly propertyNumberClosingMark: string . ", "url": "/0.1.0/pretty-print/Parameters/Parameters.ts.html#type-class", "relUrl": "/pretty-print/Parameters/Parameters.ts.html#type-class" },"1007": { "doc": "Parameters/Parameters.ts", "title": "Module markers", "content": " ", "url": "/0.1.0/pretty-print/Parameters/Parameters.ts.html#module-markers", "relUrl": "/pretty-print/Parameters/Parameters.ts.html#module-markers" },"1008": { "doc": "Parameters/Parameters.ts", "title": "moduleTag", "content": "Module tag . Signature . export declare const moduleTag: \"@parischap/pretty-print/Parameters/\" . ", "url": "/0.1.0/pretty-print/Parameters/Parameters.ts.html#moduletag", "relUrl": "/pretty-print/Parameters/Parameters.ts.html#moduletag" },"1009": { "doc": "Parameters/Parameters.ts", "title": "Parameters/Parameters.ts", "content": " ", "url": "/0.1.0/pretty-print/Parameters/Parameters.ts.html", "relUrl": "/pretty-print/Parameters/Parameters.ts.html" },"1010": { "doc": "Parameters/PartName.ts", "title": "PartName overview", "content": "This module implements a union type that represents the possible names of the parts of the string representation of a value. Each part name identifies a specific visual element (e.g. property key, separator, bracket) so that a PPStyleMap can assign a distinct style to each one. ", "url": "/0.1.0/pretty-print/Parameters/PartName.ts.html#partname-overview", "relUrl": "/pretty-print/Parameters/PartName.ts.html#partname-overview" },"1011": { "doc": "Parameters/PartName.ts", "title": "Table of contents", "content": ". | Models . | Type (type alias) | . | . ", "url": "/0.1.0/pretty-print/Parameters/PartName.ts.html", "relUrl": "/pretty-print/Parameters/PartName.ts.html" },"1012": { "doc": "Parameters/PartName.ts", "title": "Models", "content": " ", "url": "/0.1.0/pretty-print/Parameters/PartName.ts.html#models", "relUrl": "/pretty-print/Parameters/PartName.ts.html#models" },"1013": { "doc": "Parameters/PartName.ts", "title": "Type (type alias)", "content": "Type of a PPPartName . Signature . export type Type = | \"ByPassed\" | \"PrimitiveValue\" | \"PropertyKey\" | \"PrototypeMarks\" | \"KeyValueSeparator\" | \"InBetweenPropertySeparator\" | \"NonPrimitiveValueMarks\" | \"Tab\" | \"Tag\" . ", "url": "/0.1.0/pretty-print/Parameters/PartName.ts.html#type-type-alias", "relUrl": "/pretty-print/Parameters/PartName.ts.html#type-type-alias" },"1014": { "doc": "Parameters/PartName.ts", "title": "Parameters/PartName.ts", "content": " ", "url": "/0.1.0/pretty-print/Parameters/PartName.ts.html", "relUrl": "/pretty-print/Parameters/PartName.ts.html" },"1015": { "doc": "PortError.ts", "title": "PortError overview", "content": "Tagged error type used to capture exceptions thrown by native JavaScript functions when those functions are ported to the Effect world (e.g. JSON.parse, JSON.stringify). ", "url": "/0.1.0/effect-lib/PortError.ts.html#porterror-overview", "relUrl": "/effect-lib/PortError.ts.html#porterror-overview" },"1016": { "doc": "PortError.ts", "title": "Mental model", "content": ". | Type is a Data.TaggedError that wraps a thrown value (originalError) together with context describing where the throw came from (originalFunctionName, moduleName, libraryName). | Use this error in Effect.try (or equivalent) catch handlers to keep the original exception inspectable while moving error handling out of the throw/catch axis. | . ", "url": "/0.1.0/effect-lib/PortError.ts.html#mental-model", "relUrl": "/effect-lib/PortError.ts.html#mental-model" },"1017": { "doc": "PortError.ts", "title": "Quickstart", "content": "Example (Wrap a throwing native API) . import { Effect } from \"effect\" import * as MPortError from \"@parischap/effect-lib/MPortError\" const safeJSONParse = (s: string) =&gt; Effect.try({ try: () =&gt; JSON.parse(s), catch: (e) =&gt; new MPortError.Type({ originalError: e, originalFunctionName: \"JSON.parse\", moduleName: \"my-module.ts\", libraryName: \"my-app\" }) }) . ", "url": "/0.1.0/effect-lib/PortError.ts.html#quickstart", "relUrl": "/effect-lib/PortError.ts.html#quickstart" },"1018": { "doc": "PortError.ts", "title": "Table of contents", "content": ". | Models . | Type (class) | . | Module markers . | moduleTag | . | . ", "url": "/0.1.0/effect-lib/PortError.ts.html", "relUrl": "/effect-lib/PortError.ts.html" },"1019": { "doc": "PortError.ts", "title": "Models", "content": " ", "url": "/0.1.0/effect-lib/PortError.ts.html#models", "relUrl": "/effect-lib/PortError.ts.html#models" },"1020": { "doc": "PortError.ts", "title": "Type (class)", "content": "Tagged error wrapping an exception thrown by a native function call. Carries the original thrown value plus contextual identifiers to help locate the source. Signature . export declare class Type . ", "url": "/0.1.0/effect-lib/PortError.ts.html#type-class", "relUrl": "/effect-lib/PortError.ts.html#type-class" },"1021": { "doc": "PortError.ts", "title": "Module markers", "content": " ", "url": "/0.1.0/effect-lib/PortError.ts.html#module-markers", "relUrl": "/effect-lib/PortError.ts.html#module-markers" },"1022": { "doc": "PortError.ts", "title": "moduleTag", "content": "Module tag. Signature . export declare const moduleTag: \"@parischap/effect-lib/PortError/\" . ", "url": "/0.1.0/effect-lib/PortError.ts.html#moduletag", "relUrl": "/effect-lib/PortError.ts.html#moduletag" },"1023": { "doc": "PortError.ts", "title": "PortError.ts", "content": " ", "url": "/0.1.0/effect-lib/PortError.ts.html", "relUrl": "/effect-lib/PortError.ts.html" },"1024": { "doc": "Predicate.ts", "title": "Predicate overview", "content": "Extension to the Effect Predicate module providing type-level utilities for predicates and refinements, an enhanced struct predicate, a strict-equality predicate constructor, and runtime guards for the container/primitive shapes defined in MTypes. ", "url": "/0.1.0/effect-lib/Predicate.ts.html#predicate-overview", "relUrl": "/effect-lib/Predicate.ts.html#predicate-overview" },"1025": { "doc": "Predicate.ts", "title": "Mental model", "content": ". | Predicate.Predicate&lt;A&gt; is a function (a: A) =&gt; boolean. | Predicate.Refinement&lt;A, B&gt; is a predicate that narrows A to B when it returns true. | This module focuses on type-level introspection (Source, Target, Coverage), value-level constructors (strictEquals, struct), and runtime guards for the container shapes declared in MTypes (OverOne, OverTwo, Singleton, Pair, plus primitive vs non-primitive splits and function arity). | . ", "url": "/0.1.0/effect-lib/Predicate.ts.html#mental-model", "relUrl": "/effect-lib/Predicate.ts.html#mental-model" },"1026": { "doc": "Predicate.ts", "title": "Common tasks", "content": ". | Construct: {@link strictEquals}, {@link struct} | Introspect at type level: {@link Source}, {@link Target}, {@link Coverage} | Lift records: {@link PredicatesToSources}, {@link PredicatesToTargets}, {@link PredicatesToCoverages}, {@link SourcesToPredicates} | Primitive split: {@link isPrimitive}, {@link isNonPrimitive} | Function arity: {@link isOneArgFunction}, {@link isTwoArgFunction} | Tuple shapes: {@link isSingleton}, {@link isReadonlySingleton}, {@link isPair}, {@link isReadonlyPair}, {@link isOverOne}, {@link isReadonlyOverOne}, {@link isOverTwo}, {@link isReadonlyOverTwo} | . ", "url": "/0.1.0/effect-lib/Predicate.ts.html#common-tasks", "relUrl": "/effect-lib/Predicate.ts.html#common-tasks" },"1027": { "doc": "Predicate.ts", "title": "Quickstart", "content": "Example (Strict equality and struct refinement) . import { pipe, Array } from \"effect\" import * as MPredicate from \"@parischap/effect-lib/MPredicate\" // strictEquals console.log(pipe([1, 2, 3, 2], Array.filter(MPredicate.strictEquals(2)))) // [2, 2] // struct refinement type Animal = { readonly name: string; readonly age: number | string } const isAdult = MPredicate.struct&lt;Animal, { readonly age: (n: unknown) =&gt; n is number }&gt;({ age: (n): n is number =&gt; typeof n === \"number\" &amp;&amp; n &gt;= 18 }) . ", "url": "/0.1.0/effect-lib/Predicate.ts.html#quickstart", "relUrl": "/effect-lib/Predicate.ts.html#quickstart" },"1028": { "doc": "Predicate.ts", "title": "Table of contents", "content": ". | Constructors . | strictEquals | struct | . | Guards . | isNonPrimitive | isOneArgFunction | isOverOne | isOverTwo | isPair | isPrimitive | isReadonlyOverOne | isReadonlyOverTwo | isReadonlyPair | isReadonlySingleton | isSingleton | isTwoArgFunction | . | Models . | EffectPredicate (interface) | . | Utility types . | Coverage (type alias) | PredicatesToCoverages (type alias) | PredicatesToSources (type alias) | PredicatesToTargets (type alias) | Source (type alias) | SourcesToPredicates (type alias) | Target (type alias) | . | . ", "url": "/0.1.0/effect-lib/Predicate.ts.html", "relUrl": "/effect-lib/Predicate.ts.html" },"1029": { "doc": "Predicate.ts", "title": "Constructors", "content": " ", "url": "/0.1.0/effect-lib/Predicate.ts.html#constructors", "relUrl": "/effect-lib/Predicate.ts.html#constructors" },"1030": { "doc": "Predicate.ts", "title": "strictEquals", "content": "Builds a predicate that tests strict equality (===) against that. | Use to filter, partition, or match values that must be referentially equal to a fixed value. | Comparison is ===, not Equal.equals; suitable for primitives or when reference identity is intended. | The returned predicate accepts any supertype B of that. | . Example (Filtering with strictEquals) . import { pipe, Array } from \"effect\" import * as MPredicate from \"@parischap/effect-lib/MPredicate\" console.log(pipe([1, 2, 3, 2, 1], Array.filter(MPredicate.strictEquals(2)))) // [2, 2] . Signature . export declare const strictEquals: &lt;B, A extends B&gt;(that: A) =&gt; Predicate.Predicate&lt;B&gt; . ", "url": "/0.1.0/effect-lib/Predicate.ts.html#strictequals", "relUrl": "/effect-lib/Predicate.ts.html#strictequals" },"1031": { "doc": "Predicate.ts", "title": "struct", "content": "Enhanced version of Predicate.struct that supports IDE field completion, allows passing only a subset of the struct fields, and correctly infers a Refinement (instead of a plain Predicate) even when only some fields use refinements. | Use to validate part of a struct without writing predicates for every field. | Returns a Refinement if at least one field’s predicate is a refinement, otherwise a plain Predicate. | Fields not provided are not checked. | . Example (Refining a struct on a single field) . import * as MPredicate from \"@parischap/effect-lib/MPredicate\" type Person = { readonly name: string; readonly age: number | string } const hasNumericAge = MPredicate.struct&lt;Person, { readonly age: (n: unknown) =&gt; n is number }&gt;({ age: (n): n is number =&gt; typeof n === \"number\" }) const p: Person = { name: \"Alice\", age: 30 } if (hasNumericAge(p)) { // `p.age` has been narrowed to `number` console.log(p.age + 1) // 31 } . Signature . export declare const struct: &lt;O extends MTypes.NonPrimitive, F extends Partial&lt;SourcesToPredicates&lt;MTypes.Data&lt;O&gt;&gt;&gt;&gt;( fields: F ) =&gt; [Extract&lt;F[keyof F], MTypes.AnyRefinement&gt;] extends [never] ? Predicate.Predicate&lt;O&gt; : Predicate.Refinement&lt; O, { readonly [key in keyof O]: key extends keyof F ? F[key] extends MTypes.AnyPredicate ? Target&lt;F[key]&gt; &amp; O[key] : never : O[key] } &gt; . ", "url": "/0.1.0/effect-lib/Predicate.ts.html#struct", "relUrl": "/effect-lib/Predicate.ts.html#struct" },"1032": { "doc": "Predicate.ts", "title": "Guards", "content": " ", "url": "/0.1.0/effect-lib/Predicate.ts.html#guards", "relUrl": "/effect-lib/Predicate.ts.html#guards" },"1033": { "doc": "Predicate.ts", "title": "isNonPrimitive", "content": "Refines an unknown value to a JavaScript non-primitive (record, class instance, array, or function). | Acts as a type guard narrowing the input to MTypes.NonPrimitive. | Excludes null; includes functions (unlike Predicate.isObject, which excludes them). | Use when distinguishing primitives from anything else in unknown data. | . Example (Splitting primitives from non-primitives) . import * as MPredicate from \"@parischap/effect-lib/MPredicate\" console.log(MPredicate.isNonPrimitive({ a: 1 })) // true console.log(MPredicate.isNonPrimitive(() =&gt; 1)) // true console.log(MPredicate.isNonPrimitive(null)) // false console.log(MPredicate.isNonPrimitive(42)) // false . Signature . export declare const isNonPrimitive: &lt;A&gt;(input: A) =&gt; input is Exclude&lt;A, MTypes.Primitive&gt; &amp; MTypes.NonPrimitive . ", "url": "/0.1.0/effect-lib/Predicate.ts.html#isnonprimitive", "relUrl": "/effect-lib/Predicate.ts.html#isnonprimitive" },"1034": { "doc": "Predicate.ts", "title": "isOneArgFunction", "content": "Refines a function with an unknown number of arguments to one that takes exactly one argument. | Acts as a type guard checking f.length === 1. | Useful when working with overloaded callbacks where arity matters. | . Example (Detecting a unary callback) . import * as MPredicate from \"@parischap/effect-lib/MPredicate\" console.log(MPredicate.isOneArgFunction((n: number) =&gt; n + 1)) // true console.log(MPredicate.isOneArgFunction((a: number, b: number) =&gt; a + b)) // false . Signature . export declare const isOneArgFunction: &lt;A, R&gt;(f: (a: A, ...args: ReadonlyArray&lt;any&gt;) =&gt; R) =&gt; f is (a: A) =&gt; R . ", "url": "/0.1.0/effect-lib/Predicate.ts.html#isoneargfunction", "relUrl": "/effect-lib/Predicate.ts.html#isoneargfunction" },"1035": { "doc": "Predicate.ts", "title": "isOverOne", "content": "Refines an Array&lt;A&gt; to an OverOne&lt;A&gt; (a non-empty array). | Acts as a type guard checking u.length &gt; 0. | . Example (Guarding a non-empty array) . import * as MPredicate from \"@parischap/effect-lib/MPredicate\" console.log(MPredicate.isOverOne([5])) // true console.log(MPredicate.isOverOne([])) // false . Signature . export declare const isOverOne: &lt;A&gt;(u: Array&lt;A&gt;) =&gt; u is MTypes.OverOne&lt;A&gt; . ", "url": "/0.1.0/effect-lib/Predicate.ts.html#isoverone", "relUrl": "/effect-lib/Predicate.ts.html#isoverone" },"1036": { "doc": "Predicate.ts", "title": "isOverTwo", "content": "Refines an Array&lt;A&gt; to an OverTwo&lt;A&gt; (an array with at least two elements). | Acts as a type guard checking u.length &gt;= 2. | . Example (Guarding an array with two or more elements) . import * as MPredicate from \"@parischap/effect-lib/MPredicate\" console.log(MPredicate.isOverTwo([5, 6])) // true console.log(MPredicate.isOverTwo([5])) // false . Signature . export declare const isOverTwo: &lt;A&gt;(u: Array&lt;A&gt;) =&gt; u is MTypes.OverTwo&lt;A&gt; . ", "url": "/0.1.0/effect-lib/Predicate.ts.html#isovertwo", "relUrl": "/effect-lib/Predicate.ts.html#isovertwo" },"1037": { "doc": "Predicate.ts", "title": "isPair", "content": "Refines an Array&lt;A&gt; to a Pair&lt;A, A&gt; (a tuple with exactly two elements). | Acts as a type guard checking u.length === 2. | . Example (Guarding a pair) . import * as MPredicate from \"@parischap/effect-lib/MPredicate\" console.log(MPredicate.isPair([5, 6])) // true console.log(MPredicate.isPair([5])) // false . Signature . export declare const isPair: &lt;A&gt;(u: Array&lt;A&gt;) =&gt; u is MTypes.Pair&lt;A, A&gt; . ", "url": "/0.1.0/effect-lib/Predicate.ts.html#ispair", "relUrl": "/effect-lib/Predicate.ts.html#ispair" },"1038": { "doc": "Predicate.ts", "title": "isPrimitive", "content": "Refines an unknown value to a JavaScript primitive (string, number, bigint, boolean, symbol, null, or undefined). | Acts as a type guard narrowing the input to MTypes.Primitive. | Defined as the negation of {@link isNonPrimitive}. | . Example (Guarding a primitive) . import * as MPredicate from \"@parischap/effect-lib/MPredicate\" console.log(MPredicate.isPrimitive(42)) // true console.log(MPredicate.isPrimitive(\"hi\")) // true console.log(MPredicate.isPrimitive(null)) // true console.log(MPredicate.isPrimitive([1, 2])) // false . Signature . export declare const isPrimitive: &lt;A&gt;(input: A) =&gt; input is Exclude&lt;A, MTypes.NonPrimitive&gt; &amp; MTypes.Primitive . ", "url": "/0.1.0/effect-lib/Predicate.ts.html#isprimitive", "relUrl": "/effect-lib/Predicate.ts.html#isprimitive" },"1039": { "doc": "Predicate.ts", "title": "isReadonlyOverOne", "content": "Refines a ReadonlyArray&lt;A&gt; to a ReadonlyOverOne&lt;A&gt; (a non-empty readonly array). | Acts as a type guard checking u.length &gt; 0. | . Signature . export declare const isReadonlyOverOne: &lt;A&gt;(u: ReadonlyArray&lt;A&gt;) =&gt; u is MTypes.ReadonlyOverOne&lt;A&gt; . ", "url": "/0.1.0/effect-lib/Predicate.ts.html#isreadonlyoverone", "relUrl": "/effect-lib/Predicate.ts.html#isreadonlyoverone" },"1040": { "doc": "Predicate.ts", "title": "isReadonlyOverTwo", "content": "Refines a ReadonlyArray&lt;A&gt; to a ReadonlyOverTwo&lt;A&gt; (a readonly array with at least two elements). | Acts as a type guard checking u.length &gt;= 2. | . Signature . export declare const isReadonlyOverTwo: &lt;A&gt;(u: ReadonlyArray&lt;A&gt;) =&gt; u is MTypes.ReadonlyOverTwo&lt;A&gt; . ", "url": "/0.1.0/effect-lib/Predicate.ts.html#isreadonlyovertwo", "relUrl": "/effect-lib/Predicate.ts.html#isreadonlyovertwo" },"1041": { "doc": "Predicate.ts", "title": "isReadonlyPair", "content": "Refines a ReadonlyArray&lt;A&gt; to a ReadonlyPair&lt;A, A&gt; (a tuple with exactly two elements). | Acts as a type guard checking u.length === 2. | . Signature . export declare const isReadonlyPair: &lt;A&gt;(u: ReadonlyArray&lt;A&gt;) =&gt; u is MTypes.ReadonlyPair&lt;A, A&gt; . ", "url": "/0.1.0/effect-lib/Predicate.ts.html#isreadonlypair", "relUrl": "/effect-lib/Predicate.ts.html#isreadonlypair" },"1042": { "doc": "Predicate.ts", "title": "isReadonlySingleton", "content": "Refines a ReadonlyArray&lt;A&gt; to a ReadonlySingleton&lt;A&gt; (a tuple with exactly one element). | Acts as a type guard checking u.length === 1. | . Signature . export declare const isReadonlySingleton: &lt;A&gt;(u: ReadonlyArray&lt;A&gt;) =&gt; u is MTypes.ReadonlySingleton&lt;A&gt; . ", "url": "/0.1.0/effect-lib/Predicate.ts.html#isreadonlysingleton", "relUrl": "/effect-lib/Predicate.ts.html#isreadonlysingleton" },"1043": { "doc": "Predicate.ts", "title": "isSingleton", "content": "Refines an Array&lt;A&gt; to a Singleton&lt;A&gt; (a tuple with exactly one element). | Acts as a type guard checking u.length === 1. | . Example (Guarding a singleton) . import * as MPredicate from \"@parischap/effect-lib/MPredicate\" console.log(MPredicate.isSingleton([5])) // true console.log(MPredicate.isSingleton([5, 6])) // false . Signature . export declare const isSingleton: &lt;A&gt;(u: Array&lt;A&gt;) =&gt; u is MTypes.Singleton&lt;A&gt; . ", "url": "/0.1.0/effect-lib/Predicate.ts.html#issingleton", "relUrl": "/effect-lib/Predicate.ts.html#issingleton" },"1044": { "doc": "Predicate.ts", "title": "isTwoArgFunction", "content": "Refines a function with an unknown number of arguments to one that takes exactly two arguments. | Acts as a type guard checking f.length === 2. | . Example (Detecting a binary callback) . import * as MPredicate from \"@parischap/effect-lib/MPredicate\" console.log(MPredicate.isTwoArgFunction((a: number, b: number) =&gt; a + b)) // true console.log(MPredicate.isTwoArgFunction((n: number) =&gt; n + 1)) // false . Signature . export declare const isTwoArgFunction: &lt;A, B, R&gt;( f: (a: A, b: B, ...args: ReadonlyArray&lt;any&gt;) =&gt; R ) =&gt; f is (a: A, b: B) =&gt; R . ", "url": "/0.1.0/effect-lib/Predicate.ts.html#istwoargfunction", "relUrl": "/effect-lib/Predicate.ts.html#istwoargfunction" },"1045": { "doc": "Predicate.ts", "title": "Models", "content": " ", "url": "/0.1.0/effect-lib/Predicate.ts.html#models", "relUrl": "/effect-lib/Predicate.ts.html#models" },"1046": { "doc": "Predicate.ts", "title": "EffectPredicate (interface)", "content": "An effectful predicate: a function from Z to Effect&lt;boolean, E, R&gt;. | Use when the predicate result depends on an effectful computation (I/O, async, etc.). | Mirrors Predicate.Predicate but lifted into Effect. | . Signature . export interface EffectPredicate&lt;in Z, out E, out R&gt; { (x: Z): Effect.Effect&lt;boolean, E, R&gt; } . ", "url": "/0.1.0/effect-lib/Predicate.ts.html#effectpredicate-interface", "relUrl": "/effect-lib/Predicate.ts.html#effectpredicate-interface" },"1047": { "doc": "Predicate.ts", "title": "Utility types", "content": " ", "url": "/0.1.0/effect-lib/Predicate.ts.html#utility-types", "relUrl": "/effect-lib/Predicate.ts.html#utility-types" },"1048": { "doc": "Predicate.ts", "title": "Coverage (type alias)", "content": "Type utility extracting the type a refinement narrows to, returning never for plain predicates. | Returns B for Predicate.Refinement&lt;A, B&gt;. | Returns never for Predicate.Predicate&lt;A&gt; (since plain predicates do not narrow). | Useful for computing what a refinement removes from a remaining input space. | . Signature . export type Coverage&lt;R extends MTypes.AnyPredicate&gt; = readonly [R] extends readonly [ Predicate.Refinement&lt;infer _, infer A&gt; ] ? A : never . ", "url": "/0.1.0/effect-lib/Predicate.ts.html#coverage-type-alias", "relUrl": "/effect-lib/Predicate.ts.html#coverage-type-alias" },"1049": { "doc": "Predicate.ts", "title": "PredicatesToCoverages (type alias)", "content": "Type utility mapping an array/record of predicates to an array/record of their coverages. Signature . export type PredicatesToCoverages&lt;T extends PredicateArray&gt; = { readonly [key in keyof T]: Coverage&lt;T[key]&gt; } . ", "url": "/0.1.0/effect-lib/Predicate.ts.html#predicatestocoverages-type-alias", "relUrl": "/effect-lib/Predicate.ts.html#predicatestocoverages-type-alias" },"1050": { "doc": "Predicate.ts", "title": "PredicatesToSources (type alias)", "content": "Type utility mapping an array/record of predicates to an array/record of their sources. Signature . export type PredicatesToSources&lt;T extends PredicateArray&gt; = { readonly [key in keyof T]: Source&lt;T[key]&gt; } . ", "url": "/0.1.0/effect-lib/Predicate.ts.html#predicatestosources-type-alias", "relUrl": "/effect-lib/Predicate.ts.html#predicatestosources-type-alias" },"1051": { "doc": "Predicate.ts", "title": "PredicatesToTargets (type alias)", "content": "Type utility mapping an array/record of predicates to an array/record of their targets. Signature . export type PredicatesToTargets&lt;T extends PredicateArray&gt; = { readonly [key in keyof T]: Target&lt;T[key]&gt; } . ", "url": "/0.1.0/effect-lib/Predicate.ts.html#predicatestotargets-type-alias", "relUrl": "/effect-lib/Predicate.ts.html#predicatestotargets-type-alias" },"1052": { "doc": "Predicate.ts", "title": "Source (type alias)", "content": "Type utility extracting the source type of a predicate or refinement. | For Predicate.Predicate&lt;A&gt; and Predicate.Refinement&lt;A, B&gt; it returns A. | Useful when generic code must reason about the input of an unknown predicate. | . Example (Extracting the source) . import type * as MPredicate from \"@parischap/effect-lib/MPredicate\" import type * as Predicate from \"effect/Predicate\" type _Source = MPredicate.Source&lt;Predicate.Refinement&lt;unknown, string&gt;&gt; // unknown . Signature . export type Source&lt;R extends MTypes.AnyPredicate&gt; = readonly [R] extends readonly [Predicate.Predicate&lt;infer A&gt;] ? A : never . ", "url": "/0.1.0/effect-lib/Predicate.ts.html#source-type-alias", "relUrl": "/effect-lib/Predicate.ts.html#source-type-alias" },"1053": { "doc": "Predicate.ts", "title": "SourcesToPredicates (type alias)", "content": "Type utility mapping an array/record of values to an array/record of predicates over those values. Signature . export type SourcesToPredicates&lt;T extends MTypes.NonPrimitive&gt; = { readonly [key in keyof T]: Predicate.Predicate&lt;T[key]&gt; } . ", "url": "/0.1.0/effect-lib/Predicate.ts.html#sourcestopredicates-type-alias", "relUrl": "/effect-lib/Predicate.ts.html#sourcestopredicates-type-alias" },"1054": { "doc": "Predicate.ts", "title": "Target (type alias)", "content": "Type utility extracting the narrowed type of a predicate or refinement. | For Predicate.Refinement&lt;A, B&gt; it returns B. | For Predicate.Predicate&lt;A&gt; it returns A (no narrowing). | . Example (Extracting the target) . import type * as MPredicate from \"@parischap/effect-lib/MPredicate\" import type * as Predicate from \"effect/Predicate\" type _Target = MPredicate.Target&lt;Predicate.Refinement&lt;unknown, string&gt;&gt; // string . Signature . export type Target&lt;R extends MTypes.AnyPredicate&gt; = readonly [R] extends readonly [ Predicate.Refinement&lt;infer _, infer A&gt; ] ? A : Source&lt;R&gt; . ", "url": "/0.1.0/effect-lib/Predicate.ts.html#target-type-alias", "relUrl": "/effect-lib/Predicate.ts.html#target-type-alias" },"1055": { "doc": "Predicate.ts", "title": "Predicate.ts", "content": " ", "url": "/0.1.0/effect-lib/Predicate.ts.html", "relUrl": "/effect-lib/Predicate.ts.html" },"1056": { "doc": "Parameters/PrimitiveFormatter.ts", "title": "PrimitiveFormatter overview", "content": "This module implements a type that converts a primitive value to its string representation. Typical responsibilities include: surrounding strings in quotes, truncating long strings with an ellipsis, appending n to bigints, and formatting numbers with a custom formatter. Use the make function to define custom instances if the pre-built ones do not suit your needs. ", "url": "/0.1.0/pretty-print/Parameters/PrimitiveFormatter.ts.html#primitiveformatter-overview", "relUrl": "/pretty-print/Parameters/PrimitiveFormatter.ts.html#primitiveformatter-overview" },"1057": { "doc": "Parameters/PrimitiveFormatter.ts", "title": "Table of contents", "content": ". | Constructors . | make | utilInspectLikeMaker | . | Equivalences . | equivalence | . | Getters . | action | id | . | Instances . | utilInspectLike | . | Models . | Type (class) . | make (static method) | [MData.idSymbol] (method) | [Hash.symbol] (method) | [MEquivalenceBasedEqualityData.isEquivalentToSymbol] (method) | [MEquivalenceBasedEqualityData.hasSameTypeMarkerAsSymbol] (method) | id (property) | action (property) | . | . | Module markers . | moduleTag | . | . ", "url": "/0.1.0/pretty-print/Parameters/PrimitiveFormatter.ts.html", "relUrl": "/pretty-print/Parameters/PrimitiveFormatter.ts.html" },"1058": { "doc": "Parameters/PrimitiveFormatter.ts", "title": "Constructors", "content": " ", "url": "/0.1.0/pretty-print/Parameters/PrimitiveFormatter.ts.html#constructors", "relUrl": "/pretty-print/Parameters/PrimitiveFormatter.ts.html#constructors" },"1059": { "doc": "Parameters/PrimitiveFormatter.ts", "title": "make", "content": "Constructor of a PPPrimitiveFormatter . Signature . export declare const make: (params: MTypes.Data&lt;Type&gt;) =&gt; Type . ", "url": "/0.1.0/pretty-print/Parameters/PrimitiveFormatter.ts.html#make", "relUrl": "/pretty-print/Parameters/PrimitiveFormatter.ts.html#make" },"1060": { "doc": "Parameters/PrimitiveFormatter.ts", "title": "utilInspectLikeMaker", "content": "Constructor that builds a PPPrimitiveFormatter instance modelled on util.inspect: - Strings are truncated at maxStringLength characters (an ellipsis is appended when truncated) and surrounded with quoteChar. Pass maxStringLength = +Infinity to disable truncation. - Numbers are formatted with numberFormatter. - Bigints are formatted with bigintFormatter and suffixed with n. Signature . export declare const utilInspectLikeMaker: ({ id, maxStringLength, quoteChar, numberFormatter, bigintFormatter }: { readonly id: string readonly maxStringLength: number readonly quoteChar: string readonly numberFormatter: MTypes.OneArgFunction&lt;number, string&gt; readonly bigintFormatter: MTypes.OneArgFunction&lt;bigint, string&gt; }) =&gt; Type . ", "url": "/0.1.0/pretty-print/Parameters/PrimitiveFormatter.ts.html#utilinspectlikemaker", "relUrl": "/pretty-print/Parameters/PrimitiveFormatter.ts.html#utilinspectlikemaker" },"1061": { "doc": "Parameters/PrimitiveFormatter.ts", "title": "Equivalences", "content": " ", "url": "/0.1.0/pretty-print/Parameters/PrimitiveFormatter.ts.html#equivalences", "relUrl": "/pretty-print/Parameters/PrimitiveFormatter.ts.html#equivalences" },"1062": { "doc": "Parameters/PrimitiveFormatter.ts", "title": "equivalence", "content": "Equivalence . Signature . export declare const equivalence: Equivalence.Equivalence&lt;Type&gt; . ", "url": "/0.1.0/pretty-print/Parameters/PrimitiveFormatter.ts.html#equivalence", "relUrl": "/pretty-print/Parameters/PrimitiveFormatter.ts.html#equivalence" },"1063": { "doc": "Parameters/PrimitiveFormatter.ts", "title": "Getters", "content": " ", "url": "/0.1.0/pretty-print/Parameters/PrimitiveFormatter.ts.html#getters", "relUrl": "/pretty-print/Parameters/PrimitiveFormatter.ts.html#getters" },"1064": { "doc": "Parameters/PrimitiveFormatter.ts", "title": "action", "content": "Returns the action property of self . Signature . export declare const action: MTypes.OneArgFunction&lt;Type, MTypes.OneArgFunction&lt;PPValue.Primitive, string&gt;&gt; . ", "url": "/0.1.0/pretty-print/Parameters/PrimitiveFormatter.ts.html#action", "relUrl": "/pretty-print/Parameters/PrimitiveFormatter.ts.html#action" },"1065": { "doc": "Parameters/PrimitiveFormatter.ts", "title": "id", "content": "Returns the id property of self . Signature . export declare const id: MTypes.OneArgFunction&lt;Type, string&gt; . ", "url": "/0.1.0/pretty-print/Parameters/PrimitiveFormatter.ts.html#id", "relUrl": "/pretty-print/Parameters/PrimitiveFormatter.ts.html#id" },"1066": { "doc": "Parameters/PrimitiveFormatter.ts", "title": "Instances", "content": " ", "url": "/0.1.0/pretty-print/Parameters/PrimitiveFormatter.ts.html#instances", "relUrl": "/pretty-print/Parameters/PrimitiveFormatter.ts.html#instances" },"1067": { "doc": "Parameters/PrimitiveFormatter.ts", "title": "utilInspectLike", "content": "PPPrimitiveFormatter instance modelled on util.inspect: - Strings are truncated at 10 000 characters and surrounded with '. - Numbers are formatted with MString.fromNumber(10) (same output as Number.prototype.toString()). - Bigints are formatted with MString.fromNumber(10) (same output as BigInt.prototype.toString()) and suffixed with n. Signature . export declare const utilInspectLike: Type . ", "url": "/0.1.0/pretty-print/Parameters/PrimitiveFormatter.ts.html#utilinspectlike", "relUrl": "/pretty-print/Parameters/PrimitiveFormatter.ts.html#utilinspectlike" },"1068": { "doc": "Parameters/PrimitiveFormatter.ts", "title": "Models", "content": " ", "url": "/0.1.0/pretty-print/Parameters/PrimitiveFormatter.ts.html#models", "relUrl": "/pretty-print/Parameters/PrimitiveFormatter.ts.html#models" },"1069": { "doc": "Parameters/PrimitiveFormatter.ts", "title": "Type (class)", "content": "Type that represents a PPPrimitiveFormatter . Signature . export declare class Type { private constructor({ id, action }: MTypes.Data&lt;Type&gt;) } . make (static method) . Static constructor . Signature . static make(params: MTypes.Data&lt;Type&gt;): Type . [MData.idSymbol] (method) . Returns the id of this . Signature . [MData.idSymbol](): string | (() =&gt; string) . [Hash.symbol] (method) . Calculates the hash value of this . Signature . [Hash.symbol](): number . [MEquivalenceBasedEqualityData.isEquivalentToSymbol] (method) . Function that implements the equivalence of this and that . Signature . [MEquivalenceBasedEqualityData.isEquivalentToSymbol](this: this, that: this): boolean . [MEquivalenceBasedEqualityData.hasSameTypeMarkerAsSymbol] (method) . Predicate that returns true if that has the same type marker as this . Signature . [MEquivalenceBasedEqualityData.hasSameTypeMarkerAsSymbol](that: unknown): boolean . id (property) . Id of this PPPrimitiveFormatter instance. Useful for equality and debugging . Signature . readonly id: string . action (property) . Action of this PPPrimitiveFormatter. Takes a PPValue.Primitive and returns its string representation (e.g. 'hello' for a string, 42 for a number, 42n for a bigint) . Signature . readonly action: MTypes.OneArgFunction&lt;PPValue.Primitive, string&gt; . ", "url": "/0.1.0/pretty-print/Parameters/PrimitiveFormatter.ts.html#type-class", "relUrl": "/pretty-print/Parameters/PrimitiveFormatter.ts.html#type-class" },"1070": { "doc": "Parameters/PrimitiveFormatter.ts", "title": "Module markers", "content": " ", "url": "/0.1.0/pretty-print/Parameters/PrimitiveFormatter.ts.html#module-markers", "relUrl": "/pretty-print/Parameters/PrimitiveFormatter.ts.html#module-markers" },"1071": { "doc": "Parameters/PrimitiveFormatter.ts", "title": "moduleTag", "content": "Module tag . Signature . export declare const moduleTag: \"@parischap/pretty-print/Parameters/PrimitiveFormatter/\" . ", "url": "/0.1.0/pretty-print/Parameters/PrimitiveFormatter.ts.html#moduletag", "relUrl": "/pretty-print/Parameters/PrimitiveFormatter.ts.html#moduletag" },"1072": { "doc": "Parameters/PrimitiveFormatter.ts", "title": "Parameters/PrimitiveFormatter.ts", "content": " ", "url": "/0.1.0/pretty-print/Parameters/PrimitiveFormatter.ts.html", "relUrl": "/pretty-print/Parameters/PrimitiveFormatter.ts.html" },"1073": { "doc": "Parameters/PropertyFilter.ts", "title": "PropertyFilter overview", "content": "This module implements a type that takes care of filtering properties when printing non-primitive values. With the make function, you can 