ter.ts.html#action", "relUrl": "/pretty-print/Parameters/PropertyFilter.ts.html#action" },"1083": { "doc": "Parameters/PropertyFilter.ts", "title": "id", "content": "Returns the id property of self . Signature . export declare const id: MTypes.OneArgFunction&lt;Type, string&gt; . ", "url": "/0.1.0/pretty-print/Parameters/PropertyFilter.ts.html#id", "relUrl": "/pretty-print/Parameters/PropertyFilter.ts.html#id" },"1084": { "doc": "Parameters/PropertyFilter.ts", "title": "Instances", "content": " ", "url": "/0.1.0/pretty-print/Parameters/PropertyFilter.ts.html#instances", "relUrl": "/pretty-print/Parameters/PropertyFilter.ts.html#instances" },"1085": { "doc": "Parameters/PropertyFilter.ts", "title": "none", "content": "PPPropertyFilter instance that removes no properties . Signature . export declare const none: Type . ", "url": "/0.1.0/pretty-print/Parameters/PropertyFilter.ts.html#none", "relUrl": "/pretty-print/Parameters/PropertyFilter.ts.html#none" },"1086": { "doc": "Parameters/PropertyFilter.ts", "title": "removeEnumerables", "content": "PPPropertyFilter instance that removes enumerable properties of non-primitive values . Signature . export declare const removeEnumerables: Type . ", "url": "/0.1.0/pretty-print/Parameters/PropertyFilter.ts.html#removeenumerables", "relUrl": "/pretty-print/Parameters/PropertyFilter.ts.html#removeenumerables" },"1087": { "doc": "Parameters/PropertyFilter.ts", "title": "removeFunctions", "content": "PPPropertyFilter instance that removes properties of non-primitive values whose value is a function . Signature . export declare const removeFunctions: Type . ", "url": "/0.1.0/pretty-print/Parameters/PropertyFilter.ts.html#removefunctions", "relUrl": "/pretty-print/Parameters/PropertyFilter.ts.html#removefunctions" },"1088": { "doc": "Parameters/PropertyFilter.ts", "title": "removeNonEnumerables", "content": "PPPropertyFilter instance that removes non-enumerable properties of non-primitive values . Signature . export declare const removeNonEnumerables: Type . ", "url": "/0.1.0/pretty-print/Parameters/PropertyFilter.ts.html#removenonenumerables", "relUrl": "/pretty-print/Parameters/PropertyFilter.ts.html#removenonenumerables" },"1089": { "doc": "Parameters/PropertyFilter.ts", "title": "removeNonFunctions", "content": "PPPropertyFilter instance that removes properties of non-primitive values whose value is not a function . Signature . export declare const removeNonFunctions: Type . ", "url": "/0.1.0/pretty-print/Parameters/PropertyFilter.ts.html#removenonfunctions", "relUrl": "/pretty-print/Parameters/PropertyFilter.ts.html#removenonfunctions" },"1090": { "doc": "Parameters/PropertyFilter.ts", "title": "removeStringKeys", "content": "PPPropertyFilter instance that removes properties of non-primitive values with a string key . Signature . export declare const removeStringKeys: Type . ", "url": "/0.1.0/pretty-print/Parameters/PropertyFilter.ts.html#removestringkeys", "relUrl": "/pretty-print/Parameters/PropertyFilter.ts.html#removestringkeys" },"1091": { "doc": "Parameters/PropertyFilter.ts", "title": "removeSymbolicKeys", "content": "PPPropertyFilter instance that removes properties of non-primitive values with a symbolic key . Signature . export declare const removeSymbolicKeys: Type . ", "url": "/0.1.0/pretty-print/Parameters/PropertyFilter.ts.html#removesymbolickeys", "relUrl": "/pretty-print/Parameters/PropertyFilter.ts.html#removesymbolickeys" },"1092": { "doc": "Parameters/PropertyFilter.ts", "title": "Models", "content": " ", "url": "/0.1.0/pretty-print/Parameters/PropertyFilter.ts.html#models", "relUrl": "/pretty-print/Parameters/PropertyFilter.ts.html#models" },"1093": { "doc": "Parameters/PropertyFilter.ts", "title": "Type (class)", "content": "Type that represents a PPPropertyFilter . Signature . export declare class Type { constructor({ id, action }: MTypes.Data&lt;Type&gt;) } . [MData.idSymbol] (method) . Returns the id of this . Signature . [MData.idSymbol](): string | (() =&gt; string) . [Hash.symbol] (method) . Calculates the hash value of this . Signature . [Hash.symbol](): number . [MEquivalenceBasedEqualityData.isEquivalentToSymbol] (method) . Function that implements the equivalence of this and that . Signature . [MEquivalenceBasedEqualityData.isEquivalentToSymbol](this: this, that: this): boolean . [MEquivalenceBasedEqualityData.hasSameTypeMarkerAsSymbol] (method) . Predicate that returns true if that has the same type marker as this . Signature . [MEquivalenceBasedEqualityData.hasSameTypeMarkerAsSymbol](that: unknown): boolean . id (property) . Id of this PropertyFilter instance. Useful for equality and debugging . Signature . readonly id: string . action (property) . Action of this PropertyFilter instance . Signature . readonly action: MTypes.OneArgFunction&lt;PPValues.Type, PPValues.Type&gt; . ", "url": "/0.1.0/pretty-print/Parameters/PropertyFilter.ts.html#type-class", "relUrl": "/pretty-print/Parameters/PropertyFilter.ts.html#type-class" },"1094": { "doc": "Parameters/PropertyFilter.ts", "title": "Module markers", "content": " ", "url": "/0.1.0/pretty-print/Parameters/PropertyFilter.ts.html#module-markers", "relUrl": "/pretty-print/Parameters/PropertyFilter.ts.html#module-markers" },"1095": { "doc": "Parameters/PropertyFilter.ts", "title": "moduleTag", "content": "Module tag . Signature . export declare const moduleTag: \"@parischap/pretty-print/Parameters/PropertyFilter/\" . ", "url": "/0.1.0/pretty-print/Parameters/PropertyFilter.ts.html#moduletag", "relUrl": "/pretty-print/Parameters/PropertyFilter.ts.html#moduletag" },"1096": { "doc": "Parameters/PropertyFilter.ts", "title": "Parameters/PropertyFilter.ts", "content": " ", "url": "/0.1.0/pretty-print/Parameters/PropertyFilter.ts.html", "relUrl": "/pretty-print/Parameters/PropertyFilter.ts.html" },"1097": { "doc": "Parameters/PropertyFormatter.ts", "title": "PropertyFormatter overview", "content": "This module implements a type that takes care of the stringification of the properties of a non- primitive value. From the stringified representation of the value of a property which it receives, it must return the stringified representation of the whole property (key and value). With the make function, you can define your own instances if the provided ones don’t suit your needs. ", "url": "/0.1.0/pretty-print/Parameters/PropertyFormatter.ts.html#propertyformatter-overview", "relUrl": "/pretty-print/Parameters/PropertyFormatter.ts.html#propertyformatter-overview" },"1098": { "doc": "Parameters/PropertyFormatter.ts", "title": "Table of contents", "content": ". | Constructors . | keyAndValue | make | treeify | treeifyHideLeaves | . | Equivalences . | equivalence | . | Getters . | action | id | . | Instances . | usualTreeify | usualTreeifyHideLeaves | utilInspectLikeArrayAndRecord | utilInspectLikeIterable | valueOnly | . | Models . | Type (class) . | [MData.idSymbol] (method) | [Hash.symbol] (method) | [MEquivalenceBasedEqualityData.isEquivalentToSymbol] (method) | [MEquivalenceBasedEqualityData.hasSameTypeMarkerAsSymbol] (method) | id (property) | action (property) | . | . | Module markers . | moduleTag | . | . ", "url": "/0.1.0/pretty-print/Parameters/PropertyFormatter.ts.html", "relUrl": "/pretty-print/Parameters/PropertyFormatter.ts.html" },"1099": { "doc": "Parameters/PropertyFormatter.ts", "title": "Constructors", "content": " ", "url": "/0.1.0/pretty-print/Parameters/PropertyFormatter.ts.html#constructors", "relUrl": "/pretty-print/Parameters/PropertyFormatter.ts.html#constructors" },"1100": { "doc": "Parameters/PropertyFormatter.ts", "title": "keyAndValue", "content": "Constructor that builds a PPPropertyFormatter instance that prints the key and value of a property on the same line, separated by keyValueSeparatorMark (similar to the usual way a record is printed). prototypePrefixMark is prepended and prototypeSuffixMark is appended to property keys as many times as the depth of the property in the prototypal chain (useful to visually distinguish inherited properties). Signature . export declare const keyAndValue: ({ keyValueSeparatorMark, prototypePrefixMark, prototypeSuffixMark }: { readonly keyValueSeparatorMark: string readonly prototypePrefixMark: string readonly prototypeSuffixMark: string }) =&gt; Type . ", "url": "/0.1.0/pretty-print/Parameters/PropertyFormatter.ts.html#keyandvalue", "relUrl": "/pretty-print/Parameters/PropertyFormatter.ts.html#keyandvalue" },"1101": { "doc": "Parameters/PropertyFormatter.ts", "title": "make", "content": "Constructor . Signature . export declare const make: (params: MTypes.Data&lt;Type&gt;) =&gt; Type . ", "url": "/0.1.0/pretty-print/Parameters/PropertyFormatter.ts.html#make", "relUrl": "/pretty-print/Parameters/PropertyFormatter.ts.html#make" },"1102": { "doc": "Parameters/PropertyFormatter.ts", "title": "treeify", "content": "Constructor that builds a PPPropertyFormatter instance for tree-style output: . | For a leaf property: prints key and value on the same line, separated by keyValueSeparatorMark (same as keyAndValue). | For a non-leaf property: prints the key on its own line and the formatted sub-tree on the following lines, with no separator. | . Signature . export declare const treeify: ({ keyValueSeparatorMark, prototypePrefixMark, prototypeSuffixMark }: { readonly keyValueSeparatorMark: string readonly prototypePrefixMark: string readonly prototypeSuffixMark: string }) =&gt; Type . ", "url": "/0.1.0/pretty-print/Parameters/PropertyFormatter.ts.html#treeify", "relUrl": "/pretty-print/Parameters/PropertyFormatter.ts.html#treeify" },"1103": { "doc": "Parameters/PropertyFormatter.ts", "title": "treeifyHideLeaves", "content": "Constructor that builds a PPPropertyFormatter instance for tree-style output with hidden leaves: - For a leaf property: prints only the key (the value is hidden). - For a non-leaf property: prints the key on its own line and the formatted sub-tree on the following lines, with no separator. Signature . export declare const treeifyHideLeaves: ({ keyValueSeparatorMark, prototypePrefixMark, prototypeSuffixMark }: { readonly keyValueSeparatorMark: string readonly prototypePrefixMark: string readonly prototypeSuffixMark: string }) =&gt; Type . ", "url": "/0.1.0/pretty-print/Parameters/PropertyFormatter.ts.html#treeifyhideleaves", "relUrl": "/pretty-print/Parameters/PropertyFormatter.ts.html#treeifyhideleaves" },"1104": { "doc": "Parameters/PropertyFormatter.ts", "title": "Equivalences", "content": " ", "url": "/0.1.0/pretty-print/Parameters/PropertyFormatter.ts.html#equivalences", "relUrl": "/pretty-print/Parameters/PropertyFormatter.ts.html#equivalences" },"1105": { "doc": "Parameters/PropertyFormatter.ts", "title": "equivalence", "content": "PropertyFormatter equivalence . Signature . export declare const equivalence: Equivalence.Equivalence&lt;Type&gt; . ", "url": "/0.1.0/pretty-print/Parameters/PropertyFormatter.ts.html#equivalence", "relUrl": "/pretty-print/Parameters/PropertyFormatter.ts.html#equivalence" },"1106": { "doc": "Parameters/PropertyFormatter.ts", "title": "Getters", "content": " ", "url": "/0.1.0/pretty-print/Parameters/PropertyFormatter.ts.html#getters", "relUrl": "/pretty-print/Parameters/PropertyFormatter.ts.html#getters" },"1107": { "doc": "Parameters/PropertyFormatter.ts", "title": "action", "content": "Returns the action property of self . Signature . export declare const action: MTypes.OneArgFunction&lt; Type, ({ property, stringifiedPropValue, isLeaf, hideKey, parameters }: { readonly property: PPValue.Any readonly stringifiedPropValue: PPStringifiedValue.Type readonly isLeaf: boolean readonly hideKey: boolean readonly parameters: PPParameters.Type }) =&gt; PPStringifiedValue.Type &gt; . ", "url": "/0.1.0/pretty-print/Parameters/PropertyFormatter.ts.html#action", "relUrl": "/pretty-print/Parameters/PropertyFormatter.ts.html#action" },"1108": { "doc": "Parameters/PropertyFormatter.ts", "title": "id", "content": "Returns the id property of self . Signature . export declare const id: MTypes.OneArgFunction&lt;Type, string&gt; . ", "url": "/0.1.0/pretty-print/Parameters/PropertyFormatter.ts.html#id", "relUrl": "/pretty-print/Parameters/PropertyFormatter.ts.html#id" },"1109": { "doc": "Parameters/PropertyFormatter.ts", "title": "Instances", "content": " ", "url": "/0.1.0/pretty-print/Parameters/PropertyFormatter.ts.html#instances", "relUrl": "/pretty-print/Parameters/PropertyFormatter.ts.html#instances" },"1110": { "doc": "Parameters/PropertyFormatter.ts", "title": "usualTreeify", "content": "PropertyFormatter instance that treeifies a non-primitive value (and shows the leaves) . Signature . export declare const usualTreeify: Type . ", "url": "/0.1.0/pretty-print/Parameters/PropertyFormatter.ts.html#usualtreeify", "relUrl": "/pretty-print/Parameters/PropertyFormatter.ts.html#usualtreeify" },"1111": { "doc": "Parameters/PropertyFormatter.ts", "title": "usualTreeifyHideLeaves", "content": "PropertyFormatter instance that treeifies a non-primitive value (and hides the leaves) . Signature . export declare const usualTreeifyHideLeaves: Type . ", "url": "/0.1.0/pretty-print/Parameters/PropertyFormatter.ts.html#usualtreeifyhideleaves", "relUrl": "/pretty-print/Parameters/PropertyFormatter.ts.html#usualtreeifyhideleaves" },"1112": { "doc": "Parameters/PropertyFormatter.ts", "title": "utilInspectLikeArrayAndRecord", "content": "PropertyFormatter instance that formats a non-primitive value in the way util.inspect does for records. Property key and value are separated by : (if the key is shown, which is usually not the case for arrays). @ is suffixed to all property keys as many times as the depth of the property in the prototypal chain . Signature . export declare const utilInspectLikeArrayAndRecord: Type . ", "url": "/0.1.0/pretty-print/Parameters/PropertyFormatter.ts.html#utilinspectlikearrayandrecord", "relUrl": "/pretty-print/Parameters/PropertyFormatter.ts.html#utilinspectlikearrayandrecord" },"1113": { "doc": "Parameters/PropertyFormatter.ts", "title": "utilInspectLikeIterable", "content": "PropertyFormatter instance that formats a non-primitive value in the way util.inspect does for maps and sets. Property key and value are separated by =&gt; (if the key is shown, which is usually not the case for sets). @ is suffixed to all property keys as many times as the depth of the property in the prototypal chain . Signature . export declare const utilInspectLikeIterable: Type . ", "url": "/0.1.0/pretty-print/Parameters/PropertyFormatter.ts.html#utilinspectlikeiterable", "relUrl": "/pretty-print/Parameters/PropertyFormatter.ts.html#utilinspectlikeiterable" },"1114": { "doc": "Parameters/PropertyFormatter.ts", "title": "valueOnly", "content": "PropertyFormatter instance that prints only the value of a property (similar to the usual way an array is printed). Signature . export declare const valueOnly: Type . ", "url": "/0.1.0/pretty-print/Parameters/PropertyFormatter.ts.html#valueonly", "relUrl": "/pretty-print/Parameters/PropertyFormatter.ts.html#valueonly" },"1115": { "doc": "Parameters/PropertyFormatter.ts", "title": "Models", "content": " ", "url": "/0.1.0/pretty-print/Parameters/PropertyFormatter.ts.html#models", "relUrl": "/pretty-print/Parameters/PropertyFormatter.ts.html#models" },"1116": { "doc": "Parameters/PropertyFormatter.ts", "title": "Type (class)", "content": "Type that represents a PropertyFormatter. Signature . export declare class Type { public constructor({ id, action }: MTypes.Data&lt;Type&gt;) } . [MData.idSymbol] (method) . Returns the id of this . Signature . [MData.idSymbol](): string | (() =&gt; string) . [Hash.symbol] (method) . Calculates the hash value of this . Signature . [Hash.symbol](): number . [MEquivalenceBasedEqualityData.isEquivalentToSymbol] (method) . Function that implements the equivalence of this and that . Signature . [MEquivalenceBasedEqualityData.isEquivalentToSymbol](this: this, that: this): boolean . [MEquivalenceBasedEqualityData.hasSameTypeMarkerAsSymbol] (method) . Predicate that returns true if that has the same type marker as this . Signature . [MEquivalenceBasedEqualityData.hasSameTypeMarkerAsSymbol](that: unknown): boolean . id (property) . Id of this PPPropertyFormatter instance. Useful for equality and debugging . Signature . readonly id: string . action (property) . Action of this PPPropertyFormatter. The action takes as input: . | property: the property being stringified, | stringifiedPropValue: the stringified representation of the value of that property, | isLeaf: a boolean that indicates if the property is a leaf (useful to hide leaves when treeifying), | hideKey : a boolean that indicates if the key must be displayed (useful for iterables like arrays for which keys have been generated automatically by auto-incrementation and are usually not displayed) | parameters : the parameters passed by the user to build the PPStringifier. | . It returns a stringified representation of the whole property. Signature . readonly action: ({ property, stringifiedPropValue, isLeaf, hideKey, parameters, }: { readonly property: PPValue.Any; readonly stringifiedPropValue: PPStringifiedValue.Type; readonly isLeaf: boolean; readonly hideKey: boolean; readonly parameters: PPParameters.Type; }) =&gt; PPStringifiedValue.Type . ", "url": "/0.1.0/pretty-print/Parameters/PropertyFormatter.ts.html#type-class", "relUrl": "/pretty-print/Parameters/PropertyFormatter.ts.html#type-class" },"1117": { "doc": "Parameters/PropertyFormatter.ts", "title": "Module markers", "content": " ", "url": "/0.1.0/pretty-print/Parameters/PropertyFormatter.ts.html#module-markers", "relUrl": "/pretty-print/Parameters/PropertyFormatter.ts.html#module-markers" },"1118": { "doc": "Parameters/PropertyFormatter.ts", "title": "moduleTag", "content": "Module tag . Signature . export declare const moduleTag: \"@parischap/pretty-print/Parameters/PropertyFormatter/\" . ", "url": "/0.1.0/pretty-print/Parameters/PropertyFormatter.ts.html#moduletag", "relUrl": "/pretty-print/Parameters/PropertyFormatter.ts.html#moduletag" },"1119": { "doc": "Parameters/PropertyFormatter.ts", "title": "Parameters/PropertyFormatter.ts", "content": " ", "url": "/0.1.0/pretty-print/Parameters/PropertyFormatter.ts.html", "relUrl": "/pretty-print/Parameters/PropertyFormatter.ts.html" },"1120": { "doc": "Parameters/PropertyNumberDisplayOption.ts", "title": "PropertyNumberDisplayOption overview", "content": "This module implements a type that represents the possible options regarding the display of the number of properties of a non-primitive value. ", "url": "/0.1.0/pretty-print/Parameters/PropertyNumberDisplayOption.ts.html#propertynumberdisplayoption-overview", "relUrl": "/pretty-print/Parameters/PropertyNumberDisplayOption.ts.html#propertynumberdisplayoption-overview" },"1121": { "doc": "Parameters/PropertyNumberDisplayOption.ts", "title": "Table of contents", "content": ". ", "url": "/0.1.0/pretty-print/Parameters/PropertyNumberDisplayOption.ts.html", "relUrl": "/pretty-print/Parameters/PropertyNumberDisplayOption.ts.html" },"1122": { "doc": "Parameters/PropertyNumberDisplayOption.ts", "title": "Parameters/PropertyNumberDisplayOption.ts", "content": " ", "url": "/0.1.0/pretty-print/Parameters/PropertyNumberDisplayOption.ts.html", "relUrl": "/pretty-print/Parameters/PropertyNumberDisplayOption.ts.html" },"1123": { "doc": "Record.ts", "title": "Record overview", "content": "Extension to the Effect Record module providing unsafe field access and helpers for invoking zero-argument methods reflectively. Although it’s possible to build a record whose key is a literal type, e.g. ‘a’ | ‘b’, this possibility should never be used: if you know what the keys are, use the Struct type instead. ", "url": "/0.1.0/effect-lib/Record.ts.html#record-overview", "relUrl": "/effect-lib/Record.ts.html#record-overview" },"1124": { "doc": "Record.ts", "title": "Mental model", "content": ". | Type&lt;K,A&gt; is Record.ReadonlyRecord&lt;K, A&gt;, i.e. a plain JavaScript object used as a string-keyed map. | The reflective helpers ({@link tryZeroParamFunction}, {@link tryZeroParamStringFunction}) are used by formatters like the pretty-print package to discover whether a value defines a custom string representation (toString, toJSON, …). | . ", "url": "/0.1.0/effect-lib/Record.ts.html#mental-model", "relUrl": "/effect-lib/Record.ts.html#mental-model" },"1125": { "doc": "Record.ts", "title": "Common tasks", "content": ". | Unchecked access: {@link unsafeGet} | Reflective invocation: {@link tryZeroParamFunction}, {@link tryZeroParamStringFunction} | . ", "url": "/0.1.0/effect-lib/Record.ts.html#common-tasks", "relUrl": "/effect-lib/Record.ts.html#common-tasks" },"1126": { "doc": "Record.ts", "title": "Quickstart", "content": "Example (Try invoking toJSON on a value) . import * as MRecord from \"@parischap/effect-lib/MRecord\" const date = new Date(\"2024-01-01T00:00:00Z\") console.log(MRecord.tryZeroParamFunction({ functionName: \"toJSON\" })(date)) // Some('2024-01-01T00:00:00.000Z') . ", "url": "/0.1.0/effect-lib/Record.ts.html#quickstart", "relUrl": "/effect-lib/Record.ts.html#quickstart" },"1127": { "doc": "Record.ts", "title": "Table of contents", "content": ". | Models . | Type (type alias) | . | Utils . | tryZeroParamFunction | tryZeroParamStringFunction | unsafeGet | . | . ", "url": "/0.1.0/effect-lib/Record.ts.html", "relUrl": "/effect-lib/Record.ts.html" },"1128": { "doc": "Record.ts", "title": "Models", "content": " ", "url": "/0.1.0/effect-lib/Record.ts.html#models", "relUrl": "/effect-lib/Record.ts.html#models" },"1129": { "doc": "Record.ts", "title": "Type (type alias)", "content": "Type on which this module’s functions operate. Signature . export type Type&lt;K extends string | symbol, A&gt; = Record.ReadonlyRecord&lt;K, A&gt; . ", "url": "/0.1.0/effect-lib/Record.ts.html#type-type-alias", "relUrl": "/effect-lib/Record.ts.html#type-type-alias" },"1130": { "doc": "Record.ts", "title": "Utils", "content": " ", "url": "/0.1.0/effect-lib/Record.ts.html#utils", "relUrl": "/effect-lib/Record.ts.html#utils" },"1131": { "doc": "Record.ts", "title": "tryZeroParamFunction", "content": "Tries to invoke the zero-argument method named functionName on self. | Returns Option.some(result) when self[functionName] is a function declaring zero parameters and is not the same reference as exception (when exception is supplied). | Returns Option.none when the property is missing, not a function, declares one or more parameters, or matches exception. | The exception parameter is useful to skip an inherited default (e.g. Object.prototype.toString when probing for a custom toString). | . Example (Detect a custom toString) . import * as MRecord from \"@parischap/effect-lib/MRecord\" const tryCustomToString = MRecord.tryZeroParamFunction({ functionName: \"toString\", exception: Object.prototype.toString }) console.log(tryCustomToString(new Date(0))) // Some('Thu Jan 01 1970 ...') console.log(tryCustomToString({ a: 1 })) // None . Signature . export declare const tryZeroParamFunction: &lt;K extends string | symbol&gt;({ functionName, exception }: { readonly functionName: NoInfer&lt;K&gt; readonly exception?: MTypes.AnyFunction }) =&gt; (self: Type&lt;K, unknown&gt;) =&gt; Option.Option&lt;unknown&gt; . ", "url": "/0.1.0/effect-lib/Record.ts.html#tryzeroparamfunction", "relUrl": "/effect-lib/Record.ts.html#tryzeroparamfunction" },"1132": { "doc": "Record.ts", "title": "tryZeroParamStringFunction", "content": "Same as {@link tryZeroParamFunction} but additionally returns Option.none when the result is not a string. | Use when probing for a string-producing method (e.g. toString, toJSON returning a string). | . Example (Custom string-producing method) . import * as MRecord from \"@parischap/effect-lib/MRecord\" const tryToJSON = MRecord.tryZeroParamStringFunction({ functionName: \"toJSON\" }) console.log(tryToJSON(new Date(\"2024-01-01T00:00:00Z\"))) // Some('2024-01-01T00:00:00.000Z') . Signature . export declare const tryZeroParamStringFunction: &lt;K extends string | symbol&gt;(params: { readonly functionName: K readonly exception?: MTypes.AnyFunction }) =&gt; (self: Type&lt;K, unknown&gt;) =&gt; Option.Option&lt;string&gt; . ", "url": "/0.1.0/effect-lib/Record.ts.html#tryzeroparamstringfunction", "relUrl": "/effect-lib/Record.ts.html#tryzeroparamstringfunction" },"1133": { "doc": "Record.ts", "title": "unsafeGet", "content": "Returns the value at key in self without checking that the key exists. | Use only when the presence of key is guaranteed by construction. | Returns undefined (typed as A) when key is missing. | . Example (Unchecked access) . import { pipe } from \"effect\" import * as MRecord from \"@parischap/effect-lib/MRecord\" console.log(pipe({ a: 1, b: 2 }, MRecord.unsafeGet(\"a\"))) // 1 . Signature . export declare const unsafeGet: &lt;K extends string | symbol&gt;(key: NoInfer&lt;K&gt;) =&gt; &lt;A&gt;(self: Type&lt;K, A&gt;) =&gt; A . ", "url": "/0.1.0/effect-lib/Record.ts.html#unsafeget", "relUrl": "/effect-lib/Record.ts.html#unsafeget" },"1134": { "doc": "Record.ts", "title": "Record.ts", "content": " ", "url": "/0.1.0/effect-lib/Record.ts.html", "relUrl": "/effect-lib/Record.ts.html" },"1135": { "doc": "RegExp.ts", "title": "RegExp overview", "content": "Constructors and pre-built RegExp instances backed by patterns from {@link “./RegExpString.js” | MRegExpString}. ", "url": "/0.1.0/effect-lib/RegExp.ts.html#regexp-overview", "relUrl": "/effect-lib/RegExp.ts.html#regexp-overview" },"1136": { "doc": "RegExp.ts", "title": "Mental model", "content": ". | This module materializes the string patterns from MRegExpString as actual RegExp objects. | When you need a regex with custom flags (e.g. the g flag), build it with {@link fromRegExpString}; the bundled instances are flag-free. | . ", "url": "/0.1.0/effect-lib/RegExp.ts.html#mental-model", "relUrl": "/effect-lib/RegExp.ts.html#mental-model" },"1137": { "doc": "RegExp.ts", "title": "Common tasks", "content": ". | Construct from a pattern string: {@link fromRegExpString} | Pre-built instances: {@link lineBreak}, {@link universalPathSep}, {@link semVer}, {@link email} | . ", "url": "/0.1.0/effect-lib/RegExp.ts.html#common-tasks", "relUrl": "/effect-lib/RegExp.ts.html#common-tasks" },"1138": { "doc": "RegExp.ts", "title": "Quickstart", "content": "Example (Match a SemVer string) . import * as MRegExp from \"@parischap/effect-lib/MRegExp\" console.log(MRegExp.semVer.test(\"1.2.3\")) // true console.log(MRegExp.semVer.test(\"1.2\")) // false . ", "url": "/0.1.0/effect-lib/RegExp.ts.html#quickstart", "relUrl": "/effect-lib/RegExp.ts.html#quickstart" },"1139": { "doc": "RegExp.ts", "title": "Table of contents", "content": ". | Constructors . | fromRegExpString | . | Instances . | email | lineBreak | semVer | universalPathSep | . | . ", "url": "/0.1.0/effect-lib/RegExp.ts.html", "relUrl": "/effect-lib/RegExp.ts.html" },"1140": { "doc": "RegExp.ts", "title": "Constructors", "content": " ", "url": "/0.1.0/effect-lib/RegExp.ts.html#constructors", "relUrl": "/effect-lib/RegExp.ts.html#constructors" },"1141": { "doc": "RegExp.ts", "title": "fromRegExpString", "content": "Builds a RegExp from a pattern string, optionally with flags. Example (Build a regex with the i flag) . import { pipe } from \"effect\" import * as MRegExp from \"@parischap/effect-lib/MRegExp\" const ci = pipe(\"hello\", MRegExp.fromRegExpString(\"i\")) console.log(ci.test(\"HELLO\")) // true . Signature . export declare const fromRegExpString: (flags?: string) =&gt; (s: string) =&gt; RegExp . ", "url": "/0.1.0/effect-lib/RegExp.ts.html#fromregexpstring", "relUrl": "/effect-lib/RegExp.ts.html#fromregexpstring" },"1142": { "doc": "RegExp.ts", "title": "Instances", "content": " ", "url": "/0.1.0/effect-lib/RegExp.ts.html#instances", "relUrl": "/effect-lib/RegExp.ts.html#instances" },"1143": { "doc": "RegExp.ts", "title": "email", "content": "A RegExp matching an entire e-mail address. Uses {@link MRegExpString.email} anchored to a full line. Signature . export declare const email: RegExp . ", "url": "/0.1.0/effect-lib/RegExp.ts.html#email", "relUrl": "/effect-lib/RegExp.ts.html#email" },"1144": { "doc": "RegExp.ts", "title": "lineBreak", "content": "A RegExp matching a line break (CRLF, CR or LF). No g flag. Signature . export declare const lineBreak: RegExp . ", "url": "/0.1.0/effect-lib/RegExp.ts.html#linebreak", "relUrl": "/effect-lib/RegExp.ts.html#linebreak" },"1145": { "doc": "RegExp.ts", "title": "semVer", "content": "A RegExp matching an entire SemVer string of the form X.Y.Z. Uses {@link MRegExpString.semVer} anchored to a full line. Signature . export declare const semVer: RegExp . ", "url": "/0.1.0/effect-lib/RegExp.ts.html#semver", "relUrl": "/effect-lib/RegExp.ts.html#semver" },"1146": { "doc": "RegExp.ts", "title": "universalPathSep", "content": "A RegExp matching a path separator on any platform (/ or \\). Signature . export declare const universalPathSep: RegExp . ", "url": "/0.1.0/effect-lib/RegExp.ts.html#universalpathsep", "relUrl": "/effect-lib/RegExp.ts.html#universalpathsep" },"1147": { "doc": "RegExp.ts", "title": "RegExp.ts", "content": " ", "url": "/0.1.0/effect-lib/RegExp.ts.html", "relUrl": "/effect-lib/RegExp.ts.html" },"1148": { "doc": "RegExpString.ts", "title": "RegExpString overview", "content": "Composable regular-expression patterns expressed as plain strings. ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#regexpstring-overview", "relUrl": "/effect-lib/RegExpString.ts.html#regexpstring-overview" },"1149": { "doc": "RegExpString.ts", "title": "Mental model", "content": ". | Patterns are produced as string’s and combined as string’s. The final pattern is fed to the RegExp constructor by callers (or by helpers in {@link “./RegExp.js” | MRegExp}). | Combinators ({@link zeroOrMore}, {@link oneOrMore}, {@link either}, …) wrap their argument in a non-capturing group (?:…) so they remain composable without affecting capture indices. | Pre-built instances cover the common building blocks (digits, sign, separators, line breaks) and a few full patterns ({@link semVer}, {@link email}, {@link base10Number}). | . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#mental-model", "relUrl": "/effect-lib/RegExpString.ts.html#mental-model" },"1150": { "doc": "RegExpString.ts", "title": "Common tasks", "content": ". | Quantifiers: {@link zeroOrMore}, {@link oneOrMore}, {@link repeatBetween}, {@link optional} | Composition: {@link either}, {@link anyCharIn}, {@link charNotIn} | Anchors / lookarounds: {@link makeLine}, {@link atStart}, {@link atEnd}, {@link positiveLookAhead}, {@link negativeLookAhead} | Capturing: {@link capture}, {@link optionalCapture} | Numbers: {@link unsignedBase10Int}, {@link unsignedNonNullBase10Int}, {@link base10Number}, {@link binaryInt}, {@link octalInt}, {@link hexaInt} | Pre-built: {@link semVer}, {@link email}, {@link lineBreak}, {@link universalPathSep} | . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#common-tasks", "relUrl": "/effect-lib/RegExpString.ts.html#common-tasks" },"1151": { "doc": "RegExpString.ts", "title": "Quickstart", "content": "Example (Compose a pattern) . import { pipe } from \"effect\" import * as MRegExpString from \"@parischap/effect-lib/MRegExpString\" const pattern = pipe(MRegExpString.digit, MRegExpString.oneOrMore, MRegExpString.makeLine) console.log(new RegExp(pattern).test(\"12345\")) // true console.log(new RegExp(pattern).test(\"12a45\")) // false . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#quickstart", "relUrl": "/effect-lib/RegExpString.ts.html#quickstart" },"1152": { "doc": "RegExpString.ts", "title": "Table of contents", "content": ". | Constants . | DIGIT_GROUP_SIZE | . | Constructors . | fromRegExp | . | Instances . | CR | LF | anyChar | anyCharButLineBreak | anyWord | anyWordLetter | anythingButDot | arrowbase | backslash | base10Number | binaryInt | digit | dollar | dot | email | hexaInt | letter | lineBreak | lowerCaseLetter | lowerCaseLetterOrDigit | minus | nonSpace | nonZeroDigit | octalInt | plus | semVer | sign | slash | space | spaces | star | tab | universalPathSep | unsignedBase10Int | unsignedNonNullBase10Int | upperCaseLetter | . | Utils . | anyCharIn | atEnd | atStart | capture | charNotIn | either | makeLine | negativeLookAhead | oneOrMore | optional | optionalCapture | positiveLookAhead | repeatBetween | zeroOrMore | . | . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html", "relUrl": "/effect-lib/RegExpString.ts.html" },"1153": { "doc": "RegExpString.ts", "title": "Constants", "content": " ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#constants", "relUrl": "/effect-lib/RegExpString.ts.html#constants" },"1154": { "doc": "RegExpString.ts", "title": "DIGIT_GROUP_SIZE", "content": "Size of a group of digits separated by a thousand separator (e.g. 1,234,567). Signature . export declare const DIGIT_GROUP_SIZE: 3 . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#digit_group_size", "relUrl": "/effect-lib/RegExpString.ts.html#digit_group_size" },"1155": { "doc": "RegExpString.ts", "title": "Constructors", "content": " ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#constructors", "relUrl": "/effect-lib/RegExpString.ts.html#constructors" },"1156": { "doc": "RegExpString.ts", "title": "fromRegExp", "content": "Returns the source of regExp as a string. Signature . export declare const fromRegExp: (regExp: RegExp) =&gt; string . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#fromregexp", "relUrl": "/effect-lib/RegExpString.ts.html#fromregexp" },"1157": { "doc": "RegExpString.ts", "title": "Instances", "content": " ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#instances", "relUrl": "/effect-lib/RegExpString.ts.html#instances" },"1158": { "doc": "RegExpString.ts", "title": "CR", "content": "A regular expression string representing a carriage return . Signature . export declare const CR: string . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#cr", "relUrl": "/effect-lib/RegExpString.ts.html#cr" },"1159": { "doc": "RegExpString.ts", "title": "LF", "content": "A regular expression string representing a line-feed . Signature . export declare const LF: string . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#lf", "relUrl": "/effect-lib/RegExpString.ts.html#lf" },"1160": { "doc": "RegExpString.ts", "title": "anyChar", "content": "A regular expression string representing any character . Signature . export declare const anyChar: string . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#anychar", "relUrl": "/effect-lib/RegExpString.ts.html#anychar" },"1161": { "doc": "RegExpString.ts", "title": "anyCharButLineBreak", "content": "A regular expression string representing any character but a lineBreak . Signature . export declare const anyCharButLineBreak: \".\" . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#anycharbutlinebreak", "relUrl": "/effect-lib/RegExpString.ts.html#anycharbutlinebreak" },"1162": { "doc": "RegExpString.ts", "title": "anyWord", "content": "A regular expression string representing a word . Signature . export declare const anyWord: string . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#anyword", "relUrl": "/effect-lib/RegExpString.ts.html#anyword" },"1163": { "doc": "RegExpString.ts", "title": "anyWordLetter", "content": "A regular expression string representing a word letter . Signature . export declare const anyWordLetter: string . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#anywordletter", "relUrl": "/effect-lib/RegExpString.ts.html#anywordletter" },"1164": { "doc": "RegExpString.ts", "title": "anythingButDot", "content": "A regular expression string representing anything but a dot . Signature . export declare const anythingButDot: string . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#anythingbutdot", "relUrl": "/effect-lib/RegExpString.ts.html#anythingbutdot" },"1165": { "doc": "RegExpString.ts", "title": "arrowbase", "content": "A regular expression string representing the arrowbase . Signature . export declare const arrowbase: \"@\" . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#arrowbase", "relUrl": "/effect-lib/RegExpString.ts.html#arrowbase" },"1166": { "doc": "RegExpString.ts", "title": "backslash", "content": "A regular expression string representing a backslashString . Signature . export declare const backslash: string . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#backslash", "relUrl": "/effect-lib/RegExpString.ts.html#backslash" },"1167": { "doc": "RegExpString.ts", "title": "base10Number", "content": "Returns a regular expression string representing a left-padded number in base 10 using thousandSeparator as thousand separator, fractionalSeparator as fractional separator and eNotationChars as possible characters for scientific notation. | thousandSeparator: Usually a string made of at most one character but not mandatory. Should be different from fractionalSeparator. Will not throw otherwise but unexpected results might occur. Use ‘’ for no thousand separator. | fractionalSeparator: usually a one-character string but not mandatory (e.g. ‘.’). Should not be an empty string and be different from thousandSeparator. Will not throw otherwise but unexpected results might occur. | eNotationChars: array of possible chracters that can be used to represent an exponent (e.g. value: [‘E’, ‘e’]). | fillChar: usually a one-character string but not mandatory (e.g. ‘ ‘). If not an empty string, zero or more fillChar’s are tolerated between the sign and the number (or at the start of the number if it is unsigned). Beware if you use a digit as fillChar (e.g. you use ‘0’ as fillChar and try to parse ‘0000’) | . Signature . export declare const base10Number: ({ thousandSeparator, fractionalSeparator, eNotationChars, fillChar }: { readonly thousandSeparator: string readonly fractionalSeparator: string readonly eNotationChars: ReadonlyArray&lt;string&gt; readonly fillChar: string }) =&gt; string . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#base10number", "relUrl": "/effect-lib/RegExpString.ts.html#base10number" },"1168": { "doc": "RegExpString.ts", "title": "binaryInt", "content": "A regular expression string representing an integer in base 2. Signature . export declare const binaryInt: string . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#binaryint", "relUrl": "/effect-lib/RegExpString.ts.html#binaryint" },"1169": { "doc": "RegExpString.ts", "title": "digit", "content": "A regular expression string representing a digit . Signature . export declare const digit: string . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#digit", "relUrl": "/effect-lib/RegExpString.ts.html#digit" },"1170": { "doc": "RegExpString.ts", "title": "dollar", "content": "A regular expression string representing a dollar sign . Signature . export declare const dollar: string . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#dollar", "relUrl": "/effect-lib/RegExpString.ts.html#dollar" },"1171": { "doc": "RegExpString.ts", "title": "dot", "content": "A regular expression string representing a dot . Signature . export declare const dot: string . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#dot", "relUrl": "/effect-lib/RegExpString.ts.html#dot" },"1172": { "doc": "RegExpString.ts", "title": "email", "content": "A regular expression string representing an email - Imported from https://stackoverflow.com/questions/201323/how-can-i-validate-an-email-address-using-a-regular-expression . Signature . export declare const email: string . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#email", "relUrl": "/effect-lib/RegExpString.ts.html#email" },"1173": { "doc": "RegExpString.ts", "title": "hexaInt", "content": "A regular expression string representing an integer in base 16. Signature . export declare const hexaInt: string . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#hexaint", "relUrl": "/effect-lib/RegExpString.ts.html#hexaint" },"1174": { "doc": "RegExpString.ts", "title": "letter", "content": "A regular expression string representing a letter . Signature . export declare const letter: \"[A-Za-z]\" . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#letter", "relUrl": "/effect-lib/RegExpString.ts.html#letter" },"1175": { "doc": "RegExpString.ts", "title": "lineBreak", "content": "A regular expression string representing a linebreak in Windows, Unix and Mac Os . Signature . export declare const lineBreak: string . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#linebreak", "relUrl": "/effect-lib/RegExpString.ts.html#linebreak" },"1176": { "doc": "RegExpString.ts", "title": "lowerCaseLetter", "content": "A regular expression string representing a lowercase letter . Signature . export declare const lowerCaseLetter: \"[a-z]\" . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#lowercaseletter", "relUrl": "/effect-lib/RegExpString.ts.html#lowercaseletter" },"1177": { "doc": "RegExpString.ts", "title": "lowerCaseLetterOrDigit", "content": "A regular expression string representing a lowercase letter or a digit. Signature . export declare const lowerCaseLetterOrDigit: \"[a-z0-9]\" . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#lowercaseletterordigit", "relUrl": "/effect-lib/RegExpString.ts.html#lowercaseletterordigit" },"1178": { "doc": "RegExpString.ts", "title": "minus", "content": "A regular expression string representing a minus sign . Signature . export declare const minus: \"-\" . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#minus", "relUrl": "/effect-lib/RegExpString.ts.html#minus" },"1179": { "doc": "RegExpString.ts", "title": "nonSpace", "content": "A regular expression string representing a non-space character. Signature . export declare const nonSpace: string . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#nonspace", "relUrl": "/effect-lib/RegExpString.ts.html#nonspace" },"1180": { "doc": "RegExpString.ts", "title": "nonZeroDigit", "content": "A regular expression string representing a strictly positive digit . Signature . export declare const nonZeroDigit: \"[1-9]\" . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#nonzerodigit", "relUrl": "/effect-lib/RegExpString.ts.html#nonzerodigit" },"1181": { "doc": "RegExpString.ts", "title": "octalInt", "content": "A regular expression string representing an integer in base 8. Signature . export declare const octalInt: string . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#octalint", "relUrl": "/effect-lib/RegExpString.ts.html#octalint" },"1182": { "doc": "RegExpString.ts", "title": "plus", "content": "A regular expression string representing a plus sign . Signature . export declare const plus: string . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#plus", "relUrl": "/effect-lib/RegExpString.ts.html#plus" },"1183": { "doc": "RegExpString.ts", "title": "semVer", "content": "A regular expression string representing a simplified SemVer. See https://semver.org/ for a more accurate version . Signature . export declare const semVer: string . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#semver", "relUrl": "/effect-lib/RegExpString.ts.html#semver" },"1184": { "doc": "RegExpString.ts", "title": "sign", "content": "A regular expression string representing a plus or a minus sign . Signature . export declare const sign: string . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#sign", "relUrl": "/effect-lib/RegExpString.ts.html#sign" },"1185": { "doc": "RegExpString.ts", "title": "slash", "content": "A regular expression string representing a slash . Signature . export declare const slash: string . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#slash", "relUrl": "/effect-lib/RegExpString.ts.html#slash" },"1186": { "doc": "RegExpString.ts", "title": "space", "content": "A regular expression string representing a space . Signature . export declare const space: string . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#space", "relUrl": "/effect-lib/RegExpString.ts.html#space" },"1187": { "doc": "RegExpString.ts", "title": "spaces", "content": "A regular expression string representing zero or more spaces . Signature . export declare const spaces: string . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#spaces", "relUrl": "/effect-lib/RegExpString.ts.html#spaces" },"1188": { "doc": "RegExpString.ts", "title": "star", "content": "A regular expression string representing a star . Signature . export declare const star: string . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#star", "relUrl": "/effect-lib/RegExpString.ts.html#star" },"1189": { "doc": "RegExpString.ts", "title": "tab", "content": "A regular expression string representing a tab . Signature . export declare const tab: string . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#tab", "relUrl": "/effect-lib/RegExpString.ts.html#tab" },"1190": { "doc": "RegExpString.ts", "title": "universalPathSep", "content": "A path separator regular expression string to split all possible paths . Signature . export declare const universalPathSep: string . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#universalpathsep", "relUrl": "/effect-lib/RegExpString.ts.html#universalpathsep" },"1191": { "doc": "RegExpString.ts", "title": "unsignedBase10Int", "content": "Returns a regular expression string representing an unsigned integer in base 10 using thousandSeparator as thousand separator. Pass an empty string for no thousand separator. Signature . export declare const unsignedBase10Int: (thousandSeparator: string) =&gt; string . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#unsignedbase10int", "relUrl": "/effect-lib/RegExpString.ts.html#unsignedbase10int" },"1192": { "doc": "RegExpString.ts", "title": "unsignedNonNullBase10Int", "content": "Returns a regular expression string representing an unsigned non-null integer in base 10 using thousandSeparator as thousand separator. Pass an empty string for no thousand separator. Signature . export declare const unsignedNonNullBase10Int: (thousandSeparator: string) =&gt; string . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#unsignednonnullbase10int", "relUrl": "/effect-lib/RegExpString.ts.html#unsignednonnullbase10int" },"1193": { "doc": "RegExpString.ts", "title": "upperCaseLetter", "content": "A regular expression string representing an uppercase letter . Signature . export declare const upperCaseLetter: \"[A-Z]\" . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#uppercaseletter", "relUrl": "/effect-lib/RegExpString.ts.html#uppercaseletter" },"1194": { "doc": "RegExpString.ts", "title": "Utils", "content": " ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#utils", "relUrl": "/effect-lib/RegExpString.ts.html#utils" },"1195": { "doc": "RegExpString.ts", "title": "anyCharIn", "content": "Returns a pattern matching any one of the supplied characters as a character class. | For an empty input returns the empty string. | For a single argument returns it verbatim (no class is added). | For two or more, builds [abc…]. | . Example . import * as MRegExpString from \"@parischap/effect-lib/MRegExpString\" console.log(MRegExpString.anyCharIn([\"a\", \"b\", \"c\"])) // '[abc]' . Signature . export declare const anyCharIn: (args: ReadonlyArray&lt;string&gt;) =&gt; string . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#anycharin", "relUrl": "/effect-lib/RegExpString.ts.html#anycharin" },"1196": { "doc": "RegExpString.ts", "title": "atEnd", "content": "Anchors self to the end of a line by appending $. Signature . export declare const atEnd: MTypes.StringTransformer . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#atend", "relUrl": "/effect-lib/RegExpString.ts.html#atend" },"1197": { "doc": "RegExpString.ts", "title": "atStart", "content": "Anchors self to the start of a line by prepending ^. Signature . export declare const atStart: MTypes.StringTransformer . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#atstart", "relUrl": "/effect-lib/RegExpString.ts.html#atstart" },"1198": { "doc": "RegExpString.ts", "title": "capture", "content": "Wraps self in a named capture group (?&lt;name&gt;…). Example . import { pipe } from \"effect\" import * as MRegExpString from \"@parischap/effect-lib/MRegExpString\" console.log(pipe(MRegExpString.digit, MRegExpString.capture(\"d\"))) // '(?&lt;d&gt;\\\\d)' . Signature . export declare const capture: (name: string) =&gt; (self: string) =&gt; string . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#capture", "relUrl": "/effect-lib/RegExpString.ts.html#capture" },"1199": { "doc": "RegExpString.ts", "title": "charNotIn", "content": "Returns a pattern matching any character not in the supplied set, as a negated character class [^abc…]. Signature . export declare const charNotIn: (args: MTypes.ReadonlyOverOne&lt;string&gt;) =&gt; string . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#charnotin", "relUrl": "/effect-lib/RegExpString.ts.html#charnotin" },"1200": { "doc": "RegExpString.ts", "title": "either", "content": "Returns a pattern matching any one of args (alternation). | Empty strings in args are dropped. | For a single non-empty argument, returns it verbatim (no group is added). | For two or more, joins with | inside a non-capturing group. | . Example . import * as MRegExpString from \"@parischap/effect-lib/MRegExpString\" console.log(MRegExpString.either(\"foo\", \"bar\", \"baz\")) // '(?:foo|bar|baz)' . Signature . export declare const either: (...args: ReadonlyArray&lt;string&gt;) =&gt; string . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#either", "relUrl": "/effect-lib/RegExpString.ts.html#either" },"1201": { "doc": "RegExpString.ts", "title": "makeLine", "content": "Wraps self between ^ and $ so it must span an entire line. Signature . export declare const makeLine: MTypes.StringTransformer . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#makeline", "relUrl": "/effect-lib/RegExpString.ts.html#makeline" },"1202": { "doc": "RegExpString.ts", "title": "negativeLookAhead", "content": "Wraps self in a negative lookahead (?!…). Signature . export declare const negativeLookAhead: MTypes.StringTransformer . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#negativelookahead", "relUrl": "/effect-lib/RegExpString.ts.html#negativelookahead" },"1203": { "doc": "RegExpString.ts", "title": "oneOrMore", "content": "Wraps self so it may appear one or more times, using a non-capturing group. Signature . export declare const oneOrMore: MTypes.StringTransformer . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#oneormore", "relUrl": "/effect-lib/RegExpString.ts.html#oneormore" },"1204": { "doc": "RegExpString.ts", "title": "optional", "content": "Wraps self so it is optional, using a non-capturing group. Signature . export declare const optional: MTypes.StringTransformer . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#optional", "relUrl": "/effect-lib/RegExpString.ts.html#optional" },"1205": { "doc": "RegExpString.ts", "title": "optionalCapture", "content": "Combines {@link capture} and {@link optional}: wraps self in a named capture group followed by ?. Signature . export declare const optionalCapture: (name: string) =&gt; (self: string) =&gt; string . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#optionalcapture", "relUrl": "/effect-lib/RegExpString.ts.html#optionalcapture" },"1206": { "doc": "RegExpString.ts", "title": "positiveLookAhead", "content": "Wraps self in a positive lookahead (?=…). Signature . export declare const positiveLookAhead: MTypes.StringTransformer . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#positivelookahead", "relUrl": "/effect-lib/RegExpString.ts.html#positivelookahead" },"1207": { "doc": "RegExpString.ts", "title": "repeatBetween", "content": "Wraps self so it may appear between low and high times. | low must be a non-negative integer with low &lt;= high. | high must be a strictly positive integer or +Infinity; +Infinity is rendered as an open-ended quantifier {low,}. | . Example . import { pipe } from \"effect\" import * as MRegExpString from \"@parischap/effect-lib/MRegExpString\" console.log(pipe(\"a\", MRegExpString.repeatBetween(2, 4))) // '(?:a){2,4}' console.log(pipe(\"a\", MRegExpString.repeatBetween(2, Infinity))) // '(?:a){2,}' . Signature . export declare const repeatBetween: (low: number, high: number) =&gt; (self: string) =&gt; string . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#repeatbetween", "relUrl": "/effect-lib/RegExpString.ts.html#repeatbetween" },"1208": { "doc": "RegExpString.ts", "title": "zeroOrMore", "content": "Wraps self so it may appear zero or more times, using a non-capturing group. Example . import * as MRegExpString from \"@parischap/effect-lib/MRegExpString\" console.log(MRegExpString.zeroOrMore(\"a\")) // '(?:a)*' . Signature . export declare const zeroOrMore: (self: string) =&gt; string . ", "url": "/0.1.0/effect-lib/RegExpString.ts.html#zeroormore", "relUrl": "/effect-lib/RegExpString.ts.html#zeroormore" },"1209": { "doc": "RegExpString.ts", "title": "RegExpString.ts", "content": " ", "url": "/0.1.0/effect-lib/RegExpString.ts.html", "relUrl": "/effect-lib/RegExpString.ts.html" },"1210": { "doc": "Result.ts", "title": "Result overview", "content": "Extension to the Effect Result module providing optional-error recovery, flattening, and lifting into Effect. ", "url": "/0.1.0/effect-lib/Result.ts.html#result-overview", "relUrl": "/effect-lib/Result.ts.html#result-overview" },"1211": { "doc": "Result.ts", "title": "Mental model", "content": ". | Result.Result&lt;A, E&gt; is a synchronous, retry-free Either-like sum type with success A and failure E. | This module focuses on small bridges: collapse a missing-element failure into an Option, flatten nested Result’s, and lift into Effect. | . ", "url": "/0.1.0/effect-lib/Result.ts.html#mental-model", "relUrl": "/effect-lib/Result.ts.html#mental-model" },"1212": { "doc": "Result.ts", "title": "Common tasks", "content": ". | Handle missing elements: {@link optionFromOptional} | Collapse nesting: {@link flatten} | . ", "url": "/0.1.0/effect-lib/Result.ts.html#common-tasks", "relUrl": "/effect-lib/Result.ts.html#common-tasks" },"1213": { "doc": "Result.ts", "title": "Quickstart", "content": "Example (Collapse a NoSuchElementError into an Option) . import { Cause, Result } from \"effect\" import * as MResult from \"@parischap/effect-lib/MResult\" console.log(MResult.optionFromOptional(Result.succeed(1))) // Success(Some(1)) console.log(MResult.optionFromOptional(Result.fail(new Cause.NoSuchElementError()))) // Success(None) . ", "url": "/0.1.0/effect-lib/Result.ts.html#quickstart", "relUrl": "/effect-lib/Result.ts.html#quickstart" },"1214": { "doc": "Result.ts", "title": "Table of contents", "content": ". | Models . | Type (type alias) | . | Utils . | flatten | optionFromOptional | . | . ", "url": "/0.1.0/effect-lib/Result.ts.html", "relUrl": "/effect-lib/Result.ts.html" },"1215": { "doc": "Result.ts", "title": "Models", "content": " ", "url": "/0.1.0/effect-lib/Result.ts.html#models", "relUrl": "/effect-lib/Result.ts.html#models" },"1216": { "doc": "Result.ts", "title": "Type (type alias)", "content": "Type on which this module’s functions operate. Signature . export type Type&lt;A, E = never&gt; = Result.Result&lt;A, E&gt; . ", "url": "/0.1.0/effect-lib/Result.ts.html#type-type-alias", "relUrl": "/effect-lib/Result.ts.html#type-type-alias" },"1217": { "doc": "Result.ts", "title": "Utils", "content": " ", "url": "/0.1.0/effect-lib/Result.ts.html#utils", "relUrl": "/effect-lib/Result.ts.html#utils" },"1218": { "doc": "Result.ts", "title": "flatten", "content": "Flattens a nested Result&lt;Result&lt;R, L1&gt;, L2&gt; into Result&lt;R, L1 | L2&gt;. Signature . export declare const flatten: &lt;R, L1, L2&gt;(self: Type&lt;Type&lt;R, L1&gt;, L2&gt;) =&gt; Type&lt;R, L1 | L2&gt; . ", "url": "/0.1.0/effect-lib/Result.ts.html#flatten", "relUrl": "/effect-lib/Result.ts.html#flatten" },"1219": { "doc": "Result.ts", "title": "optionFromOptional", "content": "Converts a Result&lt;A, E&gt; whose failure channel may include NoSuchElementError into a Result&lt;Option&lt;A&gt;, Exclude&lt;E, NoSuchElementError&gt;&gt;. | A NoSuchElementError failure becomes Result.succeed(Option.none()). | Any other failure is preserved as-is. | A success of A becomes Result.succeed(Option.some(a)). | . Example (Distinguishing absence from real failures) . import { Cause, Result } from \"effect\" import * as MResult from \"@parischap/effect-lib/MResult\" console.log(MResult.optionFromOptional(Result.succeed(1))) // Success(Some(1)) console.log(MResult.optionFromOptional(Result.fail(new Cause.NoSuchElementError()))) // Success(None) console.log(MResult.optionFromOptional(Result.fail(\"boom\"))) // Failure('boom') . Signature . export declare const optionFromOptional: &lt;A, E&gt;( self: Type&lt;A, E&gt; ) =&gt; Type&lt;Option.Option&lt;A&gt;, Exclude&lt;E, Cause.NoSuchElementError&gt;&gt; . ", "url": "/0.1.0/effect-lib/Result.ts.html#optionfromoptional", "relUrl": "/effect-lib/Result.ts.html#optionfromoptional" },"1220": { "doc": "Result.ts", "title": "Result.ts", "content": " ", "url": "/0.1.0/effect-lib/Result.ts.html", "relUrl": "/effect-lib/Result.ts.html" },"1221": { "doc": "Color/RgbColor.ts", "title": "RgbColor overview", "content": "This module defines an RGB color. Use the make function to build custom RGB colors from red, green, and blue components (0-255). ", "url": "/0.1.0/ansi-styles/Color/RgbColor.ts.html#rgbcolor-overview", "relUrl": "/ansi-styles/Color/RgbColor.ts.html#rgbcolor-overview" },"1222": { "doc": "Color/RgbColor.ts", "title": "Table of contents", "content": ". | Constructors . | make | . | Equivalences . | equivalence | . | Instances . | aliceBlue | antiqueWhite | aqua | aquaMarine | azure | beige | bisque | black | blanchedAlmond | blue | blueViolet | brown | burlyWood | cadetBlue | chartreuse | chocolate | coral | cornFlowerBlue | cornSilk | crimson | cyan | darkBlue | darkCyan | darkGoldenRod | darkGray | darkGreen | darkKhaki | darkMagenta | darkOliveGreen | darkOrange | darkOrchid | darkRed | darkSalmon | darkSeaGreen | darkSlateBlue | darkSlateGray | darkTurquoise | darkViolet | deepPink | deepSkyBlue 