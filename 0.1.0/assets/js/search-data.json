ceBasedEqualityData.isEquivalentToSymbol] (method) . Function that implements the equivalence of this and that . Signature . [MEquivalenceBasedEqualityData.isEquivalentToSymbol](this: this, that: this): boolean . [MEquivalenceBasedEqualityData.hasSameTypeMarkerAsSymbol] (method) . Predicate that returns true if that has the same type marker as this . Signature . [MEquivalenceBasedEqualityData.hasSameTypeMarkerAsSymbol](that: unknown): boolean . uniStyledTexts (property) . The text as an array of UniStyled . Signature . readonly uniStyledTexts: readonly ASUnistyledText.Type[] . ", "url": "/0.1.0/ansi-styles/Text.ts.html#type-class", "relUrl": "/ansi-styles/Text.ts.html#type-class" },"1777": { "doc": "Text.ts", "title": "Module markers", "content": " ", "url": "/0.1.0/ansi-styles/Text.ts.html#module-markers", "relUrl": "/ansi-styles/Text.ts.html#module-markers" },"1778": { "doc": "Text.ts", "title": "moduleTag", "content": "Module tag . Signature . export declare const moduleTag: \"@parischap/ansi-styles/Text/\" . ", "url": "/0.1.0/ansi-styles/Text.ts.html#moduletag", "relUrl": "/ansi-styles/Text.ts.html#moduletag" },"1779": { "doc": "Text.ts", "title": "Predicates", "content": " ", "url": "/0.1.0/ansi-styles/Text.ts.html#predicates", "relUrl": "/ansi-styles/Text.ts.html#predicates" },"1780": { "doc": "Text.ts", "title": "isEmpty", "content": "Predicate that returns true if self is empty . Signature . export declare const isEmpty: Predicate.Predicate&lt;Type&gt; . ", "url": "/0.1.0/ansi-styles/Text.ts.html#isempty", "relUrl": "/ansi-styles/Text.ts.html#isempty" },"1781": { "doc": "Text.ts", "title": "isNotEmpty", "content": "Predicate that returns true if self is not empty . Signature . export declare const isNotEmpty: Predicate.Predicate&lt;Type&gt; . ", "url": "/0.1.0/ansi-styles/Text.ts.html#isnotempty", "relUrl": "/ansi-styles/Text.ts.html#isnotempty" },"1782": { "doc": "Text.ts", "title": "Utils", "content": " ", "url": "/0.1.0/ansi-styles/Text.ts.html#utils", "relUrl": "/ansi-styles/Text.ts.html#utils" },"1783": { "doc": "Text.ts", "title": "append", "content": "Builds a new Text by appending that to self . Signature . export declare const append: (that: Type) =&gt; (self: Type) =&gt; Type . ", "url": "/0.1.0/ansi-styles/Text.ts.html#append", "relUrl": "/ansi-styles/Text.ts.html#append" },"1784": { "doc": "Text.ts", "title": "appendIfNotEmpty", "content": "Appends that to self if self is not empty. Returns self otherwise. Signature . export declare const appendIfNotEmpty: (that: Type) =&gt; MTypes.OneArgFunction&lt;Type&gt; . ", "url": "/0.1.0/ansi-styles/Text.ts.html#appendifnotempty", "relUrl": "/ansi-styles/Text.ts.html#appendifnotempty" },"1785": { "doc": "Text.ts", "title": "concat", "content": "Builds a new Text by concatenating all passed Texts or strings . Signature . export declare const concat: (...elems: ReadonlyArray&lt;string | Type&gt;) =&gt; Type . ", "url": "/0.1.0/ansi-styles/Text.ts.html#concat", "relUrl": "/ansi-styles/Text.ts.html#concat" },"1786": { "doc": "Text.ts", "title": "join", "content": "Builds a new Text by joining all passed Texts and adding self as separator in between . Signature . export declare const join: (self: Type) =&gt; (arr: ReadonlyArray&lt;Type&gt;) =&gt; Type . ", "url": "/0.1.0/ansi-styles/Text.ts.html#join", "relUrl": "/ansi-styles/Text.ts.html#join" },"1787": { "doc": "Text.ts", "title": "prepend", "content": "Builds a new Text by prepending that to self . Signature . export declare const prepend: (that: Type) =&gt; (self: Type) =&gt; Type . ", "url": "/0.1.0/ansi-styles/Text.ts.html#prepend", "relUrl": "/ansi-styles/Text.ts.html#prepend" },"1788": { "doc": "Text.ts", "title": "prependIfNotEmpty", "content": "Prepends that to self if self is not empty. Returns self otherwise. Signature . export declare const prependIfNotEmpty: (that: Type) =&gt; MTypes.OneArgFunction&lt;Type&gt; . ", "url": "/0.1.0/ansi-styles/Text.ts.html#prependifnotempty", "relUrl": "/ansi-styles/Text.ts.html#prependifnotempty" },"1789": { "doc": "Text.ts", "title": "removeEmptyAndJoin", "content": "Removes empty Text values from self and joins the remaining Text values using sep. Signature . export declare const removeEmptyAndJoin: (sep: Type) =&gt; MTypes.OneArgFunction&lt;Iterable&lt;Type&gt;, Type&gt; . ", "url": "/0.1.0/ansi-styles/Text.ts.html#removeemptyandjoin", "relUrl": "/ansi-styles/Text.ts.html#removeemptyandjoin" },"1790": { "doc": "Text.ts", "title": "repeat", "content": "Builds a new Text by repeating n times the passed Text. n must be a strictly positive integer. Signature . export declare const repeat: (n: number) =&gt; (self: Type) =&gt; Type . ", "url": "/0.1.0/ansi-styles/Text.ts.html#repeat", "relUrl": "/ansi-styles/Text.ts.html#repeat" },"1791": { "doc": "Text.ts", "title": "surround", "content": "Builds a new Text by prepending startText and appending ‘endText’ to self . Signature . export declare const surround: (prefix: Type, suffix: Type) =&gt; MTypes.OneArgFunction&lt;Type&gt; . ", "url": "/0.1.0/ansi-styles/Text.ts.html#surround", "relUrl": "/ansi-styles/Text.ts.html#surround" },"1792": { "doc": "Text.ts", "title": "surroundIfNotEmpty", "content": "Surrounds self with prefix and suffix if self is not empty. Returns self otherwise. Signature . export declare const surroundIfNotEmpty: (prefix: Type, suffix: Type) =&gt; MTypes.OneArgFunction&lt;Type&gt; . ", "url": "/0.1.0/ansi-styles/Text.ts.html#surroundifnotempty", "relUrl": "/ansi-styles/Text.ts.html#surroundifnotempty" },"1793": { "doc": "Text.ts", "title": "Text.ts", "content": " ", "url": "/0.1.0/ansi-styles/Text.ts.html", "relUrl": "/ansi-styles/Text.ts.html" },"1794": { "doc": "Color/ThreeBitColor.ts", "title": "ThreeBitColor overview", "content": "This module defines ThreeBit colors . ", "url": "/0.1.0/ansi-styles/Color/ThreeBitColor.ts.html#threebitcolor-overview", "relUrl": "/ansi-styles/Color/ThreeBitColor.ts.html#threebitcolor-overview" },"1795": { "doc": "Color/ThreeBitColor.ts"