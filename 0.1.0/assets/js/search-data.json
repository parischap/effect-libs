ignature . export declare const id: MTypes.OneArgFunction&lt;Type, string&gt; . ", "url": "/0.1.0/pretty-print/Parameters/StyleMap.ts.html#id", "relUrl": "/pretty-print/Parameters/StyleMap.ts.html#id" },"1654": { "doc": "Parameters/StyleMap.ts", "title": "styles", "content": "Returns the styles property of self . Signature . export declare const styles: MTypes.OneArgFunction&lt;Type, PPStyles.Type&gt; . ", "url": "/0.1.0/pretty-print/Parameters/StyleMap.ts.html#styles", "relUrl": "/pretty-print/Parameters/StyleMap.ts.html#styles" },"1655": { "doc": "Parameters/StyleMap.ts", "title": "Instances", "content": " ", "url": "/0.1.0/pretty-print/Parameters/StyleMap.ts.html#instances", "relUrl": "/pretty-print/Parameters/StyleMap.ts.html#instances" },"1656": { "doc": "Parameters/StyleMap.ts", "title": "darkMode", "content": "StyleMap instance for ansi dark mode . Signature . export declare const darkMode: Type . ", "url": "/0.1.0/pretty-print/Parameters/StyleMap.ts.html#darkmode", "relUrl": "/pretty-print/Parameters/StyleMap.ts.html#darkmode" },"1657": { "doc": "Parameters/StyleMap.ts", "title": "none", "content": "StyleMap instance that doesn’t apply any formatting (uses the none ASContextStyler of the ansi- styles library for all parts to be formatted) . Signature . export declare const none: Type . ", "url": "/0.1.0/pretty-print/Parameters/StyleMap.ts.html#none", "relUrl": "/pretty-print/Parameters/StyleMap.ts.html#none" },"1658": { "doc": "Parameters/StyleMap.ts", "title": "Models", "content": " ", "url": "/0.1.0/pretty-print/Parameters/StyleMap.ts.html#models", "relUrl": "/pretty-print/Parameters/StyleMap.ts.html#models" },"1659": { "doc": "Parameters/StyleMap.ts", "title": "Type (class)", "content": "Type that represents a PPStyleMap . Signature . export declare class Type { private constructor({ id, styles }: MTypes.Data&lt;Type&gt;) } . make (static method) . Static constructor . Signature . static make(params: MTypes.Data&lt;Type&gt;): Type . [MData.idSymbol] (method) . Returns the id of this . Signature . [MData.idSymbol](): string | (() =&gt; string) . [Hash.symbol] (method) . Calculates the hash value of this . Signature . [Hash.symbol](): number . [MEquivalenceBasedEqualityData.isEquivalentToSymbol] (method) . Function that implements the equivalence of this and that . Signature . [MEquivalenceBasedEqualityData.isEquivalentToSymbol](this: this, that: this): boolean . [MEquivalenceBasedEqualityData.hasSameTypeMarkerAsSymbol] (method) . Predicate that returns true if that has the same type marker as this . Signature . [MEquivalenceBasedEqualityData.hasSameTypeMarkerAsSymbol](that: unknown): boolean . id (property) . Id of this PPStyleMap instance. Useful for equality and debugging. Signature . readonly id: string . styles (property) . Map of Style’s to be applied to the different parts of the value to stringify . Signature . readonly styles: PPStyles.Type . ", "url": "/0.1.0/pretty-print/Parameters/StyleMap.ts.html#type-class", "relUrl": "/pretty-print/Parameters/StyleMap.ts.html#type-class" },"1660": { "doc": "Parameters/StyleMap.ts", "title": "Module markers", "content": " ", "url": "/0.1.0/pretty-print/Parameters/StyleMap.ts.html#module-markers", "relUrl": "/pretty-print/Parameters/StyleMap.ts.html#module-markers" },"1661": { "doc": "Parameters/StyleMap.ts", "title": "moduleTag", "content": "Module tag . Signature . export declare const moduleTag: \"@parischap/pretty-print/Parameters/StyleMap/\" . ", "url": "/0.1.0/pretty-print/Parameters/StyleMap.ts.html#moduletag", "relUrl": "/pretty-print/Parameters/StyleMap.ts.html#moduletag" },"1662": { "doc": "Parameters/StyleMap.ts", "title": "Parameters/StyleMap.ts", "content": " ", "url": "/0.1.0/pretty-print/Parameters/StyleMap.ts.html", "relUrl": "/pretty-print/Parameters/StyleMap.ts.html" },"1663": { "doc": "formatting/template/Template.ts", "title": "Template overview", "content": "This module implements a CVTemplate which is a model of a text that has always the same structure. In such a text, there are immutable and mutable parts. Let’s take the following two texts as an example: . | Text1 = “John is a 47-year-old man.” | Text2 = “Jenny is a 5-year-old girl.” | . These two texts obviously share the same structure which is the template: . “Placeholder1 is a Placeholder2-year-old Placeholder3”. Placeholder1, Placeholder2 and Placeholder3 are the mutable parts of the template. They contain valuable information. We call them CVTemplatePlaceholder’s. ” is a “, “-year-old “ and “.” are the immutable parts of the template. We call them CVTemplateSeparator’s. From a text with the above structure, we can extract the values of Placeholder1, Placeholder2, and Placeholder3. In the present case: . | For text1: { Placeholder1 : ‘John’, Placeholder2 : ‘47’, Placeholder3 : ‘man’ } | For text2: { Placeholder1 : ‘Jenny’, Placeholder2 : ‘5’, Placeholder3 : ‘girl’} | . Extracting the values of placeholders from a text according to a template is called parsing. The result of parsing is an object whose properties are named after the name of the placeholders they represent. Inversely, given a template and the values of the placeholders that compose it (provided as the properties of an object), we can generate a text. This is called formatting. In the present case, with the object: . { Placeholder1 : ‘Tom’, Placeholder2 : ‘15’, Placeholder3 : ‘boy’ } . We will obtain the text: “Tom is a 15-year-old boy.” . Once you have created a CVTemplate, you must feed it to a CVTemplateParser or CVTemplateFormatter. Note that Effect does provide the Schema.TemplateLiteralParser API which partly addresses the same problem. But there are some limitations to that API. For instance, template literal types cannot represent a fixed-length string or a string composed only of capital letters… It is for instance impossible to represent a date in the form YYYYMMDD with the Schema.TemplateLiteralParser. A schema in the form const schema = Schema.TemplateLiteralParser(Schema.NumberFromString,Schema.NumberFromString, Schema.NumberFromString) does not work as the first NumberFromString combinator reads the whole date . ", "url": "/0.1.0/conversions/formatting/template/Template.ts.html#template-overview", "relUrl": "/conversions/formatting/template/Template.ts.html#template-overview" },"1664": { "doc": "formatting/template/Template.ts", "title": "Table of contents", "content": ". | Constructors . | make | . | Getters . | templateParts | . | Models . | Type (class) . | make (static method) | [MData.idSymbol] (method) | syntheticDescription (property) | placeholderDescription (property) | templateParts (property) | . | . | Module markers . | moduleTag | . | . ", "url": "/0.1.0/conversions/formatting/template/Template.ts.html", "relUrl": "/conversions/formatting/template/Template.ts.html" },"1665": { "doc": "formatting/template/Template.ts", "title": "Constructors", "content": " ", "url": "/0.1.0/conversions/formatting/template/Template.ts.html#constructors", "relUrl": "/conversions/formatting/template/Template.ts.html#constructors" },"1666": { "doc": "formatting/template/Template.ts", "title": "make", "content": "Constructor . Signature . export declare const make: &lt;const PS extends CVTemplateParts.Type&gt;( ...templateParts: PS ) =&gt; Type&lt;CVTemplateParts.ToPlaceHolderTypes&lt;PS&gt;&gt; . ", "url": "/0.1.0/conversions/formatting/template/Template.ts.html#make", "relUrl": "/conversions/formatting/template/Template.ts.html#make" },"1667": { "doc": "formatting/template/Template.ts", "title": "Getters", "content": " ", "url": "/0.1.0/conversions/formatting/template/Template.ts.html#getters", "relUrl": "/conversions/formatting/template/Template.ts.html#getters" },"1668": { "doc": "formatting/template/Template.ts", "title": "templateParts", "content": "Returns the templateParts property of self . Signature . export declare const templateParts: &lt;PlaceholderTypes extends MTypes.Object&gt;( self: Type&lt;PlaceholderTypes&gt; ) =&gt; CVTemplateParts.Type . ", "url": "/0.1.0/conversions/formatting/template/Template.ts.html#templateparts", "relUrl": "/conversions/formatting/template/Template.ts.html#templateparts" },"1669": { "doc": "formatting/template/Template.ts", "title": "Models", "content": " ", "url": "/0.1.0/conversions/formatting/template/Template.ts.html#models", "relUrl": "/conversions/formatting/template/Template.ts.html#models" },"1670": { "doc": "formatting/template/Template.ts", "title": "Type (class)", "content": "Type that represents a CVTemplate . Signature . export declare class Type&lt;PlaceholderTypes&gt; { private constructor({ syntheticDescription, placeholderDescription, templateParts }: MTypes.Data&lt;Type&lt;PlaceholderTypes&gt;&gt;) } . make (static method) . Static constructor . Signature . static make&lt;const PS extends CVTemplateParts.Type&gt;( templateParts: PS, ): Type&lt;CVTemplateParts.ToPlaceHolderTypes&lt;PS&gt;&gt; . [MData.idSymbol] (method) . Returns the id of this . Signature . [MData.idSymbol](): string | (() =&gt; string) . syntheticDescription (property) . Synthetic description of self . Signature . readonly syntheticDescription: string . placeholderDescription (property) . Placeholder description of self . Signature . readonly placeholderDescription: string . templateParts (property) . Array of the TemplatePart’s composing this template . Signature . readonly templateParts: CVTemplateParts.Type . ", "url": "/0.1.0/conversions/formatting/template/Template.ts.html#type-class", "relUrl": "/conversions/formatting/template/Template.ts.html#type-class" },"1671": { "doc": "formatting/template/Template.ts", "title": "Module markers", "content": " ", "url": "/0.1.0/conversions/formatting/template/Template.ts.html#module-markers", "relUrl": "/conversions/formatting/template/Template.ts.html#module-markers" },"1672": { "doc": "formatting/template/Template.ts", "title": "moduleTag", "content": "Module tag . Signature . export declare const moduleTag: \"@parischap/conversions/formatting/template/\" . ", "url": "/0.1.0/conversions/formatting/template/Template.ts.html#moduletag", "relUrl": "/conversions/formatting/template/Template.ts.html#moduletag" },"1673": { "doc": "formatting/template/Template.ts", "title": "formatting/template/Template.ts", "content": " ", "url": "/0.1.0/conversions/formatting/template/Template.ts.html", "relUrl": "/conversions/formatting/template/Template.ts.html" },"1674": { "doc": "formatting/template/TemplateFormatter.ts", "title": "TemplateFormatter overview", "content": "This module implements a CVTemplateFormatter, i.e. an object that is capable of converting a a record of values to a string according to the CVTemplate that was used to construct it. If you don’t want to build a CVTemplate beforehand, you can also construct a CVTemplateFormatter directly from CVTemplatePart’s . ", "url": "/0.1.0/conversions/formatting/template/TemplateFormatter.ts.html#templateformatter-overview", "relUrl": "/conversions/formatting/template/TemplateFormatter.ts.html#templateformatter-overview" },"1675": { "doc": "formatting/template/TemplateFormatter.ts", "title": "Table of contents", "content": ". | Constructors . | { fromTemplate } | { fromTemplateParts } | . | Getters . | format | formatOrThrow | . | Models . | Type (class) . | make (static method) | fromTemplate (static method) | fromTemplateParts (static method) | [MData.idSymbol] (method) | description (property) | format (property) | formatOrThrow (property) | . | . | Module markers . | moduleTag | . | . ", "url": "/0.1.0/conversions/formatting/template/TemplateFormatter.ts.html", "relUrl": "/conversions/formatting/template/TemplateFormatter.ts.html" },"1676": { "doc": "formatting/template/TemplateFormatter.ts", "title": "Constructors", "content": " ", "url": "/0.1.0/conversions/formatting/template/TemplateFormatter.ts.html#constructors", "relUrl": "/conversions/formatting/template/TemplateFormatter.ts.html#constructors" },"1677": { "doc": "formatting/template/TemplateFormatter.ts", "title": "{ fromTemplate }", "content": "Constructor of a CVTemplateFormatter from a CVTemplate . Signature . export declare const { fromTemplate }: any . ", "url": "/0.1.0/conversions/formatting/template/TemplateFormatter.ts.html#-fromtemplate-", "relUrl": "/conversions/formatting/template/TemplateFormatter.ts.html#-fromtemplate-" },"1678": { "doc": "formatting/template/TemplateFormatter.ts", "title": "{ fromTemplateParts }", "content": "Constructor of a CVTemplateFormatter directly from CVTemplateParts . Signature . export declare const { fromTemplateParts }: any . ", "url": "/0.1.0/conversions/formatting/template/TemplateFormatter.ts.html#-fromtemplateparts-", "relUrl": "/conversions/formatting/template/TemplateFormatter.ts.html#-fromtemplateparts-" },"1679": { "doc": "formatting/template/TemplateFormatter.ts", "title": "Getters", "content": " ", "url": "/0.1.0/conversions/formatting/template/TemplateFormatter.ts.html#getters", "relUrl": "/conversions/formatting/template/TemplateFormatter.ts.html#getters" },"1680": { "doc": "formatting/template/TemplateFormatter.ts", "title": "format", "content": "Returns the format property of self. Signature . export declare const format: &lt;PlaceholderTypes extends MTypes.Object&gt;( self: Type&lt;PlaceholderTypes&gt; ) =&gt; Type&lt;PlaceholderTypes&gt;[\"format\"] . ", "url": "/0.1.0/conversions/formatting/template/TemplateFormatter.ts.html#format", "relUrl": "/conversions/formatting/template/TemplateFormatter.ts.html#format" },"1681": { "doc": "formatting/template/TemplateFormatter.ts", "title": "formatOrThrow", "content": "Returns the formatOrThrow property of self. Signature . export declare const formatOrThrow: &lt;PlaceholderTypes extends MTypes.Object&gt;( self: Type&lt;PlaceholderTypes&gt; ) =&gt; Type&lt;PlaceholderTypes&gt;[\"formatOrThrow\"] . ", "url": "/0.1.0/conversions/formatting/template/TemplateFormatter.ts.html#formatorthrow", "relUrl": "/conversions/formatting/template/TemplateFormatter.ts.html#formatorthrow" },"1682": { "doc": "formatting/template/TemplateFormatter.ts", "title": "Models", "content": " ", "url": "/0.1.0/conversions/formatting/template/TemplateFormatter.ts.html#models", "relUrl": "/conversions/formatting/template/TemplateFormatter.ts.html#models" },"1683": { "doc": "formatting/template/TemplateFormatter.ts", "title": "Type (class)", "content": "Type that represents a CVTemplateFormatter . Signature . export declare class Type&lt;PlaceholderTypes&gt; { private constructor({ description, format, formatOrThrow }: MTypes.Data&lt;Type&lt;PlaceholderTypes&gt;&gt;) } . make (static method) . Class constructor . Signature . private static make({ syntheticDescription, placeholderDescription, templateParts, }: { readonly syntheticDescription: string; readonly placeholderDescription: string; readonly templateParts: CVTemplateParts.Type; }): Type&lt;any&gt; . fromTemplate (static method) . Constructor of a CVTemplateFormatter from a CVTemplate . Signature . static fromTemplate&lt;PlaceholderTypes extends MTypes.Object&gt;( this: void, template: CVTemplate.Type&lt;PlaceholderTypes&gt;, ): Type&lt;PlaceholderTypes&gt; . fromTemplateParts (static method) . Constructor of a CVTemplateFormatter directly from CVTemplateParts . Signature . static fromTemplateParts&lt;const PS extends CVTemplateParts.Type&gt;( this: void, ...templateParts: PS ): Type&lt;CVTemplateParts.ToPlaceHolderTypes&lt;PS&gt;&gt; . [MData.idSymbol] (method) . Returns the id of this . Signature . [MData.idSymbol](): string | (() =&gt; string) . description (property) . Description of this CVTemplateFormatter . Signature . readonly description: string . format (property) . Function that tries to format a record according to the template passed to build this formatter . Signature . readonly format: MTypes.OneArgFunction&lt;PlaceholderTypes, Result.Result&lt;string, MInputError.Type&gt;&gt; . formatOrThrow (property) . Same as format but throws in case of failure . Signature . readonly formatOrThrow: MTypes.OneArgFunction&lt;PlaceholderTypes, string&gt; . ", "url": "/0.1.0/conversions/formatting/template/TemplateFormatter.ts.html#type-class", "relUrl": "/conversions/formatting/template/TemplateFormatter.ts.html#type-class" },"1684": { "doc": "formatting/template/TemplateFormatter.ts", "title": "Module markers", "content": " ", "url": "/0.1.0/conversions/formatting/template/TemplateFormatter.ts.html#module-markers", "relUrl": "/conversions/formatting/template/TemplateFormatter.ts.html#module-markers" },"1685": { "doc": "formatting/template/TemplateFormatter.ts", "title": "moduleTag", "content": "Module tag . Signature . export declare const moduleTag: \"@parischap/conversions/formatting/template/TemplateFormatter/\" . ", "url": "/0.1.0/conversions/formatting/template/TemplateFormatter.ts.html#moduletag", "relUrl": "/conversions/formatting/template/TemplateFormatter.ts.html#moduletag" },"1686": { "doc": "formatting/template/TemplateFormatter.ts", "title": "formatting/template/TemplateFormatter.ts", "content": " ", "url": "/0.1.0/conversions/formatting/template/TemplateFormatter.ts.html", "relUrl": "/conversions/formatting/template/TemplateFormatter.ts.html" },"1687": { "doc": "formatting/template/TemplateParser.ts", "title": "TemplateParser overview", "content": "This module implements a CVTemplateParser, i.e. an object that is capable of converting a string to a record of values according to the CVTemplate that was used to construct it. If you don’t want to build a CVTemplate beforehand, you can also construct a CVTemplateParser directly from CVTemplatePart’s . ", "url": "/0.1.0/conversions/formatting/template/TemplateParser.ts.html#templateparser-overview", "relUrl": "/conversions/formatting/template/TemplateParser.ts.html#templateparser-overview" },"1688": { "doc": "formatting/template/TemplateParser.ts", "title": "Table of contents", "content": ". | Constructors . | fromTemplate | fromTemplateParts | . | Models . | Type (class) . | make (static method) | fromTemplate (static method) | fromTemplateParts (static method) | [MData.idSymbol] (method) | description (property) | parse (property) | parseOrThrow (property) | . | . | Module markers . | moduleTag | . | Parsing . | parse | parseOrThrow | . | . ", "url": "/0.1.0/conversions/formatting/template/TemplateParser.ts.html", "relUrl": "/conversions/formatting/template/TemplateParser.ts.html" },"1689": { "doc": "formatting/template/TemplateParser.ts", "title": "Constructors", "content": " ", "url": "/0.1.0/conversions/formatting/template/TemplateParser.ts.html#constructors", "relUrl": "/conversions/formatting/template/TemplateParser.ts.html#constructors" },"1690": { "doc": "formatting/template/TemplateParser.ts", "title": "fromTemplate", "content": "Constructor of a CVTemplateParser from a CVTemplate . Signature . export declare const fromTemplate: typeof Type.fromTemplate . ", "url": "/0.1.0/conversions/formatting/template/TemplateParser.ts.html#fromtemplate", "relUrl": "/conversions/formatting/template/TemplateParser.ts.html#fromtemplate" },"1691": { "doc": "formatting/template/TemplateParser.ts", "title": "fromTemplateParts", "content": "Constructor of a CVTemplateParser directly from CVTemplateParts . Signature . export declare const fromTemplateParts: typeof Type.fromTemplateParts . ", "url": "/0.1.0/conversions/formatting/template/TemplateParser.ts.html#fromtemplateparts", "relUrl": "/conversions/formatting/template/TemplateParser.ts.html#fromtemplateparts" },"1692": { "doc": "formatting/template/TemplateParser.ts", "title": "Models", "content": " ", "url": "/0.1.0/conversions/formatting/template/TemplateParser.ts.html#models", "relUrl": "/conversions/formatting/template/TemplateParser.ts.html#models" },"1693": { "doc": "formatting/template/TemplateParser.ts", "title": "Type (class)", "content": "Type that represents a CVTemplateParser . Signature . export declare class Type&lt;PlaceholderTypes&gt; { private constructor({ description, parse, parseOrThrow }: MTypes.Data&lt;Type&lt;PlaceholderTypes&gt;&gt;) } . make (static method) . Class constructor . Signature . private static make({ syntheticDescription, placeholderDescription, templateParts, }: { readonly syntheticDescription: string; readonly placeholderDescription: string; readonly templateParts: CVTemplateParts.Type; }): Type&lt;never&gt; . fromTemplate (static method) . Constructor of a CVTemplateParser from a template . Signature . static fromTemplate&lt;PlaceholderTypes extends MTypes.Object&gt;( template: CVTemplate.Type&lt;PlaceholderTypes&gt;, ): Type&lt;PlaceholderTypes&gt; . fromTemplateParts (static method) . Constructor of a CVTemplateParser directly from CVTemplateParts . Signature . static fromTemplateParts&lt;const PS extends CVTemplateParts.Type&gt;( ...templateParts: PS ): Type&lt;CVTemplateParts.ToPlaceHolderTypes&lt;PS&gt;&gt; . [MData.idSymbol] (method) . Returns the id of this . Signature . [MData.idSymbol](): string | (() =&gt; string) . description (property) . Description of this CVTemplateParser . Signature . readonly description: string . parse (property) . Function that tries to parse a text according to the template passed to build this parser . Signature . readonly parse: MTypes.OneArgFunction&lt;string, Result.Result&lt;PlaceholderTypes, MInputError.Type&gt;&gt; . parseOrThrow (property) . Same as parse but throws in case of failure . Signature . readonly parseOrThrow: MTypes.OneArgFunction&lt;string, PlaceholderTypes&gt; . ", "url": "/0.1.0/conversions/formatting/template/TemplateParser.ts.html#type-class", "relUrl": "/conversions/formatting/template/TemplateParser.ts.html#type-class" },"1694": { "doc": "formatting/template/TemplateParser.ts", "title": "Module markers", "content": " ", "url": "/0.1.0/conversions/formatting/template/TemplateParser.ts.html#module-markers", "relUrl": "/conversions/formatting/template/TemplateParser.ts.html#module-markers" },"1695": { "doc": "formatting/template/TemplateParser.ts", "title": "moduleTag", "content": "Module tag . Signature . export declare const moduleTag: \"@parischap/conversions/formatting/template/TemplateParser/\" . ", "url": "/0.1.0/conversions/formatting/template/TemplateParser.ts.html#moduletag", "relUrl": "/conversions/formatting/template/TemplateParser.ts.html#moduletag" },"1696": { "doc": "formatting/template/TemplateParser.ts", "title": "Parsing", "content": " ", "url": "/0.1.0/conversions/formatting/template/TemplateParser.ts.html#parsing", "relUrl": "/conversions/formatting/template/TemplateParser.ts.html#parsing" },"1697": { "doc": "formatting/template/TemplateParser.ts", "title": "parse", "content": "Returns the parser property of self. Signature . export declare const parse: &lt;PlaceholderTypes extends MTypes.Object&gt;( self: Type&lt;PlaceholderTypes&gt; ) =&gt; Type&lt;PlaceholderTypes&gt;[\"parse\"] . ", "url": "/0.1.0/conversions/formatting/template/TemplateParser.ts.html#parse", "relUrl": "/conversions/formatting/template/TemplateParser.ts.html#parse" },"1698": { "doc": "formatting/template/TemplateParser.ts", "title": "parseOrThrow", "content": "Returns the parseOrThrow property of self. Signature . export declare const parseOrThrow: &lt;PlaceholderTypes extends MTypes.Object&gt;( self: Type&lt;PlaceholderTypes&gt; ) =&gt; Type&lt;PlaceholderTypes&gt;[\"parseOrThrow\"] . ", "url": "/0.1.0/conversions/formatting/template/TemplateParser.ts.html#parseorthrow", "relUrl": "/conversions/formatting/template/TemplateParser.ts.html#parseorthrow" },"1699": { "doc": "formatting/template/TemplateParser.ts", "title": "formatting/template/TemplateParser.ts", "content": " ", "url": "/0.1.0/conversions/formatting/template/TemplateParser.ts.html", "relUrl": "/conversions/formatting/template/TemplateParser.ts.html" },"1700": { "doc": "formatting/template/TemplatePart/TemplatePart.ts", "title": "TemplatePart overview", "content": "This module implements a CVTemplatePart which is the constituent of CVTemplate (see Template.ts). There are two kinds of CVTemplatePart’s: CVTemplateSeparator’s (see TemplateSeparator.ts) and CVTemplatePlaceholder’s (see TemplatePlaceholder.ts) . ", "url": "/0.1.0/conversions/formatting/template/TemplatePart/TemplatePart.ts.html#templatepart-overview", "relUrl": "/conversions/formatting/template/TemplatePart/TemplatePart.ts.html#templatepart-overview" },"1701": { "doc": "formatting/template/TemplatePart/TemplatePart.ts", "title": "Table of contents", "content": ". | Guards . | isPlaceholder | isSeparator | . | Models . | Type (type alias) | . | . ", "url": "/0.1.0/conversions/formatting/template/TemplatePart/TemplatePart.ts.html", "relUrl": "/conversions/formatting/template/TemplatePart/TemplatePart.ts.html" },"1702": { "doc": "formatting/template/TemplatePart/TemplatePart.ts", "title": "Guards", "content": " ", "url": "/0.1.0/conversions/formatting/template/TemplatePart/TemplatePart.ts.html#guards", "relUrl": "/conversions/formatting/template/TemplatePart/TemplatePart.ts.html#guards" },"1703": { "doc": "formatting/template/TemplatePart/TemplatePart.ts", "title": "isPlaceholder", "content": "Type guard . Signature . export declare const isPlaceholder: &lt;const N extends string, T&gt;(u: Type&lt;N, T&gt;) =&gt; u is CVTemplatePlaceholder.Type&lt;N, T&gt; . ", "url": "/0.1.0/conversions/formatting/template/TemplatePart/TemplatePart.ts.html#isplaceholder", "relUrl": "/conversions/formatting/template/TemplatePart/TemplatePart.ts.html#isplaceholder" },"1704": { "doc": "formatting/template/TemplatePart/TemplatePart.ts", "title": "isSeparator", "content": "Type guard . Signature . export declare const isSeparator: &lt;const N extends string, T&gt;(u: Type&lt;N, T&gt;) =&gt; u is CVTemplateSeparator.Type . ", "url": "/0.1.0/conversions/formatting/template/TemplatePart/TemplatePart.ts.html#isseparator", "relUrl": "/conversions/formatting/template/TemplatePart/TemplatePart.ts.html#isseparator" },"1705": { "doc": "formatting/template/TemplatePart/TemplatePart.ts", "title": "Models", "content": " ", "url": "/0.1.0/conversions/formatting/template/TemplatePart/TemplatePart.ts.html#models", "relUrl": "/conversions/formatting/template/TemplatePart/TemplatePart.ts.html#models" },"1706": { "doc": "formatting/template/TemplatePart/TemplatePart.ts", "title": "Type (type alias)", "content": "Type of a TemplatePart . Signature . export type Type&lt;N extends string, T&gt; = CVTemplateSeparator.Type | CVTemplatePlaceholder.Type&lt;N, T&gt; . ", "url": "/0.1.0/conversions/formatting/template/TemplatePart/TemplatePart.ts.html#type-type-alias", "relUrl": "/conversions/formatting/template/TemplatePart/TemplatePart.ts.html#type-type-alias" },"1707": { "doc": "formatting/template/TemplatePart/TemplatePart.ts", "title": "formatting/template/TemplatePart/TemplatePart.ts", "content": " ", "url": "/0.1.0/conversions/formatting/template/TemplatePart/TemplatePart.ts.html", "relUrl": "/conversions/formatting/template/TemplatePart/TemplatePart.ts.html" },"1708": { "doc": "formatting/template/TemplatePart/TemplatePlaceholder/TemplatePlaceholder.ts", "title": "TemplatePlaceholder overview", "content": "This module implements a CVTemplatePlaceholder which constitutes the mutable parts of a CVTemplate (see Template.ts and TemplatePart.ts) . Each CVTemplatePlaceholder defines a parser and a formatter: . | The parser takes a text, consumes a part of that text, optionally converts the consumed part to a value of type T and, if successful, returns a success of that value and of what has not been consumed. In case of failure, it returns a failure. | The formatter takes a value of type T, converts it to a string (if T is not string), checks that the result is coherent and, if so, returns a success of that string. Otherwise, it returns a failure | . ", "url": "/0.1.0/conversions/formatting/template/TemplatePart/TemplatePlaceholder/TemplatePlaceholder.ts.html#templateplaceholder-overview", "relUrl": "/conversions/formatting/template/TemplatePart/TemplatePlaceholder/TemplatePlaceholder.ts.html#templateplaceholder-overview" },"1709": { "doc": "formatting/template/TemplatePart/TemplatePlaceholder/TemplatePlaceholder.ts", "title": "Table of contents", "content": ". | Constructors . | anythingBut | fixedLength | fulfilling | make | mappedLiterals | number | numberMappedLiterals | paddedFixedLength | toEnd | . | Destructors . | getLabelledDescription | modify | . | Getters . | description | formatter | label | name | parser | tSchemaInstance | . | Models . | Any (interface) | Type (class) . | make (static method) | [MData.idSymbol] (method) | name (property) | label (property) | description (property) | parser (property) | formatter (property) | tSchemaInstance (property) | . | . | Module markers . | moduleTag | . | Utility types . | ExtractName (type alias) | ExtractType (type alias) | . | . ", "url": "/0.1.0/conversions/formatting/template/TemplatePart/TemplatePlaceholder/TemplatePlaceholder.ts.html", "relUrl": "/conversions/formatting/template/TemplatePart/TemplatePlaceholder/TemplatePlaceholder.ts.html" },"1710": { "doc": "formatting/template/TemplatePart/TemplatePlaceholder/TemplatePlaceholder.ts", "title": "Constructors", "content": " ", "url": "/0.1.0/conversions/formatting/template/TemplatePart/TemplatePlaceholder/TemplatePlaceholder.ts.html#constructors", "relUrl": "/conversions/formatting/template/TemplatePart/TemplatePlaceholder/TemplatePlaceholder.ts.html#constructors" },"1711": { "doc": "formatting/template/TemplatePart/TemplatePlaceholder/TemplatePlaceholder.ts", "title": "anythingBut", "content": "This CVTemplatePlaceholder instance is a special case of the fulfilling CVTemplatePlaceholder instance. The parser of this Placeholder reads from the text until it meets one of the forbiddenChars passed as parameter (the result must be a non-empty string). The formatter only accepts a non-empty string that does not contain any of the forbidden chars and write it to the text. forbiddenChars should be an array of 1-character strings (will not throw otherwise but strange behaviors can be expected) . Signature . export declare const anythingBut: &lt;const N extends string&gt;({ name, forbiddenChars }: { readonly name: N readonly forbiddenChars: MTypes.OverOne&lt;string&gt; }) =&gt; Type&lt;N, string&gt; . ", "url": "/0.1.0/conversions/formatting/template/TemplatePart/TemplatePlaceholder/TemplatePlaceholder.ts.html#anythingbut", "relUrl": "/conversions/formatting/template/TemplatePart/TemplatePlaceholder/TemplatePlaceholder.ts.html#anythingbut" },"1712": { "doc": "formatting/template/TemplatePart/TemplatePlaceholder/TemplatePlaceholder.ts", "title": "fixedLength", "content": "Builds a CVTemplatePlaceholder instance that parses/formats exactly length characters from a string. length must be a strictly positive integer. Signature . export declare const fixedLength: &lt;const N extends string&gt;({ name, length }: { readonly name: N readonly length: number }) =&gt; Type&lt;N, string&gt; . ", "url": "/0.1.0/conversions/formatting/template/TemplatePart/TemplatePlaceholder/TemplatePlaceholder.ts.html#fixedlength", "relUrl": "/conversions/formatting/template/TemplatePart/TemplatePlaceholder/TemplatePlaceholder.ts.html#fixedlength" },"1713": { "doc": "formatting/template/TemplatePart/TemplatePlaceholder/TemplatePlaceholder.ts", "title": "fulfilling", "content": "Builds a CVTemplatePlaceholder whose parser reads as much of the text as it can that fulfills the passed regular expression. The formatter only accepts a string that matches the passed regular expression and writes it into the text. regExp must start with the ^ character. Otherwise, the parser and formatter will not work properly. Signature . export declare const fulfilling: &lt;const N extends string&gt;({ name, regExp, regExpDescriptor }: { readonly name: N readonly regExp: RegExp readonly regExpDescriptor: string }) =&gt; Type&lt;N, string&gt; . ", "url": "/0.1.0/conversions/formatting/template/TemplatePart/TemplatePlaceholder/TemplatePlaceholder.ts.html#fulfilling", "relUrl": "/conversions/formatting/template/TemplatePart/TemplatePlaceholder/TemplatePlaceholder.ts.html#fulfilling" },"1714": { "doc": "formatting/template/TemplatePart/TemplatePlaceholder/TemplatePlaceholder.ts", "title": "make", "content": "Constructor . Signature . export declare const make: &lt;const N extends string, T&gt;(params: Omit&lt;MTypes.Data&lt;Type&lt;N, T&gt;&gt;, \"label\"&gt;) =&gt; Type&lt;N, T&gt; . ", "url": "/0.1.0/conversions/formatting/template/TemplatePart/TemplatePlaceholder/TemplatePlaceholder.ts.html#make", "relUrl": "/conversions/formatting/template/TemplatePart/TemplatePlaceholder/TemplatePlaceholder.ts.html#make" },"1715": { "doc": "formatting/template/TemplatePart/TemplatePlaceholder/TemplatePlaceholder.ts", "title": "mappedLiterals", "content": "Builds a CVTemplatePlaceholder instance that works as a map: . The parser expects one of the keys of keyValuePairs and will return the associated value. The formatter expects one of the values of keyValuePairs and will return the associated key. keyValuePairs should define a bijection (each key and each value must be present only once). It is best if the type of the values defines a toString method. Value equality is checked with The Effect Equal.equals function. schemaInstance is a Schema instance that transforms a value of type T into a value of type T. It is an optional parameter. You need only provide it if you intend to use a CVTemplate built from this CVTemplatePlaceholder within the Effect.Schema module. In that case, you can build such a Schema with the Schema.declare function (if you don’t provide it, the Schema will return an error) . Signature . export declare const mappedLiterals: &lt;const N extends string, T&gt;({ name, keyValuePairs, schemaInstance }: { readonly name: N readonly keyValuePairs: ReadonlyArray&lt;readonly [string, T]&gt; readonly schemaInstance?: Schema.Codec&lt;T&gt; }) =&gt; Type&lt;N, T&gt; . ", "url": "/0.1.0/conversions/formatting/template/TemplatePart/TemplatePlaceholder/TemplatePlaceholder.ts.html#mappedliterals", "relUrl": "/conversions/formatting/template/TemplatePart/TemplatePlaceholder/TemplatePlaceholder.ts.html#mappedliterals" },"1716": { "doc": "formatting/template/TemplatePart/TemplatePlaceholder/TemplatePlaceholder.ts", "title": "number", "content": "CVTemplatePlaceholder instance that tries to parse/format a number according to the passed numberBase10Format. Parsing: if numberBase10Format represents a base-10 number format with a fixed length of l (see CVTemplatePlaceholder.getFixedLength), the parser first reads l characters from the text and tries to convert them to a number in the given format. Otherwise it reads from the text all the characters that it can interpret as a number in the provided numberBase10Format and converts the consumed text into a number. Formatting: the number is converted to a string according to numberBase10Format. If numberBase10Format represents a base-10 number format with a fixed length of l, the formatter will fail if the result of the conversion is not exactly l-characters long. Otherwise, the formatter never fails. Signature . export declare const number: &lt;const N extends string&gt;({ name, numberBase10Format }: { readonly name: N readonly numberBase10Format: CVNumberBase10Format.Type }) =&gt; Type&lt;N, number&gt; . ", "url": "/0.1.0/conversions/formatting/template/TemplatePart/TemplatePlaceholder/TemplatePlaceholder.ts.html#number", "relUrl": "/conversions/formatting/template/TemplatePart/TemplatePlaceholder/TemplatePlaceholder.ts.html#number" },"1717": { "doc": "formatting/template/TemplatePart/TemplatePlaceholder/TemplatePlaceholder.ts", "title": "numberMappedLiterals", "content": "Same as mappedLiterals but T is assumed to be number which should be the most usual use case . Signature . export declare const numberMappedLiterals: &lt;const N extends string&gt;(params: { readonly name: N readonly keyValuePairs: ReadonlyArray&lt;readonly [string, number]&gt; }) =&gt; Type&lt;N, number&gt; . ", "url": "/0.1.0/conversions/formatting/template/TemplatePart/TemplatePlaceholder/TemplatePlaceholder.ts.html#numbermappedliterals", "relUrl": "/conversions/formatting/template/TemplatePart/TemplatePlaceholder/TemplatePlaceholder.ts.html#numbermappedliterals" },"1718": { "doc": "formatting/template/TemplatePart/TemplatePlaceholder/TemplatePlaceholder.ts", "title": "paddedFixedLength", "content": "Same as fixedLength but the consumed text is trimmed off of a fillChar at fillPosition and the written text is padded with a fillChar at fillPosition. fillChar should be a one- character string. length should be a strictly positive integer . Signature . export declare const paddedFixedLength: &lt;const N extends string&gt;(params: { readonly name: N readonly length: number readonly fillChar: string readonly fillPosition: MStringFillPosition.Type }) =&gt; Type&lt;N, string&gt; . ", "url": "/0.1.0/conversions/formatting/template/TemplatePart/TemplatePlaceholder/TemplatePlaceholder.ts.html#paddedfixedlength", "relUrl": "/conversions/formatting/template/TemplatePart/TemplatePlaceholder/TemplatePlaceholder.ts.html#paddedfixedlength" },"1719": { "doc": "formatting/template/TemplatePart/TemplatePlaceholder/TemplatePlaceholder.ts", "title": "toEnd", "content": "This CVTemplatePlaceholder instance is another special case of the fulfilling CVTemplatePlaceholder instance. The parser of this CVTemplatePlaceholder reads all the remaining text. The formatter accepts any string and writes it. This CVTemplatePlaceholder should only be used as the last CVTemplatePart of a CVTemplate. Signature . export declare const toEnd: &lt;const N extends string&gt;(name: N) =&gt; Type&lt;N, string&gt; . ", "url": "/0.1.0/conversions/formatting/template/TemplatePart/TemplatePlaceholder/TemplatePlaceholder.ts.html#toend", "relUrl": "/conversions/formatting/template/TemplatePart/TemplatePlaceholder/TemplatePlaceholder.ts.html#toend" },"1720": { "doc": "formatting/template/TemplatePart/TemplatePlaceholder/TemplatePlaceholder.ts", "title": "Destructors", "content": " ", "url": "/0.1.0/conversions/formatting/template/TemplatePart/TemplatePlaceholder/TemplatePlaceholder.ts.html#destructors", "relUrl": "/conversions/formatting/template/TemplatePart/TemplatePlaceholder/TemplatePlaceholder.ts.html#destructors" },"1721": { "doc": "formatting/template/TemplatePart/TemplatePlaceholder/TemplatePlaceholder.ts", "title": "getLabelledDescription", "content": "Returns a description of self, e.g. “#dd: 2-character string left-padded with ‘0’ to unsigned integer.” . Signature . export declare const getLabelledDescription: (self: Any) =&gt; string . ", "url": "/0.1.0/conversions/formatting/template/TemplatePart/TemplatePlaceholder/TemplatePlaceholder.ts.html#getlabelleddescription", "relUrl": "/conversions/formatting/template/TemplatePart/TemplatePlaceholder/TemplatePlaceholder.ts.html#getlabelleddescription" },"1722": { "doc": "formatting/template/TemplatePart/TemplatePlaceholder/TemplatePlaceholder.ts", "title": "modify", "content": "Returns a copy of self where a postParser function is executed after the parser of self and a preFormatter function is executed before the formatter of self. Exists in two versions: a version where the postParser and preFormatter use the same type as the original parser and formatter. And a version where a conversion to another type T1 is implemented. Signature . export declare const modify: { &lt;T&gt;({ descriptorMapper, postParser, preFormatter }: { readonly descriptorMapper: MTypes.OneArgFunction&lt;string&gt; readonly postParser: MTypes.OneArgFunction&lt;T, Result.Result&lt;T, MInputError.Type&gt;&gt; readonly preFormatter: MTypes.OneArgFunction&lt;T, Result.Result&lt;T, MInputError.Type&gt;&gt; }): &lt;const N extends string&gt;(self: Type&lt;N, T&gt;) =&gt; Type&lt;N, T&gt; &lt;T, T1&gt;({ descriptorMapper, postParser, preFormatter, t1SchemaInstance }: { readonly descriptorMapper: MTypes.OneArgFunction&lt;string&gt; readonly postParser: MTypes.OneArgFunction&lt;T, Result.Result&lt;T1, MInputError.Type&gt;&gt; readonly preFormatter: MTypes.OneArgFunction&lt;T1, Result.Result&lt;T, MInputError.Type&gt;&gt; readonly t1SchemaInstance: Schema.Codec&lt;T1, T1&gt; }): &lt;const N extends string&gt;(self: Type&lt;N, T&gt;) =&gt; Type&lt;N, T1&gt; } . ", "url": "/0.1.0/conversions/formatting/template/TemplatePart/TemplatePlaceholder/TemplatePlaceholder.ts.html#modify", "relUrl": "/conversions/formatting/template/TemplatePart/TemplatePlaceholder/TemplatePlaceholder.ts.html#modify" },"1723": { "doc": "formatting/template/TemplatePart/TemplatePlaceholder/TemplatePlaceholder.ts", "title": "Getters", "content": " ", "url": "/0.1.0/conversions/formatting/template/TemplatePart/TemplatePlaceholder/TemplatePlaceholder.ts.html#getters", "relUrl": "/conversions/formatting/template/TemplatePart/TemplatePlaceholder/TemplatePlaceholder.ts.html#getters" },"1724": { "doc": "formatting/template/TemplatePart/TemplatePlaceholder/TemplatePlaceholder.ts", "title": "description", "content": "Returns the description property of self . Signature . export declare const description: (self: Any) =&gt; string . ", "url": "/0.1.0/conversions/formatting/template/TemplatePart/TemplatePlaceholder/TemplatePlaceholder.ts.html#description", "relUrl": "/conversions/formatting/template/TemplatePart/TemplatePlaceholder/TemplatePlaceholder.ts.html#description" },"1725": { "doc": "formatting/template/TemplatePart/TemplatePlaceholder/TemplatePlaceholder.ts", "title": "formatter", "content": "Returns the formatter property of self . Signature . export declare const formatter: &lt;const N extends string, T&gt;(self: Type&lt;N, T&gt;) =&gt; TemplatePlaceholderFormatter&lt;N, T&gt; . ", "url": "/0.1.0/conversions/formatting/template/TemplatePart/TemplatePlaceholder/TemplatePlaceholder.ts.html#formatter", "relUrl": "/conversions/formatting/template/TemplatePart/TemplatePlaceholder/TemplatePlaceholder.ts.html#formatter" },"1726": { 