 "doc": "Color/ThreeBitColor.ts", "title": "brightYellow", "content": "Original Bright Yellow color instance . Signature . export declare const brightYellow: Type . ", "url": "/0.1.0/ansi-styles/Color/ThreeBitColor.ts.html#brightyellow", "relUrl": "/ansi-styles/Color/ThreeBitColor.ts.html#brightyellow" },"1815": { "doc": "Color/ThreeBitColor.ts", "title": "cyan", "content": "Original Cyan color instance . Signature . export declare const cyan: Type . ", "url": "/0.1.0/ansi-styles/Color/ThreeBitColor.ts.html#cyan", "relUrl": "/ansi-styles/Color/ThreeBitColor.ts.html#cyan" },"1816": { "doc": "Color/ThreeBitColor.ts", "title": "green", "content": "Original Green color instance . Signature . export declare const green: Type . ", "url": "/0.1.0/ansi-styles/Color/ThreeBitColor.ts.html#green", "relUrl": "/ansi-styles/Color/ThreeBitColor.ts.html#green" },"1817": { "doc": "Color/ThreeBitColor.ts", "title": "magenta", "content": "Original Magenta color instance . Signature . export declare const magenta: Type . ", "url": "/0.1.0/ansi-styles/Color/ThreeBitColor.ts.html#magenta", "relUrl": "/ansi-styles/Color/ThreeBitColor.ts.html#magenta" },"1818": { "doc": "Color/ThreeBitColor.ts", "title": "red", "content": "Original Red color instance . Signature . export declare const red: Type . ", "url": "/0.1.0/ansi-styles/Color/ThreeBitColor.ts.html#red", "relUrl": "/ansi-styles/Color/ThreeBitColor.ts.html#red" },"1819": { "doc": "Color/ThreeBitColor.ts", "title": "white", "content": "Original White color instance . Signature . export declare const white: Type . ", "url": "/0.1.0/ansi-styles/Color/ThreeBitColor.ts.html#white", "relUrl": "/ansi-styles/Color/ThreeBitColor.ts.html#white" },"1820": { "doc": "Color/ThreeBitColor.ts", "title": "yellow", "content": "Original Yellow color instance . Signature . export declare const yellow: Type . ", "url": "/0.1.0/ansi-styles/Color/ThreeBitColor.ts.html#yellow", "relUrl": "/ansi-styles/Color/ThreeBitColor.ts.html#yellow" },"1821": { "doc": "Color/ThreeBitColor.ts", "title": "Models", "content": " ", "url": "/0.1.0/ansi-styles/Color/ThreeBitColor.ts.html#models", "relUrl": "/ansi-styles/Color/ThreeBitColor.ts.html#models" },"1822": { "doc": "Color/ThreeBitColor.ts", "title": "Type (class)", "content": "ThreeBitColor Type . Signature . export declare class Type { private constructor({ offset, isBright }: { readonly offset: ASThreeBitColorOffset.Type; readonly isBright: boolean }) } . make (static method) . Static constructor . Signature . static make(params: { readonly offset: ASThreeBitColorOffset.Type; readonly isBright: boolean; }): Type . [Hash.symbol] (method) . Calculates the hash value of this . Signature . [Hash.symbol](): number . [MEquivalenceBasedEqualityData.isEquivalentToSymbol] (method) . Function that implements the equivalence of this and that . Signature . [MEquivalenceBasedEqualityData.isEquivalentToSymbol](this: this, that: this): boolean . [MEquivalenceBasedEqualityData.hasSameTypeMarkerAsSymbol] (method) . Predicate that returns true if that has the same type marker as this . Signature . [MEquivalenceBasedEqualityData.hasSameTypeMarkerAsSymbol](that: unknown): boolean . offset (property) . Offset of this color . Signature . readonly offset: ASThreeBitColorOffset.Type . isBright (property) . Indicates whether the color is bright . Signature . readonly isBright: boolean . ", "url": "/0.1.0/ansi-styles/Color/ThreeBitColor.ts.html#type-class", "relUrl": "/ansi-styles/Color/ThreeBitColor.ts.html#type-class" },"1823": { "doc": "Color/ThreeBitColor.ts", "title": "Module markers", "content": " ", "url": "/0.1.0/ansi-styles/Color/ThreeBitColor.ts.html#module-markers", "relUrl": "/ansi-styles/Color/ThreeBitColor.ts.html#module-markers" },"1824": { "doc": "Color/ThreeBitColor.ts", "title": "moduleTag", "content": "Module tag . Signature . export declare const moduleTag: \"@parischap/ansi-styles/Color/ThreeBitColor/\" . ", "url": "/0.1.0/ansi-styles/Color/ThreeBitColor.ts.html#moduletag", "relUrl": "/ansi-styles/Color/ThreeBitColor.ts.html#moduletag" },"1825": { "doc": "Color/ThreeBitColor.ts", "title": "Color/ThreeBitColor.ts", "content": " ", "url": "/0.1.0/ansi-styles/Color/ThreeBitColor.ts.html", "relUrl": "/ansi-styles/Color/ThreeBitColor.ts.html" },"1826": { "doc": "Tree/Tree.ts", "title": "Tree overview", "content": "Heterogeneous trees: each node is either a leaf carrying a value of type B or a non-leaf carrying a value of type A and a forest of child trees. ", "url": "/0.1.0/effect-lib/Tree/Tree.ts.html#tree-overview", "relUrl": "/effect-lib/Tree/Tree.ts.html#tree-overview" },"1827": { "doc": "Tree/Tree.ts", "title": "Mental model", "content": ". | Type&lt;A, B&gt; is a discriminated union of {@link “./TreeLeaf.js” | MTreeLeaf.Type&lt;B&gt;} and | . | {@link “./TreeNonLeaf.js” | MTreeNonLeaf.Type&lt;A, B&gt;}. | . | A “tree” with a single leaf is just a leaf — perfectly valid. When the API must guarantee a non-leaf root, take MTreeNonLeaf.Type&lt;A, B&gt; directly. | {@link unfold} and {@link unfoldAndFold} build trees iteratively from a seed plus an unfold function returning either a leaf payload (Result.fail) or a non-leaf payload with child seeds (Result.succeed). Cycle detection is opt-in via a seed Equivalence. | . ", "url": "/0.1.0/effect-lib/Tree/Tree.ts.html#mental-model", "relUrl": "/effect-lib/Tree/Tree.ts.html#mental-model" },"1828": { "doc": "Tree/Tree.ts", "title": "Common tasks", "content": ". | Discriminate: {@link isLeaf}, {@link isNonLeaf} | Build: {@link unfold}, {@link unfoldAndFold} | Read values: {@link value} | Compare: {@link makeEquivalence} | Fold: {@link fold}, {@link reduce}, {@link reduceRight}, {@link unfoldAndFold} | Map / extend: {@link map}, {@link mapAccum}, {@link extendDown}, {@link extendUp} | . ", "url": "/0.1.0/effect-lib/Tree/Tree.ts.html#common-tasks", "relUrl": "/effect-lib/Tree/Tree.ts.html#common-tasks" },"1829": { "doc": "Tree/Tree.ts", "title": "Quickstart", "content": "Example (Build a tree from a seed and sum its leaves) . import { Result, pipe } from \"effect\" import * as MTree from \"@parischap/effect-lib/Tree/Tree\" const buildAndSum = pipe( 3, MTree.unfoldAndFold({ unfold: (n: number) =&gt; (n &lt;= 0 ? Result.fail(0) : Result.succeed([\"node\" as const, [n - 1, n - 1]] as const)), foldNonLeaf: (_value, children) =&gt; children.reduce((a, b) =&gt; a + b, 1), foldLeaf: (n) =&gt; n }) ) console.log(buildAndSum) // count of non-leaf nodes . ", "url": "/0.1.0/effect-lib/Tree/Tree.ts.html#quickstart", "relUrl": "/effect-lib/Tree/Tree.ts.html#quickstart" },"1830": { "doc": "Tree/Tree.ts", "title": "Table of contents", "content": ". | Constructors . | unfold | unfoldAndFold | . | Equivalences . | makeEquivalence | . | Getters . | value | . | Guards . | isLeaf | isNonLeaf | . | Models . | Type (type alias) | . | Module markers . | moduleTag | . | Utils . | extendDown | extendUp | fold | map | mapAccum | reduce | reduceRight | . | . ", "url": "/0.1.0/effect-lib/Tree/Tree.ts.html", "relUrl": "/effect-lib/Tree/Tree.ts.html" },"1831": { "doc": "Tree/Tree.ts", "title": "Constructors", "content": " ", "url": "/0.1.0/effect-lib/Tree/Tree.ts.html#constructors", "relUrl": "/effect-lib/Tree/Tree.ts.html#constructors" },"1832": { "doc": "Tree/Tree.ts", "title": "unfold", "content": "Builds a tree by repeatedly applying an unfold function to seeds. | Non-recursive; uses a queue to process all nodes. | The unfold function returns either a leaf value (Failure) or a non-leaf value with child seeds (Success). | Optionally detects cycles using an equivalence on seeds. | When a cycle is detected, cycleSource is passed as some to allow modification. | . Example (Build tree from seed) . import { pipe } from \"effect\" import * as Result from \"effect/Result\" import * as MTree from \"@parischap/effect-lib/Tree/Tree\" const tree = MTree.unfold&lt;number, string, number&gt;((n) =&gt; n === 0 ? Result.fail(\"leaf\") : Result.succeed([\"node\", [n - 1]]) )(3) . Signature . export declare const unfold: { &lt;S, A, B&gt;(f: (seed: S) =&gt; Result.Result&lt;MTypes.Pair&lt;A, ReadonlyArray&lt;S&gt;&gt;, B&gt;): MTypes.OneArgFunction&lt;S, Type&lt;A, B&gt;&gt; &lt;S, A, B&gt;( f: (seed: S, cycleSource: Option.Option&lt;NoInfer&lt;A&gt;&gt;) =&gt; Result.Result&lt;MTypes.Pair&lt;A, ReadonlyArray&lt;S&gt;&gt;, B&gt;, seedEquivalence: Equivalence.Equivalence&lt;S&gt; ): MTypes.OneArgFunction&lt;S, Type&lt;A, B&gt;&gt; } . ", "url": "/0.1.0/effect-lib/Tree/Tree.ts.html#unfold", "relUrl": "/effect-lib/Tree/Tree.ts.html#unfold" },"1833": { "doc": "Tree/Tree.ts", "title": "unfoldAndFold", "content": "Builds a tree and simultaneously folds it in bottom-up order. | Combines tree construction and folding for efficiency. | Leaf nodes are folded using foldLeaf; non-leaf nodes using foldNonLeaf with accumulated children. | Returns the final folded value (bottom-up aggregation). | Optionally detects cycles using seed equivalence. | . Example (Build and fold tree) . import * as Result from \"effect/Result\" import * as MTree from \"@parischap/effect-lib/Tree/Tree\" const result = MTree.unfoldAndFold({ unfold: (n) =&gt; (n === 0 ? Result.fail(1) : Result.succeed([\"parent\", [n - 1]])), foldLeaf: (val) =&gt; val, foldNonLeaf: (val, children) =&gt; val.length + children[0] })(2) . Signature . export declare const unfoldAndFold: { &lt;A, B, S = A, C = B&gt;(opts: { readonly unfold: ( seed: S, cycleSource: Option.Option&lt;NoInfer&lt;A&gt;&gt; ) =&gt; Result.Result&lt;MTypes.Pair&lt;A, ReadonlyArray&lt;S&gt;&gt;, B&gt; readonly foldNonLeaf: (value: A, children: ReadonlyArray&lt;C&gt;) =&gt; C readonly foldLeaf: (value: B) =&gt; C readonly seedEquivalence: Equivalence.Equivalence&lt;S&gt; }): MTypes.OneArgFunction&lt;S, C&gt; &lt;A, B, S = A, C = B&gt;(opts: { readonly unfold: (seed: S) =&gt; Result.Result&lt;MTypes.Pair&lt;A, ReadonlyArray&lt;S&gt;&gt;, B&gt; readonly foldNonLeaf: (value: A, children: ReadonlyArray&lt;C&gt;) =&gt; C readonly foldLeaf: (value: B) =&gt; C }): MTypes.OneArgFunction&lt;S, C&gt; } . ", "url": "/0.1.0/effect-lib/Tree/Tree.ts.html#unfoldandfold", "relUrl": "/effect-lib/Tree/Tree.ts.html#unfoldandfold" },"1834": { "doc": "Tree/Tree.ts", "title": "Equivalences", "content": " ", "url": "/0.1.0/effect-lib/Tree/Tree.ts.html#equivalences", "relUrl": "/effect-lib/Tree/Tree.ts.html#equivalences" },"1835": { "doc": "Tree/Tree.ts", "title": "makeEquivalence", "content": "Returns an equivalence on Type&lt;A, B&gt; derived from an equivalence on A (non-leaf values) and one on B (leaf values). | Two trees are equivalent iff they have the same shape and corresponding values match under the supplied equivalences. | . Example . import { Equivalence } from \"effect\" import * as MTree from \"@parischap/effect-lib/Tree/Tree\" import * as MTreeLeaf from \"@parischap/effect-lib/Tree/TreeLeaf\" import * as MTreeNonLeaf from \"@parischap/effect-lib/Tree/TreeNonLeaf\" const eq = MTree.makeEquivalence(Equivalence.string, Equivalence.number) const tree1 = MTreeNonLeaf.make({ value: \"root\", forest: [MTreeLeaf.make(1), MTreeLeaf.make(2)] }) const tree2 = MTreeNonLeaf.make({ value: \"root\", forest: [MTreeLeaf.make(1), MTreeLeaf.make(2)] }) console.log(eq(tree1, tree2)) // true . Signature . export declare const makeEquivalence: &lt;A, B&gt;( aEquivalence: Equivalence.Equivalence&lt;A&gt;, bEquivalence: Equivalence.Equivalence&lt;B&gt; ) =&gt; Equivalence.Equivalence&lt;Type&lt;A, B&gt;&gt; . ", "url": "/0.1.0/effect-lib/Tree/Tree.ts.html#makeequivalence", "relUrl": "/effect-lib/Tree/Tree.ts.html#makeequivalence" },"1836": { "doc": "Tree/Tree.ts", "title": "Getters", "content": " ", "url": "/0.1.0/effect-lib/Tree/Tree.ts.html#getters", "relUrl": "/effect-lib/Tree/Tree.ts.html#getters" },"1837": { "doc": "Tree/Tree.ts", "title": "value", "content": "Returns the value field of self. Result type is A | B because self may be a leaf (carrying B) or a non-leaf (carrying A). Signature . export declare const value: &lt;A, B&gt;(self: Type&lt;A, B&gt;) =&gt; A | B . ", "url": "/0.1.0/effect-lib/Tree/Tree.ts.html#value", "relUrl": "/effect-lib/Tree/Tree.ts.html#value" },"1838": { "doc": "Tree/Tree.ts", "title": "Guards", "content": " ", "url": "/0.1.0/effect-lib/Tree/Tree.ts.html#guards", "relUrl": "/effect-lib/Tree/Tree.ts.html#guards" },"1839": { "doc": "Tree/Tree.ts", "title": "isLeaf", "content": "Tests whether u is a leaf node. | Acts as a type guard narrowing the input to MTreeLeaf.Type&lt;B&gt;. | . Signature . export declare const isLeaf: &lt;A, B&gt;(u: Type&lt;A, B&gt;) =&gt; u is MTreeLeaf.Type&lt;B&gt; . ", "url": "/0.1.0/effect-lib/Tree/Tree.ts.html#isleaf", "relUrl": "/effect-lib/Tree/Tree.ts.html#isleaf" },"1840": { "doc": "Tree/Tree.ts", "title": "isNonLeaf", "content": "Tests whether u is a non-leaf node. | Acts as a type guard narrowing the input to MTreeNonLeaf.Type&lt;A, B&gt;. | . Signature . export declare const isNonLeaf: &lt;A, B&gt;(u: Type&lt;A, B&gt;) =&gt; u is MTreeNonLeaf.Type&lt;A, B&gt; . ", "url": "/0.1.0/effect-lib/Tree/Tree.ts.html#isnonleaf", "relUrl": "/effect-lib/Tree/Tree.ts.html#isnonleaf" },"1841": { "doc": "Tree/Tree.ts", "title": "Models", "content": " ", "url": "/0.1.0/effect-lib/Tree/Tree.ts.html#models", "relUrl": "/effect-lib/Tree/Tree.ts.html#models" },"1842": { "doc": "Tree/Tree.ts", "title": "Type (type alias)", "content": "Type of a Tree . Signature . export type Type&lt;A, B&gt; = MTreeLeaf.Type&lt;B&gt; | MTreeNonLeaf.Type&lt;A, B&gt; . ", "url": "/0.1.0/effect-lib/Tree/Tree.ts.html#type-type-alias", "relUrl": "/effect-lib/Tree/Tree.ts.html#type-type-alias" },"1843": { "doc": "Tree/Tree.ts", "title": "Module markers", "content": " ", "url": "/0.1.0/effect-lib/Tree/Tree.ts.html#module-markers", "relUrl": "/effect-lib/Tree/Tree.ts.html#module-markers" },"1844": { "doc": "Tree/Tree.ts", "title": "moduleTag", "content": "Module tag . Signature . export declare const moduleTag: \"@parischap/effect-lib/Tree/\" . ", "url": "/0.1.0/effect-lib/Tree/Tree.ts.html#moduletag", "relUrl": "/effect-lib/Tree/Tree.ts.html#moduletag" },"1845": { "doc": "Tree/Tree.ts", "title": "Utils", "content": " ", "url": "/0.1.0/effect-lib/Tree/Tree.ts.html#utils", "relUrl": "/effect-lib/Tree/Tree.ts.html#utils" },"1846": { "doc": "Tree/Tree.ts", "title": "extendDown", "content": "Extends a tree in top-down order, transforming each node to a new value. | More powerful than {@link map}—receives the entire node (not just its value). | Processes tree top-down: root first, then children level-by-level. | Functions receive the node itself and its level for context-aware transformation. | Use when transformation depends on position in tree or sibling relationships. | . Example (Extend down: tag by level) . import * as MTree from \"@parischap/effect-lib/Tree/Tree\" import * as MTreeLeaf from \"@parischap/effect-lib/Tree/TreeLeaf\" import * as MTreeNonLeaf from \"@parischap/effect-lib/Tree/TreeNonLeaf\" const tree = MTreeNonLeaf.make({ value: \"root\", forest: [MTreeLeaf.make(\"leaf\")] }) const extended = MTree.extendDown({ fNonLeaf: (node, level) =&gt; `${node.value}@${level}`, fLeaf: (leaf, level) =&gt; `${leaf.value}@${level}` })(tree) . Signature . export declare const extendDown: &lt;A, B, C, D&gt;({ fNonLeaf, fLeaf }: { readonly fNonLeaf: (tree: Type&lt;NoInfer&lt;A&gt;, NoInfer&lt;B&gt;&gt;, level: number) =&gt; C readonly fLeaf: (leaf: MTreeLeaf.Type&lt;NoInfer&lt;B&gt;&gt;, level: number) =&gt; D }) =&gt; MTypes.OneArgFunction&lt;Type&lt;A, B&gt;, Type&lt;C, D&gt;&gt; . ", "url": "/0.1.0/effect-lib/Tree/Tree.ts.html#extenddown", "relUrl": "/effect-lib/Tree/Tree.ts.html#extenddown" },"1847": { "doc": "Tree/Tree.ts", "title": "extendUp", "content": "Extends a tree in bottom-up order, transforming each node to a new value. | More powerful than {@link map}—receives the entire node (not just its value). | Processes tree bottom-up: leaves first, then non-leaves up to root. | Children are processed before their parent. | Functions receive the node itself and its level for context-aware transformation. | Use when transformation depends on processing children first. | . Example (Extend up: aggregate child count) . import * as MTree from \"@parischap/effect-lib/Tree/Tree\" import * as MTreeLeaf from \"@parischap/effect-lib/Tree/TreeLeaf\" import * as MTreeNonLeaf from \"@parischap/effect-lib/Tree/TreeNonLeaf\" const tree = MTreeNonLeaf.make({ value: \"root\", forest: [MTreeLeaf.make(\"a\"), MTreeLeaf.make(\"b\")] }) const extended = MTree.extendUp({ fNonLeaf: (node, level) =&gt; node.forest.length, fLeaf: (leaf, level) =&gt; 0 })(tree) . Signature . export declare const extendUp: &lt;A, B, C, D&gt;({ fNonLeaf, fLeaf }: { readonly fNonLeaf: (tree: Type&lt;NoInfer&lt;A&gt;, NoInfer&lt;B&gt;&gt;, level: number) =&gt; C readonly fLeaf: (leaf: MTreeLeaf.Type&lt;NoInfer&lt;B&gt;&gt;, level: number) =&gt; D }) =&gt; MTypes.OneArgFunction&lt;Type&lt;A, B&gt;, Type&lt;C, D&gt;&gt; . ", "url": "/0.1.0/effect-lib/Tree/Tree.ts.html#extendup", "relUrl": "/effect-lib/Tree/Tree.ts.html#extendup" },"1848": { "doc": "Tree/Tree.ts", "title": "fold", "content": "Folds a tree into a summary value in bottom-up order. | Processes leaves first, then combines results upward. | Use to aggregate or transform tree data recursively. | foldLeaf handles terminal nodes; foldNonLeaf combines parent values with folded children. | Each function receives a level parameter for depth-aware logic. | . Example (Fold tree to sum) . import * as MTree from \"@parischap/effect-lib/Tree/Tree\" import * as MTreeLeaf from \"@parischap/effect-lib/Tree/TreeLeaf\" import * as MTreeNonLeaf from \"@parischap/effect-lib/Tree/TreeNonLeaf\" const tree = MTreeNonLeaf.make({ value: 10, forest: [MTreeLeaf.make(5), MTreeLeaf.make(3)] }) const sum = MTree.fold({ foldLeaf: (n) =&gt; n, foldNonLeaf: (n, children) =&gt; n + children.reduce((a, b) =&gt; a + b, 0) })(tree) console.log(sum) // 18 . Signature . export declare const fold: &lt;A, B, C&gt;({ foldNonLeaf: fNonLeaf, foldLeaf: fLeaf }: { readonly foldNonLeaf: (a: NoInfer&lt;A&gt;, bs: ReadonlyArray&lt;C&gt;, level: number) =&gt; C readonly foldLeaf: (a: NoInfer&lt;B&gt;, level: number) =&gt; C }) =&gt; MTypes.OneArgFunction&lt;Type&lt;A, B&gt;, C&gt; . ", "url": "/0.1.0/effect-lib/Tree/Tree.ts.html#fold", "relUrl": "/effect-lib/Tree/Tree.ts.html#fold" },"1849": { "doc": "Tree/Tree.ts", "title": "map", "content": "Maps a tree, transforming both leaf and non-leaf values. | Use to apply transformations to all node values. | Non-leaf values transformed via fNonLeaf; leaf values via fLeaf. | Both functions receive the node’s level (0 at root) for depth-aware logic. | Returns a new tree with transformed values (structure unchanged). | . Example (Map tree values) . import * as MTree from \"@parischap/effect-lib/Tree/Tree\" import * as MTreeLeaf from \"@parischap/effect-lib/Tree/TreeLeaf\" import * as MTreeNonLeaf from \"@parischap/effect-lib/Tree/TreeNonLeaf\" const tree = MTreeNonLeaf.make({ value: \"node\", forest: [MTreeLeaf.make(5), MTreeLeaf.make(3)] }) const mapped = MTree.map({ fNonLeaf: (val) =&gt; val.toUpperCase(), fLeaf: (num) =&gt; num * 2 })(tree) . Signature . export declare const map: &lt;A, B, C, D&gt;({ fNonLeaf, fLeaf }: { readonly fNonLeaf: (a: NoInfer&lt;A&gt;, level: number) =&gt; C readonly fLeaf: (b: NoInfer&lt;B&gt;, level: number) =&gt; D }) =&gt; MTypes.OneArgFunction&lt;Type&lt;A, B&gt;, Type&lt;C, D&gt;&gt; . ", "url": "/0.1.0/effect-lib/Tree/Tree.ts.html#map", "relUrl": "/effect-lib/Tree/Tree.ts.html#map" },"1850": { "doc": "Tree/Tree.ts", "title": "mapAccum", "content": "Maps a tree with an accumulator in a top-down pass. | Use to transform both structure and values while threading state through the tree. | Leaf and non-leaf nodes processed separately with separate folding functions. | Level parameter indicates depth (0 at root). | Accumulator is passed down through the tree traversal. | . Example (Map with accumulator) . import * as MTree from \"@parischap/effect-lib/Tree/Tree\" import * as MTreeLeaf from \"@parischap/effect-lib/Tree/TreeLeaf\" import * as MTreeNonLeaf from \"@parischap/effect-lib/Tree/TreeNonLeaf\" const tree = MTreeNonLeaf.make({ value: \"root\", forest: [MTreeLeaf.make(1), MTreeLeaf.make(2)] }) const result = MTree.mapAccum({ accum: 0, fNonLeaf: (s, val) =&gt; [s + 1, val.toUpperCase()], fLeaf: (s, val) =&gt; val * 10 })(tree) . Signature . export declare const mapAccum: &lt;S, A, B, C, D&gt;({ accum, fNonLeaf, fLeaf }: { readonly accum: S readonly fNonLeaf: (s: S, a: NoInfer&lt;A&gt;, level: number) =&gt; MTypes.Pair&lt;S, C&gt; readonly fLeaf: (s: S, b: NoInfer&lt;B&gt;, level: number) =&gt; D }) =&gt; MTypes.OneArgFunction&lt;Type&lt;A, B&gt;, Type&lt;C, D&gt;&gt; . ", "url": "/0.1.0/effect-lib/Tree/Tree.ts.html#mapaccum", "relUrl": "/effect-lib/Tree/Tree.ts.html#mapaccum" },"1851": { "doc": "Tree/Tree.ts", "title": "reduce", "content": "Reduces a tree to a summary value, processing children left to right. | Top-down traversal accumulating a result value. | Functions applied in order: non-leaf first, then each child in left-to-right order. | Each function receives the accumulator, node value, and depth level. | Use for aggregating properties or collecting information from the tree. | . Example (Reduce tree) . import * as MTree from \"@parischap/effect-lib/Tree/Tree\" import * as MTreeLeaf from \"@parischap/effect-lib/Tree/TreeLeaf\" import * as MTreeNonLeaf from \"@parischap/effect-lib/Tree/TreeNonLeaf\" const tree = MTreeNonLeaf.make({ value: 1, forest: [MTreeLeaf.make(2), MTreeLeaf.make(3)] }) const sum = MTree.reduce({ z: 0, fNonLeaf: (acc, val) =&gt; acc + val, fLeaf: (acc, val) =&gt; acc + val })(tree) console.log(sum) // 6 . Signature . export declare const reduce: &lt;A, B, Z&gt;({ z, fNonLeaf, fLeaf }: { readonly z: Z readonly fNonLeaf: (z: Z, a: NoInfer&lt;A&gt;, level: number) =&gt; Z readonly fLeaf: (z: Z, b: NoInfer&lt;B&gt;, level: number) =&gt; Z }) =&gt; MTypes.OneArgFunction&lt;Type&lt;A, B&gt;, Z&gt; . ", "url": "/0.1.0/effect-lib/Tree/Tree.ts.html#reduce", "relUrl": "/effect-lib/Tree/Tree.ts.html#reduce" },"1852": { "doc": "Tree/Tree.ts", "title": "reduceRight", "content": "Reduces a tree to a summary value, processing children right to left. | Top-down traversal accumulating a result value. | Functions applied in order: non-leaf first, then each child in right-to-left order. | Each function receives the accumulator, node value, and depth level. | Similar to {@link reduce} but with reversed child processing order. | . Example (Reduce tree right-to-left) . import * as MTree from \"@parischap/effect-lib/Tree/Tree\" import * as MTreeLeaf from \"@parischap/effect-lib/Tree/TreeLeaf\" import * as MTreeNonLeaf from \"@parischap/effect-lib/Tree/TreeNonLeaf\" const tree = MTreeNonLeaf.make({ value: \"A\", forest: [MTreeLeaf.make(\"B\"), MTreeLeaf.make(\"C\")] }) const result = MTree.reduceRight({ z: \"\", fNonLeaf: (acc, val) =&gt; acc + val, fLeaf: (acc, val) =&gt; acc + val })(tree) console.log(result) // \"ACB\" . Signature . export declare const reduceRight: &lt;A, B, Z&gt;({ z, fNonLeaf, fLeaf }: { readonly z: Z readonly fNonLeaf: (z: Z, a: NoInfer&lt;A&gt;, level: number) =&gt; Z readonly fLeaf: (z: Z, b: NoInfer&lt;B&gt;, level: number) =&gt; Z }) =&gt; MTypes.OneArgFunction&lt;Type&lt;A, B&gt;, Z&gt; . ", "url": "/0.1.0/effect-lib/Tree/Tree.ts.html#reduceright", "relUrl": "/effect-lib/Tree/Tree.ts.html#reduceright" },"1853": { "doc": "Tree/Tree.ts", "title": "Tree/Tree.ts", "content": " ", "url": "/0.1.0/effect-lib/Tree/Tree.ts.html", "relUrl": "/effect-lib/Tree/Tree.ts.html" },"1854": { "doc": "Tree/TreeForest.ts", "title": "TreeForest overview", "content": "Type alias for the children of a non-leaf tree node. A Type&lt;A, B&gt; is ReadonlyArray&lt;MTree.Type&lt;A, B&gt;&gt;. See {@link “./TreeNonLeaf.js” | MTreeNonLeaf} for the consumer of this alias and {@link “./Tree.js” | MTree} for tree-wide operations. ", "url": "/0.1.0/effect-lib/Tree/TreeForest.ts.html#treeforest-overview", "relUrl": "/effect-lib/Tree/TreeForest.ts.html#treeforest-overview" },"1855": { "doc": "Tree/TreeForest.ts", "title": "Table of contents", "content": ". | Models . | Type (type alias) | . | . ", "url": "/0.1.0/effect-lib/Tree/TreeForest.ts.html", "relUrl": "/effect-lib/Tree/TreeForest.ts.html" },"1856": { "doc": "Tree/TreeForest.ts", "title": "Models", "content": " ", "url": "/0.1.0/effect-lib/Tree/TreeForest.ts.html#models", "relUrl": "/effect-lib/Tree/TreeForest.ts.html#models" },"1857": { "doc": "Tree/TreeForest.ts", "title": "Type (type alias)", "content": "Type alias used by {@link “./TreeNonLeaf.js” | MTreeNonLeaf} to declare the children of a non-leaf node. Signature . export type Type&lt;A, B&gt; = ReadonlyArray&lt;MTree.Type&lt;A, B&gt;&gt; . ", "url": "/0.1.0/effect-lib/Tree/TreeForest.ts.html#type-type-alias", "relUrl": "/effect-lib/Tree/TreeForest.ts.html#type-type-alias" },"1858": { "doc": "Tree/TreeForest.ts", "title": "Tree/TreeForest.ts", "content": " ", "url": "/0.1.0/effect-lib/Tree/TreeForest.ts.html", "relUrl": "/effect-lib/Tree/TreeForest.ts.html" },"1859": { "doc": "Tree/TreeLeaf.ts", "title": "TreeLeaf overview", "content": "Leaf node of a tree: a value of type B with no children. Companion of {@link “./TreeNonLeaf.js” | MTreeNonLeaf}; both are unioned into {@link “./Tree.js” | MTree.Type}. ", "url": "/0.1.0/effect-lib/Tree/TreeLeaf.ts.html#treeleaf-overview", "relUrl": "/effect-lib/Tree/TreeLeaf.ts.html#treeleaf-overview" },"1860": { "doc": "Tree/TreeLeaf.ts", "title": "Quickstart", "content": "Example (Create a leaf) . import * as MTreeLeaf from \"@parischap/effect-lib/Tree/TreeLeaf\" const leaf = MTreeLeaf.make(42) console.log(leaf.value) // 42 . ", "url": "/0.1.0/effect-lib/Tree/TreeLeaf.ts.html#quickstart", "relUrl": "/effect-lib/Tree/TreeLeaf.ts.html#quickstart" },"1861": { "doc": "Tree/TreeLeaf.ts", "title": "Table of contents", "content": ". | Constructors . | make | . | Models . | Type (class) . | make (static method) | [MData.idSymbol] (method) | . | . | Module markers . | moduleTag | . | . ", "url": "/0.1.0/effect-lib/Tree/TreeLeaf.ts.html", "relUrl": "/effect-lib/Tree/TreeLeaf.ts.html" },"1862": { "doc": "Tree/TreeLeaf.ts", "title": "Constructors", "content": " ", "url": "/0.1.0/effect-lib/Tree/TreeLeaf.ts.html#constructors", "relUrl": "/effect-lib/Tree/TreeLeaf.ts.html#constructors" },"1863": { "doc": "Tree/TreeLeaf.ts", "title": "make", "content": "Builds a leaf node carrying value. Example . import * as MTreeLeaf from \"@parischap/effect-lib/Tree/TreeLeaf\" console.log(MTreeLeaf.make(42).value) // 42 . Signature . export declare const make: &lt;B&gt;(value: B) =&gt; Type&lt;B&gt; . ", "url": "/0.1.0/effect-lib/Tree/TreeLeaf.ts.html#make", "relUrl": "/effect-lib/Tree/TreeLeaf.ts.html#make" },"1864": { "doc": "Tree/TreeLeaf.ts", "title": "Models", "content": " ", "url": "/0.1.0/effect-lib/Tree/TreeLeaf.ts.html#models", "relUrl": "/effect-lib/Tree/TreeLeaf.ts.html#models" },"1865": { "doc": "Tree/TreeLeaf.ts", "title": "Type (class)", "content": "Leaf node holding a value of type B. Has no children. Signature . export declare class Type&lt;B&gt; { private constructor({ value }: MTypes.Data&lt;Type&lt;B&gt;&gt;) } . make (static method) . Static constructor . Signature . static make&lt;B&gt;(params: MTypes.Data&lt;Type&lt;B&gt;&gt;): Type&lt;B&gt; . [MData.idSymbol] (method) . Returns the id of this . Signature . [MData.idSymbol](): string | (() =&gt; string) . ", "url": "/0.1.0/effect-lib/Tree/TreeLeaf.ts.html#type-class", "relUrl": "/effect-lib/Tree/TreeLeaf.ts.html#type-class" },"1866": { "doc": "Tree/TreeLeaf.ts", "title": "Module markers", "content": " ", "url": "/0.1.0/effect-lib/Tree/TreeLeaf.ts.html#module-markers", "relUrl": "/effect-lib/Tree/TreeLeaf.ts.html#module-markers" },"1867": { "doc": "Tree/TreeLeaf.ts", "title": "moduleTag", "content": "Module tag. Signature . export declare const moduleTag: \"@parischap/effect-lib/Tree/TreeLeaf/\" . ", "url": "/0.1.0/effect-lib/Tree/TreeLeaf.ts.html#moduletag", "relUrl": "/effect-lib/Tree/TreeLeaf.ts.html#moduletag" },"1868": { "doc": "Tree/TreeLeaf.ts", "title": "Tree/TreeLeaf.ts", "content": " ", "url": "/0.1.0/effect-lib/Tree/TreeLeaf.ts.html", "relUrl": "/effect-lib/Tree/TreeLeaf.ts.html" },"1869": { "doc": "Tree/TreeNode.ts", "title": "TreeNode overview", "content": "Abstract base class shared by every tree node — only here to factor out the value field and its getter. | Most code interacts with the concrete subclasses {@link “./TreeLeaf.js” | MTreeLeaf} and |   | . | {@link “./TreeNonLeaf.js” | MTreeNonLeaf} or with the {@link “./Tree.js” | MTree} union. | . ", "url": "/0.1.0/effect-lib/Tree/TreeNode.ts.html#treenode-overview", "relUrl": "/effect-lib/Tree/TreeNode.ts.html#treenode-overview" },"1870": { "doc": "Tree/TreeNode.ts", "title": "Table of contents", "content": ". | Getters . | value | . | Models . | Type (class) . | value (property) | . | . | Module markers . | moduleTag | . | . ", "url": "/0.1.0/effect-lib/Tree/TreeNode.ts.html", "relUrl": "/effect-lib/Tree/TreeNode.ts.html" },"1871": { "doc": "Tree/TreeNode.ts", "title": "Getters", "content": " ", "url": "/0.1.0/effect-lib/Tree/TreeNode.ts.html#getters", "relUrl": "/effect-lib/Tree/TreeNode.ts.html#getters" },"1872": { "doc": "Tree/TreeNode.ts", "title": "value", "content": "Returns the value field of self. Works on both leaf and non-leaf nodes. Signature . export declare const value: &lt;A&gt;(self: Type&lt;A&gt;) =&gt; A . ", "url": "/0.1.0/effect-lib/Tree/TreeNode.ts.html#value", "relUrl": "/effect-lib/Tree/TreeNode.ts.html#value" },"1873": { "doc": "Tree/TreeNode.ts", "title": "Models", "content": " ", "url": "/0.1.0/effect-lib/Tree/TreeNode.ts.html#models", "relUrl": "/effect-lib/Tree/TreeNode.ts.html#models" },"1874": { "doc": "Tree/TreeNode.ts", "title": "Type (class)", "content": "Abstract base class holding a value of type A. Concrete subclasses are MTreeLeaf.Type&lt;A&gt; and MTreeNonLeaf.Type&lt;_, A&gt;. Signature . export declare class Type&lt;A&gt; { protected constructor({ value }: MTypes.Data&lt;Type&lt;A&gt;&gt;) } . value (property) . Value of a node . Signature . readonly value: A . ", "url": "/0.1.0/effect-lib/Tree/TreeNode.ts.html#type-class", "relUrl": "/effect-lib/Tree/TreeNode.ts.html#type-class" },"1875": { "doc": "Tree/TreeNode.ts", "title": "Module markers", "content": " ", "url": "/0.1.0/effect-lib/Tree/TreeNode.ts.html#module-markers", "relUrl": "/effect-lib/Tree/TreeNode.ts.html#module-markers" },"1876": { "doc": "Tree/TreeNode.ts", "title": "moduleTag", "content": "Module tag. Signature . export declare const moduleTag: \"@parischap/effect-lib/Tree/TreeNode/\" . ", "url": "/0.1.0/effect-lib/Tree/TreeNode.ts.html#moduletag", "relUrl": "/effect-lib/Tree/TreeNode.ts.html#moduletag" },"1877": { "doc": "Tree/TreeNode.ts", "title": "Tree/TreeNode.ts", "content": " ", "url": "/0.1.0/effect-lib/Tree/TreeNode.ts.html", "relUrl": "/effect-lib/Tree/TreeNode.ts.html" },"1878": { "doc": "Tree/TreeNonLeaf.ts", "title": "TreeNonLeaf overview", "content": "Internal (branching) node of a tree: a value of type A paired with a forest of child trees. Companion of {@link “./TreeLeaf.js” | MTreeLeaf}; both are unioned into {@link “./Tree.js” | MTree.Type}. ", "url": "/0.1.0/effect-lib/Tree/TreeNonLeaf.ts.html#treenonleaf-overview", "relUrl": "/effect-lib/Tree/TreeNonLeaf.ts.html#treenonleaf-overview" },"1879": { "doc": "Tree/TreeNonLeaf.ts", "title": "Quickstart", "content": "Example (Build a branch with two leaves) . import * as MTreeLeaf from \"@parischap/effect-lib/Tree/TreeLeaf\" import * as MTreeNonLeaf from \"@parischap/effect-lib/Tree/TreeNonLeaf\" const branch = MTreeNonLeaf.make({ value: \"root\", forest: [MTreeLeaf.make(\"a\"), MTreeLeaf.make(\"b\")] }) console.log(branch.value) // 'root' console.log(branch.forest.length) // 2 . ", "url": "/0.1.0/effect-lib/Tree/TreeNonLeaf.ts.html#quickstart", "relUrl": "/effect-lib/Tree/TreeNonLeaf.ts.html#quickstart" },"1880": { "doc": "Tree/TreeNonLeaf.ts", "title": "Table of contents", "content": ". | Constructors . | make | . | Models . | Type (class) . | make (static method) | [MData.idSymbol] (method) | forest (property) | . | . | Module markers . | moduleTag | . | . ", "url": "/0.1.0/effect-lib/Tree/TreeNonLeaf.ts.html", "relUrl": "/effect-lib/Tree/TreeNonLeaf.ts.html" },"1881": { "doc": "Tree/TreeNonLeaf.ts", "title": "Constructors", "content": " ", "url": "/0.1.0/effect-lib/Tree/TreeNonLeaf.ts.html#constructors", "relUrl": "/effect-lib/Tree/TreeNonLeaf.ts.html#constructors" },"1882": { "doc": "Tree/TreeNonLeaf.ts", "title": "make", "content": "Builds a non-leaf node from value and forest. Signature . export declare const make: &lt;A, B&gt;(params: MTypes.Data&lt;Type&lt;A, B&gt;&gt;) =&gt; Type&lt;A, B&gt; . ", "url": "/0.1.0/effect-lib/Tree/TreeNonLeaf.ts.html#make", "relUrl": "/effect-lib/Tree/TreeNonLeaf.ts.html#make" },"1883": { "doc": "Tree/TreeNonLeaf.ts", "title": "Models", "content": " ", "url": "/0.1.0/effect-lib/Tree/TreeNonLeaf.ts.html#models", "relUrl": "/effect-lib/Tree/TreeNonLeaf.ts.html#models" },"1884": { "doc": "Tree/TreeNonLeaf.ts", "title": "Type (class)", "content": "Internal node holding a value of type A and a forest of children of type MTreeForest.Type&lt;A, B&gt;. Signature . export declare class Type&lt;A, B&gt; { private constructor({ value, forest }: MTypes.Data&lt;Type&lt;A, B&gt;&gt;) } . make (static method) . Static constructor . Signature . static make&lt;A, B&gt;(params: MTypes.Data&lt;Type&lt;A, B&gt;&gt;): Type&lt;A, B&gt; . [MData.idSymbol] (method) . Returns the id of this . Signature . [MData.idSymbol](): string | (() =&gt; string) . forest (property) . The children of a NonLeaf . Signature . readonly forest: MTreeForest.Type&lt;A, B&gt; . ", "url": "/0.1.0/effect-lib/Tree/TreeNonLeaf.ts.html#type-class", "relUrl": "/effect-lib/Tree/TreeNonLeaf.ts.html#type-class" },"1885": { "doc": "Tree/TreeNonLeaf.ts", "title": "Module markers", "content": " ", "url": "/0.1.0/effect-lib/Tree/TreeNonLeaf.ts.html#module-markers", "relUrl": "/effect-lib/Tree/TreeNonLeaf.ts.html#module-markers" },"1886": { "doc": "Tree/TreeNonLeaf.ts", "title": "moduleTag", "content": "Module tag. Signature . export declare const moduleTag: \"@parischap/effect-lib/Tree/TreeNonLeaf/\" . ", "url": "/0.1.0/effect-lib/Tree/TreeNonLeaf.ts.html#moduletag", "relUrl": "/effect-lib/Tree/TreeNonLeaf.ts.html#moduletag" },"1887": { "doc": "Tree/TreeNonLeaf.ts", "title": "Tree/TreeNonLeaf.ts", "content": " ", "url": "/0.1.0/effect-lib/Tree/TreeNonLeaf.ts.html", "relUrl": "/effect-lib/Tree/TreeNonLeaf.ts.html" },"1888": { "doc": "Tuple.ts", "title": "Tuple overview", "content": "Extension to the Effect Tuple module providing safe single-element construction, element replication, and prefix prepending. ", "url": "/0.1.0/effect-lib/Tuple.ts.html#tuple-overview", "relUrl": "/effect-lib/Tuple.ts.html#tuple-overview" },"1889": { "doc": "Tuple.ts", "title": "Mental model", "content": ". | Tuples are fixed-length arrays whose element types are tracked individually by TypeScript. | This module focuses on a small set of constructors and editing helpers; combine them with Effect’s Tuple for the rest. | . ", "url": "/0.1.0/effect-lib/Tuple.ts.html#mental-model", "relUrl": "/effect-lib/Tuple.ts.html#mental-model" },"1890": { "doc": "Tuple.ts", "title": "Common tasks", "content": ". | Construct: {@link of}, {@link replicate} | Edit: {@link prependElement} | . ", "url": "/0.1.0/effect-lib/Tuple.ts.html#common-tasks", "relUrl": "/effect-lib/Tuple.ts.html#common-tasks" },"1891": { "doc": "Tuple.ts", "title": "Quickstart", "content": "Example (Build a [1] tuple from Array.map) . import { Array, pipe } from \"effect\" import * as MTuple from \"@parischap/effect-lib/MTuple\" console.log(pipe([1, 2, 3], Array.map(MTuple.of))) // [[1], [2], [3]] . ", "url": "/0.1.0/effect-lib/Tuple.ts.html#quickstart", "relUrl": "/effect-lib/Tuple.ts.html#quickstart" },"1892": { "doc": "Tuple.ts", "title": "Table of contents", "content": ". | Constructors . | of | replicate | . | Utils . | prependElement | . | . ", "url": "/0.1.0/effect-lib/Tuple.ts.html", "relUrl": "/effect-lib/Tuple.ts.html" },"1893": { "doc": "Tuple.ts", "title": "Constructors", "content": " ", "url": "/0.1.0/effect-lib/Tuple.ts.html#constructors", "relUrl": "/effect-lib/Tuple.ts.html#constructors" },"1894": { "doc": "Tuple.ts", "title": "of", "content": "Builds a single-element tuple [a]. | Prefer this over Tuple.make inside callbacks of variadic-aware iterators (Array.map, Array.filter, …): those iterators pass extra arguments (the index, the source) and Tuple.make, being variadic, would silently include them. For example, pipe([1, 2, 3], Array.map(Tuple.make)) yields [[1, 0], [2, 1], [3, 2]] rather than the probably-intended [[1], [2], [3]]. | . Example (Single-element tuple) . import { Array, pipe } from \"effect\" import * as MTuple from \"@parischap/effect-lib/MTuple\" console.log(pipe([1, 2, 3], Array.map(MTuple.of))) // [[1], [2], [3]] . Signature . export declare const of: &lt;A&gt;(a: A) =&gt; [A] . ", "url": "/0.1.0/effect-lib/Tuple.ts.html#of", "relUrl": "/effect-lib/Tuple.ts.html#of" },"1895": { "doc": "Tuple.ts", "title": "replicate", "content": "Builds a tuple of length n whose every element is a. | n is captured at the type level, so the result is typed Tuple&lt;A, N&gt;. | . Example (Replicate a value) . import { pipe } from \"effect\" import * as MTuple from \"@parischap/effect-lib/MTuple\" console.log(pipe(\"x\", MTuple.replicate(3))) // ['x', 'x', 'x'] . Signature . export declare const replicate: &lt;N extends number&gt;(n: N) =&gt; &lt;A&gt;(a: A) =&gt; MTypes.Tuple&lt;A, N&gt; . ", "url": "/0.1.0/effect-lib/Tuple.ts.html#replicate", "relUrl": "/effect-lib/Tuple.ts.html#replicate" },"1896": { "doc": "Tuple.ts", "title": "Utils", "content": " ", "url": "/0.1.0/effect-lib/Tuple.ts.html#utils", "relUrl": "/effect-lib/Tuple.ts.html#utils" },"1897": { "doc": "Tuple.ts", "title": "prependElement", "content": "Returns [that, ...self], prepending that to the head of self while preserving the tuple type. Example (Prepend an element) . import { pipe } from \"effect\" import * as MTuple from \"@parischap/effect-lib/MTuple\" console.log(pipe([2, 3] as const, MTuple.prependElement(1))) // [1, 2, 3] . Signature . export declare const prependElement: &lt;B&gt;(that: B) =&gt; &lt;A extends ReadonlyArray&lt;unknown&gt;&gt;(self: A) =&gt; [B, ...A] . ", "url": "/0.1.0/effect-lib/Tuple.ts.html#prependelement", "relUrl": "/effect-lib/Tuple.ts.html#prependelement" },"1898": { "doc": "Tuple.ts", "title": "Tuple.ts", "content": " ", "url": "/0.1.0/effect-lib/Tuple.ts.html", "relUrl": "/effect-lib/Tuple.ts.html" },"1899": { "doc": "types/TypesCategory.ts", "title": "TypesCategory overview", "content": "Enum classifying JavaScript values into ten runtime categories, plus a {@link fromValue} constructor and per-category predicates. ", "url": "/0.1.0/effect-lib/types/TypesCategory.ts.html#typescategory-overview", "relUrl": "/effect-lib/types/TypesCategory.ts.html#typescategory-overview" },"1900": { "doc": "types/TypesCategory.ts", "title": "Mental model", "content": ". | Type has 10 cases: String, Number, Bigint, Boolean, Symbol, Null, Undefined, Record, Array, Function. | Record is the computer-science meaning (a string-keyed object), not the TypeScript Record&lt;K, V&gt; utility — arrays and functions get their own categories despite being objects at the JS level. | {@link fromValue} normalizes any JavaScript value to one of these categories; {@link isPrimitive} / {@link isNonPrimitive} group the categories accordingly. | . ", "url": "/0.1.0/effect-lib/types/TypesCategory.ts.html#mental-model", "relUrl": "/effect-lib/types/TypesCategory.ts.html#mental-model" },"1901": { "doc": "types/TypesCategory.ts", "title": "Common tasks", "content": ". | Classify a value: {@link fromValue} | Group test: {@link isPrimitive}, {@link isNonPrimitive} | Per-category test: {@link isString}, {@link isNumber}, {@link isBigint}, {@link isBoolean}, {@link isSymbol}, {@link isNull}, {@link isUndefined}, {@link isFunction}, {@link isArray}, {@link isRecord} | . ", "url": "/0.1.0/effect-lib/types/TypesCategory.ts.html#common-tasks", "relUrl": "/effect-lib/types/TypesCategory.ts.html#common-tasks" },"1902": { "doc": "types/TypesCategory.ts", "title": "Quickstart", "content": "Example (Classify and dispatch on category) . import * as MTypesCategory from \"@parischap/effect-lib/types/TypesCategory\" console.log(MTypesCategory.fromValue(\"hi\") === MTypesCategory.Type.String) // true console.log(MTypesCategory.isNonPrimitive(MTypesCategory.fromValue([1, 2]))) // true . ", "url": "/0.1.0/effect-lib/types/TypesCategory.ts.html#quickstart", "relUrl": "/effect-lib/types/TypesCategory.ts.html#quickstart" },"1903": { "doc": "types/TypesCategory.ts", "title": "Table of contents", "content": ". | Constructors . | fromValue | . | Predicates . | isArray | isBigint | isBoolean | isFunction | isNonPrimitive | isNull | isNumber | isPrimitive | isRecord | isString | isSymbol | isUndefined | . | . ", "url": "/0.1.0/effect-lib/types/TypesCategory.ts.html", "relUrl": "/effect-lib/types/TypesCategory.ts.html" },"1904": { "doc": "types/TypesCategory.ts", "title": "Constructors", "content": " ", "url": "/0.1.0/effect-lib/types/TypesCategory.ts.html#constructors", "relUrl": "/effect-lib/types/TypesCategory.ts.html#constructors" },"1905": { "doc": "types/TypesCategory.ts", "title": "fromValue", "content": "Builds the category of u. | Returns the matching {@link Type} variant for any JavaScript value. | null and arrays each get their own category, even though typeof reports them as 'object'. | . Signature . export declare const fromValue: (u: unknown) =&gt; Type . ", "url": "/0.1.0/effect-lib/types/TypesCategory.ts.html#fromvalue", "relUrl": "/effect-lib/types/TypesCategory.ts.html#fromvalue" },"1906": { "doc": "types/TypesCategory.ts", "title": "Predicates", "content": " ", "url": "/0.1.0/effect-lib/types/TypesCategory.ts.html#predicates", "relUrl": "/effect-lib/types/TypesCategory.ts.html#predicates" },"1907": { "doc": "types/TypesCategory.ts", "title": "isArray", "content": "Returns true if self represents an array. false otherwise . Signature . export declare const isArray: Predicate.Predicate&lt;Type&gt; . ", "url": "/0.1.0/effect-lib/types/TypesCategory.ts.html#isarray", "relUrl": "/effect-lib/types/TypesCategory.ts.html#isarray" },"1908": { "doc": "types/TypesCategory.ts", "title": "isBigint", "content": "Returns true if self represents a bigint. false otherwise . Signature . export declare const isBigint: Predicate.Predicate&lt;Type&gt; . ", "url": "/0.1.0/effect-lib/types/TypesCategory.ts.html#isbigint", "relUrl": "/effect-lib/types/TypesCategory.ts.html#isbigint" },"1909": { "doc": "types/TypesCategory.ts", "title": "isBoolean", "content": "Returns true if self represents a boolean. false otherwise . Signature . export declare const isBoolean: Predicate.Predicate&lt;Type&gt; . ", "url": "/0.1.0/effect-lib/types/TypesCategory.ts.html#isboolean", "relUrl": "/effect-lib/types/TypesCategory.ts.html#isboolean" },"1910": { "doc": "types/TypesCategory.ts", "title": "isFunction", "content": "Returns true if self represents a function. false otherwise . Signature . export declare const isFunction: Predicate.Predicate&lt;Type&gt; . ", "url": "/0.1.0/effect-lib/types/TypesCategory.ts.html#isfunction", "relUrl": "/effect-lib/types/TypesCategory.ts.html#isfunction" },"1911": { "doc": "types/TypesCategory.ts", "title": "isNonPrimitive", "content": "Returns true if self represents a non-primitive. false otherwise . Signature . export declare const isNonPrimitive: Predicate.Predicate&lt;Type&gt; . ", "url": "/0.1.0/effect-lib/types/TypesCategory.ts.html#isnonprimitive", "relUrl": "/effect-lib/types/TypesCategory.ts.html#isnonprimitive" },"1912": { "doc": "types/TypesCategory.ts", "title": "isNull", "content": "Returns true if self is null. false otherwise . Signature . export declare const isNull: Predicate.Predicate&lt;Type&gt; . ", "url": "/0.1.0/effect-lib/types/TypesCategory.ts.html#isnull", "relUrl": "/effect-lib/types/TypesCategory.ts.html#isnull" },"1913": { "doc": "types/TypesCategory.ts", "title": "isNumber", "content": "Returns true if self represents a number. false otherwise . Signature . export declare const isNumber: Predicate.Predicate&lt;Type&gt; . ", "url": "/0.1.0/effect-lib/types/TypesCategory.ts.html#isnumber", "relUrl": "/effect-lib/types/TypesCategory.ts.html#isnumber" },"1914": { "doc": "types/TypesCategory.ts", "title": "isPrimitive", "content": "Returns true if self represents a primitive. false otherwise . Signature . export declare const isPrimitive: Predicate.Predicate&lt;Type&gt; . ", "url": "/0.1.0/effect-lib/types/TypesCategory.ts.html#isprimitive", "relUrl": "/effect-lib/types/TypesCategory.ts.html#isprimitive" },"1915": { "doc": "types/TypesCategory.ts", "title": "isRecord", "content": "Returns true if self represents a record. false otherwise . Signature . export declare const isRecord: Predicate.Predicate&lt;Type&gt; . ", "url": "/0.1.0/effect-lib/types/TypesCategory.ts.html#isrecord", "relUrl": "/effect-lib/types/TypesCategory.ts.html#isrecord" },"1916": { "doc": "types/TypesCategory.ts", "title": "isString", "content": "Returns true if self represents a string. false otherwise . Signature . export declare const isString: Predicate.Predicate&lt;Type&gt; . ", "url": "/0.1.0/effect-lib/types/TypesCategory.ts.html#isstring", "relUrl": "/effect-lib/types/TypesCategory.ts.html#isstring" },"1917": { "doc": "types/TypesCategory.ts", "title": "isSymbol", "content": "Returns true if self represents a symbol. false otherwise . Signature . export declare const isSymbol: Predicate.Predicate&lt;Type&gt; . ", "url": "/0.1.0/effect-lib/types/TypesCategory.ts.html#issymbol", "relUrl": "/effect-lib/types/TypesCategory.ts.html#issymbol" },"1918": { "doc": "types/TypesCategory.ts", "title": "isUndefined", "content": "Returns true if self is undefined. false otherwise . Signature . export declare const isUndefined: Predicate.Predicate&lt;Type&gt; . ", "url": "/0.1.0/effect-lib/types/TypesCategory.ts.html#isundefined", "relUrl": "/effect-lib/types/TypesCategory.ts.html#isundefined" },"1919": { "doc": "types/TypesCategory.ts", "title": "types/TypesCategory.ts", "content": " ", "url": "/0.1.0/effect-lib/types/TypesCategory.ts.html", "relUrl": "/effect-lib/types/TypesCategory.ts.html" },"1920": { "doc": "Parameters/ValueOrder.ts", "title": "ValueOrder overview", "content": "This module implements a type that represents an order on the properties of a non-primitive value. A PPValueOrder can be used as the propertySortOrder field of a PPNonPrimitiveParameters so that properties are sorted before being formatted. Several pre-built orderings are provided (by prototypal depth, by key, by callability, by key type, by enumerability, by source). They can be combined with Order.combine from the Effect library if a multi-criteria order is needed. ", "url": "/0.1.0/pretty-print/Parameters/ValueOrder.ts.html#valueorder-overview", "relUrl": "/pretty-print/Parameters/ValueOrder.ts.html#valueorder-overview" },"1921": { "doc": "Parameters/ValueOrder.ts", "title": "Table of contents", "content": ". | Models . | Type (interface) | . | Ordering . | byCallability | byEnumerability | byKeyType | byOneLineStringKey | byProtoDepth | bySource | . | . ", "url": "/0.1.0/pretty-print/Parameters/ValueOrder.ts.html", "relUrl": "/pretty-print/Parameters/ValueOrder.ts.html" },"1922": { "doc": "Parameters/ValueOrder.ts", "title": "Models", "content": " ", "url": "/0.1.0/pretty-print/Parameters/ValueOrder.ts.html#models", "relUrl": "/pretty-print/Parameters/ValueOrder.ts.html#models" },"1923": { "doc": "Parameters/ValueOrder.ts", "title": "Type (interface)", "content": "Type of a PPValueOrder . Signature . export interface Type extends Order.Order&lt;PPValue.Any&gt; {} . ", "url": "/0.1.0/pretty-print/Parameters/ValueOrder.ts.html#type-interface", "relUrl": "/pretty-print/Parameters/ValueOrder.ts.html#type-interface" },"1924": { "doc": "Parameters/ValueOrder.ts", "title": "Ordering", "content": " ", "url": "/0.1.0/pretty-print/Parameters/ValueOrder.ts.html#ordering", "relUrl": "/pretty-print/Parameters/ValueOrder.ts.html#ordering" },"1925": { "doc": "Parameters/ValueOrder.ts", "title": "byCallability", "content": "Order instance based on the callability of the content property (non functions first, then functions) . Signature . export declare const byCallability: Type . ", "url": "/0.1.0/pretty-print/Parameters/ValueOrder.ts.html#bycallability", "relUrl": "/pretty-print/Parameters/ValueOrder.ts.html#bycallability" },"1926": { "doc": "Parameters/ValueOrder.ts", "title": "byEnumerability", "content": "Order instance based on the enumerability of the property to which the value belongs (non- enumerable keys first, then enumerable keys) . Signature . export declare const byEnumerability: Type . ", "url": "/0.1.0/pretty-print/Parameters/ValueOrder.ts.html#byenumerability", "relUrl": "/pretty-print/Parameters/ValueOrder.ts.html#byenumerability" },"1927": { "doc": "Parameters/ValueOrder.ts", "title": "byKeyType", "content": "Order instance based on the type of the key associated to the value (symbolic keys first, then string keys) . Signature . export declare const byKeyType: Type . ", "url": "/0.1.0/pretty-print/Parameters/ValueOrder.ts.html#bykeytype", "relUrl": "/pretty-print/Parameters/ValueOrder.ts.html#bykeytype" },"1928": { "doc": "Parameters/ValueOrder.ts", "title": "byOneLineStringKey", "content": "Order instance based on the oneLineStringKey property . Signature . export declare const byOneLineStringKey: Type . ", "url": "/0.1.0/pretty-print/Parameters/ValueOrder.ts.html#byonelinestringkey", "relUrl": "/pretty-print/Parameters/ValueOrder.ts.html#byonelinestringkey" },"1929": { "doc": "Parameters/ValueOrder.ts", "title": "byProtoDepth", "content": "Order instance based on the protoDepth property, lowest depth first . Signature . export declare const byProtoDepth: Type . ", "url": "/0.1.0/pretty-print/Parameters/ValueOrder.ts.html#byprotodepth", "relUrl": "/pretty-print/Parameters/ValueOrder.ts.html#byprotodepth" },"1930": { "doc": "Parameters/ValueOrder.ts", "title": "bySource", "content": "Order instance based on the source of the property (first from iterating on the non primitive value then from Object.ownKeys) . Signature . export declare const bySource: Type . ", "url": "/0.1.0/pretty-print/Parameters/ValueOrder.ts.html#bysource", "relUrl": "/pretty-print/Parameters/ValueOrder.ts.html#bysource" },"1931": { "doc": "Parameters/ValueOrder.ts", "title": "Parameters/ValueOrder.ts", "content": " ", "url": "/0.1.0/pretty-print/Parameters/ValueOrder.ts.html", "relUrl": "/pretty-print/Parameters/ValueOrder.ts.html" },"1932": { "doc": "formatting/DateTimeFormat/DateTimeFormatContext/WeekDayNames.ts", "title": "WeekDayNames overview", "content": "Module that implements a type that represents the names of the seven days of a week . ", "url": "/0.1.0/conversions/formatting/DateTimeFormat/DateTimeFormatContext/WeekDayNames.ts.html#weekdaynames-overview", "relUrl": "/conversions/formatting/DateTimeFormat/DateTimeFormatContext/WeekDayNames.ts.html#weekdaynames-overview" },"1933": { "doc": "formatting/DateTimeFormat/DateTimeFormatContext/WeekDayNames.ts", "title": "Table of contents", "content": ". | Models . | Type (interface) | . | . ", "url": "/0.1.0/conversions/formatting/DateTimeFormat/DateTimeFormatContext/WeekDayNames.ts.html", "relUrl": "/conversions/formatting/DateTimeFormat/DateTimeFormatContext/WeekDayNames.ts.html" },"1934": { "doc": "formatting/DateTimeFormat/DateTimeFormatContext/WeekDayNames.ts", "title": "Models", "content": " ", "url": "/0.1.0/conversions/formatting/DateTimeFormat/DateTimeFormatContext/WeekDayNames.ts.html#models", "relUrl": "/conversions/formatting/DateTimeFormat/DateTimeFormatContext/WeekDayNames.ts.html#models" },"1935": { "doc": "formatting/DateTimeFormat/DateTimeFormatContext/WeekDayNames.ts", "title": "Type (interface)", "content": "Type of a CVWeekDayNames . Signature . export interface Type extends MTypes.ReadonlyTuple&lt;string, 7&gt; {} . ", "url": "/0.1.0/conversions/formatting/DateTimeFormat/DateTimeFormatContext/WeekDayNames.ts.html#type-interface", "relUrl": "/conversions/formatting/DateTimeFormat/DateTimeFormatContext/WeekDayNames.ts.html#type-interface" },"1936": { "doc": "formatting/DateTimeFormat/DateTimeFormatContext/WeekDayNames.ts", "title": "formatting/DateTimeFormat/DateTimeFormatContext/WeekDayNames.ts", "content": " ", "url": "/0.1.0/conversions/formatting/DateTimeFormat/DateTimeFormatContext/WeekDayNames.ts.html", "relUrl": "/conversions/formatting/DateTimeFormat/DateTimeFormatContext/WeekDayNames.ts.html" },"1937": { "doc": "DateTime/date-time-constants.ts", "title": "date-time-constants overview", "content": "This module defines constants used by the CVGregorianDate, CVIsoDate and CVDateTime modules . ", "url": "/0.1.0/conversions/DateTime/date-time-constants.ts.html#date-time-constants-overview", "relUrl": "/conversions/DateTime/date-time-constants.ts.html#date-time-constants-overview" },"1938": { "doc": "DateTime/date-time-constants.ts", "title": "Table of contents", "content": ". | Constants . | COMMON_YEAR_MS | DAY_MS | FOUR_HUNDRED_YEARS_MS | FOUR_YEARS_MS | HOUR_MS | HUNDRED_YEARS_MS | LEAP_YEAR_MS | LONG_YEAR_MS | MAX_FULL_YEAR | MAX_TIMESTAMP | MINUTE_MS | MIN_FULL_YEAR | MIN_TIMESTAMP | SECOND_MS | SHORT_YEAR_MS | WEEK_MS | . | . ", "url": "/0.1.0/conversions/DateTime/date-time-constants.ts.html", "relUrl": "/conversions/DateTime/date-time-constants.ts.html" },"1939": { "doc": "DateTime/date-time-constants.ts", "title": "Constants", "content": " ", "url": "/0.1.0/conversions/DateTime/date-time-constants.ts.html#constants", "relUrl": "/conversions/DateTime/date-time-constants.ts.html#constants" },"1940": { "doc": "DateTime/date-time-constants.ts", "title": "COMMON_YEAR_MS", "content": "Duration of a normal year in milliseconds . Signature . export declare const COMMON_YEAR_MS: number . ", "url": "/0.1.0/conversions/DateTime/date-time-constants.ts.html#common_year_ms", "relUrl": "/conversions/DateTime/date-time-constants.ts.html#common_year_ms" },"1941": { "doc": "DateTime/date-time-constants.ts", "title": "DAY_MS", "content": "Duration of a day in milliseconds . Signature . export declare const DAY_MS: number . ", "url": "/0.1.0/conversions/DateTime/date-time-constants.ts.html#day_ms", "relUrl": "/conversions/DateTime/date-time-constants.ts.html#day_ms" },"1942": { "doc": "DateTime/date-time-constants.ts", "title": "FOUR_HUNDRED_YEARS_MS", "content": "Duration in milliseconds of a 400-year period that has a leap year every 4th year except the 100th year. But the 400th year is a leap year . Signature . export declare const FOUR_HUNDRED_YEARS_MS: number . ", "url": "/0.1.0/conversions/DateTime/date-time-constants.ts.html#four_hundred_years_ms", "relUrl": "/conversions/DateTime/date-time-constants.ts.html#four_hundred_years_ms" },"1943": { "doc": "DateTime/date-time-constants.ts", "title": "FOUR_YEARS_MS", "content": "Duration in milliseconds of a four-year period containing a leap year . Signature . export declare const FOUR_YEARS_MS: number . ", "url": "/0.1.0/conversions/DateTime/date-time-constants.ts.html#four_years_ms", "relUrl": "/conversions/DateTime/date-time-constants.ts.html#four_years_ms" },"1944": { "doc": "DateTime/date-time-constants.ts", "title": "HOUR_MS", "content": "Duration of an hour in milliseconds . Signature . export declare const HOUR_MS: number . ", "url": "/0.1.0/conversions/DateTime/date-time-constants.ts.html#hour_ms", "relUrl": "/conversions/DateTime/date-time-constants.ts.html#hour_ms" },"1945": { "doc": "DateTime/date-time-constants.ts", "title": "HUNDRED_YEARS_MS", "content": "Duration in milliseconds of a 100-year period that has a leap year every 4th year except the 100th year . Signature . export declare const HUNDRED_YEARS_MS: number . ", "url": "/0.1.0/conversions/DateTime/date-time-constants.ts.html#hundred_years_ms", "relUrl": "/conversions/DateTime/date-time-constants.ts.html#hundred_years_ms" },"1946": { "doc": "DateTime/date-time-constants.ts", "title": "LEAP_YEAR_MS", "content": "Duration of a leap year in milliseconds . Signature . export declare const LEAP_YEAR_MS: number . ", "url": "/0.1.0/conversions/DateTime/date-time-constants.ts.html#leap_year_ms", "relUrl": "/conversions/DateTime/date-time-constants.ts.html#leap_year_ms" },"1947": { "doc": "DateTime/date-time-constants.ts", "title": "LONG_YEAR_MS", "content": "Duration of a long iso year in milliseconds . Signature . export declare const LONG_YEAR_MS: number . ", "url": "/0.1.0/conversions/DateTime/date-time-constants.ts.html#long_year_ms", "relUrl": "/conversions/DateTime/date-time-constants.ts.html#long_year_ms" },"1948": { "doc": "DateTime/date-time-constants.ts", "title": "MAX_FULL_YEAR", "content": "Maximal usable year (ECMA-262) . Signature . export declare const MAX_FULL_YEAR: number . ", "url": "/0.1.0/conversions/DateTime/date-time-constants.ts.html#max_full_year", "relUrl": "/conversions/DateTime/date-time-constants.ts.html#max_full_year" },"1949": { "doc": "DateTime/date-time-constants.ts", "title": "MAX_TIMESTAMP", "content": "Maximal usable timestamp (ECMA-262) . Signature . export declare const MAX_TIMESTAMP: 8640000000000000 . ", "url": "/0.1.0/conversions/DateTime/date-time-constants.ts.html#max_timestamp", "relUrl": "/conversions/DateTime/date-time-constants.ts.html#max_timestamp" },"1950": { "doc": "DateTime/date-time-constants.ts", "title": "MINUTE_MS", "content": "Duration of a minute in milliseconds . Signature . export declare const MINUTE_MS: number . ", "url": "/0.1.0/conversions/DateTime/date-time-constants.ts.html#minute_ms", "relUrl": "/conversions/DateTime/date-time-constants.ts.html#minute_ms" },"1951": { "doc": "DateTime/date-time-constants.ts", "title": "MIN_FULL_YEAR", "content": "Minimal usable year (ECMA-262) . Signature . export declare const MIN_FULL_YEAR: number . ", "url": "/0.1.0/conversions/DateTime/date-time-constants.ts.html#min_full_year", "relUrl": "/conversions/DateTime/date-time-constants.ts.html#min_full_year" },"1952": { "doc": "DateTime/date-time-constants.ts", "title": "MIN_TIMESTAMP", "content": "Minimal usable timestamp (ECMA-262) . Signature . export declare const MIN_TIMESTAMP: number . ", "url": "/0.1.0/conversions/DateTime/date-time-constants.ts.html#min_timestamp", "relUrl": "/conversions/DateTime/date-time-constants.ts.html#min_timestamp" },"1953": { "doc": "DateTime/date-time-constants.ts", "title": "SECOND_MS", "content": "Duration of a second in milliseconds . Signature . export declare const SECOND_MS: 1000 . ", "url": "/0.1.0/conversions/DateTime/date-time-constants.ts.html#second_ms", "relUrl": "/conversions/DateTime/date-time-constants.ts.html#second_ms" },"1954": { "doc": "DateTime/date-time-constants.ts", "title": "SHORT_YEAR_MS", "content": "Duration of a short iso year in milliseconds . Signature . export declare const SHORT_YEAR_MS: number . ", "url": "/0.1.0/conversions/DateTime/date-time-constants.ts.html#short_year_ms", "relUrl": "/conversions/DateTime/date-time-constants.ts.html#short_year_ms" },"1955": { "doc": "DateTime/date-time-constants.ts", "title": "WEEK_MS", "content": "Duration of a week in milliseconds . Signature . export declare const WEEK_MS: number . ", "url": "/0.1.0/conversions/DateTime/date-time-constants.ts.html#week_ms", "relUrl": "/conversions/DateTime/date-time-constants.ts.html#week_ms" },"1956": { "doc": "DateTime/date-time-constants.ts", "title": "DateTime/date-time-constants.ts", "content": " ", "url": "/0.1.0/conversions/DateTime/date-time-constants.ts.html", "relUrl": "/conversions/DateTime/date-time-constants.ts.html" },"1957": { "doc": "pretty-print", "title": "pretty-print", "content": "pretty-print 1.0.7 . A functional library to pretty-print and treeify objects . ", "url": "/0.1.0/docs/pretty-print", "relUrl": "/docs/pretty-print" },"1958": { "doc": "ansi-styles", "title": "ansi-styles", "content": "ansi-styles 1.0.7 . A functional library to style your strings in terminals . ", "url": "/0.1.0/docs/ansi-styles", "relUrl": "/docs/ansi-styles" },"1959": { "doc": "conversions", "title": "conversions", "content": "conversions 1.0.7 . A functional library to replace partially the native Intl API . ", "url": "/0.1.0/docs/conversions", "relUrl": "/docs/conversions" },"1960": { "doc": "effect-lib", "title": "effect-lib", "content": "effect-lib 0.20.0 . An extension to the official Effect library . ", "url": "/0.1.0/docs/effect-lib", "relUrl": "/docs/effect-lib" },"1961": { "doc": "Packages", "title": "Packages", "content": "effect-libs 0.1.0 . effect-libs is a set of open-source libraries to be used in complement to the effect library. Extends some Effect modules (Array, Chunk, Option, Either, String, …). Adds extra-functionalities such as date and number parsing/formatting, sscanf/sprintf templating, number rounding, object pretty-printing, colored terminal printing, a simple yet very efficient matcher and a tree with cycle detection . ", "url": "/0.1.0/", "relUrl": "/" },"1962": { "doc": "types/types.ts", "title": "types overview", "content": "Foundational primitive / container types used throughout effect-lib. ", "url": "/0.1.0/effect-lib/types/types.ts.html#types-overview", "relUrl": "/effect-lib/types/types.ts.html#types-overview" },"1963": { "doc": "types/types.ts", "title": "Mental model", "content": ". | Containers: NonPrimitive, Object, Pair, Singleton, OverOne (non-empty), OverTwo (≥ 2 elements), and their readonly variants — typed views over Array/ReadonlyArray used by the rest of the package. | Primitives: Primitive, NonNullablePrimitive, Unknown — describe the shape space of JavaScript values. | All values type union: Unknown — same as unknown but defined as a type union, allows pattern matching. | Function shapes: AnyFunction, OneArgFunction, StringTransformer, NumberFromString. | Predicate / refinement shapes: AnyPredicate, AnyRefinement, RefinementFrom. | Type-level utilities: Data strips inherited / pipeable / equality fields off an object type to produce its plain-data view (used by class constructors); Proto is its complement; Tuple&lt;T, N&gt; materializes a fixed-size tuple; IntersectAndSimplify and ToKeyIntersection help build intersections in conditional types. | . Runtime guards for these shapes live in MPredicate. ", "url": "/0.1.0/effect-lib/types/types.ts.html#mental-model", "relUrl": "/effect-lib/types/types.ts.html#mental-model" },"1964": { "doc": "types/types.ts", "title": "Common tasks", "content": ". | Tuple / array shapes: {@link Pair}, {@link Singleton}, {@link OverOne}, {@link OverTwo} | Primitive shapes: {@link Primitive}, {@link NonNullablePrimitive}, {@link NonPrimitive}, {@link Unknown} | Type-level helpers: {@link Data}, {@link Proto}, {@link Tuple}, {@link ReadonlyTuple}, {@link MapToTarget}, {@link IntersectAndSimplify}, {@link ToKeyIntersection}, {@link WithMutable}, {@link WithRequired} | . ", "url": "/0.1.0/effect-lib/types/types.ts.html#common-tasks", "relUrl": "/effect-lib/types/types.ts.html#common-tasks" },"1965": { "doc": "types/types.ts", "title": "Table of contents", "content": ". | Models . | AnyArray (interface) | AnyFunction (interface) | AnyPredicate (type alias) | AnyReadonlyArray (interface) | AnyRefinement (type alias) | EmptyArray (type alias) | EmptyReadonlyArray (type alias) | NonNullablePrimitive (type alias) | NonPrimitive (interface) | NumberFromString (interface) | Object (interface) | OneArgFunction (interface) | OverOne (type alias) | OverTwo (type alias) | Pair (type alias) | Primitive (type alias) | ReadonlyNonPrimitive (interface) | ReadonlyObject (interface) | ReadonlyOverOne (type alias) | ReadonlyOverTwo (type alias) | ReadonlyPair (type alias) | ReadonlySingleton (type alias) | ReadonlyUnknown (type alias) | RefinementFrom (type alias) | Singleton (type alias) | StringTransformer (interface) | Unknown (type alias) | . | Utility types . | Data (type alias) | IntersectAndSimplify (type alias) | MapToTarget (type alias) | Proto (type alias) | ReadonlyTuple (type alias) | ToKeyIntersection (type alias) | Tuple (type alias) | WithMutable (type alias) | WithRequired (type alias) | . | . ", "url": "/0.1.0/effect-lib/types/types.ts.html", "relUrl": "/effect-lib/types/types.ts.html" },"1966": { "doc": "types/types.ts", "title": "Models", "content": " ", "url": "/0.1.0/effect-lib/types/types.ts.html#models", "relUrl": "/effect-lib/types/types.ts.html#models" },"1967": { "doc": "types/types.ts", "title": "AnyArray (interface)", "content": "Type that represents an array . Signature . export interface AnyArray extends Array&lt;any&gt; {} . ", "url": "/0.1.0/effect-lib/types/types.ts.html#anyarray-interface", "relUrl": "/effect-lib/types/types.ts.html#anyarray-interface" },"1968": { "doc": "types/types.ts", "title": "AnyFunction (interface)", "content": "Type that represents a function . Signature . export interface AnyFunction { (...args: ReadonlyArray&lt;any&gt;): any } . ", "url": "/0.1.0/effect-lib/types/types.ts.html#anyfunction-interface", "relUrl": "/effect-lib/types/types.ts.html#anyfunction-interface" },"1969": { "doc": "types/types.ts", "title": "AnyPredicate (type alias)", "content": "Type that represents any predicate or refinement . Signature . export type AnyPredicate = Predicate.Predicate.Any . ", "url": "/0.1.0/effect-lib/types/types.ts.html#anypredicate-type-alias", "relUrl": "/effect-lib/types/types.ts.html#anypredicate-type-alias" },"1970": { "doc": "types/types.ts", "title": "AnyReadonlyArray (interface)", "content": "Type that represents a ReadonlyArray . Signature . export interface AnyReadonlyArray extends ReadonlyArray&lt;any&gt; {} . ", "url": "/0.1.0/effect-lib/types/types.ts.html#anyreadonlyarray-interface", "relUrl": "/effect-lib/types/types.ts.html#anyreadonlyarray-interface" },"1971": { "doc": "types/types.ts", "title": "AnyRefinement (type alias)", "content": "Type that represents any refinement . Signature . export type AnyRefinement = Predicate.Refinement.Any . ", "url": "/0.1.0/effect-lib/types/types.ts.html#anyrefinement-type-alias", "relUrl": "/effect-lib/types/types.ts.html#anyrefinement-type-alias" },"1972": { "doc": "types/types.ts", "title": "EmptyArray (type alias)", "content": "Type that represents an empty array or tuple . Signature . export type EmptyArray = [] . ", "url": "/0.1.0/effect-lib/types/types.ts.html#emptyarray-type-alias", "relUrl": "/effect-lib/types/types.ts.html#emptyarray-type-alias" },"1973": { "doc": "types/types.ts", "title": "EmptyReadonlyArray (type alias)", "content": "Type that represents an empty array or tuple . Signature . export type EmptyReadonlyArray = readonly [] . ", "url": "/0.1.0/effect-lib/types/types.ts.html#emptyreadonlyarray-type-alias", "relUrl": "/effect-lib/types/types.ts.html#emptyreadonlyarray-type-alias" },"1974": { "doc": "types/types.ts", "title": "NonNullablePrimitive (type alias)", "content": "Type that represents a primitive except null and undefined . Signature . export type NonNullablePrimitive = string | number | bigint | boolean | symbol . ", "url": "/0.1.0/effect-lib/types/types.ts.html#nonnullableprimitive-type-alias", "relUrl": "/effect-lib/types/types.ts.html#nonnullableprimitive-type-alias" },"1975": { "doc": "types/types.ts", "title": "NonPrimitive (interface)", "content": "Type that represents anything but a JavaScript primitive. It includes records (in their usual computer science meaning), class instances, arrays, and functions but not null or undefined. Equivalent to the Effect ObjectKeyword type. Should be defined as an alias to the object type but the object type cannot be indexed so this definition is better . Signature . export interface NonPrimitive { // DO NOT REPLACE any by unknown: in that case, arrays and functions are excluded. [key: PropertyKey]: any } . ", "url": "/0.1.0/effect-lib/types/types.ts.html#nonprimitive-interface", "relUrl": "/effect-lib/types/types.ts.html#nonprimitive-interface" },"1976": { "doc": "types/types.ts", "title": "NumberFromString (interface)", "content": "Type that represents a function that transforms a string into a number. Signature . export interface NumberFromString extends OneArgFunction&lt;string, number&gt; {} . ", "url": "/0.1.0/effect-lib/types/types.ts.html#numberfromstring-interface", "relUrl": "/effect-lib/types/types.ts.html#numberfromstring-interface" },"1977": { "doc": "types/types.ts", "title": "Object (interface)", "content": "Type that represents a real object, not an array, not a function, not null. However, this type does not represent a class instance. So prefer using NonPrimitive when class instances are important (even though this type includes functions and arrays which may not be desirable) . Signature . export interface Object { [x: PropertyKey]: unknown } . ", "url": "/0.1.0/effect-lib/types/types.ts.html#object-interface", "relUrl": "/effect-lib/types/types.ts.html#object-interface" },"1978": { "doc": "types/types.ts", "title": "OneArgFunction (interface)", "content": "Type that represents a function with one argument . Signature . export interface OneArgFunction&lt;in A, out B = A&gt; { (a: A): B } . ", "url": "/0.1.0/effect-lib/types/types.ts.html#oneargfunction-interface", "relUrl": "/effect-lib/types/types.ts.html#oneargfunction-interface" },"1979": { "doc": "types/types.ts", "title": "OverOne (type alias)", "content": "Type that represents a non empty array . Signature . export type OverOne&lt;A&gt; = [A, ...Array&lt;A&gt;] . ", "url": "/0.1.0/effect-lib/types/types.ts.html#overone-type-alias", "relUrl": "/effect-lib/types/types.ts.html#overone-type-alias" },"1980": { "doc": "types/types.ts", "title": "OverTwo (type alias)", "content": "Type that represents an array with at least two elements . Signature . export type OverTwo&lt;A&gt; = [A, A, ...Array&lt;A&gt;] . ", "url": "/0.1.0/effect-lib/types/types.ts.html#overtwo-type-alias", "relUrl": "/effect-lib/types/types.ts.html#overtwo-type-alias" },"1981": { "doc": "types/types.ts", "title": "Pair (type alias)", "content": "Type that represents a tuple or array with two elements . Signature . export type Pair&lt;A, B&gt; = [A, B] . ", "url": "/0.1.0/effect-lib/types/types.ts.html#pair-type-alias", "relUrl": "/effect-lib/types/types.ts.html#pair-type-alias" },"1982": { "doc": "types/types.ts", "title": "Primitive (type alias)", "content": "Type that represents a primitive . Signature . export type Primitive = NonNullablePrimitive | null | undefined . ", "url": "/0.1.0/effect-lib/types/types.ts.html#primitive-type-alias", "relUrl": "/effect-lib/types/types.ts.html#primitive-type-alias" },"1983": { "doc": "types/types.ts", "title": "ReadonlyNonPrimitive (interface)", "content": "Same as NonPrimitive but readonly . Signature . export interface ReadonlyNonPrimitive { // DO NOT REPLACE any by unknown: in that case, arrays and functions are excluded. readonly [key: PropertyKey]: any } . ", "url": "/0.1.0/effect-lib/types/types.ts.html#readonlynonprimitive-interface", "relUrl": "/effect-lib/types/types.ts.html#readonlynonprimitive-interface" },"1984": { "doc": "types/types.ts", "title": "ReadonlyObject (interface)", "content": "Same as Object but readonly . Signature . export interface ReadonlyObject { readonly [x: PropertyKey]: unknown } . ", "url": "/0.1.0/effect-lib/types/types.ts.html#readonlyobject-interface", "relUrl": "/effect-lib/types/types.ts.html#readonlyobject-interface" },"1985": { "doc": "types/types.ts", "title": "ReadonlyOverOne (type alias)", "content": "Type that represents a non empty array . Signature . export type ReadonlyOverOne&lt;A&gt; = readonly [A, ...ReadonlyArray&lt;A&gt;] . ", "url": "/0.1.0/effect-lib/types/types.ts.html#readonlyoverone-type-alias", "relUrl": "/effect-lib/types/types.ts.html#readonlyoverone-type-alias" },"1986": { "doc": "types/types.ts", "title": "ReadonlyOverTwo (type alias)", "content": "Type that represents an array with at least two elements . Signature . export type ReadonlyOverTwo&lt;A&gt; = readonly [A, A, ...ReadonlyArray&lt;A&gt;] . ", "url": "/0.1.0/effect-lib/types/types.ts.html#readonlyovertwo-type-alias", "relUrl": "/effect-lib/types/types.ts.html#readonlyovertwo-type-alias" },"1987": { "doc": "types/types.ts", "title": "ReadonlyPair (type alias)", "content": "Type that represents a tuple or array with two elements . Signature . export type ReadonlyPair&lt;A, B&gt; = readonly [A, B] . ", "url": "/0.1.0/effect-lib/types/types.ts.html#readonlypair-type-alias", "relUrl": "/effect-lib/types/types.ts.html#readonlypair-type-alias" },"1988": { "doc": "types/types.ts", "title": "ReadonlySingleton (type alias)", "content": "Type that represents a tuple or array with one element . Signature . export type ReadonlySingleton&lt;A&gt; = readonly [A] . ", "url": "/0.1.0/effect-lib/types/types.ts.html#readonlysingleton-type-alias", "relUrl": "/effect-lib/types/types.ts.html#readonlysingleton-type-alias" },"1989": { "doc": "types/types.ts", "title": "ReadonlyUnknown (type alias)", "content": "Same as Unknown but readonly . Signature . export type ReadonlyUnknown = Primitive | ReadonlyNonPrimitive . ", "url": "/0.1.0/effect-lib/types/types.ts.html#readonlyunknown-type-alias", "relUrl": "/effect-lib/types/types.ts.html#readonlyunknown-type-alias" },"1990": { "doc": "types/types.ts", "title": "RefinementFrom (type alias)", "content": "Type that represents any refinement from a given type . Signature . export type RefinementFrom&lt;Source&gt; = Predicate.Refinement&lt;Source, any&gt; . ", "url": "/0.1.0/effect-lib/types/types.ts.html#refinementfrom-type-alias", "relUrl": "/effect-lib/types/types.ts.html#refinementfrom-type-alias" },"1991": { "doc": "types/types.ts", "title": "Singleton (type alias)", "content": "Type that represents a tuple or array with one element . Signature . export type Singleton&lt;A&gt; = [A] . ", "url": "/0.1.0/effect-lib/types/types.ts.html#singleton-type-alias", "relUrl": "/effect-lib/types/types.ts.html#singleton-type-alias" },"1992": { "doc": "types/types.ts", "title": "StringTransformer (interface)", "content": "Type of a string transformer, i.e. a function that transforms a string into another one . Signature . export interface StringTransformer extends OneArgFunction&lt;string&gt; {} . ", "url": "/0.1.0/effect-lib/types/types.ts.html#stringtransformer-interface", "relUrl": "/effect-lib/types/types.ts.html#stringtransformer-interface" },"1993": { "doc": "types/types.ts", "title": "Unknown (type alias)", "content": "Type that represents all possible Javascript values but not all possible Typescript types (it does not represent Branded types for instance) . Signature . export type Unknown = Primitive | NonPrimitive . ", "url": "/0.1.0/effect-lib/types/types.ts.html#unknown-type-alias", "relUrl": "/effect-lib/types/types.ts.html#unknown-type-alias" },"1994": { "doc": "types/types.ts", "title": "Utility types", "content": " ", "url": "/0.1.0/effect-lib/types/types.ts.html#utility-types", "relUrl": "/effect-lib/types/types.ts.html#utility-types" },"1995": { "doc": "types/types.ts", "title": "Data (type alias)", "content": "Utility type that removes all non-data. An Optionals parameter can be passed with a list of fields to make optional . Signature . export type Data&lt;T extends NonPrimitive, Optionals extends string = never&gt; = { [k in keyof T as [k] extends [ symbol | `_${string}` | \"toString\" | \"toJSON\" | \"pipe\" | typeof Equal.symbol | typeof Hash.symbol | Optionals ] ? never : k]: T[k] } &amp; { [k in keyof T as [k] extends [Optionals] ? k : never]?: T[k] } . ", "url": "/0.1.0/effect-lib/types/types.ts.html#data-type-alias", "relUrl": "/effect-lib/types/types.ts.html#data-type-alias" },"1996": { "doc": "types/types.ts", "title": "IntersectAndSimplify (type alias)", "content": "Utility type that creates an intersection and simplifies it which Typescript does not do by itself (see https://stackoverflow.com/questions/72395823/why-does-typescript-not-simplify-the- intersection-of-a-type-and-one-of-its-super) . Signature . export type IntersectAndSimplify&lt;T, U&gt; = [T] extends [U] ? T : [U] extends [T] ? U : T &amp; U . ", "url": "/0.1.0/effect-lib/types/types.ts.html#intersectandsimplify-type-alias", "relUrl": "/effect-lib/types/types.ts.html#intersectandsimplify-type-alias" },"1997": { "doc": "types/types.ts", "title": "MapToTarget (type alias)", "content": "Utility type that changes the types of all keys of a tuple, array, struct or record to Target . Signature . export type MapToTarget&lt;T, Target&gt; = { [k in keyof T]: Target } . ", "url": "/0.1.0/effect-lib/types/types.ts.html#maptotarget-type-alias", "relUrl": "/effect-lib/types/types.ts.html#maptotarget-type-alias" },"1998": { "doc": "types/types.ts", "title": "Proto (type alias)", "content": "Utility type that removes all data from a type. Signature . export type Proto&lt;T extends NonPrimitive&gt; = Omit&lt;T, keyof Data&lt;T&gt;&gt; . ", "url": "/0.1.0/effect-lib/types/types.ts.html#proto-type-alias", "relUrl": "/effect-lib/types/types.ts.html#proto-type-alias" },"1999": { "doc": "types/types.ts", "title": "ReadonlyTuple (type alias)", "content": "Utility type that generates a readonly tuple of N T’s . Signature . export type ReadonlyTuple&lt;T, N extends number&gt; = Readonly&lt;Tuple&lt;T, N&gt;&gt; . ", "url": "/0.1.0/effect-lib/types/types.ts.html#readonlytuple-type-alias", "relUrl": "/effect-lib/types/types.ts.html#readonlytuple-type-alias" },"2000": { "doc": "types/types.ts", "title": "ToKeyIntersection (type alias)", "content": "Utility type that creates an intersection of the types all keys of a type. Meant to be used with Tuples even though not set as a constraint . Signature . export type ToKeyIntersection&lt;T&gt; = [ { readonly [K in keyof T]: (x: T[K]) =&gt; void } ] extends [ { readonly [K: number]: (x: infer I) =&gt; void } ] ? I : never . ", "url": "/0.1.0/effect-lib/types/types.ts.html#tokeyintersection-type-alias", "relUrl": "/effect-lib/types/types.ts.html#tokeyintersection-type-alias" },"2001": { "doc": "types/types.ts", "title": "Tuple (type alias)", "content": "Utility type that generates a tuple of N T’s . Signature . export type Tuple&lt;T, N extends number&gt; = N extends N ? (number extends N ? Array&lt;T&gt; : _TupleOf&lt;T, N, []&gt;) : never . ", "url": "/0.1.0/effect-lib/types/types.ts.html#tuple-type-alias", "relUrl": "/effect-lib/types/types.ts.html#tuple-type-alias" },"2002": { "doc": "types/types.ts", "title": "WithMutable (type alias)", "content": "Utility type that makes field field of target type X mutable . Signature . export type WithMutable&lt;X, field extends string | symbol&gt; = { readonly [k in keyof X as [k] extends [field] ? never : k]: X[k] } &amp; { -readonly [k in keyof X as [k] extends readonly [field] ? k : never]: X[k] } . ", "url": "/0.1.0/effect-lib/types/types.ts.html#withmutable-type-alias", "relUrl": "/effect-lib/types/types.ts.html#withmutable-type-alias" },"2003": { "doc": "types/types.ts", "title": "WithRequired (type alias)", "content": "Utility type that makes field field of target type X required . Signature . export type WithRequired&lt;X, field extends string | symbol&gt; = { readonly [k in keyof X as readonly [k] extends readonly [field] ? never : k]: X[k] } &amp; { readonly [k in keyof X as readonly [k] extends readonly [field] ? k : never]-?: X[k] } . ", "url": "/0.1.0/effect-lib/types/types.ts.html#withrequired-type-alias", "relUrl": "/effect-lib/types/types.ts.html#withrequired-type-alias" },"2004": { "doc": "types/types.ts", "title": "types/types.ts", "content": " ", "url": "/0.1.0/effect-lib/types/types.ts.html", "relUrl": "/effect-lib/types/types.ts.html" } } </div> </div> <div class="search-overlay"></div> </div> </body> </html>
