 of self. Signature . export declare const extractAsBigDecimal: MTypes.OneArgFunction&lt; Type, MTypes.OneArgFunction&lt;string, Option.Option&lt;MTypes.Pair&lt;BigDecimal.BigDecimal, string&gt;&gt;&gt; &gt; . ", "url": "/0.1.0/conversions/formatting/NumberBase10Format/NumberBase10Parser.ts.html#extractasbigdecimal", "relUrl": "/conversions/formatting/NumberBase10Format/NumberBase10Parser.ts.html#extractasbigdecimal" },"946": { "doc": "formatting/NumberBase10Format/NumberBase10Parser.ts", "title": "extractAsBigDecimalOrThrow", "content": "Returns the extractAsBigDecimalOrThrow property of self. Signature . export declare const extractAsBigDecimalOrThrow: MTypes.OneArgFunction&lt; Type, MTypes.OneArgFunction&lt;string, MTypes.Pair&lt;BigDecimal.BigDecimal, string&gt;&gt; &gt; . ", "url": "/0.1.0/conversions/formatting/NumberBase10Format/NumberBase10Parser.ts.html#extractasbigdecimalorthrow", "relUrl": "/conversions/formatting/NumberBase10Format/NumberBase10Parser.ts.html#extractasbigdecimalorthrow" },"947": { "doc": "formatting/NumberBase10Format/NumberBase10Parser.ts", "title": "extractAsNumber", "content": "Returns the extractAsNumber property of self. Signature . export declare const extractAsNumber: MTypes.OneArgFunction&lt; Type, MTypes.OneArgFunction&lt;string, Option.Option&lt;MTypes.Pair&lt;number, string&gt;&gt;&gt; &gt; . ", "url": "/0.1.0/conversions/formatting/NumberBase10Format/NumberBase10Parser.ts.html#extractasnumber", "relUrl": "/conversions/formatting/NumberBase10Format/NumberBase10Parser.ts.html#extractasnumber" },"948": { "doc": "formatting/NumberBase10Format/NumberBase10Parser.ts", "title": "extractAsNumberOrThrow", "content": "Returns the extractAsNumberOrThrow property of self. Signature . export declare const extractAsNumberOrThrow: MTypes.OneArgFunction&lt; Type, MTypes.OneArgFunction&lt;string, MTypes.Pair&lt;number, string&gt;&gt; &gt; . ", "url": "/0.1.0/conversions/formatting/NumberBase10Format/NumberBase10Parser.ts.html#extractasnumberor