DateTimeFormatContext.ts.html#fromlocale", "relUrl": "/conversions/formatting/DateTimeFormat/DateTimeFormatContext/DateTimeFormatContext.ts.html#fromlocale" },"329": { "doc": "formatting/DateTimeFormat/DateTimeFormatContext/DateTimeFormatContext.ts", "title": "fromLocaleOrThrow", "content": "Same as fromLocale but returns directly a CVDateTimeFormatContext or throws in case of an error . Signature . export declare const fromLocaleOrThrow: (locale: string) =&gt; Type . ", "url": "/0.1.0/conversions/formatting/DateTimeFormat/DateTimeFormatContext/DateTimeFormatContext.ts.html#fromlocaleorthrow", "relUrl": "/conversions/formatting/DateTimeFormat/DateTimeFormatContext/DateTimeFormatContext.ts.html#fromlocaleorthrow" },"330": { "doc": "formatting/DateTimeFormat/DateTimeFormatContext/DateTimeFormatContext.ts", "title": "fromNames", "content": "Constructs a CVDateTimeFormatContext from translations provided as strings . Signature . export declare const fromNames: ({ name, shortWeekdayNames, longWeekdayNames, shortMonthNames, longMonthNames, dayPeriodNames }: { readonly name: string readonly shortWeekdayNames: CVWeekDayNames.Type readonly longWeekdayNames: CVWeekDayNames.Type readonly shortMonthNames: CVMonthNames.Type readonly longMonthNames: CVMonthNames.Type readonly dayPeriodNames: CVDayPeriodNames.Type }) =&gt; Type . ", "url": "/0.1.0/conversions/formatting/DateTimeFormat/DateTimeFormatContext/DateTimeFormatContext.ts.html#fromnames", "relUrl": "/conversions/formatting/DateTimeFormat/DateTimeFormatContext/DateTimeFormatContext.ts.html#fromnames" },"331": { "doc": "formatting/DateTimeFormat/DateTimeFormatContext/DateTimeFormatContext.ts", "title": "Getters", "content": " ", "url": "/0.1.0/conversions/formatting/DateTimeFormat/DateTimeFormatContext/DateTimeFormatContext.ts.html#getters", "relUrl": "/conversions/formatting/DateTimeFormat/DateTimeFormatContext/DateTimeFormatContext.ts.html#getters" },"332": { "doc": "formatting/DateTimeFormat/DateTimeFormatContext/DateTim