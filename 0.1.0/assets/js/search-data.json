ngOption.ts", "content": " ", "url": "/0.1.0/conversions/rounding/RoundingOption/RoundingOption.ts.html", "relUrl": "/conversions/rounding/RoundingOption/RoundingOption.ts.html" },"1401": { "doc": "formatting/Schema.ts", "title": "Schema overview", "content": "An extension to the Effect.Schema module that adds Schema instances for number and date formatting and parsing and implements new brands . ", "url": "/0.1.0/conversions/formatting/Schema.ts.html#schema-overview", "relUrl": "/conversions/formatting/Schema.ts.html#schema-overview" },"1402": { "doc": "formatting/Schema.ts", "title": "Table of contents", "content": ". | Instances . | CVDateTime | . | Utils . | BigDecimalFromString | CVDateTimeFromString | DateFromCVDateTime | DateFromString | DateTimeZonedFromCVDateTime | DateTimeZonedFromString | FiniteFromString | Template | . | . ", "url": "/0.1.0/conversions/formatting/Schema.ts.html", "relUrl": "/conversions/formatting/Schema.ts.html" },"1403": { "doc": "formatting/Schema.ts", "title": "Instances", "content": " ", "url": "/0.1.0/conversions/formatting/Schema.ts.html#instances", "relUrl": "/conversions/formatting/Schema.ts.html#instances" },"1404": { "doc": "formatting/Schema.ts", "title": "CVDateTime", "content": "A Schema that represents a CVDateTime . Signature . export declare const CVDateTime: Schema.Codec&lt;CVDateTime.Type, CVDateTime.Type, never, never&gt; . ", "url": "/0.1.0/conversions/formatting/Schema.ts.html#cvdatetime", "relUrl": "/conversions/formatting/Schema.ts.html#cvdatetime" },"1405": { "doc": "formatting/Schema.ts", "title": "Utils", "content": " ", "url": "/0.1.0/conversions/formatting/Schema.ts.html#utils", "relUrl": "/conversions/formatting/Schema.ts.html#utils" },"1406": { "doc": "formatting/Schema.ts", "title": "BigDecimalFromString", "content": "A Schema that transforms a string into a BigDecimal according to format. Read documentation of module NumberBase10Format.ts for more details . Signature . export declare const BigDecimalFromString: ( format: CVNumberBase10Format.Type ) =&gt; Schema.Codec&lt;BigDecimal.BigDecimal, string&gt; . ", "url": "/0.1.0/conversions/formatting/Schema.ts.html#bigdecimalfromstring", "relUrl": "/conversions/formatting/Schema.ts.html#bigdecimalfromstring" },"1407": { "doc": "formatting/Schema.ts", "title": "CVDateTimeFromString", "content": "A Schema that transforms a string into a CVDateTime according to the given parser and formatter. Read documentation of modules DateTimeParser.ts and DateTimeFormatter.ts for more details. Signature . export declare const CVDateTimeFromString: ( parser: CVDateTimeParser.Type, formatter: CVDateTimeFormatter.Type ) =&gt; Schema.Codec&lt;CVDateTime.Type, string&gt; . ", "url": "/0.1.0/conversions/formatting/Schema.ts.html#cvdatetimefromstring", "relUrl": "/conversions/formatting/Schema.ts.html#cvdatetimefromstring" },"1408": { "doc": "formatting/Schema.ts", "title": "DateFromCVDateTime", "content": "A Schema that transforms a CVDateTime into a Javascript Date. Upon encoding, the CVDateTime object is created with the default timeZoneOffset of the machine this code is running on . Signature . export declare const DateFromCVDateTime: Schema.Codec&lt;Date, CVDateTime.Type, never, never&gt; . ", "url": "/0.1.0/conversions/formatting/Schema.ts.html#datefromcvdatetime", "relUrl": "/conversions/formatting/Schema.ts.html#datefromcvdatetime" },"1409": { "doc": "formatting/Schema.ts", "title": "DateFromString", "content": "A Schema that transforms a string into a Javascript Date according to the given parser and formatter. Read documentation of modules DateTimeParser.ts and DateTimeFormatter.ts for more details. Signature . export declare const DateFromString: ( parser: CVDateTimeParser.Type, formatter: CVDateTimeFormatter.Type ) =&gt; Schema.Codec&lt;Date, string&gt; . ", "url": "/0.1.0/conversions/formatting/Schema.ts.html#datefromstring", "relUrl": "/conversions/formatting/Schema.ts.html#datefromstring" },"1410": { "doc": "formatting/Schema.ts", "title": "DateTimeZonedFromCVDateTime", "content": "A Schema that transforms a CVDateTime into an Effect.DateTime.Zoned. Both objects share the same time zone offset . Signature . export declare const DateTimeZonedFromCVDateTime: Schema.Codec&lt;DateTime.Zoned, CVDateTime.Type, never, never&gt; . ", "url": "/0.1.0/conversions/formatting/Schema.ts.html#datetimezonedfromcvdatetime", "relUrl": "/conversions/formatting/Schema.ts.html#datetimezonedfromcvdatetime" },"1411": { "doc": "formatting/Schema.ts", "title": "DateTimeZonedFromString", "content": "A Schema that transforms a string into an Effect.DateTime.Zoned according to the given parser and formatter. Read documentation of modules DateTimeParser.ts and DateTimeFormatter.ts for more details. Signature . export declare const DateTimeZonedFromString: ( parser: CVDateTimeParser.Type, formatter: CVDateTimeFormatter.Type ) =&gt; Schema.Codec&lt;DateTime.Zoned, string&gt; . ", "url": "/0.1.0/conversions/formatting/Schema.ts.html#datetimezonedfromstring", "relUrl": "/conversions/formatting/Schema.ts.html#datetimezonedfromstring" },"1412": { "doc": "formatting/Schema.ts", "title": "FiniteFromString", "content": "A Schema that transforms a string into a number according to the format. Read documentation of module NumberBase10Format.ts for more details . Signature . export declare const FiniteFromString: (format: CVNumberBase10Format.Type) =&gt; Schema.Codec&lt;number, string&gt; . ", "url": "/0.1.0/conversions/formatting/Schema.ts.html#finitefromstring", "relUrl": "/conversions/formatting/Schema.ts.html#finitefromstring" },"1413": { "doc": "formatting/Schema.ts", "title": "Template", "content": "A Schema that transforms a string into an object according to template. Read documentation of module Template.ts for more details . Signature . export declare const Template: &lt;PlaceholderTypes extends MTypes.Object&gt;( template: CVTemplate.Type&lt;PlaceholderTypes&gt; ) =&gt; Schema.Codec&lt;PlaceholderTypes, string&gt; . ", "url": "/0.1.0/conversions/formatting/Schema.ts.html#template", "relUrl": "/conversions/formatting/Schema.ts.html#template" },"1414": { "doc": "formatting/Schema.ts", "title": "formatting/Schema.ts", "content": " ", "url": "/0.1.0/conversions/formatting/Schema.ts.html", "relUrl": "/conversions/formatting/Schema.ts.html" },"1415": { "doc": "String/String.ts", "title": "String overview", "content": "Extension to the Effect String module: stringification of unknown / primitive values, indexed search, custom-character trimming, padding, splitting (including bit-aligned chunking), indented multi-line formatting, and lightweight string predicates (SemVer, e-mail, digit, …). ", "url": "/0.1.0/effect-lib/String/String.ts.html#string-overview", "relUrl": "/effect-lib/String/String.ts.html#string-overview" },"1416": { "doc": "String/String.ts", "title": "Mental model", "content": ". | All functions are pure, data-last, and treat strings as immutable values. | Search helpers ({@link search}, {@link searchAll}, {@link searchRight}) accept either a literal string (no escaping needed) or a RegExp. They return positions through {@link “./StringSearchResult.js” | MStringSearchResult}. | Both regex-based searches and {@link match} / {@link matches} reset lastIndex before use, so passing a RegExp literal with the g flag is safe but global matches are not iterated; only the first match is returned (use {@link searchAll} for all). | . ", "url": "/0.1.0/effect-lib/String/String.ts.html#mental-model", "relUrl": "/effect-lib/String/String.ts.html#mental-model" },"1417": { "doc": "String/String.ts", "title": "Common tasks", "content": ". | Stringify: {@link fromUnknown}, {@link fromPrimitive}, {@link fromNonNullablePrimitive}, {@link fromNumber} | Search: {@link search}, {@link searchAll}, {@link searchRight}, {@link count} | Slice: {@link takeBut}, {@link takeRightBut}, {@link takeTo}, {@link takeRightFrom} | Trim / strip / pad: {@link trimStart}, {@link trimEnd}, {@link trim}, {@link stripLeft}, {@link stripLeftOption}, {@link stripRight}, {@link stripRightOption}, {@link pad} | Combine: {@link append}, {@link appendIfNotEmpty}, {@link prepend}, {@link prependIfNotEmpty}, {@link surroundIfNotEmpty}, {@link replaceBetween} | Match: {@link match}, {@link matches}, {@link matchWithCapturingGroups} | Split: {@link splitAt}, {@link splitAtFromRight}, {@link splitEquallyRestAtStart}, {@link splitEquallyRestAtEnd} | Format: {@link tabify}, {@link removeNCharsEveryMCharsFromRight} | Predicates: {@link isMultiLine}, {@link isSemVer}, {@link isEmail}, {@link hasLength}, {@link isDigit} | . ", "url": "/0.1.0/effect-lib/String/String.ts.html#common-tasks", "relUrl": "/effect-lib/String/String.ts.html#common-tasks" },"1418": { "doc": "String/String.ts", "title": "Quickstart", "content": "Example (Indexed search and padding) . import { Option, pipe } from \"effect\" import * as MString from \"@parischap/effect-lib/MString\" import * as MStringFillPosition from \"@parischap/effect-lib/String/StringFillPosition\" const found = pipe(\"hello world\", MString.search(\"world\")) console.log(Option.map(found, (r) =&gt; r.startIndex)) // Some(6) console.log(pipe(\"42\", MString.pad({ length: 5, fillChar: \"0\", fillPosition: MStringFillPosition.Type.Left }))) // '00042' . ", "url": "/0.1.0/effect-lib/String/String.ts.html#quickstart", "relUrl": "/effect-lib/String/String.ts.html#quickstart" },"1419": { "doc": "String/String.ts", "title": "Table of contents", "content": ". | Constructors . | fromNonNullablePrimitive | fromNumber | fromPrimitive | fromUnknown | . | Destructors . | matchWithCapturingGroups | . | Models . | Type (type alias) | . | Predicates . | hasLength | isDigit | isEmail | isMultiLine | isSemVer | matches | . | Utils . | append | appendIfNotEmpty | count | match | pad | prepend | prependIfNotEmpty | removeNCharsEveryMCharsFromRight | replaceBetween | search | searchAll | searchRight | splitAt | splitAtFromRight | splitEquallyRestAtEnd | splitEquallyRestAtStart | stripLeft | stripLeftOption | stripRight | stripRightOption | surroundIfNotEmpty | tabify | takeBut | takeRightBut | takeRightFrom | takeTo | trim | trimEnd | trimStart | . | . ", "url": "/0.1.0/effect-lib/String/String.ts.html", "relUrl": "/effect-lib/String/String.ts.html" },"1420": { "doc": "String/String.ts", "title": "Constructors", "content": " ", "url": "/0.1.0/effect-lib/String/String.ts.html#constructors", "relUrl": "/effect-lib/String/String.ts.html#constructors" },"1421": { "doc": "String/String.ts", "title": "fromNonNullablePrimitive", "content": "Builds a string from a primitive value other than null and undefined. | Numbers and BigInts are converted using base-10 (not scientific notation). | Other primitives use their .toString() method. | Returns string representation suitable for display or further processing. | . Example (Convert non-nullable primitive) . import * as MString from '@parischap/effect-lib/String/String'; console.log(MString.fromNonNullablePrimitive(42)); // \"42\" console.log(MString.fromNonNullablePrimitive(true)); // \"true\" console.log(MString.fromNonNullablePrimitive(3.14n)); // \"3.14\" . Signature . export declare const fromNonNullablePrimitive: (u: MTypes.NonNullablePrimitive) =&gt; string . ", "url": "/0.1.0/effect-lib/String/String.ts.html#fromnonnullableprimitive", "relUrl": "/effect-lib/String/String.ts.html#fromnonnullableprimitive" },"1422": { "doc": "String/String.ts", "title": "fromNumber", "content": "Converts a number to a string using a specified radix. | Radix 10 with non-scientific numbers uses the special fixed-point conversion. | Other radixes and BigInt use native .toString(radix). | Decimal parts preserved for floating-point numbers. | Handles very large and very small numbers without scientific notation. | . Example (Convert to string with radix) . import * as MString from \"@parischap/effect-lib/String/String\" const toBase10 = MString.fromNumber(10) console.log(toBase10(255)) // \"255\" console.log(toBase10(1e-10)) // \"0.0000000001\" const toBase16 = MString.fromNumber(16) console.log(toBase16(255)) // \"ff\" . Signature . export declare const fromNumber: (radix: number) =&gt; MTypes.OneArgFunction&lt;number | bigint, string&gt; . ", "url": "/0.1.0/effect-lib/String/String.ts.html#fromnumber", "relUrl": "/effect-lib/String/String.ts.html#fromnumber" },"1423": { "doc": "String/String.ts", "title": "fromPrimitive", "content": "Builds a string from a primitive value, handling null and undefined. | null converts to \"null\" and undefined to \"undefined\". | Non-nullable primitives delegated to {@link fromNonNullablePrimitive}. | Numbers and BigInts use base-10 conversion (no scientific notation). | . Example (Convert nullable primitive) . import * as MString from \"@parischap/effect-lib/String/String\" console.log(MString.fromPrimitive(null)) // \"null\" console.log(MString.fromPrimitive(undefined)) // \"undefined\" console.log(MString.fromPrimitive(123)) // \"123\" console.log(MString.fromPrimitive(false)) // \"false\" . Signature . export declare const fromPrimitive: MTypes.OneArgFunction&lt;MTypes.Primitive, string&gt; . ", "url": "/0.1.0/effect-lib/String/String.ts.html#fromprimitive", "relUrl": "/effect-lib/String/String.ts.html#fromprimitive" },"1424": { "doc": "String/String.ts", "title": "fromUnknown", "content": "Builds a string from an unknown value. | Primitives delegated to {@link fromPrimitive}. | Objects serialized via JSON.stringify with 2-space indentation. | Use for debugging or logging arbitrary values. | . Example (Convert unknown value) . import * as MString from \"@parischap/effect-lib/String/String\" console.log(MString.fromUnknown(42)) // \"42\" console.log(MString.fromUnknown({ x: 1 })) // \"{\\n \\\"x\\\": 1\\n}\" . Signature . export declare const fromUnknown: (u: unknown) =&gt; string . ", "url": "/0.1.0/effect-lib/String/String.ts.html#fromunknown", "relUrl": "/effect-lib/String/String.ts.html#fromunknown" },"1425": { "doc": "String/String.ts", "title": "Destructors", "content": " ", "url": "/0.1.0/effect-lib/String/String.ts.html#destructors", "relUrl": "/effect-lib/String/String.ts.html#destructors" },"1426": { "doc": "String/String.ts", "title": "matchWithCapturingGroups", "content": "Matches a regex pattern and extracts named capturing groups. | Throws if regex has g flag or missing expected named groups. | Returns Option.some with match text and group values. | Undefined optional capturing groups converted to empty strings. | Use for structured pattern extraction (named groups). | Type-safe group extraction based on capturingGroupNames array. | . Example (Extract named groups) . import { Option } from \"effect\" import * as MString from \"@parischap/effect-lib/MString\" const result = MString.matchWithCapturingGroups(/(?&lt;year&gt;\\d{4})-(?&lt;month&gt;\\d{2})-(?&lt;day&gt;\\d{2})/, [ \"year\", \"month\", \"day\" ] as const)(\"2024-05-01\") if (Option.isSome(result)) { console.log(result.value.groups.year) // '2024' } . Signature . export declare const matchWithCapturingGroups: &lt;const Names extends ReadonlyArray&lt;string&gt;&gt;( regExp: RegExp, capturingGroupNames: Names ) =&gt; ( self: Type ) =&gt; Option.Option&lt;{ match: string; groups: { [k in keyof Names as [k] extends [number] ? Names[k] : never]: string } }&gt; . ", "url": "/0.1.0/effect-lib/String/String.ts.html#matchwithcapturinggroups", "relUrl": "/effect-lib/String/String.ts.html#matchwithcapturinggroups" },"1427": { "doc": "String/String.ts", "title": "Models", "content": " ", "url": "/0.1.0/effect-lib/String/String.ts.html#models", "relUrl": "/effect-lib/String/String.ts.html#models" },"1428": { "doc": "String/String.ts", "title": "Type (type alias)", "content": "Type on which this module’s functions operate . Signature . export type Type = string . ", "url": "/0.1.0/effect-lib/String/String.ts.html#type-type-alias", "relUrl": "/effect-lib/String/String.ts.html#type-type-alias" },"1429": { "doc": "String/String.ts", "title": "Predicates", "content": " ", "url": "/0.1.0/effect-lib/String/String.ts.html#predicates", "relUrl": "/effect-lib/String/String.ts.html#predicates" },"1430": { "doc": "String/String.ts", "title": "hasLength", "content": "Tests whether the string has exactly the specified length. | Returns true if self.length === l. | Returns false otherwise. | Use for length validation in predicates or guards. | . Example (Test length) . import * as MString from \"@parischap/effect-lib/String/String\" const isLengthFive = MString.hasLength(5) console.log(isLengthFive(\"hello\")) // true console.log(isLengthFive(\"hi\")) // false . Signature . export declare const hasLength: (l: number) =&gt; Predicate.Predicate&lt;Type&gt; . ", "url": "/0.1.0/effect-lib/String/String.ts.html#haslength", "relUrl": "/effect-lib/String/String.ts.html#haslength" },"1431": { "doc": "String/String.ts", "title": "isDigit", "content": "Tests whether the string is a single ASCII digit character (0–9). | Returns true only for strings of exactly 1 character in range [0-9]. | Returns false for multi-character strings or non-digit characters. | Returns false for non-ASCII digits. | Use to validate single numeric digit input. | . Example (Test digit character) . import * as MString from \"@parischap/effect-lib/String/String\" console.log(MString.isDigit(\"5\")) // true console.log(MString.isDigit(\"0\")) // true console.log(MString.isDigit(\"55\")) // false console.log(MString.isDigit(\"a\")) // false . Signature . export declare const isDigit: Predicate.Predicate&lt;string&gt; . ", "url": "/0.1.0/effect-lib/String/String.ts.html#isdigit", "relUrl": "/effect-lib/String/String.ts.html#isdigit" },"1432": { "doc": "String/String.ts", "title": "isEmail", "content": "Tests whether the string is a valid email address. | Uses internal email regex for validation. | Returns true if matches email pattern, false otherwise. | Note: No format is fully RFC-compliant; use for basic validation. | Use to validate user input emails. | . Example (Test email) . import * as MString from \"@parischap/effect-lib/String/String\" console.log(MString.isEmail(\"user@example.com\")) // true console.log(MString.isEmail(\"invalid.email\")) // false . Signature . export declare const isEmail: Predicate.Predicate&lt;string&gt; . ", "url": "/0.1.0/effect-lib/String/String.ts.html#isemail", "relUrl": "/effect-lib/String/String.ts.html#isemail" },"1433": { "doc": "String/String.ts", "title": "isMultiLine", "content": "Tests whether the string contains line break characters. | Returns true if any end-of-line character found (platform-independent). | Returns false for single-line strings. | Uses internal lineBreak regex for detection. | Use to distinguish single-line from multi-line strings. | . Example (Test for multiple lines) . import * as MString from \"@parischap/effect-lib/String/String\" console.log(MString.isMultiLine(\"hello\")) // false console.log(MString.isMultiLine(\"hello\\nworld\")) // true . Signature . export declare const isMultiLine: Predicate.Predicate&lt;string&gt; . ", "url": "/0.1.0/effect-lib/String/String.ts.html#ismultiline", "relUrl": "/effect-lib/String/String.ts.html#ismultiline" },"1434": { "doc": "String/String.ts", "title": "isSemVer", "content": "Tests whether the string is a valid semantic version. | Format: major.minor.patch[-prerelease][+build]. | Uses internal semVer regex for validation. | Returns true if matches SemVer spec, false otherwise. | Use to validate version strings. | . Example (Test semantic version) . import * as MString from \"@parischap/effect-lib/String/String\" console.log(MString.isSemVer(\"1.0.0\")) // true console.log(MString.isSemVer(\"1.0.0-alpha\")) // true console.log(MString.isSemVer(\"1.0\")) // false . Signature . export declare const isSemVer: Predicate.Predicate&lt;string&gt; . ", "url": "/0.1.0/effect-lib/String/String.ts.html#issemver", "relUrl": "/effect-lib/String/String.ts.html#issemver" },"1435": { "doc": "String/String.ts", "title": "matches", "content": "Tests whether the string matches a regex pattern. | Type guard version of {@link match} returning boolean. | Ignores g flag; always checks single match. | Resets lastIndex before matching; safe with global regexps. | Returns true if pattern matches, false otherwise. | Use for predicate checks without extracting match text. | . Example (Test pattern match) . import * as MString from \"@parischap/effect-lib/String/String\" console.log(MString.matches(/^[A-Z]/)(\"Hello\")) // true console.log(MString.matches(/^[a-z]/)(\"Hello\")) // false . Signature . export declare const matches: (regExp: RegExp) =&gt; Predicate.Predicate&lt;Type&gt; . ", "url": "/0.1.0/effect-lib/String/String.ts.html#matches", "relUrl": "/effect-lib/String/String.ts.html#matches" },"1436": { "doc": "String/String.ts", "title": "Utils", "content": " ", "url": "/0.1.0/effect-lib/String/String.ts.html#utils", "relUrl": "/effect-lib/String/String.ts.html#utils" },"1437": { "doc": "String/String.ts", "title": "append", "content": "Appends a string to the end. | Simple concatenation: self + s. | No trimming or normalization applied. | Returns new string without modifying input. | Use for unconditional concatenation. | . Example (Append string) . import * as MString from \"@parischap/effect-lib/String/String\" console.log(MString.append(\".txt\")(\"readme\")) // \"readme.txt\" console.log(MString.append(\"!\")(\"hello\")) // \"hello!\" . Signature . export declare const append: (s: string) =&gt; MTypes.StringTransformer . ", "url": "/0.1.0/effect-lib/String/String.ts.html#append", "relUrl": "/effect-lib/String/String.ts.html#append" },"1438": { "doc": "String/String.ts", "title": "appendIfNotEmpty", "content": "Appends a string only if the original string is non-empty. | Returns s appended if string length &gt; 0. | Returns empty string if input string is empty. | Use to conditionally add suffixes to non-empty strings. | Common for adding punctuation or delimiters. | . Example (Append if not empty) . import * as MString from \"@parischap/effect-lib/String/String\" console.log(MString.appendIfNotEmpty(\"!\")(\"hello\")) // \"hello!\" console.log(MString.appendIfNotEmpty(\"!\")(\"\")) // \"\" . Signature . export declare const appendIfNotEmpty: (s: string) =&gt; MTypes.StringTransformer . ", "url": "/0.1.0/effect-lib/String/String.ts.html#appendifnotempty", "relUrl": "/effect-lib/String/String.ts.html#appendifnotempty" },"1439": { "doc": "String/String.ts", "title": "count", "content": "Counts non-overlapping occurrences of a pattern in the string. | Supports both string patterns and RegExp patterns. | Counts all non-overlapping matches found via {@link searchAll}. | Returns 0 if no matches found. | Use for pattern frequency analysis. | . Example (Count occurrences) . import * as MString from \"@parischap/effect-lib/String/String\" console.log(MString.count(\"o\")(\"hello world\")) // 2 console.log(MString.count(/[aeiou]/g)(\"hello world\")) // 3 . Signature . export declare const count: (regexp: RegExp | string) =&gt; MTypes.NumberFromString . ", "url": "/0.1.0/effect-lib/String/String.ts.html#count", "relUrl": "/effect-lib/String/String.ts.html#count" },"1440": { "doc": "String/String.ts", "title": "match", "content": "Finds first regex match without side effects. | Uses RegExp.prototype.exec instead of String.prototype.match. | Ignores the g flag; always returns only first match. | Resets lastIndex before matching; safe with global regexps. | Returns Option.some with matched text or Option.none. | Use when you need single match without g flag complications. | . Example (Match pattern) . import { Option, pipe } from \"effect\" import * as MString from \"@parischap/effect-lib/MString\" const result = pipe(\"abc123def\", MString.match(/\\d+/)) console.log(Option.getOrElse(result, () =&gt; \"\")) // '123' . Signature . export declare const match: (regExp: RegExp) =&gt; (self: Type) =&gt; Option.Option&lt;string&gt; . ", "url": "/0.1.0/effect-lib/String/String.ts.html#match", "relUrl": "/effect-lib/String/String.ts.html#match" },"1441": { "doc": "String/String.ts", "title": "pad", "content": "Pads a string to a specific length with a fill character. | fillChar must be a single character (default behavior for longer strings unspecified). | If string length already meets target, no change applied. | fillPosition determines whether padding added to left or right. | length should be a positive integer. | Returns new string or original if already long enough. | . Example (Pad string) . import * as MString from \"@parischap/effect-lib/String/String\" import * as MStringFillPosition from \"@parischap/effect-lib/String/StringFillPosition\" const padLeft = MString.pad({ length: 10, fillChar: \"0\", fillPosition: MStringFillPosition.Type.Left }) console.log(padLeft(\"42\")) // \"00000042\" . Signature . export declare const pad: ({ length, fillChar, fillPosition }: { readonly length: number readonly fillChar: string readonly fillPosition: MStringFillPosition.Type }) =&gt; MTypes.OneArgFunction&lt;Type&gt; . ", "url": "/0.1.0/effect-lib/String/String.ts.html#pad", "relUrl": "/effect-lib/String/String.ts.html#pad" },"1442": { "doc": "String/String.ts", "title": "prepend", "content": "Prepends a string to the beginning. | Simple concatenation: s + self. | No trimming or normalization applied. | Returns new string without modifying input. | Use for unconditional concatenation. | . Example (Prepend string) . import * as MString from \"@parischap/effect-lib/String/String\" console.log(MString.prepend(\"http://\")(\"example.com\")) // \"http://example.com\" console.log(MString.prepend(\"Hello \")(\"World\")) // \"Hello World\" . Signature . export declare const prepend: (s: string) =&gt; MTypes.StringTransformer . ", "url": "/0.1.0/effect-lib/String/String.ts.html#prepend", "relUrl": "/effect-lib/String/String.ts.html#prepend" },"1443": { "doc": "String/String.ts", "title": "prependIfNotEmpty", "content": "Prepends a string only if the original string is non-empty. | Returns s prepended if string length &gt; 0. | Returns empty string if input string is empty. | Use to conditionally add prefixes to non-empty strings. | Common for adding protocol or namespace prefixes. | . Example (Prepend if not empty) . import * as MString from \"@parischap/effect-lib/String/String\" console.log(MString.prependIfNotEmpty(\"&gt;&gt;&gt; \")(\"log message\")) // \"&gt;&gt;&gt; log message\" console.log(MString.prependIfNotEmpty(\"&gt;&gt;&gt; \")(\"\")) // \"\" . Signature . export declare const prependIfNotEmpty: (s: string) =&gt; MTypes.StringTransformer . ", "url": "/0.1.0/effect-lib/String/String.ts.html#prependifnotempty", "relUrl": "/effect-lib/String/String.ts.html#prependifnotempty" },"1444": { "doc": "String/String.ts", "title": "removeNCharsEveryMCharsFromRight", "content": "Removes n characters from every m-character chunk from the right. | Splits string into (m + n)-character chunks. | Keeps first m characters of each chunk. | Discards last n characters of each chunk. | If n === 0, returns string unchanged. | m and n must be positive integers. | Use for removing trailing characters at regular intervals (e.g., removing formatting). | . Example (Remove characters at intervals) . import * as MString from \"@parischap/effect-lib/String/String\" const removeHyphens = MString.removeNCharsEveryMCharsFromRight({ m: 3, n: 1 }) console.log(removeHyphens(\"123-456-789-\")) // \"123456789\" . Signature . export declare const removeNCharsEveryMCharsFromRight: ({ m, n }: { readonly m: number readonly n: number }) =&gt; MTypes.StringTransformer . ", "url": "/0.1.0/effect-lib/String/String.ts.html#removencharseverymcharsfromright", "relUrl": "/effect-lib/String/String.ts.html#removencharseverymcharsfromright" },"1445": { "doc": "String/String.ts", "title": "replaceBetween", "content": "Replaces the substring between two indexes. | If startIndex === endIndex, replacement is inserted at that position. | If startIndex &gt; endIndex, characters between them appear before and after replacement. | Negative indexes clamped to 0; overlong indexes clamped to string length. | Returns new string with replacement applied. | Use for substring replacement without regex complexity. | . Example (Replace between indexes) . import * as MString from \"@parischap/effect-lib/String/String\" console.log(MString.replaceBetween(\"***\", 5, 10)(\"hello world\")) // \"hello*** world\" console.log(MString.replaceBetween(\"X\", 3, 3)(\"abc\")) // \"abcX\" . Signature . export declare const replaceBetween: ( replacement: string, startIndex: number, endIndex: number ) =&gt; MTypes.StringTransformer . ", "url": "/0.1.0/effect-lib/String/String.ts.html#replacebetween", "relUrl": "/effect-lib/String/String.ts.html#replacebetween" },"1446": { "doc": "String/String.ts", "title": "search", "content": "Searches for the first occurrence of a pattern in the string. | Supports both string literals (without escaping special characters) and RegExp patterns. | Optionally starts search from startIndex (default 0). | The g flag on RegExp is ignored; only first match returned. | Returns Option.some with match details or Option.none if not found. | Match details include start/end indexes and matched text. | . Example (Search for first occurrence) . import { pipe } from \"effect\" import * as Option from \"effect/Option\" import * as MString from \"@parischap/effect-lib/String/String\" const text = \"The quick brown fox\" const result = pipe(text, MString.search(\"quick\")) console.log(Option.isSome(result)) // true if (Option.isSome(result)) { console.log(result.value.match) // \"quick\" } . Signature . export declare const search: ( regexp: RegExp | string, startIndex?: number ) =&gt; (self: Type) =&gt; Option.Option&lt;MStringSearchResult.Type&gt; . ", "url": "/0.1.0/effect-lib/String/String.ts.html#search", "relUrl": "/effect-lib/String/String.ts.html#search" },"1447": { "doc": "String/String.ts", "title": "searchAll", "content": "Searches for all non-overlapping occurrences of a pattern. | Supports both string patterns and RegExp patterns. | The g flag is ignored; uses internal search loop. | Returns array of all match results with indexes and matched text. | Returns empty array if no matches found. | Use to iterate over all occurrences. | . Example (Find all occurrences) . import { pipe } from \"effect\" import * as MString from \"@parischap/effect-lib/String/String\" const text = \"apple apple apple\" const matches = pipe(text, MString.searchAll(\"apple\")) console.log(matches.length) // 3 console.log(matches[0].match) // \"apple\" . Signature . export declare const searchAll: (regexp: RegExp | string) =&gt; (self: Type) =&gt; Array&lt;MStringSearchResult.Type&gt; . ", "url": "/0.1.0/effect-lib/String/String.ts.html#searchall", "relUrl": "/effect-lib/String/String.ts.html#searchall" },"1448": { "doc": "String/String.ts", "title": "searchRight", "content": "Searches for the last (rightmost) occurrence of a pattern. | Supports both string patterns and RegExp patterns. | The g flag is ignored; uses internal search. | Returns Option.some with last match details or Option.none if not found. | More efficient than calling {@link searchAll} for finding the last match. | . Example (Find last occurrence) . import { pipe } from \"effect\" import * as Option from \"effect/Option\" import * as MString from \"@parischap/effect-lib/String/String\" const text = \"one two one three\" const result = pipe(text, MString.searchRight(\"one\")) if (Option.isSome(result)) { console.log(result.value.startIndex) // 8 } . Signature . export declare const searchRight: (regexp: RegExp | string) =&gt; (self: Type) =&gt; Option.Option&lt;MStringSearchResult.Type&gt; . ", "url": "/0.1.0/effect-lib/String/String.ts.html#searchright", "relUrl": "/effect-lib/String/String.ts.html#searchright" },"1449": { "doc": "String/String.ts", "title": "splitAt", "content": "Splits string at a specific position into two parts. | First part: characters 0 to n-1 (length = n). | Second part: remaining characters. | Negative n clamped to 0; n &gt; length clamped to length. | Returns tuple [left, right] always. | Use for position-based string bisection. | . Example (Split at position) . import * as MString from \"@parischap/effect-lib/String/String\" const [left, right] = MString.splitAt(5)(\"hello world\") console.log(left) // \"hello\" console.log(right) // \" world\" . Signature . export declare const splitAt: (n: number) =&gt; (self: Type) =&gt; [left: string, right: string] . ", "url": "/0.1.0/effect-lib/String/String.ts.html#splitat", "relUrl": "/effect-lib/String/String.ts.html#splitat" },"1450": { "doc": "String/String.ts", "title": "splitAtFromRight", "content": "Splits string at a position measured from the end. | Second part: last n characters (length = n). | First part: remaining characters. | Negative n clamped to 0; n &gt; length clamped to length. | Returns tuple [left, right] always. | Use for suffix extraction with known length. | . Example (Split at position from right) . import * as MString from \"@parischap/effect-lib/String/String\" const [left, right] = MString.splitAtFromRight(5)(\"hello world\") console.log(left) // \"hello \" console.log(right) // \"world\" . Signature . export declare const splitAtFromRight: (n: number) =&gt; (self: Type) =&gt; [left: string, right: string] . ", "url": "/0.1.0/effect-lib/String/String.ts.html#splitatfromright", "relUrl": "/effect-lib/String/String.ts.html#splitatfromright" },"1451": { "doc": "String/String.ts", "title": "splitEquallyRestAtEnd", "content": "Splits string into equal chunks with remainder at end. | Chunks are bitSize characters each. | Last chunk may have 1 to bitSize characters (remainder). | Preceding chunks are exactly bitSize characters. | bitSize must be strictly positive. | Returns non-empty array of chunks. | Use for fixed-width chunking with trailing remainder. | . Example (Split equally with remainder last) . import * as MString from \"@parischap/effect-lib/String/String\" const result = MString.splitEquallyRestAtEnd(3)(\"abcdefgh\") console.log(result) // [\"abc\", \"def\", \"gh\"] . Signature . export declare const splitEquallyRestAtEnd: (bitSize: number) =&gt; MTypes.OneArgFunction&lt;Type, MTypes.OverOne&lt;string&gt;&gt; . ", "url": "/0.1.0/effect-lib/String/String.ts.html#splitequallyrestatend", "relUrl": "/effect-lib/String/String.ts.html#splitequallyrestatend" },"1452": { "doc": "String/String.ts", "title": "splitEquallyRestAtStart", "content": "Splits string into equal chunks with remainder at start. | Chunks are bitSize characters each. | First chunk may have 1 to bitSize characters (remainder). | Remaining chunks are exactly bitSize characters. | bitSize must be strictly positive. | Returns reversed array from internal unfold. | Use for fixed-width formatting with leading remainder. | . Example (Split equally with remainder first) . import * as MString from \"@parischap/effect-lib/String/String\" const result = MString.splitEquallyRestAtStart(3)(\"abcdefgh\") console.log(result) // [\"ab\", \"cde\", \"fgh\"] or similar . Signature . export declare const splitEquallyRestAtStart: (bitSize: number) =&gt; MTypes.OneArgFunction&lt;Type, Array&lt;string&gt;&gt; . ", "url": "/0.1.0/effect-lib/String/String.ts.html#splitequallyrestatstart", "relUrl": "/effect-lib/String/String.ts.html#splitequallyrestatstart" },"1453": { "doc": "String/String.ts", "title": "stripLeft", "content": "Removes a prefix from the string if present. | Returns string without prefix if prefix matches. | Returns original string if prefix not found. | Always returns a string (never Option). | Use for unconditional prefix removal. | . Example (Strip prefix) . import * as MString from \"@parischap/effect-lib/String/String\" console.log(MString.stripLeft(\"http://\")(\"http://example.com\")) // \"example.com\" console.log(MString.stripLeft(\"https://\")(\"http://example.com\")) // \"http://example.com\" . Signature . export declare const stripLeft: (s: string) =&gt; MTypes.StringTransformer . ", "url": "/0.1.0/effect-lib/String/String.ts.html#stripleft", "relUrl": "/effect-lib/String/String.ts.html#stripleft" },"1454": { "doc": "String/String.ts", "title": "stripLeftOption", "content": "Optionally removes a prefix from the start of the string. | Returns Option.some with stripped string if prefix matches. | Returns Option.none if string doesn’t start with prefix. | Returns new string with prefix removed or Option.none. | Use in optional chains where missing prefix is valid. | . Example (Strip prefix optionally) . import { pipe } from \"effect\" import * as Option from \"effect/Option\" import * as MString from \"@parischap/effect-lib/String/String\" const result = pipe(\"file.txt\", MString.stripLeftOption(\"file\")) console.log(Option.isSome(result)) // true console.log(Option.getOrElse(result, () =&gt; \"\")) // \".txt\" . Signature . export declare const stripLeftOption: (s: string) =&gt; MTypes.OneArgFunction&lt;Type, Option.Option&lt;string&gt;&gt; . ", "url": "/0.1.0/effect-lib/String/String.ts.html#stripleftoption", "relUrl": "/effect-lib/String/String.ts.html#stripleftoption" },"1455": { "doc": "String/String.ts", "title": "stripRight", "content": "Removes a suffix from the string if present. | Returns string without suffix if suffix matches. | Returns original string if suffix not found. | Always returns a string (never Option). | Use for unconditional suffix removal. | . Example (Strip suffix) . import * as MString from \"@parischap/effect-lib/String/String\" console.log(MString.stripRight(\".txt\")(\"readme.txt\")) // \"readme\" console.log(MString.stripRight(\".md\")(\"readme.txt\")) // \"readme.txt\" . Signature . export declare const stripRight: (s: string) =&gt; MTypes.StringTransformer . ", "url": "/0.1.0/effect-lib/String/String.ts.html#stripright", "relUrl": "/effect-lib/String/String.ts.html#stripright" },"1456": { "doc": "String/String.ts", "title": "stripRightOption", "content": "Optionally removes a suffix from the end of the string. | Returns Option.some with stripped string if suffix matches. | Returns Option.none if string doesn’t end with suffix. | Returns new string with suffix removed or Option.none. | Use in optional chains where missing suffix is valid. | . Example (Strip suffix optionally) . import { pipe } from \"effect\" import * as Option from \"effect/Option\" import * as MString from \"@parischap/effect-lib/String/String\" const result = pipe(\"file.txt\", MString.stripRightOption(\".txt\")) console.log(Option.isSome(result)) // true console.log(Option.getOrElse(result, () =&gt; \"\")) // \"file\" . Signature . export declare const stripRightOption: (s: string) =&gt; MTypes.OneArgFunction&lt;Type, Option.Option&lt;string&gt;&gt; . ", "url": "/0.1.0/effect-lib/String/String.ts.html#striprightoption", "relUrl": "/effect-lib/String/String.ts.html#striprightoption" },"1457": { "doc": "String/String.ts", "title": "surroundIfNotEmpty", "content": "Surrounds string with prefix and suffix if non-empty. | Returns prefix + self + suffix if string length &gt; 0. | Returns empty string if input string is empty. | Use to wrap content with delimiters or markup (quotes, tags, etc.). | Useful for formatting output conditionally. | . Example (Surround if not empty) . import * as MString from \"@parischap/effect-lib/String/String\" const quoted = MString.surroundIfNotEmpty({ prefix: '\"', suffix: '\"' }) console.log(quoted(\"hello\")) // '\"hello\"' console.log(quoted(\"\")) // \"\" . Signature . export declare const surroundIfNotEmpty: ({ prefix, suffix }: { readonly prefix: string readonly suffix: string }) =&gt; MTypes.StringTransformer . ", "url": "/0.1.0/effect-lib/String/String.ts.html#surroundifnotempty", "relUrl": "/effect-lib/String/String.ts.html#surroundifnotempty" },"1458": { "doc": "String/String.ts", "title": "tabify", "content": "Adds indentation to each line in the string. | Prepends tabChar repeated count times to each line. | First line indented; subsequent lines indented after line breaks. | Default count is 1. | Uses internal lineBreak regex for platform-independent handling. | Returns new string with consistent indentation. | Use for pretty-printing multi-line content. | . Example (Add indentation) . import * as MString from \"@parischap/effect-lib/String/String\" const result = MString.tabify(\" \", 1)(\"line1\\nline2\\nline3\") console.log(result) // \" line1\\n line2\\n line3\" . Signature . export declare const tabify: (tabChar: string, count?: number) =&gt; MTypes.StringTransformer . ", "url": "/0.1.0/effect-lib/String/String.ts.html#tabify", "relUrl": "/effect-lib/String/String.ts.html#tabify" },"1459": { "doc": "String/String.ts", "title": "takeBut", "content": "Returns substring excluding the last n characters. | If n is negative, string returned unchanged. | If n greater than string length, empty string returned. | Use to trim a known suffix length without searching. | Inverse of {@link takeRight} semantically. | . Example (Take all but last n characters) . import * as MString from \"@parischap/effect-lib/String/String\" console.log(MString.takeBut(3)(\"hello\")) // \"he\" console.log(MString.takeBut(-1)(\"hello\")) // \"hello\" . Signature . export declare const takeBut: (n: number) =&gt; MTypes.StringTransformer . ", "url": "/0.1.0/effect-lib/String/String.ts.html#takebut", "relUrl": "/effect-lib/String/String.ts.html#takebut" },"1460": { "doc": "String/String.ts", "title": "takeRightBut", "content": "Returns substring excluding the first n characters. | If n is negative, string returned unchanged. | If n greater than string length, empty string returned. | Use to skip a known prefix length without searching. | Inverse of {@link String.takeLeft} semantically. | . Example (Take all but first n characters) . import * as MString from \"@parischap/effect-lib/String/String\" console.log(MString.takeRightBut(3)(\"hello\")) // \"lo\" console.log(MString.takeRightBut(-1)(\"hello\")) // \"hello\" . Signature . export declare const takeRightBut: (n: number) =&gt; MTypes.StringTransformer . ", "url": "/0.1.0/effect-lib/String/String.ts.html#takerightbut", "relUrl": "/effect-lib/String/String.ts.html#takerightbut" },"1461": { "doc": "String/String.ts", "title": "takeRightFrom", "content": "Extracts substring from first occurrence of pattern to end. | Returns characters after the first pattern match. | Returns full string if pattern not found. | Supports both string patterns and RegExp (without escaping requirements). | Use to split at first occurrence and keep the part after delimiter. | . Example (Take from pattern to end) . import { pipe } from \"effect\" import * as MString from \"@parischap/effect-lib/String/String\" const text = \"hello@world.com\" const result = pipe(text, MString.takeRightFrom(\"@\")) console.log(result) // \"world.com\" . Signature . export declare const takeRightFrom: (regexp: RegExp | string) =&gt; MTypes.StringTransformer . ", "url": "/0.1.0/effect-lib/String/String.ts.html#takerightfrom", "relUrl": "/effect-lib/String/String.ts.html#takerightfrom" },"1462": { "doc": "String/String.ts", "title": "takeTo", "content": "Extracts substring from start up to first occurrence of pattern. | Returns characters before the first pattern match. | Returns full string if pattern not found. | Supports both string patterns and RegExp (without escaping requirements). | Use to split at first occurrence without including the delimiter. | . Example (Take up to pattern) . import { pipe } from \"effect\" import * as MString from \"@parischap/effect-lib/String/String\" const text = \"hello@world.com\" const result = pipe(text, MString.takeTo(\"@\")) console.log(result) // \"hello\" . Signature . export declare const takeTo: (regexp: RegExp | string) =&gt; MTypes.StringTransformer . ", "url": "/0.1.0/effect-lib/String/String.ts.html#taketo", "relUrl": "/effect-lib/String/String.ts.html#taketo" },"1463": { "doc": "String/String.ts", "title": "trim", "content": "Removes padding characters from left or right of a string. | Only removes characters matching fillChar (single character). | Direction determined by fillPosition. | Removes all contiguous matching characters from that side. | Returns original string if no matching characters found. | Use to reverse padding or strip known suffixes/prefixes. | . Example (Trim padding) . import * as MString from \"@parischap/effect-lib/String/String\" import * as MStringFillPosition from \"@parischap/effect-lib/String/StringFillPosition\" const trimRight = MString.trim({ fillChar: \".\", fillPosition: MStringFillPosition.Type.Right }) console.log(trimRight(\"file.txt...\")) // \"file.txt\" . Signature . export declare const trim: ({ fillChar, fillPosition }: { readonly fillChar: string readonly fillPosition: MStringFillPosition.Type }) =&gt; MTypes.StringTransformer . ", "url": "/0.1.0/effect-lib/String/String.ts.html#trim", "relUrl": "/effect-lib/String/String.ts.html#trim" },"1464": { "doc": "String/String.ts", "title": "trimEnd", "content": "Removes characters from the end of the string. | Only single charToRemove character is supported. | Removes all trailing instances of the character. | Returns string unchanged if last character doesn’t match. | Use for custom right-trimming beyond whitespace. | . Example (Trim end character) . import * as MString from \"@parischap/effect-lib/String/String\" const result = MString.trimEnd(\"!\")(\"hello!!!\") console.log(result) // \"hello\" . Signature . export declare const trimEnd: (charToRemove: string) =&gt; MTypes.StringTransformer . ", "url": "/0.1.0/effect-lib/String/String.ts.html#trimend", "relUrl": "/effect-lib/String/String.ts.html#trimend" },"1465": { "doc": "String/String.ts", "title": "trimStart", "content": "Removes characters from the start of the string. | Only single charToRemove character is supported. | Removes all leading instances of the character. | Returns string unchanged if first character doesn’t match. | Use for custom left-trimming beyond whitespace. | . Example (Trim start character) . import * as MString from \"@parischap/effect-lib/String/String\" const result = MString.trimStart(\"*\")(\"***hello***\") console.log(result) // \"hello***\" . Signature . export declare const trimStart: (charToRemove: string) =&gt; MTypes.StringTransformer . ", "url": "/0.1.0/effect-lib/String/String.ts.html#trimstart", "relUrl": "/effect-lib/String/String.ts.html#trimstart" },"1466": { "doc": "String/String.ts", "title": "String/String.ts", "content": " ", "url": "/0.1.0/effect-lib/String/String.ts.html", "relUrl": "/effect-lib/String/String.ts.html" },"1467": { "doc": "String/StringFillPosition.ts", "title": "StringFillPosition overview", "content": "Two-valued enum used by string-padding helpers to choose the side that gets filled. ", "url": "/0.1.0/effect-lib/String/StringFillPosition.ts.html#stringfillposition-overview", "relUrl": "/effect-lib/String/StringFillPosition.ts.html#stringfillposition-overview" },"1468": { "doc": "String/StringFillPosition.ts", "title": "Mental model", "content": ". | Type.Left indicates that filler is added on the left of the source string (the characters of self end up flush right). | Type.Right indicates the symmetric case. | | Pair this enum with {@link “./String.js” | MString.pad} / MString.trim. | . | . ", "url": "/0.1.0/effect-lib/String/StringFillPosition.ts.html#mental-model", "relUrl": "/effect-lib/String/StringFillPosition.ts.html#mental-model" },"1469": { "doc": "String/StringFillPosition.ts", "title": "Quickstart", "content": "Example (Right-aligned padding) . import { pipe } from \"effect\" import * as MString from \"@parischap/effect-lib/MString\" import * as MStringFillPosition from \"@parischap/effect-lib/String/StringFillPosition\" console.log(pipe(\"42\", MString.pad({ length: 5, fillChar: \"0\", fillPosition: MStringFillPosition.Type.Left }))) // '00042' . ", "url": "/0.1.0/effect-lib/String/StringFillPosition.ts.html#quickstart", "relUrl": "/effect-lib/String/StringFillPosition.ts.html#quickstart" },"1470": { "doc": "String/StringFillPosition.ts", "title": "Table of contents", "content": ". | Destructors . | toString | . | . ", "url": "/0.1.0/effect-lib/String/StringFillPosition.ts.html", "relUrl": "/effect-lib/String/StringFillPosition.ts.html" },"1471": { "doc": "String/StringFillPosition.ts", "title": "Destructors", "content": " ", "url": "/0.1.0/effect-lib/String/StringFillPosition.ts.html#destructors", "relUrl": "/effect-lib/String/StringFillPosition.ts.html#destructors" },"1472": { "doc": "String/StringFillPosition.ts", "title": "toString", "content": "Returns the lowercase string representation of self ('left' or 'right'). Example . import * as MStringFillPosition from \"@parischap/effect-lib/String/StringFillPosition\" console.log(MStringFillPosition.toString(MStringFillPosition.Type.Left)) // 'left' . Signature . export declare const toString: MTypes.OneArgFunction&lt;Type, string&gt; . ", "url": "/0.1.0/effect-lib/String/StringFillPosition.ts.html#tostring", "relUrl": "/effect-lib/String/StringFillPosition.ts.html#tostring" },"1473": { "doc": "String/StringFillPosition.ts", "title": "String/StringFillPosition.ts", "content": " ", "url": "/0.1.0/effect-lib/String/StringFillPosition.ts.html", "relUrl": "/effect-lib/String/StringFillPosition.ts.html" },"1474": { "doc": "String/StringSearchResult.ts", "title": "StringSearchResult overview", "content": "Result type of the search operations exposed by {@link “./String.js” | MString}: a substring match together with the half-open [startIndex, endIndex) range it covers. ", "url": "/0.1.0/effect-lib/String/StringSearchResult.ts.html#stringsearchresult-overview", "relUrl": "/effect-lib/String/StringSearchResult.ts.html#stringsearchresult-overview" },"1475": { "doc": "String/StringSearchResult.ts", "title": "Mental model", "content": ". | Type is an Equal-aware value object built on {@link “../Data/EquivalenceBasedEqualityData.js” | MEquivalenceBasedEqualityData.Class}. | Two results are equal iff their startIndex, endIndex and match all coincide. | The {@link areOverlapping} Equivalence is not an equality — two matches may overlap without being equal. | Three orderings are provided: by start, by end, and a “longest first” ordering useful when resolving overlapping matches. | . ", "url": "/0.1.0/effect-lib/String/StringSearchResult.ts.html#mental-model", "relUrl": "/effect-lib/String/StringSearchResult.ts.html#mental-model" },"1476": { "doc": "String/StringSearchResult.ts", "title": "Common tasks", "content": ". | Construct: {@link make} | Compare: {@link equivalence}, {@link areOverlapping} | Order: {@link byStartIndex}, {@link byEndIndex}, {@link byLongestFirst} | Field access: {@link startIndex}, {@link endIndex}, {@link match} | . ", "url": "/0.1.0/effect-lib/String/StringSearchResult.ts.html#common-tasks", "relUrl": "/effect-lib/String/StringSearchResult.ts.html#common-tasks" },"1477": { "doc": "String/StringSearchResult.ts", "title": "Table of contents", "content": ". | Constructors . | make | . | Equivalences . | areOverlapping | equivalence | . | Getters . | endIndex | match | startIndex | . | Models . | Type (class) . | make (static method) | [MData.idSymbol] (method) | [Hash.symbol] (method) | [MEquivalenceBasedEqualityData.isEquivalentToSymbol] (method) | [MEquivalenceBasedEqualityData.hasSameTypeMarkerAsSymbol] (method) | startIndex (property) | endIndex (property) | match (property) | . | . | Module markers . | moduleTag | . | Ordering . | byEndIndex | byLongestFirst | byStartIndex | . | . ", "url": "/0.1.0/effect-lib/String/StringSearchResult.ts.html", "relUrl": "/effect-lib/String/StringSearchResult.ts.html" },"1478": { "doc": "String/StringSearchResult.ts", "title": "Constructors", "content": " ", "url": "/0.1.0/effect-lib/String/StringSearchResult.ts.html#constructors", "relUrl": "/effect-lib/String/StringSearchResult.ts.html#constructors" },"1479": { "doc": "String/StringSearchResult.ts", "title": "make", "content": "Builds a search result. Signature . export declare const make: (params: MTypes.Data&lt;Type&gt;) =&gt; Type . ", "url": "/0.1.0/effect-lib/String/StringSearchResult.ts.html#make", "relUrl": "/effect-lib/String/StringSearchResult.ts.html#make" },"1480": { "doc": "String/StringSearchResult.ts", "title": "Equivalences", "content": " ", "url": "/0.1.0/effect-lib/String/StringSearchResult.ts.html#equivalences", "relUrl": "/effect-lib/String/StringSearchResult.ts.html#equivalences" },"1481": { "doc": "String/StringSearchResult.ts", "title": "areOverlapping", "content": "Equivalence that holds when two results’ ranges overlap (touching at a single index counts as overlapping). Not an equality; use {@link equivalence} for that. Signature . export declare const areOverlapping: Equivalence.Equivalence&lt;Type&gt; . ", "url": "/0.1.0/effect-lib/String/StringSearchResult.ts.html#areoverlapping", "relUrl": "/effect-lib/String/StringSearchResult.ts.html#areoverlapping" },"1482": { "doc": "String/StringSearchResult.ts", "title": "equivalence", "content": "Equivalence that holds when two results share startIndex, endIndex and match. This is the equivalence used by Equal.equals on instances. Signature . export declare const equivalence: Equivalence.Equivalence&lt;Type&gt; . ", "url": "/0.1.0/effect-lib/String/StringSearchResult.ts.html#equivalence", "relUrl": "/effect-lib/String/StringSearchResult.ts.html#equivalence" },"1483": { "doc": "String/StringSearchResult.ts", "title": "Getters", "content": " ", "url": "/0.1.0/effect-lib/String/StringSearchResult.ts.html#getters", "relUrl": "/effect-lib/String/StringSearchResult.ts.html#getters" },"1484": { "doc": "String/StringSearchResult.ts", "title": "endIndex", "content": "Returns the endIndex field of self. Signature . export declare const endIndex: MTypes.OneArgFunction&lt;Type, number&gt; . ", "url": "/0.1.0/effect-lib/String/StringSearchResult.ts.html#endindex", "relUrl": "/effect-lib/String/StringSearchResult.ts.html#endindex" },"1485": { "doc": "String/StringSearchResult.ts", "title": "match", "content": "Returns the match field of self. Signature . export declare const match: MTypes.OneArgFunction&lt;Type, string&gt; . ", "url": "/0.1.0/effect-lib/String/StringSearchResult.ts.html#match", "relUrl": "/effect-lib/String/StringSearchResult.ts.html#match" },"1486": { "doc": "String/StringSearchResult.ts", "title": "startIndex", "content": "Returns the startIndex field of self. Signature . export declare const startIndex: MTypes.OneArgFunction&lt;Type, number&gt; . ", "url": "/0.1.0/effect-lib/String/StringSearchResult.ts.html#startindex", "relUrl": "/effect-lib/String/StringSearchResult.ts.html#startindex" },"1487": { "doc": "String/StringSearchResult.ts", "title": "Models", "content": " ", "url": "/0.1.0/effect-lib/String/StringSearchResult.ts.html#models", "relUrl": "/effect-lib/String/StringSearchResult.ts.html#models" },"1488": { "doc": "String/StringSearchResult.ts", "title": "Type (class)", "content": "Type of a search result: the matched substring and its [startIndex, endIndex) range. Signature . export declare class Type { private constructor({ startIndex, endIndex, match }: MTypes.Data&lt;Type&gt;) } . make (static method) . Static constructor . Signature . static make(params: MTypes.Data&lt;Type&gt;): Type . [MData.idSymbol] (method) . Returns the id of this . Signature . [MData.idSymbol](): string | (() =&gt; string) . [Hash.symbol] (method) . Calculates the hash value of this . Signature . [Hash.symbol](): number . [MEquivalenceBasedEqualityData.isEquivalentToSymbol] (method) . Function that implements the equivalence of this and that . Signature . [MEquivalenceBasedEqualityData.isEquivalentToSymbol](this: this, that: this): boolean . [MEquivalenceBasedEqualityData.hasSameTypeMarkerAsSymbol] (method) . Predicate that returns true if that has the same type marker as this . Signature . [MEquivalenceBasedEqualityData.hasSameTypeMarkerAsSymbol](that: unknown): boolean . startIndex (property) . The index where the match was found in the target string . Signature . readonly startIndex: number . endIndex (property) . The index of the character following the match in the target string . Signature . readonly endIndex: number . match (property) . The match . Signature . readonly match: string . ", "url": "/0.1.0/effect-lib/String/StringSearchResult.ts.html#type-class", "relUrl": "/effect-lib/String/StringSearchResult.ts.html#type-class" },"1489": { "doc": "String/StringSearchResult.ts", "title": "Module markers", "content": " ", "url": "/0.1.0/effect-lib/String/StringSearchResult.ts.html#module-markers", "relUrl": "/effect-lib/String/StringSearchResult.ts.html#module-markers" },"1490": { "doc": "String/StringSearchResult.ts", "title": "moduleTag", "content": "Module tag. Signature . export declare const moduleTag: \"@parischap/effect-lib/String/StringSearchResult/\" . ", "url": "/0.1.0/effect-lib/String/StringSearchResult.ts.html#moduletag", "relUrl": "/effect-lib/String/StringSearchResult.ts.html#moduletag" },"1491": { "doc": "String/StringSearchResult.ts", "title": "Ordering", "content": " ", "url": "/0.1.0/effect-lib/String/StringSearchResult.ts.html#ordering", "relUrl": "/effect-lib/String/StringSearchResult.ts.html#ordering" },"1492": { "doc": "String/StringSearchResult.ts", "title": "byEndIndex", "content": "Ordering on endIndex (ascending). Signature . export declare const byEndIndex: Order.Order&lt;Type&gt; . ", "url": "/0.1.0/effect-lib/String/StringSearchResult.ts.html#byendindex", "relUrl": "/effect-lib/String/StringSearchResult.ts.html#byendindex" },"1493": { "doc": "String/StringSearchResult.ts", "title": "byLongestFirst", "content": "Ordering that places the longest match first when two results share the same startIndex. | Use to disambiguate overlapping matches in favor of the most specific one. | . Signature . export declare const byLongestFirst: Order.Order&lt;Type&gt; . ", "url": "/0.1.0/effect-lib/String/StringSearchResult.ts.html#bylongestfirst", "relUrl": "/effect-lib/String/StringSearchResult.ts.html#bylongestfirst" },"1494": { "doc": "String/StringSearchResult.ts", "title": "byStartIndex", "content": "Ordering on startIndex (ascending). Signature . export declare const byStartIndex: Order.Order&lt;Type&gt; . ", "url": "/0.1.0/effect-lib/String/StringSearchResult.ts.html#bystartindex", "relUrl": "/effect-lib/String/StringSearchResult.ts.html#bystartindex" },"1495": { "doc": "String/StringSearchResult.ts", "title": "String/StringSearchResult.ts", "content": " ", "url": "/0.1.0/effect-lib/String/StringSearchResult.ts.html", "relUrl": "/effect-lib/String/StringSearchResult.ts.html" },"1496": { "doc": "stringification/StringifiedValue.ts", "title": "StringifiedValue overview", "content": "This module implements a type that represents the output of the stringification process of a value. It is a non-empty array of ASText’s (see @parischap/ansi-styles), where each element represents one line of the stringified output. At least one line is always present, though that line may be empty. ", "url": "/0.1.0/pretty-print/stringification/StringifiedValue.ts.html#stringifiedvalue-overview", "relUrl": "/pretty-print/stringification/StringifiedValue.ts.html#stringifiedvalue-overview" },"1497": { "doc": "stringification/StringifiedValue.ts", "title": "Table of contents", "content": ". | Constructors . | concat | fromFlattenedStringifiedProperties | fromJoinedStringifiedProperties | fromText | . | Destructors . | firstLine | initLines | lastLine | tailLines | toAnsiString | toLength | toText | toUnstyledStrings | . | Equivalences . | equivalence | . | Instances . | empty | . | Models . | Type (type alias) | . | Predicates . | isEmpty | isNotEmpty | . | Utils . | addLineAfter | addLineBefore | appendToLastLine | prependToAllLines | prependToFirstLine | prependToTailLines | toSingleLine | . | . ", "url": "/0.1.0/pretty-print/stringification/StringifiedValue.ts.html", "relUrl": "/pretty-print/stringification/StringifiedValue.ts.html" },"1498": { "doc": "stringification/StringifiedValue.ts", "title": "Constructors", "content": " ", "url": "/0.1.0/pretty-print/stringification/StringifiedValue.ts.html#constructors", "relUrl": "/pretty-print/stringification/StringifiedValue.ts.html#constructors" },"1499": { "doc": "stringification/StringifiedValue.ts", "title": "concat", "content": "Returns a new PPStringifiedValue formed by appending all lines of that after all lines of self . Signature . export declare const concat: (that: ReadonlyArray&lt;ASText.Type&gt;) =&gt; (self: Type) =&gt; Type . ", "url": "/0.1.0/pretty-print/stringification/StringifiedValue.ts.html#concat", "relUrl": "/pretty-print/stringification/StringifiedValue.ts.html#concat" },"1500": { "doc": "stringification/StringifiedValue.ts", "title": "fromFlattenedStringifiedProperties", "content": "Builds a PPStringifiedValue from a PPStringifiedProperties by concatenating all lines of all inner PPStringifiedValue’s into a flat array of lines. Returns the empty instance when the input array is empty. Signature . export declare const fromFlattenedStringifiedProperties: MTypes.OneArgFunction&lt; PPStringifiedProperties.Type, [ASText.Type, ...ASText.Type[]] &gt; . ", "url": "/0.1.0/pretty-print/stringification/StringifiedValue.ts.html#fromflattenedstringifiedproperties", "relUrl": "/pretty-print/stringification/StringifiedValue.ts.html#fromflattenedstringifiedproperties" },"1501": { "doc": "stringification/StringifiedValue.ts", "title": "fromJoinedStringifiedProperties", "content": "Builds a PPStringifiedValue from a PPStringifiedProperties by collapsing each inner PPStringifiedValue into a single line (joining its lines with empty text), then collecting those single lines. Returns the empty instance when the input array is empty. Signature . export declare const fromJoinedStringifiedProperties: MTypes.OneArgFunction&lt; PPStringifiedProperties.Type, [ASText.Type, ...ASText.Type[]] &gt; . ", "url": "/0.1.0/pretty-print/stringification/StringifiedValue.ts.html#fromjoinedstringifiedproperties", "relUrl": "/pretty-print/stringification/StringifiedValue.ts.html#fromjoinedstringifiedproperties" },"1502": { "doc": "stringification/StringifiedValue.ts", "title": "fromText", "content": "Wraps a single ASText into a one-line PPStringifiedValue . Signature . export declare const fromText: MTypes.OneArgFunction&lt;ASText.Type, [ASText.Type, ...ASText.Type[]]&gt; . ", "url": "/0.1.0/pretty-print/stringification/StringifiedValue.ts.html#fromtext", "relUrl": "/pretty-print/stringification/StringifiedValue.ts.html#fromtext" },"1503": { "doc": "stringification/StringifiedValue.ts", "title": "Destructors", "content": " ", "url": "/0.1.0/pretty-print/stringification/StringifiedValue.ts.html#destructors", "relUrl": "/pretty-print/stringification/StringifiedValue.ts.html#destructors" },"1504": { "doc": "stringification/StringifiedValue.ts", "title": "firstLine", "content": "Returns the first line of self . Signature . export declare const firstLine: MTypes.OneArgFunction&lt;[ASText.Type, ...ASText.Type[]], ASText.Type&gt; . ", "url": "/0.1.0/pretty-print/stringification/StringifiedValue.ts.html#firstline", "relUrl": "/pretty-print/stringification/StringifiedValue.ts.html#firstline" },"1505": { "doc": "stringification/StringifiedValue.ts", "title": "initLines", "content": "Returns all lines of self but the last . Signature . export declare const initLines: MTypes.OneArgFunction&lt;[ASText.Type, ...ASText.Type[]], readonly ASText.Type[]&gt; . ", "url": "/0.1.0/pretty-print/stringification/StringifiedValue.ts.html#initlines", "relUrl": "/pretty-print/stringification/StringifiedValue.ts.html#initlines" },"1506": { "doc": "stringification/StringifiedValue.ts", "title": "lastLine", "content": "Returns the last line of self . Signature . export declare const lastLine: MTypes.OneArgFunction&lt;[ASText.Type, ...ASText.Type[]], ASText.Type&gt; . ", "url": "/0.1.0/pretty-print/stringification/StringifiedValue.ts.html#lastline", "relUrl": "/pretty-print/stringification/StringifiedValue.ts.html#lastline" },"1507": { "doc": "stringification/StringifiedValue.ts", "title": "tailLines", "content": "Returns all lines of self but the first . Signature . export declare const tailLines: MTypes.OneArgFunction&lt;[ASText.Type, ...ASText.Type[]], readonly ASText.Type[]&gt; . ", "url": "/0.1.0/pretty-print/stringification/StringifiedValue.ts.html#taillines", "relUrl": "/pretty-print/stringification/StringifiedValue.ts.html#taillines" },"1508": { "doc": "stringification/StringifiedValue.ts", "title": "toAnsiString", "content": "Returns the ANSI string corresponding to self . Signature . export declare const toAnsiString: (sep?: ASText.Type) =&gt; MTypes.OneArgFunction&lt;Type, string&gt; . ", "url": "/0.1.0/pretty-print/stringification/StringifiedValue.ts.html#toansistring", "relUrl": "/pretty-print/stringification/StringifiedValue.ts.html#toansistring" },"1509": { "doc": "stringification/StringifiedValue.ts", "title": "toLength", "content": "Returns the length of self, i.e. the sum of the lengths of all the ASText instances constituting self . Signature . export declare const toLength: MTypes.OneArgFunction&lt;[ASText.Type, ...ASText.Type[]], number&gt; . ", "url": "/0.1.0/pretty-print/stringification/StringifiedValue.ts.html#tolength", "relUrl": "/pretty-print/stringification/StringifiedValue.ts.html#tolength" },"1510": { "doc": "stringification/StringifiedValue.ts", "title": "toText", "content": "Collapses all lines of self into a single ASText by joining them with empty text . Signature . export declare const toText: MTypes.OneArgFunction&lt;[ASText.Type, ...ASText.Type[]], ASText.Type&gt; . ", "url": "/0.1.0/pretty-print/stringification/StringifiedValue.ts.html#totext", "relUrl": "/pretty-print/stringification/StringifiedValue.ts.html#totext" },"1511": { "doc": "stringification/StringifiedValue.ts", "title": "toUnstyledStrings", "content": "Returns the strings corresponding to self without any styling . Signature . export declare const toUnstyledStrings: MTypes.OneArgFunction&lt;[ASText.Type, ...ASText.Type[]], [string, ...string[]]&gt; . ", "url": "/0.1.0/pretty-print/stringification/StringifiedValue.ts.html#tounstyledstrings", "relUrl": "/pretty-print/stringification/StringifiedValue.ts.html#tounstyledstrings" },"1512": { "doc": "stringification/StringifiedValue.ts", "title": "Equivalences", "content": " ", "url": "/0.1.0/pretty-print/stringification/StringifiedValue.ts.html#equivalences", "relUrl": "/pretty-print/stringification/StringifiedValue.ts.html#equivalences" },"1513": { "doc": "stringification/StringifiedValue.ts", "title": "equivalence", "content": "Equivalence for StringifiedValue’s. Signature . export declare const equivalence: Equivalence.Equivalence&lt;[ASText.Type, ...ASText.Type[]]&gt; . ", "url": "/0.1.0/pretty-print/stringification/StringifiedValue.ts.html#equivalence", "relUrl": "/pretty-print/stringification/StringifiedValue.ts.html#equivalence" },"1514": { "doc": "stringification/StringifiedValue.ts", "title": "Instances", "content": " ", "url": "/0.1.0/pretty-print/stringification/StringifiedValue.ts.html#instances", "relUrl": "/pretty-print/stringification/StringifiedValue.ts.html#instances" },"1515": { "doc": "stringification/StringifiedValue.ts", "title": "empty", "content": "Empty StringifiedValue instance . Signature . export declare const empty: [ASText.Type, ...ASText.Type[]] . ", "url": "/0.1.0/pretty-print/stringification/StringifiedValue.ts.html#empty", "relUrl": "/pretty-print/stringification/StringifiedValue.ts.html#empty" },"1516": { "doc": "stringification/StringifiedValue.ts", "title": "Models", "content": " ", "url": "/0.1.0/pretty-print/stringification/StringifiedValue.ts.html#models", "relUrl": "/pretty-print/stringification/StringifiedValue.ts.html#models" },"1517": { "doc": "stringification/StringifiedValue.ts", "title": "Type (type alias)", "content": "Type that represents a PPStringifiedValue . Signature . export type Type = MTypes.OverOne&lt;ASText.Type&gt; . ", "url": "/0.1.0/pretty-print/stringification/StringifiedValue.ts.html#type-type-alias", "relUrl": "/pretty-print/stringification/StringifiedValue.ts.html#type-type-alias" },"1518": { "doc": "stringification/StringifiedValue.ts", "title": "Predicates", "content": " ", "url": "/0.1.0/pretty-print/stringification/StringifiedValue.ts.html#predicates", "relUrl": "/pretty-print/stringification/StringifiedValue.ts.html#predicates" },"1519": { "doc": "stringification/StringifiedValue.ts", "title": "isEmpty", "content": "Returns true if self is empty. Signature . export declare const isEmpty: Predicate.Predicate&lt;[ASText.Type, ...ASText.Type[]]&gt; . ", "url": "/0.1.0/pretty-print/stringification/StringifiedValue.ts.html#isempty", "relUrl": "/pretty-print/stringification/StringifiedValue.ts.html#isempty" },"1520": { "doc": "stringification/StringifiedValue.ts", "title": "isNotEmpty", "content": "Returns true if self is not empty. Signature . export declare const isNotEmpty: Predicate.Predicate&lt;[ASText.Type, ...ASText.Type[]]&gt; . ", "url": "/0.1.0/pretty-print/stringification/StringifiedValue.ts.html#isnotempty", "relUrl": "/pretty-print/stringification/StringifiedValue.ts.html#isnotempty" },"1521": { "doc": "stringification/StringifiedValue.ts", "title": "Utils", "content": " ", "url": "/0.1.0/pretty-print/stringification/StringifiedValue.ts.html#utils", "relUrl": "/pretty-print/stringification/StringifiedValue.ts.html#utils" },"1522": { "doc": "stringification/StringifiedValue.ts", "title": "addLineAfter", "content": "Returns a copy of self with a new line at the end . Signature . export declare const addLineAfter: (line: ASText.Type) =&gt; MTypes.OneArgFunction&lt;ReadonlyArray&lt;ASText.Type&gt;, Type&gt; . ", "url": "/0.1.0/pretty-print/stringification/StringifiedValue.ts.html#addlineafter", "relUrl": "/pretty-print/stringification/StringifiedValue.ts.html#addlineafter" },"1523": { "doc": "stringification/StringifiedValue.ts", "title": "addLineBefore", "content": "Returns a copy of self with a new line at the start . Signature . export declare const addLineBefore: (line: ASText.Type) =&gt; MTypes.OneArgFunction&lt;ReadonlyArray&lt;ASText.Type&gt;, Type&gt; . ", "url": "/0.1.0/pretty-print/stringification/StringifiedValue.ts.html#addlinebefore", "relUrl": "/pretty-print/stringification/StringifiedValue.ts.html#addlinebefore" },"1524": { "doc": "stringification/StringifiedValue.ts", "title": "appendToLastLine", "content": "Returns a copy of self in which text has been appended to the last line . Signature . export declare const appendToLastLine: (text: ASText.Type) =&gt; MTypes.OneArgFunction&lt;Type&gt; . ", "url": "/0.1.0/pretty-print/stringification/StringifiedValue.ts.html#appendtolastline", "relUrl": "/pretty-print/stringification/StringifiedValue.ts.html#appendtolastline" },"1525": { "doc": "stringification/StringifiedValue.ts", "title": "prependToAllLines", "content": "Returns a copy of self in which text has been prepended to each line . Signature . export declare const prependToAllLines: (text: ASText.Type) =&gt; MTypes.OneArgFunction&lt;Type&gt; . ", "url": "/0.1.0/pretty-print/stringification/StringifiedValue.ts.html#prependtoalllines", "relUrl": "/pretty-print/stringification/StringifiedValue.ts.html#prependtoalllines" },"1526": { "doc": "stringification/StringifiedValue.ts", "title": "prependToFirstLine", "content": "Returns a copy of self in which text has been prepended to the first line . Signature . export declare const prependToFirstLine: (text: ASText.Type) =&gt; MTypes.OneArgFunction&lt;Type&gt; . ", "url": "/0.1.0/pretty-print/stringification/StringifiedValue.ts.html#prependtofirstline", "relUrl": "/pretty-print/stringification/StringifiedValue.ts.html#prependtofirstline" },"1527": { "doc": "stringification/StringifiedValue.ts", "title": "prependToTailLines", "content": "Returns a copy of self in which text has been prepended to all lines but the first . Signature . export declare const prependToTailLines: (text: ASText.Type) =&gt; MTypes.OneArgFunction&lt;Type&gt; . ", "url": "/0.1.0/pretty-print/stringification/StringifiedValue.ts.html#prependtotaillines", "relUrl": "/pretty-print/stringification/StringifiedValue.ts.html#prependtotaillines" },"1528": { "doc": "stringification/StringifiedValue.ts", "title": "toSingleLine", "content": "Returns a single-line version of self by collapsing all lines into one (equivalent to calling toText then fromText) . Signature . export declare const toSingleLine: MTypes.OneArgFunction&lt; [ASText.Type, ...ASText.Type[]], [ASText.Type, ...ASText.Type[]] &gt; . ", "url": "/0.1.0/pretty-print/stringification/StringifiedValue.ts.html#tosingleline", "relUrl": "/pretty-print/stringification/StringifiedValue.ts.html#tosingleline" },"1529": { "doc": "stringification/StringifiedValue.ts", "title": "stringification/StringifiedValue.ts", "content": " ", "url": "/0.1.0/pretty-print/stringification/StringifiedValue.ts.html", "relUrl": "/pretty-print/stringification/StringifiedValue.ts.html" },"1530": { "doc": "stringification/Stringifier.ts", "title": "Stringifier overview", "content": "This module implements a PPStringifier, i.e. an object built from a PPParameters instance that converts any JavaScript value into a PPStringifiedValue. The stringification pipeline handles primitive values, non-primitive values (objects, arrays, maps, sets, functions…), depth limiting, bypass shortcuts, and circular-reference detection. ", "url": "/0.1.0/pretty-print/stringification/Stringifier.ts.html#stringifier-overview", "relUrl": "/pretty-print/stringification/Stringifier.ts.html#stringifier-overview" },"1531": { "doc": "stringification/Stringifier.ts", "title": "Table of contents", "content": ". | Constructors . | make | . | Equivalences . | equivalence | . | Models . | Type (class) . | [MData.idSymbol] (method) | [Hash.symbol] (method) | [MEquivalenceBasedEqualityData.isEquivalentToSymbol] (method) | [MEquivalenceBasedEqualityData.hasSameTypeMarkerAsSymbol] (method) | id (property) | stringify (property) | . | . | Module markers . | moduleTag | . | . ", "url": "/0.1.0/pretty-print/stringification/Stringifier.ts.html", "relUrl": "/pretty-print/stringification/Stringifier.ts.html" },"1532": { "doc": "stringification/Stringifier.ts", "title": "Constructors", "content": " ", "url": "/0.1.0/pretty-print/stringification/Stringifier.ts.html#constructors", "relUrl": "/pretty-print/stringification/Stringifier.ts.html#constructors" },"1533": { "doc": "stringification/Stringifier.ts", "title": "make", "content": "Constructs a PPStringifier from a PPParameters instance . Signature . export declare const make: (parameters: PPParameters.Type) =&gt; Type . ", "url": "/0.1.0/pretty-print/stringification/Stringifier.ts.html#make", "relUrl": "/pretty-print/stringification/Stringifier.ts.html#make" },"1534": { "doc": "stringification/Stringifier.ts", "title": "Equivalences", "content": " ", "url": "/0.1.0/pretty-print/stringification/Stringifier.ts.html#equivalences", "relUrl": "/pretty-print/stringification/Stringifier.ts.html#equivalences" },"1535": { "doc": "stringification/Stringifier.ts", "title": "equivalence", "content": "Equivalence . Signature . export declare const equivalence: Equivalence.Equivalence&lt;Type&gt; . ", "url": "/0.1.0/pretty-print/stringification/Stringifier.ts.html#equivalence", "relUrl": "/pretty-print/stringification/Stringifier.ts.html#equivalence" },"1536": { "doc": "stringification/Stringifier.ts", "title": "Models", "content": " ", "url": "/0.1.0/pretty-print/stringification/Stringifier.ts.html#models", "relUrl": "/pretty-print/stringification/Stringifier.ts.html#models" },"1537": { "doc": "stringification/Stringifier.ts", "title": "Type (class)", "content": "Type that represents a PPStringifier . Signature . export declare class Type { constructor(parameters: PPParameters.Type) } . [MData.idSymbol] (method) . Returns the id of this . Signature . [MData.idSymbol](): string | (() =&gt; string) . [Hash.symbol] (method) . Calculates the hash value of this . Signature . [Hash.symbol](): number . [MEquivalenceBasedEqualityData.isEquivalentToSymbol] (method) . Function that implements the equivalence of this and that . Signature . [MEquivalenceBasedEqualityData.isEquivalentToSymbol](this: this, that: this): boolean . [MEquivalenceBasedEqualityData.hasSameTypeMarkerAsSymbol] (method) . Predicate that returns true if that has the same type marker as this . Signature . [MEquivalenceBasedEqualityData.hasSameTypeMarkerAsSymbol](that: unknown): boolean . id (property) . Id of this PPStringifier. Derived from the id of the PPParameters used to build it . Signature . readonly id: string . stringify (property) . Function that converts any JavaScript value into a PPStringifiedValue. Handles the full stringification pipeline: primitive formatting, bypass shortcuts, depth limiting, circular- reference detection, property extraction, filtering, sorting, and final assembly. Signature . readonly stringify: MTypes.OneArgFunction&lt;unknown, [ASText.Type, ...ASText.Type[]]&gt; . ", "url": "/0.1.0/pretty-print/stringification/Stringifier.ts.html#type-class", "relUrl": "/pretty-print/stringification/Stringifier.ts.html#type-class" },"1538": { "doc": "stringification/Stringifier.ts", "title": "Module markers", "content": " ", "url": "/0.1.0/pretty-print/stringification/Stringifier.ts.html#module-markers", "relUrl": "/pretty-print/stringification/Stringifier.ts.html#module-markers" },"1539": { "doc": "stringification/Stringifier.ts", "title": "moduleTag", "content": "Module tag . Signature . export declare const moduleTag: \"@parischap/pretty-print/stringification/Stringifier/\" . ", "url": "/0.1.0/pretty-print/stringification/Stringifier.ts.html#moduletag", "relUrl": "/pretty-print/stringification/Stringifier.ts.html#moduletag" },"1540": { "doc": "stringification/Stringifier.ts", "title": "stringification/Stringifier.ts", "content": " ", "url": "/0.1.0/pretty-print/stringification/Stringifier.ts.html", "relUrl": "/pretty-print/stringification/Stringifier.ts.html" },"1541": { "doc": "Struct.ts", "title": "Struct overview", "content": "Extension to the Effect Struct module providing prototype-safe struct merging, field overriding, one-key construction, derived-field enrichment, and a refined evolve. ", "url": "/0.1.0/effect-lib/Struct.ts.html#struct-overview", "relUrl": "/effect-lib/Struct.ts.html#struct-overview" },"1542": { "doc": "Struct.ts", "title": "Mental model", "content": ". | This module must be used for objects whose property names are known. When only the property types are known, use MRecord. | Compared to the spread operator, the helpers here intentionally do not copy the prototype: the result is always a fresh Data-shaped object. This makes the loss of prototype explicit instead of hidden behind syntax sugar. | Mutating variants ({@link mutableSet}, {@link mutableEnrichWith}) write in place and should be reserved for hot paths where allocation cost is unacceptable. | . ", "url": "/0.1.0/effect-lib/Struct.ts.html#mental-model", "relUrl": "/effect-lib/Struct.ts.html#mental-model" },"1543": { "doc": "Struct.ts", "title": "Common tasks", "content": ". | Merge / append: {@link prepend}, {@link append} | Override existing fields: {@link set}, {@link mutableSet} | Construct: {@link make} | Add derived fields: {@link enrichWith}, {@link mutableEnrichWith} | Transform fields: {@link evolve} | . ", "url": "/0.1.0/effect-lib/Struct.ts.html#common-tasks", "relUrl": "/effect-lib/Struct.ts.html#common-tasks" },"1544": { "doc": "Struct.ts", "title": "Quickstart", "content": "Example (Append a field then derive another from self) . import { pipe } from \"effect\" import * as MStruct from \"@parischap/effect-lib/MStruct\" const built = pipe( { firstName: \"Ada\" } as const, MStruct.append({ lastName: \"Lovelace\" } as const), MStruct.enrichWith({ fullName: ({ firstName, lastName }) =&gt; `${firstName} ${lastName}` }) ) console.log(built) // { firstName: 'Ada', lastName: 'Lovelace', fullName: 'Ada Lovelace' } . ", "url": "/0.1.0/effect-lib/Struct.ts.html#quickstart", "relUrl": "/effect-lib/Struct.ts.html#quickstart" },"1545": { "doc": "Struct.ts", "title": "Table of contents", "content": ". | Constructors . | make | . | Models . | Type (type alias) | . | Utility types . | Append (type alias) | . | Utils . | append | enrichWith | mutableEnrichWith | mutableSet | prepend | set | { | . | . ", "url": "/0.1.0/effect-lib/Struct.ts.html", "relUrl": "/effect-lib/Struct.ts.html" },"1546": { "doc": "Struct.ts", "title": "Constructors", "content": " ", "url": "/0.1.0/effect-lib/Struct.ts.html#constructors", "relUrl": "/effect-lib/Struct.ts.html#constructors" },"1547": { "doc": "Struct.ts", "title": "make", "content": "Builds a single-field struct { [key]: value }. Example (Single-key constructor) . import { pipe } from \"effect\" import * as MStruct from \"@parischap/effect-lib/MStruct\" console.log(pipe(42, MStruct.make(\"answer\"))) // { answer: 42 } . Signature . export declare const make: &lt;K extends PropertyKey&gt;(key: K) =&gt; &lt;V&gt;(value: V) =&gt; { readonly [key in K]: V } . ", "url": "/0.1.0/effect-lib/Struct.ts.html#make", "relUrl": "/effect-lib/Struct.ts.html#make" },"1548": { "doc": "Struct.ts", "title": "Models", "content": " ", "url": "/0.1.0/effect-lib/Struct.ts.html#models", "relUrl": "/effect-lib/Struct.ts.html#models" },"1549": { "doc": "Struct.ts", "title": "Type (type alias)", "content": "Type of a struct. Ideally, we would have chosen MTypes.Object. But it does not cover class instances on which we want this module to operate . Signature . export type Type = MTypes.NonPrimitive . ", "url": "/0.1.0/effect-lib/Struct.ts.html#type-type-alias", "relUrl": "/effect-lib/Struct.ts.html#type-type-alias" },"1550": { "doc": "Struct.ts", "title": "Utility types", "content": " ", "url": "/0.1.0/effect-lib/Struct.ts.html#utility-types", "relUrl": "/effect-lib/Struct.ts.html#utility-types" },"1551": { "doc": "Struct.ts", "title": "Append (type alias)", "content": "Utility type computing the result of { ...first, ...second }. | When a field exists in both First and Second, the resulting type follows JavaScript’s spread semantics: Second’s value wins, except when it is optional, in which case the result is the union of Second[k] (without undefined) and First[k]. | . Signature . export type Append&lt;First extends Type, Second extends Type&gt; = { readonly [k in keyof First | keyof Second]: k extends keyof Second ? k extends keyof First ? // Is Second[k] not optional Extract&lt;Second[k], undefined&gt; extends never ? Second[k] : Exclude&lt;Second[k], undefined&gt; | First[k] : Second[k] : First[k] } . ", "url": "/0.1.0/effect-lib/Struct.ts.html#append-type-alias", "relUrl": "/effect-lib/Struct.ts.html#append-type-alias" },"1552": { "doc": "Struct.ts", "title": "Utils", "content": " ", "url": "/0.1.0/effect-lib/Struct.ts.html#utils", "relUrl": "/effect-lib/Struct.ts.html#utils" },"1553": { "doc": "Struct.ts", "title": "append", "content": "Builds { ...self, ...that } — fields in that override fields in self. | Use instead of the spread operator when you want to make explicit that the prototype of the left-hand side is dropped. | Same as Effect’s Struct.assign but handles optional values more cleanly. | . Example (New fields override) . import { pipe } from \"effect\" import * as MStruct from \"@parischap/effect-lib/MStruct\" console.log(pipe({ a: 1, b: 2 } as const, MStruct.append({ b: 3, c: 4 } as const))) // { a: 1, b: 3, c: 4 } . Signature . export declare const append: &lt;O1 extends Type&gt;(that: O1) =&gt; &lt;O extends Type&gt;(self: O) =&gt; MTypes.Data&lt;Append&lt;O, O1&gt;&gt; . ", "url": "/0.1.0/effect-lib/Struct.ts.html#append", "relUrl": "/effect-lib/Struct.ts.html#append" },"1554": { "doc": "Struct.ts", "title": "enrichWith", "content": "Computes a record of new fields where each value is f(self) for the corresponding key, then appends them to self. | Use when several derived fields all depend on the same source struct. | Existing fields with the same key are overwritten. | . Example (Adding derived fields) . import { pipe } from \"effect\" import * as MStruct from \"@parischap/effect-lib/MStruct\" console.log( pipe( { firstName: \"Ada\", lastName: \"Lovelace\" } as const, MStruct.enrichWith({ fullName: ({ firstName, lastName }) =&gt; `${firstName} ${lastName}`, initials: ({ firstName, lastName }) =&gt; `${firstName[0]}.${lastName[0]}.` }) ) ) // { firstName: 'Ada', lastName: 'Lovelace', fullName: 'Ada Lovelace', initials: 'A.L.' } . Signature . export declare const enrichWith: &lt;O extends Type, O1 extends { [x: PropertyKey]: MTypes.OneArgFunction&lt;O, unknown&gt; }&gt;( fields: O1 ) =&gt; (self: O) =&gt; MTypes.Data&lt;Omit&lt;O, keyof O1&gt; &amp; { readonly [key in keyof O1]: ReturnType&lt;O1[key]&gt; }&gt; . ", "url": "/0.1.0/effect-lib/Struct.ts.html#enrichwith", "relUrl": "/effect-lib/Struct.ts.html#enrichwith" },"1555": { "doc": "Struct.ts", "title": "mutableEnrichWith", "content": "Same as {@link enrichWith} but writes the new fields into self in place using Object.assign. | Use only when allocation cost matters and self is not shared. | . Signature . export declare const mutableEnrichWith: &lt; O extends MTypes.NonPrimitive, O1 extends { [x: PropertyKey]: MTypes.OneArgFunction&lt;O, unknown&gt; } &gt;( fields: O1 ) =&gt; (self: O) =&gt; Omit&lt;O, keyof O1&gt; &amp; { readonly [key in keyof O1]: ReturnType&lt;O1[key]&gt; } . ", "url": "/0.1.0/effect-lib/Struct.ts.html#mutableenrichwith", "relUrl": "/effect-lib/Struct.ts.html#mutableenrichwith" },"1556": { "doc": "Struct.ts", "title": "mutableSet", "content": "Same as {@link set} but writes the new fields into self in place using Object.assign. | Use only when allocation cost matters and self is not shared. | . Signature . export declare const mutableSet: &lt;O extends Type, O1 extends Partial&lt;O&gt;&gt;( that: O1 ) =&gt; (self: O) =&gt; Omit&lt;O, keyof O1&gt; &amp; O1 . ", "url": "/0.1.0/effect-lib/Struct.ts.html#mutableset", "relUrl": "/effect-lib/Struct.ts.html#mutableset" },"1557": { "doc": "Struct.ts", "title": "prepend", "content": "Builds { ...that, ...self } — fields in self override fields in that. | Use instead of the spread operator when you want to make explicit that the prototype of the left-hand side is dropped. | Same as Effect’s Struct.assign but handles optional values more cleanly. | . Example (Self overrides defaults) . import { pipe } from \"effect\" import * as MStruct from \"@parischap/effect-lib/MStruct\" const defaults = { theme: \"light\", font: \"serif\" } as const console.log(pipe({ font: \"mono\" } as const, MStruct.prepend(defaults))) // { theme: 'light', font: 'mono' } . Signature . export declare const prepend: &lt;O1 extends Type&gt;(that: O1) =&gt; &lt;O extends Type&gt;(self: O) =&gt; MTypes.Data&lt;Append&lt;O1, O&gt;&gt; . ", "url": "/0.1.0/effect-lib/Struct.ts.html#prepend", "relUrl": "/effect-lib/Struct.ts.html#prepend" },"1558": { "doc": "Struct.ts", "title": "set", "content": "Like {@link append} but that may only override fields that already exist in self. New keys are rejected at the type level. Example (Override only declared fields) . import { pipe } from \"effect\" import * as MStruct from \"@parischap/effect-lib/MStruct\" type User = { readonly name: string; readonly age: number } const user: User = { name: \"Ada\", age: 30 } console.log(pipe(user, MStruct.set({ age: 31 }))) // { name: 'Ada', age: 31 } . Signature . export declare const set: &lt;O extends Type, O1 extends Partial&lt;O&gt;&gt;( that: O1 ) =&gt; (self: O) =&gt; MTypes.Data&lt;Omit&lt;O, keyof O1&gt; &amp; O1&gt; . ", "url": "/0.1.0/effect-lib/Struct.ts.html#set", "relUrl": "/effect-lib/Struct.ts.html#set" },"1559": { "doc": "Struct.ts", "title": "{", "content": "evolve, } . Same as Struct.evolve but the return type drops any property carried by the prototype, since those are not copied by spreading. Transformations whose key is missing in self are ignored. Example (Evolving selected fields) . import { pipe } from \"effect\" import * as MStruct from \"@parischap/effect-lib/MStruct\" console.log( pipe({ firstName: \"ada\", lastName: \"lovelace\" } as const, MStruct.evolve({ firstName: (s) =&gt; s.toUpperCase() })) ) // { firstName: 'ADA', lastName: 'lovelace' } . Signature . export declare const { evolve }: any . ", "url": "/0.1.0/effect-lib/Struct.ts.html", "relUrl": "/effect-lib/Struct.ts.html" },"1560": { "doc": "Struct.ts", "title": "Struct.ts", "content": " ", "url": "/0.1.0/effect-lib/Struct.ts.html", "relUrl": "/effect-lib/Struct.ts.html" },"1561": { "doc": "Parameters/Style.ts", "title": "Style overview", "content": "This module implements a PPStyle, a context-dependent styler whose context is the value being rendered. A PPStyle is an alias for ASContextStyler.Type&lt;PPValue.Any&gt; (see @parischap/ansi-styles/ASContextStyler). It allows the style applied to a part of the output to vary with the depth, runtime type, or key type of the value being rendered. Three palette-based constructors are provided: makeDepthIndexed, makeTypeIndexed, and makeKeyTypeIndexed. Use any constructor of ASContextStyler to define more specialized styles. ", "url": "/0.1.0/pretty-print/Parameters/Style.ts.html#style-overview", "relUrl": "/pretty-print/Parameters/Style.ts.html#style-overview" },"1562": { "doc": "Parameters/Style.ts", "title": "Table of contents", "content": ". | Constructors . | makeDepthIndexed | makeKeyTypeIndexed | makeTypeIndexed | . | Models . | Type (type alias) | . | . ", "url": "/0.1.0/pretty-print/Parameters/Style.ts.html", "relUrl": "/pretty-print/Parameters/Style.ts.html" },"1563": { "doc": "Parameters/Style.ts", "title": "Constructors", "content": " ", "url": "/0.1.0/pretty-print/Parameters/Style.ts.html#constructors", "relUrl": "/pretty-print/Parameters/Style.ts.html#constructors" },"1564": { "doc": "Parameters/Style.ts", "title": "makeDepthIndexed", "content": "Constructor of a palette-based depth-indexed PPStyle that picks a color from palette using the current nesting depth of the value being rendered. Useful for bracket coloring. Signature . export declare const makeDepthIndexed: (palette: ASPalette.Type) =&gt; Type . ", "url": "/0.1.0/pretty-print/Parameters/Style.ts.html#makedepthindexed", "relUrl": "/pretty-print/Parameters/Style.ts.html#makedepthindexed" },"1565": { "doc": "Parameters/Style.ts", "title": "makeKeyTypeIndexed", "content": "Constructor of a palette-based key-type-indexed PPStyle that picks index 0 from palette for properties whose key is a string and index 1 for properties whose key is a symbol. Useful for property-key coloring. Signature . export declare const makeKeyTypeIndexed: (palette: ASPalette.Type) =&gt; Type . ", "url": "/0.1.0/pretty-print/Parameters/Style.ts.html#makekeytypeindexed", "relUrl": "/pretty-print/Parameters/Style.ts.html#makekeytypeindexed" },"1566": { "doc": "Parameters/Style.ts", "title": "makeTypeIndexed", "content": "Constructor of a palette-based type-indexed PPStyle that picks a color from palette using the runtime type of the value’s content (string, number, bigint, boolean, symbol, null, undefined). Useful for primitive-value coloring. Signature . export declare const makeTypeIndexed: (palette: ASPalette.Type) =&gt; Type . ", "url": "/0.1.0/pretty-print/Parameters/Style.ts.html#maketypeindexed", "relUrl": "/pretty-print/Parameters/Style.ts.html#maketypeindexed" },"1567": { "doc": "Parameters/Style.ts", "title": "Models", "content": " ", "url": "/0.1.0/pretty-print/Parameters/Style.ts.html#models", "relUrl": "/pretty-print/Parameters/Style.ts.html#models" },"1568": { "doc": "Parameters/Style.ts", "title": "Type (type alias)", "content": "Type of a PPStyle . Signature . export type Type = ASContextStyler.Type&lt;PPValue.Any&gt; . ", "url": "/0.1.0/pretty-print/Parameters/Style.ts.html#type-type-alias", "relUrl": "/pretty-print/Parameters/Style.ts.html#type-type-alias" },"1569": { "doc": "Parameters/Style.ts", "title": "Parameters/Style.ts", "content": " ", "url": "/0.1.0/pretty-print/Parameters/Style.ts.html", "relUrl": "/pretty-print/Parameters/Style.ts.html" },"1570": { "doc": "Style.ts", "title": "Style overview", "content": "This module defines Style, a callable type that applies ANSI formatting to text. Styles can be composed and nested. For instance, ASStyle.red('foo') creates a text containing the string ‘foo’ styled in red. ", "url": "/0.1.0/ansi-styles/Style.ts.html#style-overview", "relUrl": "/ansi-styles/Style.ts.html#style-overview" },"1571": { "doc": "Style.ts", "title": "Table of contents", "content": ". | Constructors . | bgColor | color | . | Destructors . | toString | . | Equivalences . | equivalence | . | Getters . | style | . | Instances . | bgBlack | bgBlue | bgBrightBlack | bgBrightBlue | bgBrightCyan | bgBrightGreen | bgBrightMagenta | bgBrightRed | bgBrightWhite | bgBrightYellow | bgCyan | bgDefaultColor | bgGreen | bgMagenta | bgRed | bgWhite | bgYellow | black | blinking | blue | bold | brightBlack | brightBlue | brightCyan | brightGreen | brightMagenta | brightRed | brightWhite | brightYellow | cyan | defaultColor | dim | green | hidden | inversed | italic | magenta | none | notBlinking | notBold | notDim | notHidden | notInversed | notItalic | notOverlined | notStruckThrough | notUnderlined | overlined | red | struckThrough | underlined | white | yellow | . | Models . | Action (namespace) . | Type (interface) | . | Type (interface) | . | Module markers . | moduleTag | . | Utils . | mergeOver | mergeUnder | . | . ", "url": "/0.1.0/ansi-styles/Style.ts.html", "relUrl": "/ansi-styles/Style.ts.html" },"1572": { "doc": "Style.ts", "title": "Constructors", "content": " ", "url": "/0.1.0/ansi-styles/Style.ts.html#constructors", "relUrl": "/ansi-styles/Sty