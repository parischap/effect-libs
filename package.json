{
  "name": "@parischap-dev/effect-libs",
  "type": "module",
  "description": "effect-libs is a set of open-source libraries to be used in complement to the effect library. Offers Date and number parsing/formatting, sscanf/sprintf templating, number rounding, object pretty-printing and ansi-colors for terminal printing",
  "author": "Jérôme MARTIN",
  "license": "MIT",
  "scripts": {
    "tscheck": "tsc -b tsconfig.json --force --noEmit",
    "lint": "eslint .",
    "lint-rules": "pnpx @eslint/config-inspector",
    "format": "prettier . --write",
    "rmrf": "node --experimental-transform-types rmrf.ts",
    "mkdirp": "node --experimental-transform-types mkdirp.ts",
    "clean-node-modules": "rm node  node_modules",
    "clean-config-files": "pnpm rmrf tsconfig.json && pnpm rmrf package.json",
    "reinstall-all-dependencies": "pnpm i --force",
    "update-all-config-files": "pnpm -r -include-workspace-root=true --workspace-concurrency=1 update-config-files",
    "clean-all-node-modules": "pnpm -r -include-workspace-root=true clean-node-modules",
    "clean-all-config-files": "pnpm -r -include-workspace-root=true clean-config-files",
    "clean-all-prod": "pnpm -r clean-prod",
    "build-all": "pnpm -r build",
    "prepare-docs": "pnpm -r --if-present -include-workspace-root=true --parallel docgen && compile-docs"
  },
  "devDependencies": {
    "globals": "16.4.0",
    "eslint": "9.39.1",
    "@eslint/js": "9.39.1",
    "@eslint/json": "0.14.0",
    "@eslint/markdown": "7.5.1",
    "@html-eslint/eslint-plugin": "0.49.0",
    "@html-eslint/parser": "0.49.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-functional": "9.0.2",
    "eslint-plugin-import-x": "4.16.1",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-yml": "1.19.0",
    "typescript-eslint": "8.47.0",
    "prettier": "3.6.2",
    "prettier-plugin-jsdoc": "1.5.0",
    "@tsconfig/strictest": "2.0.8",
    "@effect/language-service": "0.55.2",
    "@types/node": "24.10.1",
    "typescript": "5.9.3",
    "jiti": "2.6.1"
  },
  "packageManager": "pnpm@10.23.0"
}