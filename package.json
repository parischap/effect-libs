{
  "name": "@parischap/effect-libs",
  "type": "module",
  "author": "Jérôme MARTIN",
  "license": "MIT",
  "description": "effect-libs is a set of open-source libraries to be used in complement to the effect library. Extends some Effect modules (`Array`, `Chunk`, `Option`, `Either`, `String`, ...). Adds extra-functionalities such as date and number parsing/formatting, sscanf/sprintf templating, number rounding, object pretty-printing, colored terminal printing, a simple yet very efficient matcher and a tree with cycle detection",
  "homepage": "https://github.com/parischap/effect-libs",
  "scripts": {
    "test-all": "vitest run",
    "lint": "oxlint --type-aware --type-check --report-unused-disable-directives --disable-nested-config",
    "lint-fix": "oxlint --type-aware --fix",
    "fmt": "oxfmt --disable-nested-config --list-different",
    "commands": "tsx node_modules/@parischap/configs/esm/bin/commands.ts",
    "build-all": "pnpm --if-present -r build",
    "lint-all": "pnpm --filter \"./**\" run  lint",
    "fmt-all": "pnpm --filter \"./**\" run  fmt",
    "lint-fix-all": "pnpm --filter \"./**\" run  lint-fix",
    "checks-all": "pnpm --filter \"./**\" run  checks",
    "docgen-all": "pnpm --filter \"./packages/*\" run  docgen",
    "prepare": "effect-tsgo patch",
    "checks": "pnpm lint"
  },
  "devDependencies": {
    "@parischap/configs": "0.1.0",
    "vitest": "4.1.5",
    "@types/node": "25.6.0",
    "@typescript/native-preview": "7.0.0-dev.20260427.1",
    "@effect/tsgo": "0.5.1",
    "@tsconfig/strictest": "2.0.8",
    "oxfmt": "0.46.0",
    "oxlint": "1.61.0",
    "oxlint-tsgolint": "0.22.0",
    "tsx": "4.21.0"
  }
}