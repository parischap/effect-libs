{
  "extends": "@parischap/configs/TsconfigBase",
  "exclude": [
    ".git",
    "dist",
    ".tsbuildinfo",
    "node_modules",
    "packages",
    "esm",
    "examples",
    "tests",
    "readme-assets",
    "vite.config.ts.timestamp-*.mjs",
    "pnpm-lock.yaml"
  ],
  "compilerOptions": {
    "tsBuildInfoFile": ".tsbuildinfo/others.tsbuildinfo",
    "rootDir": ".",
    "outDir": "dist/others",
    "declarationDir": "dist/others/dts"
  }
}