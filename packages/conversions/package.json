    "tsconfig": "tsc --showConfig --project tsconfig.esm.json",
    "examples": "unrun examples/perf.ts && unrun examples/RoundingOption_1.ts && unrun examples/RoundingOption_2.ts && unrun examples/RoundingOption_3.ts && unrun examples/NumberBase10Format_1.ts && unrun examples/NumberBase10Format_2.ts && unrun examples/Template_1.ts && unrun examples/Template_2.ts && unrun examples/Template_3.ts && unrun examples/DateTime_1.ts && unrun examples/DateTimeFormat_1.ts && unrun examples/DateTimeFormat_2.ts && unrun examples/Branding.ts",
