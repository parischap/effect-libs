{
  "$schema": "node_modules/@effect/docgen/schema.json",
  "srcDir": "esm",
  "exclude": [
    "esm/bin/**/*",
    "esm/index.ts",
    "esm/internal/**/*"
  ],
  "outDir": "docs",
  "parseCompilerOptions": "tsconfig.docgen.json",
  "examplesCompilerOptions": "tsconfig.docgen.json",
  "enforceDescriptions": true,
  "enforceExamples": false,
  "enforceVersion": false
}