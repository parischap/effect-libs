{
  "name": "@parischap-dev/configs",
  "type": "module",
  "description": "Default subrepo",
  "author": "Jérôme MARTIN",
  "license": "MIT",
  "scripts": {
    "update-config-files": "jiti node_modules/@parischap/configs/esm/bin/update-config-files.ts",
    "tscheck": "tsc -b tsconfig.json --force --noEmit",
    "lint": "eslint .",
    "lint-rules": "pnpx @eslint/config-inspector",
    "format": "prettier . --write",
    "clean-config-files": "shx rm -f package.json && shx rm -f tsconfig.json",
    "clean-node-modules": "shx rm -rf node_modules",
    "reinstall-all-dependencies": "pnpm i --force",
    "circular": "madge --extensions ts --circular --no-color --no-spinner esm",
    "checks": "pnpm circular && pnpm lint && pnpm tscheck && pnpm test",
    "test": "vitest run",
    "clean-prod": "shx rm -rf dist && shx mkdir -p dist",
    "build": "pnpm clean-prod && pnpm compile && cd ${prodFolderName} && pnpm i && cd ..",
    "examples": "",
    "compile": "tsc -b tsconfig.esm.json --force && babel dist --plugins annotate-pure-calls --out-dir dist --source-maps && pnpm prodify-lib"
  },
  "devDependencies": {
    "@parischap/configs": "workspace:@parischap-dev/configs@*"
  },
  "module": "./esm/index.js",
  "exports": {
    ".": {
      "import": "./esm/index.ts"
    }
  },
  "dependencies": {
    "effect": "^3.18.1",
    "@effect/experimental": "0.57.0"
  },
  "publishConfig": {},
  "repository": {
    "type": "git",
    "url": "git+https://github.com/parischap/myeffectdevs.git",
    "directory": "packages/configs"
  },
  "homepage": "https://github.com/parischap/myeffectdevs/tree/master/packages/configs",
  "sideEffects": [],
  "private": true
}