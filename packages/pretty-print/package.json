{
  "name": "@parischap/pretty-print",
  "type": "module",
  "author": "Jérôme MARTIN",
  "license": "MIT",
  "description": "A functional library to pretty-print and treeify objects",
  "homepage": "https://github.com/parischap/effect-libs/tree/master/packages/pretty-print",
  "scripts": {
    "test-all": "vitest run",
    "lint": "oxlint -disable-nested-config",
    "fmt": "oxfmt -disable-nested-config && oxlint --fix -disable-nested-config",
    "lint-all": "pnpm lint && pnpm --filter \"./packages/*\" run  lint-all",
    "fmt-all": "pnpm fmt && pnpm --filter \"./packages/*\" run  fmt-all",
    "check-all": "pnpm check && pnpm --filter \"./packages/*\" run  check-all",
    "configs": "pnpm -w configs",
    "circular": "madge --extensions ts --circular --no-color --no-spinner esm",
    "check": "pnpm circular && pnpm lint && pnpm test-all",
    "examples": "tsx examples/util-inspect-like.ts && tsx examples/treeify.ts && tsx examples/treeify-with-leaves.ts && tsx examples/circularity-handling.ts && tsx examples/with-date-and-regexp.ts && tsx examples/with-prototype-chain.ts && tsx examples/with-custom-style-map.ts && tsx examples/with-custom-primitive-formatter.ts && tsx examples/with-property-filter-and-sort.ts",
    "publish-to-npm": "cd dist && npm publish --access=public",
    "docgen": "docgen",
    "docgen-all": "docgen"
  },
  "@parischap/configs": {
    "description": "A functional library to pretty-print and treeify objects",
    "version": "1.0.0",
    "buildMethod": "InternalAndNpmBundling",
    "publishToNpm": true,
    "dependencies": {},
    "environment": "Neutral",
    "examples": [
      "util-inspect-like.ts",
      "treeify.ts",
      "treeify-with-leaves.ts",
      "circularity-handling.ts",
      "with-date-and-regexp.ts",
      "with-prototype-chain.ts",
      "with-custom-style-map.ts",
      "with-custom-primitive-formatter.ts",
      "with-property-filter-and-sort.ts"
    ],
    "keywords": [
      "inspect",
      "util.inspect",
      "object",
      "stringify",
      "pretty",
      "tree",
      "treeify",
      "print",
      "console",
      "visualize",
      "debug",
      "typescript",
      "effect"
    ],
    "packagePrefix": "PP",
    "peerDependencies": {
      "effect": "*",
      "@parischap/effect-lib": "*",
      "@parischap/ansi-styles": "*",
      "@parischap/conversions": "*"
    },
    "scripts": {}
  },
  "exports": {
    ".": {
      "default": "./esm/index.ts"
    },
    "./PPByPasser": {
      "default": "./esm/parameters/ByPasser.ts"
    },
    "./PPNonPrimitiveFormatter": {
      "default": "./esm/parameters/NonPrimitiveFormatter.ts"
    },
    "./PPNonPrimitiveParameters": {
      "default": "./esm/parameters/NonPrimitiveParameters.ts"
    },
    "./PPParameters": {
      "default": "./esm/parameters/Parameters.ts"
    },
    "./PPPartName": {
      "default": "./esm/parameters/PartName.ts"
    },
    "./PPPrimitiveFormatter": {
      "default": "./esm/parameters/PrimitiveFormatter.ts"
    },
    "./PPPropertyFilter": {
      "default": "./esm/parameters/PropertyFilter.ts"
    },
    "./PPPropertyFormatter": {
      "default": "./esm/parameters/PropertyFormatter.ts"
    },
    "./PPPropertyNumberDisplayOption": {
      "default": "./esm/parameters/PropertyNumberDisplayOption.ts"
    },
    "./PPResolvedNonPrimitiveParameters": {
      "default": "./esm/internal/parameters/ResolvedNonPrimitiveParameters.ts"
    },
    "./PPStringifiedProperties": {
      "default": "./esm/internal/stringification/StringifiedProperties.ts"
    },
    "./PPStringifiedValue": {
      "default": "./esm/stringification/StringifiedValue.ts"
    },
    "./PPStringifier": {
      "default": "./esm/stringification/Stringifier.ts"
    },
    "./PPStyle": {
      "default": "./esm/parameters/Style.ts"
    },
    "./PPStyleMap": {
      "default": "./esm/parameters/StyleMap.ts"
    },
    "./PPStyles": {
      "default": "./esm/internal/parameters/Styles.ts"
    },
    "./PPValue": {
      "default": "./esm/internal/stringification/Value.ts"
    },
    "./PPValueOrder": {
      "default": "./esm/parameters/ValueOrder.ts"
    },
    "./PPValues": {
      "default": "./esm/internal/stringification/Values.ts"
    }
  },
  "dependencies": {},
  "peerDependencies": {
    "effect": "*",
    "@parischap/effect-lib": "workspace:*",
    "@parischap/ansi-styles": "workspace:*",
    "@parischap/conversions": "workspace:*"
  }
}