{
  "name": "@parischap-dev/pretty-print",
  "type": "module",
  "description": "A functional library to pretty-print and treeify objects",
  "author": "Jérôme MARTIN",
  "license": "MIT",
  "scripts": {
    "tscheck": "tsc -b tsconfig.json --force --noEmit",
    "lint": "eslint .",
    "lint-rules": "pnpx @eslint/config-inspector",
    "format": "prettier . --write",
    "update-config-files": "vite-node node_modules/@parischap/configs/esm/bin/update-config-files.ts",
    "rm": "node node_modules/@parischap/configs/esm/bin/rm.js",
    "clean-node-modules": "rm node  node_modules",
    "clean-config-files": "shx rm -f package.json && shx rm -f tsconfig.json",
    "reinstall-all-dependencies": "pnpm i --force",
    "circular": "madge --extensions ts --circular --no-color --no-spinner esm",
    "checks": "pnpm circular && pnpm lint && pnpm tscheck && pnpm test",
    "test": "vitest run",
    "clean-prod": "shx rm -rf dist && shx mkdir -p dist",
    "build": "pnpm clean-prod && pnpm compile && cd ${prodFolderName} && pnpm i && cd ..",
    "examples": "vite-node examples/util-inspect-like.ts&&vite-node examples/treeify.ts&&vite-node examples/treeify-with-leaves.ts&&vite-node examples/circularity-handling.ts",
    "compile": "tsc -b tsconfig.esm.json --force && babel dist/esm --out-dir dist/cjs--plugins @babel/transform-export-namespace-from --plugins @babel/transform-modules-commonjs  --source-maps && babel dist --plugins annotate-pure-calls --out-dir dist --source-maps && pnpm prodify-lib",
    "build-and-publish": "pnpm build && pnpm checks && pnpm publish-to-npm",
    "publish-to-npm": "cd dist && npm publish --access=public && cd ..",
    "docgen": "docgen"
  },
  "devDependencies": {
    "@parischap/configs": "git+ssh://github.com/parischap/configs",
    "@parischap/pretty-print": "workspace:@parischap-dev/pretty-print@*",
    "@parischap/test-utils": "git+ssh://github.com/parischap/test-utils",
    "globals": "^16.4.0",
    "eslint": "^9.37.0",
    "@eslint/js": "^9.37.0",
    "@eslint/json": "^0.14.0",
    "@eslint/markdown": "^7.3.0",
    "@html-eslint/eslint-plugin": "^0.47.0",
    "@html-eslint/parser": "^0.47.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-functional": "^9.0.2",
    "eslint-plugin-import-x": "4.16.1",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-yml": "^1.19.0",
    "typescript-eslint": "^8.45.0",
    "prettier-plugin-jsdoc": "^1.3.3",
    "@effect/platform": "^0.93.0",
    "@effect/platform-node": "^0.100.0",
    "@effect/cluster": "^0.52.5",
    "@effect/rpc": "^0.72.1",
    "@effect/sql": "^0.48.0",
    "@effect/workflow": "^0.12.2",
    "prettier": "^3.6.2",
    "@tsconfig/strictest": "^2.0.6",
    "@effect/language-service": "^0.55.2",
    "@types/node": "^24.7.0",
    "vite-node": "^5.0.0",
    "typescript": "^5.9.3",
    "jiti": "2.6.1",
    "vitest": "^4.0.7",
    "madge": "^8.0.0",
    "@effect/experimental": "0.57.0",
    "vite": "npm:rolldown-vite@^7.1.17",
    "@babel/core": "^7.28.4",
    "babel-plugin-annotate-pure-calls": "^0.5.0",
    "@babel/plugin-transform-export-namespace-from": "^7.27.1",
    "@babel/plugin-transform-modules-commonjs": "^7.27.1",
    "@effect/docgen": "^0.5.2",
    "tsx": "^4.20.6"
  },
  "module": "./esm/index.js",
  "exports": {
    ".": {
      "import": "./esm/index.js"
    },
    "./tests": {
      "import": "./esm/index.tests.js"
    }
  },
  "peerDependencies": {
    "@parischap/effect-lib": "workspace:@parischap-dev/effect-lib@*",
    "@parischap/ansi-styles": "workspace:@parischap-dev/ansi-styles@*",
    "effect": "^3.18.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/parischap/effect-libs.git",
    "directory": "packages/pretty-print"
  },
  "homepage": "https://github.com/parischap/effect-libs/tree/master/packages/pretty-print",
  "sideEffects": [],
  "bugs": {
    "url": "https://github.com/parischap/effect-libs/issues"
  },
  "funding": [
    {
      "type": "ko-fi",
      "url": "https://ko-fi.com/parischap"
    }
  ],
  "keywords": [
    "inspect",
    "util.inspect",
    "object",
    "stringify",
    "pretty",
    "tree",
    "treeify",
    "print",
    "console",
    "visualize",
    "debug",
    "typescript",
    "effect",
    "effect",
    "typescript",
    "functional-programming"
  ],
  "publishConfig": {
    "peerDependencies": {
      "@parischap/effect-lib": "^0.11.0",
      "@parischap/ansi-styles": "^0.2.6"
    }
  }
}