{
  "name": "@parischap/node-effect-lib",
  "type": "module",
  "author": "Jérôme MARTIN",
  "license": "MIT",
  "description": "A complement to the official @effect/platform library with add-ons for Node.js",
  "homepage": "https://github.com/parischap/effect-libs/tree/master/packages/node-effect-lib",
  "scripts": {
    "test-all": "vitest run",
    "lint": "oxlint --disable-nested-config",
    "fmt": "oxfmt --disable-nested-config && oxlint --fix -disable-nested-config",
    "configs": "pnpm -w configs",
    "circular": "madge --extensions ts --circular --no-color --no-spinner esm",
    "check": "pnpm circular && pnpm lint && pnpm test-all",
    "lint-all": "pnpm lint",
    "fmt-all": "pnpm fmt",
    "check-all": "pnpm check",
    "docgen-all": "echo \"No doc generation for 'node-effect-lib'\"",
    "release-all": "echo \"Nothing to release for 'node-effect-lib'\""
  },
  "@parischap/configs": {
    "description": "A complement to the official @effect/platform library with add-ons for Node.js",
    "version": "0.1.0",
    "build": "None",
    "publishTarget": "None",
    "docScope": "None",
    "dependencies": {},
    "environment": "Node",
    "examples": [],
    "keywords": [],
    "packagePrefix": "N",
    "peerDependencies": {
      "effect": "*",
      "@effect/platform-node": "*",
      "@parischap/effect-lib": "*"
    },
    "scripts": {}
  },
  "exports": {
    ".": {
      "default": "./esm/index.ts"
    },
    "./NFs": {
      "default": "./esm/Fs.ts"
    },
    "./NPath": {
      "default": "./esm/Path.ts"
    }
  },
  "dependencies": {},
  "peerDependencies": {
    "effect": "*",
    "@effect/platform-node": "*",
    "@parischap/effect-lib": "workspace:*"
  }
}