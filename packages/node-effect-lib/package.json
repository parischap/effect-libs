{
  "name": "@parischap/node-effect-lib",
  "type": "module",
  "author": "Jérôme MARTIN",
  "license": "MIT",
  "description": "A complement to the official @effect/platform library with add-ons for Node.js",
  "homepage": "https://github.com/parischap/effect-libs/tree/master/packages/node-effect-lib",
  "scripts": {
    "test-all": "vitest run",
    "lint": "oxlint --type-check --report-unused-disable-directives --disable-nested-config",
    "lint-fix": "oxlint --fix",
    "fmt": "oxfmt --disable-nested-config --list-different",
    "commands": "tsx node_modules/@parischap/configs/esm/bin/commands.ts",
    "prepare-go": "effect-tsgo patch",
    "build-all": "pnpm --if-present -r build",
    "lint-all": "pnpm --filter \"./**\" run  lint",
    "fmt-all": "pnpm --filter \"./**\" run  fmt",
    "lint-fix-all": "pnpm --filter \"./**\" run  lint-fix",
    "checks-all": "pnpm --filter \"./**\" run  checks",
    "docgen-all": "pnpm --filter \"./packages/*\" run  docgen",
    "prepare-go-all": "pnpm --filter \"./packages/*\" run  prepare-go",
    "generate-maps": "tsx node_modules/@parischap/configs/esm/bin/generate-maps.ts",
    "checks": "pnpm circular && pnpm lint && pnpm test-all",
    "circular": "madge --extensions ts --circular --no-color --no-spinner esm",
    "build-and-publish": "pnpm checks && pnpm build && pnpm publish-to-npm",
    "publish-to-npm": "cd dist && npm publish --access=public && cd .."
  },
  "devDependencies": {
    "@parischap/configs": "0.1.0",
    "vitest": "4.1.5",
    "@types/node": "25.6.0",
    "@typescript/native-preview": "7.0.0-dev.20260427.1",
    "@effect/tsgo": "0.5.1",
    "@tsconfig/strictest": "2.0.8",
    "oxfmt": "0.46.0",
    "oxlint": "1.61.0",
    "oxlint-tsgolint": "0.22.0",
    "tsx": "4.21.0",
    "madge": "8.0.0",
    "vite": "8.0.10"
  },
  "exports": {
    ".": {
      "default": "./esm/index.ts"
    },
    "./N": {
      "default": "./esm/.DS_Store"
    },
    "./NFs": {
      "default": "./esm/Fs.ts"
    },
    "./NPath": {
      "default": "./esm/Path.ts"
    }
  },
  "peerDependencies": {
    "@parischap/effect-lib": "0.12.0",
    "effect": "4.0.0-beta.57",
    "@effect/platform-node": "4.0.0-beta.57"
  }
}