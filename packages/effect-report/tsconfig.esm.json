{
  "include": [
    "esm/**/*.ts"
  ],
  "extends": [
    "./tsconfig.base.json"
  ],
  "compilerOptions": {
    "rootDir": "esm",
    "declarationDir": "dist/dts",
    "outDir": "dist/esm",
    "tsBuildInfoFile": ".tsbuildinfo/esm.tsbuildinfo",
    "noEmit": false,
    "emitDeclarationOnly": true,
    "declarationMap": true,
    "sourceRoot": "https://raw.githubusercontent.com/parischap/effect-libs/0.1.0/packages/effect-report/esm/"
  }
}