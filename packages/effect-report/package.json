{
  "name": "@parischap-dev/effect-report",
  "type": "module",
  "description": "A functional library to prettify Effect logging",
  "author": "Jérôme MARTIN",
  "license": "MIT",
  "scripts": {
    "update-config-files": "vite-node node_modules/@parischap/configs/esm/bin/update-config-files.ts",
    "tscheck": "tsc -b tsconfig.json --force --noEmit",
    "lint": "eslint .",
    "lint-rules": "pnpx @eslint/config-inspector",
    "format": "prettier . --write",
    "clean-config-files": "shx rm -f package.json && shx rm -f tsconfig.json",
    "clean-node-modules": "shx rm -rf node_modules",
    "reinstall-all-dependencies": "pnpm i --force",
    "circular": "madge --extensions ts --circular --no-color --no-spinner esm",
    "checks": "pnpm circular && pnpm lint && pnpm tscheck && pnpm test",
    "test": "vitest run",
    "clean-prod": "shx rm -rf dist && shx mkdir -p dist",
    "build": "pnpm clean-prod && pnpm compile && cd ${prodFolderName} && pnpm i && cd ..",
    "examples": "",
    "compile": "tsc -b tsconfig.esm.json --force && babel dist --plugins annotate-pure-calls --out-dir dist --source-maps && pnpm prodify-lib"
  },
  "devDependencies": {
    "@parischap/configs": "workspace:@parischap-dev/configs@*",
    "@parischap/effect-report": "workspace:@parischap-dev/effect-report@*"
  },
  "module": "./esm/index.js",
  "exports": {
    ".": {
      "import": "./esm/index.js"
    }
  },
  "dependencies": {
    "effect": "^3.18.1"
  },
  "peerDependencies": {
    "@parischap/effect-lib": "workspace:@parischap-dev/effect-lib@*",
    "@parischap/ansi-styles": "workspace:@parischap-dev/ansi-styles@*",
    "effect": "^3.18.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/parischap/effect-libs.git",
    "directory": "packages/effect-report"
  },
  "homepage": "https://github.com/parischap/effect-libs/tree/master/packages/effect-report",
  "sideEffects": [],
  "private": true,
  "publishConfig": {
    "peerDependencies": {
      "@parischap/effect-lib": "^0.11.0",
      "@parischap/ansi-styles": "^0.2.6"
    }
  }
}