{
  "name": "@parischap/playground",
  "type": "module",
  "author": "Jérôme MARTIN",
  "license": "MIT",
  "description": "An Effect playground",
  "homepage": "https://github.com/parischap/effect-libs/tree/master/packages/playground",
  "scripts": {
    "test-all": "vitest run",
    "lint": "oxlint -disable-nested-config",
    "fmt": "oxfmt -disable-nested-config && oxlint --fix -disable-nested-config",
    "lint-all": "pnpm lint && pnpm --filter \"./packages/*\" run  lint-all",
    "fmt-all": "pnpm fmt && pnpm --filter \"./packages/*\" run  fmt-all",
    "check-all": "pnpm check && pnpm --filter \"./packages/*\" run  check-all",
    "configs": "pnpm -w configs",
    "circular": "madge --extensions ts --circular --no-color --no-spinner esm",
    "check": "pnpm circular && pnpm lint && pnpm test-all",
    "publish-to-npm-all": "pnpm publish-to-npm",
    "docgen-all": "pnpm docgen",
    "zip-release-assets-all": "pnpm docgen",
    "docgen": "echo \"No doc generation for 'playground'\"",
    "publish-to-npm": "echo \"Nothing to publish to npm for 'playground'\"",
    "zip-release-assets": "echo \"Nothing to zip for 'playground'\""
  },
  "@parischap/configs": {
    "description": "An Effect playground",
    "version": "0.1.0",
    "buildMethod": "None",
    "publishTarget": "None",
    "dependencies": {
      "@parischap/effect-lib": "*"
    },
    "environment": "Node",
    "examples": [],
    "keywords": [],
    "peerDependencies": {},
    "scripts": {}
  },
  "exports": {
    ".": {
      "default": "./esm/index.ts"
    }
  },
  "dependencies": {
    "@parischap/effect-lib": "workspace:*"
  },
  "peerDependencies": {}
}