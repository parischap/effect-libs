{
  "name": "@parischap/playground",
  "description": "An Effect playground",
  "homepage": "https://github.com/parischap/effect-libs/tree/master/packages/playground",
  "license": "MIT",
  "author": "Jérôme MARTIN",
  "type": "module",
  "exports": {
    ".": {
      "default": "./esm/index.ts"
    }
  },
  "scripts": {
    "test-all": "vitest run",
    "lint": "oxlint --disable-nested-config",
    "fmt": "oxfmt --disable-nested-config && oxlint --fix -disable-nested-config",
    "configs": "pnpm -w configs",
    "circular": "madge --extensions ts --circular --no-color --no-spinner esm",
    "check": "pnpm circular && pnpm lint && pnpm test-all",
    "lint-all": "pnpm lint",
    "fmt-all": "pnpm fmt",
    "check-all": "pnpm check",
    "docgen-all": "echo \"No doc generation for 'playground'\"",
    "release-all": "echo \"Nothing to release for 'playground'\""
  },
  "dependencies": {
    "@parischap/effect-lib": "workspace:*"
  },
  "peerDependencies": {},
  "@parischap/configs": {
    "description": "An Effect playground",
    "version": "0.1.0",
    "build": "None",
    "publishTarget": "None",
    "docScope": "None",
    "dependencies": {
      "@parischap/effect-lib": "*"
    },
    "environment": "Node",
    "examples": [],
    "keywords": [],
    "peerDependencies": {},
    "scripts": {}
  }
}
