{
  "name": "@parischap/playground",
  "description": "An Effect playground",
  "license": "MIT",
  "author": "Jérôme MARTIN",
  "type": "module",
  "module": "./esm/index.ts",
  "exports": {},
  "scripts": {
    "test": "vitest run",
    "lint": "oxlint --type-aware --type-check --report-unused-disable-directives --disable-nested-config",
    "lint-fix": "oxlint --type-aware --fix",
    "format": "prettier .",
    "clean": "unrun node_modules/@parischap/configs/esm/bin/clean.ts -activePackageOnly",
    "clean-config-files": "unrun node_modules/@parischap/configs/esm/bin/clean-config-files.ts -activePackageOnly",
    "generate-config-files": "unrun node_modules/@parischap/configs/esm/bin/generate-config-files.ts -activePackageOnly",
    "build-all": "pnpm --if-present -r build",
    "lint-all": "pnpm -r --include-workspace-root lint",
    "lint-fix-all": "pnpm -r --include-workspace-root lint-fix",
    "checks-all": "pnpm -r --include-workspace-root checks",
    "format-all": "pnpm -r --include-workspace-root format",
    "clean-all": "unrun node_modules/@parischap/configs/esm/bin/clean.ts",
    "clean-all-config-files": "unrun node_modules/@parischap/configs/esm/bin/clean-config-files.ts",
    "clean-all-node-modules": "unrun node_modules/@parischap/configs/esm/bin/clean-node-modules.ts",
    "clean-all-prod": "unrun node_modules/@parischap/configs/esm/bin/clean-prod.ts",
    "generate-all-config-files": "unrun node_modules/@parischap/configs/esm/bin/generate-config-files.ts",
    "update-all-exports": "unrun node_modules/@parischap/configs/esm/bin/update-exports.ts",
    "rewrite-all-imports": "unrun node_modules/@parischap/configs/esm/bin/rewrite-imports.ts",
    "build": "pnpm clean-prod && pnpm compile && cd dist && pnpm i && cd ..",
    "compile": "unrun node_modules/@parischap/configs/esm/bin/compile.ts -activePackageOnly",
    "checks": "pnpm circular && pnpm lint && pnpm test",
    "circular": "madge --extensions ts --circular --no-color --no-spinner esm",
    "clean-node-modules": "unrun node_modules/@parischap/configs/esm/bin/clean-node-modules.ts -activePackageOnly",
    "clean-prod": "unrun node_modules/@parischap/configs/esm/bin/clean-prod.ts -activePackageOnly",
    "update-exports": "unrun node_modules/@parischap/configs/esm/bin/update-exports.ts -activePackageOnly",
    "rewrite-imports": "unrun node_modules/@parischap/configs/esm/bin/rewrite-imports.ts -activePackageOnly",
    "tsconfig": "tsc --showConfig --project tsconfig.esm.json"
  },
  "dependencies": {
    "@parischap/effect-lib": "^0.11.0",
    "effect": "3.19.15"
  },
  "devDependencies": {
    "@effect/cluster": "0.56.1",
    "@effect/experimental": "0.58.0",
    "@effect/language-service": "0.64.1",
    "@effect/platform": "0.94.2",
    "@effect/platform-node": "0.104.1",
    "@effect/rpc": "0.73.0",
    "@effect/sql": "0.49.0",
    "@effect/workflow": "0.16.0",
    "@parischap/configs": "git+ssh://github.com/parischap/configs",
    "@tsconfig/strictest": "2.0.8",
    "@types/node": "25.0.9",
    "@typescript/native-preview": "7.0.0-dev.20260303.1",
    "madge": "8.0.0",
    "oxlint": "1.51.0",
    "oxlint-tsgolint": "0.16.0",
    "prettier": "3.7.4",
    "prettier-plugin-jsdoc": "1.8.0",
    "prettier-plugin-organize-imports": "4.3.0",
    "unrun": "0.2.28",
    "vite": "npm:rolldown-vite@7.3.1",
    "vitest": "4.0.18"
  }
}
