{
  "include": [
    "esm/**/*.ts"
  ],
  "extends": [
    "./tsconfig.base.json"
  ],
  "compilerOptions": {
    "rootDir": "esm",
    "declarationDir": "dist/dts",
    "outDir": "dist/esm",
    "tsBuildInfoFile": ".tsbuildinfo/esm.tsbuildinfo",
    "noEmit": false,
    "target": "es2020",
    "emitDeclarationOnly": true,
    "stripInternal": false,
    "types": []
  }
}