{
  "name": "@parischap/effect-lib",
  "description": "An extension to the official Effect library",
  "homepage": "https://github.com/parischap/effect-libs/tree/master/packages/effect-lib",
  "license": "MIT",
  "author": "Jérôme MARTIN",
  "type": "module",
  "exports": {
    ".": {
      "default": "./esm/index.ts"
    },
    "./MArray": {
      "default": "./esm/Array.ts"
    },
    "./MBigDecimal": {
      "default": "./esm/BigDecimal.ts"
    },
    "./MBigInt": {
      "default": "./esm/BigInt.ts"
    },
    "./MCache": {
      "default": "./esm/Cache.ts"
    },
    "./MCacheValueContainer": {
      "default": "./esm/internal/CacheValueContainer.ts"
    },
    "./MChunk": {
      "default": "./esm/Chunk.ts"
    },
    "./MData": {
      "default": "./esm/Data/Data.ts"
    },
    "./MEquivalenceBasedEqualityData": {
      "default": "./esm/Data/EquivalenceBasedEqualityData.ts"
    },
    "./MFunction": {
      "default": "./esm/Function.ts"
    },
    "./MInputError": {
      "default": "./esm/InputError.ts"
    },
    "./MMatch": {
      "default": "./esm/Match.ts"
    },
    "./MNumber": {
      "default": "./esm/Number.ts"
    },
    "./MOption": {
      "default": "./esm/Option.ts"
    },
    "./MPortError": {
      "default": "./esm/PortError.ts"
    },
    "./MPredicate": {
      "default": "./esm/Predicate.ts"
    },
    "./MRecord": {
      "default": "./esm/Record.ts"
    },
    "./MRegExp": {
      "default": "./esm/RegExp.ts"
    },
    "./MRegExpString": {
      "default": "./esm/RegExpString.ts"
    },
    "./MResult": {
      "default": "./esm/Result.ts"
    },
    "./MString": {
      "default": "./esm/String/String.ts"
    },
    "./MStringFillPosition": {
      "default": "./esm/String/StringFillPosition.ts"
    },
    "./MStringSearchResult": {
      "default": "./esm/String/StringSearchResult.ts"
    },
    "./MStruct": {
      "default": "./esm/Struct.ts"
    },
    "./MTree": {
      "default": "./esm/Tree/Tree.ts"
    },
    "./MTreeForest": {
      "default": "./esm/Tree/TreeForest.ts"
    },
    "./MTreeLeaf": {
      "default": "./esm/Tree/TreeLeaf.ts"
    },
    "./MTreeNode": {
      "default": "./esm/Tree/TreeNode.ts"
    },
    "./MTreeNonLeaf": {
      "default": "./esm/Tree/TreeNonLeaf.ts"
    },
    "./MTuple": {
      "default": "./esm/Tuple.ts"
    },
    "./MTypes": {
      "default": "./esm/types/types.ts"
    },
    "./MTypesCategory": {
      "default": "./esm/types/TypesCategory.ts"
    }
  },
  "scripts": {
    "test-all": "vitest run",
    "lint": "oxlint --disable-nested-config",
    "fmt": "oxfmt --disable-nested-config && oxlint --fix -disable-nested-config",
    "configs": "pnpm -w configs",
    "circular": "madge --extensions ts --circular --no-color --no-spinner esm",
    "check": "pnpm circular && pnpm lint && pnpm test-all",
    "lint-all": "pnpm lint",
    "fmt-all": "pnpm fmt",
    "check-all": "pnpm check",
    "docgen": "docgen",
    "docgen-all": "pnpm docgen",
    "release-all": "echo \"Nothing to release for 'effect-lib'\""
  },
  "dependencies": {},
  "peerDependencies": {
    "effect": "*"
  },
  "@parischap/configs": {
    "description": "An extension to the official Effect library",
    "version": "0.21.0",
    "build": {
      "bundling": "InternalAndNpmBundling",
      "generateMaps": true,
      "addPureAnnotations": true,
      "generateCjs": true
    },
    "publishTarget": "Npm",
    "docScope": "skipInternal",
    "dependencies": {},
    "environment": "Neutral",
    "examples": [],
    "keywords": [],
    "packagePrefix": "M",
    "peerDependencies": {
      "effect": "*"
    },
    "scripts": {}
  }
}
