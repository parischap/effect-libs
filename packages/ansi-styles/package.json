{
  "name": "@parischap/ansi-styles",
  "description": "A functional library to style your strings in terminals",
  "homepage": "https://github.com/parischap/effect-libs/tree/master/packages/ansi-styles",
  "license": "MIT",
  "author": "Jérôme MARTIN",
  "type": "module",
  "exports": {
    ".": {
      "default": "./esm/index.ts"
    },
    "./ASBackgroundColorStyleCharacteristic": {
      "default": "./esm/internal/OptionalStyleCharacteristic/ColorOptionalStyleCharacteristic/BackgroundColorStyleCharacteristic.ts"
    },
    "./ASBlinkingStyleCharacteristic": {
      "default": "./esm/internal/OptionalStyleCharacteristic/OnOffOptionalStyleCharacteristic/BlinkingStyleCharacteristic.ts"
    },
    "./ASBoldStyleCharacteristic": {
      "default": "./esm/internal/OptionalStyleCharacteristic/OnOffOptionalStyleCharacteristic/BoldStyleCharacteristic.ts"
    },
    "./ASCode": {
      "default": "./esm/internal/Code.ts"
    },
    "./ASColor": {
      "default": "./esm/Color/Color.ts"
    },
    "./ASColorOptionalStyleCharacteristic": {
      "default": "./esm/internal/OptionalStyleCharacteristic/ColorOptionalStyleCharacteristic/ColorOptionalStyleCharacteristic.ts"
    },
    "./ASContextStyler": {
      "default": "./esm/ContextStyler.ts"
    },
    "./ASDimStyleCharacteristic": {
      "default": "./esm/internal/OptionalStyleCharacteristic/OnOffOptionalStyleCharacteristic/DimStyleCharacteristic.ts"
    },
    "./ASEightBitColor": {
      "default": "./esm/Color/EightBitColor.ts"
    },
    "./ASEightBitColorCode": {
      "default": "./esm/internal/Color/EightBitColorCode.ts"
    },
    "./ASForegroundColorStyleCharacteristic": {
      "default": "./esm/internal/OptionalStyleCharacteristic/ColorOptionalStyleCharacteristic/ForegroundColorStyleCharacteristic.ts"
    },
    "./ASHiddenStyleCharacteristic": {
      "default": "./esm/internal/OptionalStyleCharacteristic/OnOffOptionalStyleCharacteristic/HiddenStyleCharacteristic.ts"
    },
    "./ASInversedStyleCharacteristic": {
      "default": "./esm/internal/OptionalStyleCharacteristic/OnOffOptionalStyleCharacteristic/InversedStyleCharacteristic.ts"
    },
    "./ASItalicStyleCharacteristic": {
      "default": "./esm/internal/OptionalStyleCharacteristic/OnOffOptionalStyleCharacteristic/ItalicStyleCharacteristic.ts"
    },
    "./ASOnOffOptionalStyleCharacteristic": {
      "default": "./esm/internal/OptionalStyleCharacteristic/OnOffOptionalStyleCharacteristic/OnOffOptionalStyleCharacteristic.ts"
    },
    "./ASOptionalStyleCharacteristic": {
      "default": "./esm/internal/OptionalStyleCharacteristic/OptionalStyleCharacteristic.ts"
    },
    "./ASOverlinedStyleCharacteristic": {
      "default": "./esm/internal/OptionalStyleCharacteristic/OnOffOptionalStyleCharacteristic/OverlinedStyleCharacteristic.ts"
    },
    "./ASPalette": {
      "default": "./esm/Palette.ts"
    },
    "./ASRgbColor": {
      "default": "./esm/Color/RgbColor.ts"
    },
    "./ASSequence": {
      "default": "./esm/internal/Sequence.ts"
    },
    "./ASStruckThroughStyleCharacteristic": {
      "default": "./esm/internal/OptionalStyleCharacteristic/OnOffOptionalStyleCharacteristic/StruckThroughStyleCharacteristic.ts"
    },
    "./ASStyle": {
      "default": "./esm/Style.ts"
    },
    "./ASStyleCharacteristics": {
      "default": "./esm/internal/StyleCharacteristics.ts"
    },
    "./ASStyles": {
      "default": "./esm/internal/Styles.ts"
    },
    "./ASText": {
      "default": "./esm/Text.ts"
    },
    "./ASThreeBitColor": {
      "default": "./esm/Color/ThreeBitColor.ts"
    },
    "./ASThreeBitColorOffset": {
      "default": "./esm/internal/Color/ThreeBitColorOffset.ts"
    },
    "./ASUnderlinedStyleCharacteristic": {
      "default": "./esm/internal/OptionalStyleCharacteristic/OnOffOptionalStyleCharacteristic/UnderlinedStyleCharacteristic.ts"
    },
    "./ASUnistyledText": {
      "default": "./esm/internal/UnistyledText.ts"
    }
  },
  "scripts": {
    "test-all": "vitest run",
    "lint": "oxlint --disable-nested-config",
    "fmt": "oxfmt --disable-nested-config && oxlint --fix -disable-nested-config",
    "lint-all": "pnpm lint && pnpm --filter \"./packages/*\" run  lint-all",
    "fmt-all": "pnpm fmt && pnpm --filter \"./packages/*\" run  fmt-all",
    "check-all": "pnpm check && pnpm --filter \"./packages/*\" run  check-all",
    "configs": "pnpm -w configs",
    "circular": "madge --extensions ts --circular --no-color --no-spinner esm",
    "check": "pnpm circular && pnpm lint && pnpm test-all",
    "publish-to-npm-all": "pnpm publish-to-npm",
    "docgen-all": "pnpm docgen",
    "zip-release-assets-all": "pnpm zip-release-assets",
    "examples": "tsx examples/basic-usage.ts && tsx examples/cancelling-a-style.ts && tsx examples/simple-colors.ts && tsx examples/all-colors.ts",
    "docgen": "docgen",
    "publish-to-npm": "pnpm publish dist --provenance --no-git-checks --access public",
    "zip-release-assets": "mkdir -p _release-assets && zip -r _release-assets/ansi-styles-maps.zip dist -i '*.map'"
  },
  "dependencies": {},
  "peerDependencies": {
    "@parischap/effect-lib": "workspace:*",
    "effect": "*"
  },
  "@parischap/configs": {
    "description": "A functional library to style your strings in terminals",
    "version": "1.0.1",
    "buildMethod": "InternalAndNpmBundling",
    "publishTarget": "ToNpmAndGithub",
    "dependencies": {},
    "environment": "Neutral",
    "examples": [
      "basic-usage.ts",
      "cancelling-a-style.ts",
      "simple-colors.ts",
      "all-colors.ts"
    ],
    "keywords": [
      "terminal",
      "color",
      "colour",
      "colors",
      "formatting",
      "cli",
      "console",
      "string",
      "ansi",
      "style",
      "styles",
      "tty",
      "formatting",
      "rgb256",
      "shell",
      "xterm",
      "log",
      "logging",
      "command-line",
      "text"
    ],
    "packagePrefix": "AS",
    "peerDependencies": {
      "effect": "*",
      "@parischap/effect-lib": "*"
    },
    "scripts": {}
  }
}
